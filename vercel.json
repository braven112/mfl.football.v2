{
  "crons": [
    {
      "path": "/api/cron/roster-sync",
      "schedule": "*/4 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/theleague/:path*",
      "destination": "/:path*",
      "has": [{ "type": "host", "value": "theleague.us" }],
      "statusCode": 301
    },
    {
      "source": "/theleague/:path*",
      "destination": "/:path*",
      "has": [{ "type": "host", "value": "www.theleague.us" }],
      "statusCode": 301
    },
    {
      "source": "/theleague",
      "destination": "/",
      "has": [{ "type": "host", "value": "theleague.us" }],
      "statusCode": 301
    },
    {
      "source": "/theleague",
      "destination": "/",
      "has": [{ "type": "host", "value": "www.theleague.us" }],
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/forum/:path*",
      "destination": "https://forum.theleague.us/forum/:path*",
      "has": [{ "type": "host", "value": "www.theleague.us" }]
    },
    {
      "source": "/forum/:path*",
      "destination": "https://forum.theleague.us/forum/:path*",
      "has": [{ "type": "host", "value": "theleague.us" }]
    }
  ]
}
