---
/**
 * AFL Free Agents Page — player research tool focused on available players.
 *
 * A leaner sibling of TheLeague's /theleague/players. AFL has no salary cap,
 * contracts, auction, or surplus value (see leagues-data.mjs → afl-fantasy
 * features: contracts:false, salaryCap:false), so this page deliberately drops
 * every cap/contract/salary/auction/surplus/DEF-spotlight column that page
 * carries and shows only browse-relevant columns: identity, age, experience,
 * draft, physicals, dynasty ADP, last-season points, and projected points.
 *
 * Data is loaded at build time from the AFL MFL feed JSON (data/afl-fantasy).
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import CollegeLogoDarkStyles from '../../components/CollegeLogoDarkStyles.astro';
import PlayerDetailsModal from '../../components/theleague/PlayerDetailsModal.astro';
import { resolveLeaguePath } from '../../utils/nav-utils';
import { getLeagueBySlug } from '../../config/leagues';
import { positionOrder } from '../../constants/roster-constants';
import { getPlayerAvatarBackground, getPlayerAvatarBorder, getPlayerAvatarRing, getPlayerAvatarRingDark, getPlayerAvatarStyleMaps } from '../../utils/nfl-team-colors';
import '../../styles/player-cell.css';
// Build-time-derived free-agent snapshot. All the heavy multi-year feed reads +
// row assembly live in scripts/compute-afl-free-agents.mjs (wired into prebuild);
// this page imports only the finished ~400KB result. See the SSR note below.
import freeAgentsData from '../../../data/afl-fantasy/derived/free-agents.json';
// AFL uses team defenses (no IDP), so a DEF free agent has no headshot of its
// own. Mirror TheLeague's hero treatment: surface a rotating pool of the team's
// marquee defenders (ESPN headshots) over the logo watermark. The data is keyed
// by NFL team code, so the shared theleague-sourced file works directly here.
import { DEF_SPOTLIGHT_PLAYERS, getDefSpotlightPlayer } from '../../data/theleague/def-spotlight-players';

// SSR (server-rendered) — NOT prerendered. Two constraints pull in opposite
// directions and the derived-snapshot import above is how we satisfy both:
//
//  1. Apex routing needs SSR. The middleware (src/middleware.ts) rewrites
//     www.afl-fantasy.com/players → /afl-fantasy/players via context.rewrite(),
//     which only resolves to routes registered in the SSR function. A
//     `prerender = true` target is a static CDN file with no SSR route, so the
//     rewrite 404s and falls back to the default (TheLeague) 404 page — that was
//     the original apex bug.
//  2. The serverless function is near Vercel's 250MB limit. If this SSR page
//     eager-globbed every year of AFL feeds (~50MB of players/weekly-results),
//     it would bundle all of it into the shared _render function and tip it over
//     (see docs/claude/insights/domains/deployment.md).
//
// Resolution: the multi-year read happens at BUILD TIME in
// scripts/compute-afl-free-agents.mjs (node fs reads are not traced into the
// function), which emits data/afl-fantasy/derived/free-agents.json. This page
// imports only that small snapshot, so it renders on-demand (routing works) while
// contributing ~0.4MB, not ~15MB, to the function. Refreshes every deploy.

// MFL player-photo CDN host — sourced from the league registry, never
// hardcoded (CLAUDE.md: never hardcode league constants like the MFL host).
const mflHost = getLeagueBySlug('afl-fantasy')!.mflHost;

// ── Derived free-agent snapshot ──
// Year resolution, per-year feed parsing, row assembly, the default sort, and the
// position counts all used to run right here off eager import.meta.glob() over 24
// years of AFL feeds. That work now happens at build time in
// scripts/compute-afl-free-agents.mjs; this page consumes only the finished
// result, keeping the SSR bundle small (see the SSR note above).
const players = freeAgentsData.players;
const faCounts = freeAgentsData.faCounts as Record<string, number>;
const nflTeamsList = freeAgentsData.nflTeamsList as string[];
const hasProjected = freeAgentsData.hasProjected;
const hasLastYrPts = freeAgentsData.hasLastYrPts;
const hasAdp = freeAgentsData.hasAdp;
const defaultSort = freeAgentsData.defaultSort;
const defaultDir = freeAgentsData.defaultDir;
const freeAgentsCount = faCounts.ALL ?? 0;

// Initial hero spotlight: top free agent by the default sort (from the snapshot).
const topFa = freeAgentsData.topFa;
const topFaIsDef = topFa?.position === 'DEF';
// For a team defense, spotlight the team's marquee defender (if mapped) so the
// hero shows a face over the logo watermark instead of a bare crest.
const topFaDefStar = topFaIsDef ? getDefSpotlightPlayer(topFa?.team) : null;
const topFaLogo = topFa && topFa.team && topFa.team !== 'FA'
  ? `/assets/nfl-logos/${topFa.team}.svg`
  : '/assets/nfl-logos/NFL.svg';
// The hero headshot shows ESPN images only. When there's no ESPN image
// (offensive player with no espnId, or an unmapped DEF) we hide the foreground
// headshot rather than falling back to an MFL photo. Falls back to the logo
// (already loaded as the watermark) rather than '' so we never emit <img src="">.
const topFaHasHeadshot = topFa
  ? (topFaIsDef ? !!topFaDefStar?.espnId : !!topFa.espnId)
  : false;
const topFaHead = topFa
  ? (topFaIsDef
      ? (topFaDefStar
          ? `https://a.espncdn.com/i/headshots/nfl/players/full/${topFaDefStar.espnId}.png`
          : topFaLogo)
      : (topFa.espnId
          ? `https://a.espncdn.com/i/headshots/nfl/players/full/${topFa.espnId}.png`
          : topFaLogo))
  : topFaLogo;
// Initial (pre-hydration) error handler for the eager hero headshot: the image
// starts fetching before client JS attaches its handler, so mirror the client's
// hero-only fallback here — try the ESPN college headshot, then hide — so an ESPN
// 404 never flashes a broken image in the first viewport. Only emitted when we're
// showing an ESPN headshot (topFaHasHeadshot). espnId is a numeric MFL/ESPN id.
const topFaHeadEspnIdRaw = topFaHasHeadshot ? (topFaIsDef ? topFaDefStar?.espnId : topFa?.espnId) : null;
const topFaHeadEspnId = topFaHeadEspnIdRaw && /^\d+$/.test(String(topFaHeadEspnIdRaw)) ? String(topFaHeadEspnIdRaw) : null;
const topFaHeadOnerror = topFaHeadEspnId
  ? `this.onerror=function(){this.onerror=null;this.style.visibility='hidden'};this.src='https://a.espncdn.com/i/headshots/college-football/players/full/${topFaHeadEspnId}.png'`
  : undefined;

const playerDataJson = JSON.stringify(players);
const faCountsJson = JSON.stringify(faCounts);
const defSpotlightJson = JSON.stringify(DEF_SPOTLIGHT_PLAYERS);

// NFL-team avatar backdrops (same pattern as players.astro / projected-free-
// agents): precomputed maps (ESPN codes + MFL aliases) so the client-side
// row builder just does a lookup. FA/unknown falls back to league-neutral.
const { bg: nflAvatarBg, border: nflAvatarBorder, ring: nflAvatarRing, ringDark: nflAvatarRingDark } = getPlayerAvatarStyleMaps();
const nflAvatarBgFallback = getPlayerAvatarBackground('FA');
const nflAvatarBorderFallback = getPlayerAvatarBorder('FA');
const nflAvatarRingFallback = getPlayerAvatarRing('FA');
const nflAvatarRingDarkFallback = getPlayerAvatarRingDark('FA');
const nflAvatarBgJson = JSON.stringify(nflAvatarBg);
const nflAvatarBorderJson = JSON.stringify(nflAvatarBorder);
const nflAvatarRingJson = JSON.stringify(nflAvatarRing);
const nflAvatarRingDarkJson = JSON.stringify(nflAvatarRingDark);

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
---

<TheLeagueLayout title="Free Agents | AFL">
  <CollegeLogoDarkStyles />
  <div class="players-page">
    <!-- Hero -->
    <div class="players-hero">
      <div class="hero-spotlight" id="hero-spotlight" aria-hidden="true" data-def={topFaIsDef ? 'true' : 'false'} data-def-player={topFaIsDef && topFaDefStar ? 'true' : 'false'}>
        <img id="hero-spotlight-logo" class="hero-spotlight__logo" src={topFaLogo} alt="" loading="eager" decoding="async" />
        <img id="hero-spotlight-head" class="hero-spotlight__head" src={topFaHead} alt="" loading="eager" decoding="async" style={topFaHasHeadshot ? undefined : 'visibility:hidden'} onerror={topFaHeadOnerror} />
      </div>
      {topFa && (
        <div class="hero-spotlight-caption" id="hero-spotlight-caption" aria-live="polite">
          <span class="hero-spotlight__label" id="hero-spotlight-label">Top Free Agent</span>
          <span class="hero-spotlight__name" id="hero-spotlight-name">{topFaDefStar ? topFaDefStar.name : topFa.name}</span>
          <span class="hero-spotlight__meta" id="hero-spotlight-meta">
            {(topFa.position === 'PK' ? 'K' : topFa.position)}{topFa.team && topFa.team !== 'FA' ? ` · ${topFa.team}` : ''}{topFa.projected != null ? ` · ${topFa.projected.toFixed(1)} pts` : ''}
          </span>
        </div>
      )}
      <div class="hero-top">
        <div class="hero-title-group">
          <h1 class="hero-title">Free Agents</h1>
          <span class="hero-count">{freeAgentsCount} available players</span>
        </div>
        <a href={r('/afl-fantasy/rosters')} class="hero-cross-link">
          View rosters
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Search -->
      <div class="hero-search">
        <svg class="hero-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input
          type="search"
          id="player-search"
          class="hero-search__input"
          placeholder="Search by player name or NFL team..."
          autocomplete="off"
        />
      </div>

      <!-- Position pills -->
      <nav class="hero-positions" id="category-tabs">
        <button class="pos-pill active" data-pos="ALL">
          All
          <span class="pos-pill__count" id="count-ALL">{faCounts.ALL || 0}</span>
        </button>
        {positionOrder.map(pos => (
          <button class="pos-pill" data-pos={pos}>
            {pos === 'PK' ? 'K' : pos}
            <span class="pos-pill__count" id={`count-${pos}`}>{faCounts[pos] || 0}</span>
          </button>
        ))}
      </nav>
    </div>

    <!-- Toolbar -->
    <div class="players-toolbar">
      <div class="toolbar-left">
        <h2 class="players-section-title">Available Players</h2>
        <span class="showing-count" aria-live="polite">
          <strong id="showing-count">50</strong> of <strong id="total-players">0</strong>
        </span>
      </div>
      <div class="toolbar-right">
        <button class="filter-toggle-btn" id="filter-toggle-btn" type="button">
          <svg class="filter-toggle-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="6" x2="20" y2="6" /><line x1="8" y1="12" x2="16" y2="12" /><line x1="11" y1="18" x2="13" y2="18" />
          </svg>
          Filters
          <span class="filter-badge" id="filter-badge" style="display: none;">0</span>
        </button>
      </div>
    </div>

    <!-- Filters panel -->
    <div class="filters-panel" id="filters-panel">
      <div class="filters-panel__inner">
        <h3 class="filters-panel-title">Filters</h3>
        <div class="filters-grid">
          <div class="filter-group">
            <label class="filter-label" for="filter-team">NFL Team</label>
            <select id="filter-team" class="filter-select">
              <option value="">All Teams</option>
              {nflTeamsList.map(team => (
                <option value={team}>{team}</option>
              ))}
            </select>
          </div>

          <div class="filter-group filter-group--age">
            <label class="filter-label">Age Range</label>
            <div class="filter-range">
              <input type="number" id="filter-age-min" class="filter-input-num" placeholder="Min" min="18" max="50" />
              <span class="filter-range__sep">&ndash;</span>
              <input type="number" id="filter-age-max" class="filter-input-num" placeholder="Max" min="18" max="50" />
            </div>
          </div>

          <div class="filter-group filter-group--ht">
            <label class="filter-label">Height (in)</label>
            <div class="filter-range">
              <input type="number" id="filter-ht-min" class="filter-input-num" placeholder="Min" min="60" max="84" />
              <span class="filter-range__sep">&ndash;</span>
              <input type="number" id="filter-ht-max" class="filter-input-num" placeholder="Max" min="60" max="84" />
            </div>
          </div>

          <div class="filter-group filter-group--wt">
            <label class="filter-label">Weight (lbs)</label>
            <div class="filter-range">
              <input type="number" id="filter-wt-min" class="filter-input-num" placeholder="Min" min="150" max="400" />
              <span class="filter-range__sep">&ndash;</span>
              <input type="number" id="filter-wt-max" class="filter-input-num" placeholder="Max" min="150" max="400" />
            </div>
          </div>

          <div class="filter-group">
            <label class="filter-label" for="filter-exp">Experience</label>
            <select id="filter-exp" class="filter-select">
              <option value="">All</option>
              <option value="rookie">Rookie</option>
              <option value="1-2">1–2 years</option>
              <option value="3-5">3–5 years</option>
              <option value="6-10">6–10 years</option>
              <option value="10+">10+ years</option>
            </select>
          </div>

          <div class="filter-group">
            <label class="filter-label" for="filter-draft">Draft Round</label>
            <select id="filter-draft" class="filter-select">
              <option value="">All</option>
              <option value="1">Round 1</option>
              <option value="2">Round 2</option>
              <option value="3">Round 3</option>
              <option value="4+">Round 4+</option>
              <option value="udfa">Undrafted</option>
            </select>
          </div>
        </div>

        <div class="filters-row-bottom">
          <label class="filter-checkbox">
            <input type="checkbox" id="show-rostered" />
            <span>Include rostered</span>
          </label>
          <label class="filter-checkbox">
            <input type="checkbox" id="show-rookies" />
            <span>Include rookies</span>
          </label>
          <button class="filter-clear-btn" id="filter-clear-btn" type="button">Clear Filters</button>
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrapper">
      <table class="players-table" id="players-table">
        <thead>
          <tr>
            <th class="sortable col-rank" data-sort="rank"><div class="th-content">#</div></th>
            <th class="sortable col-player" data-sort="name"><div class="th-content">Player</div></th>
            <th class="sortable col-age" data-sort="age"><div class="th-content">Age</div></th>
            <th class="sortable col-sm" data-sort="exp"><div class="th-content">Exp</div></th>
            <th class="sortable col-sm" data-sort="draftRd"><div class="th-content">Draft</div></th>
            <th class="sortable col-text col-college" data-sort="college" title="College" aria-label="College"><div class="th-content">C</div></th>
            <th class="sortable col-sm" data-sort="height"><div class="th-content">Ht</div></th>
            <th class="sortable col-sm" data-sort="weight"><div class="th-content">Wt</div></th>
            {hasAdp && (
              <th class="sortable col-num" data-sort="adpDyn"><div class="th-content">ADP</div></th>
            )}
            {hasLastYrPts && (
              <th class="sortable col-num" data-sort="lastYrPts"><div class="th-content">Last Yr</div></th>
            )}
            {hasProjected && (
              <th class="sortable col-num col-projected" data-sort="projected"><div class="th-content">Proj</div></th>
            )}
          </tr>
        </thead>
        <tbody id="player-table-body"></tbody>
      </table>
    </div>

    <!-- Show more -->
    <div class="show-more-wrapper" id="show-more-wrapper">
      <button class="show-more-btn" id="show-more-btn">
        Load More Players
        <svg class="show-more-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </button>
    </div>

    <!-- No data -->
    <div class="no-data" id="no-data" style="display: none;">
      <p>No player data available yet.</p>
    </div>
  </div>
  <PlayerDetailsModal hideContract={true} />
</TheLeagueLayout>

<script define:vars={{ playerDataJson, hasProjected, hasLastYrPts, hasAdp, faCountsJson, defaultSort, defaultDir, mflHost, defSpotlightJson, nflAvatarBgJson, nflAvatarBorderJson, nflAvatarBgFallback, nflAvatarBorderFallback, nflAvatarRingJson, nflAvatarRingFallback, nflAvatarRingDarkJson, nflAvatarRingDarkFallback }}>
  const players = JSON.parse(playerDataJson);
  const nflAvatarBg = JSON.parse(nflAvatarBgJson);
  const nflAvatarBorder = JSON.parse(nflAvatarBorderJson);
  const nflAvatarRing = JSON.parse(nflAvatarRingJson);
  const nflAvatarRingDark = JSON.parse(nflAvatarRingDarkJson);

  function getAvatarStyle(team) {
    // Not escapeAttr'd: values are precomputed hex/gradient strings from
    // nfl-team-colors.ts — deterministic, never contain HTML special chars.
    const bg = nflAvatarBg[team] || nflAvatarBgFallback;
    const border = nflAvatarBorder[team] || nflAvatarBorderFallback;
    const ring = nflAvatarRing[team] || nflAvatarRingFallback;
    const ringDark = nflAvatarRingDark[team] || nflAvatarRingDarkFallback;
    return ` style="--player-avatar-bg: ${bg}; --player-avatar-border: ${border}; --player-avatar-ring: ${ring}; --player-avatar-ring-dark: ${ringDark}"`;
  }

  // State
  let filteredPlayers = [];
  let currentSort = defaultSort;
  let sortDirection = defaultDir;
  let visibleCount = 50;
  let activePosition = 'ALL';
  let searchQuery = '';
  let showRostered = false;
  let showRookies = false;
  const BATCH_SIZE = 50;

  // Advanced filter state
  let filterTeam = '';
  let filterAgeMin = null;
  let filterAgeMax = null;
  let filterExp = '';
  let filterDraft = '';
  let filterHtMin = null;
  let filterHtMax = null;
  let filterWtMin = null;
  let filterWtMax = null;
  let filtersOpen = false;

  // ── Helpers ──
  function getHeadshotUrl(playerId, espnId) {
    if (espnId) return `https://a.espncdn.com/i/headshots/nfl/players/full/${espnId}.png`;
    return `https://${mflHost}/player_photos_big_2014/${playerId}_thumb.jpg`;
  }
  function getNflLogo(team) {
    if (!team || team === 'FA') return '/assets/nfl-logos/NFL.svg';
    return `/assets/nfl-logos/${team}.svg`;
  }
  const defaultHeadshot = `https://${mflHost}/player_photos_2010/no_photo_available.jpg`;
  function buildOnerror(mflId, espnId) {
    const college = espnId ? `https://a.espncdn.com/i/headshots/college-football/players/full/${espnId}.png` : null;
    const mfl = mflId ? `https://${mflHost}/player_photos_big_2014/${mflId}_thumb.jpg` : null;
    if (college && mfl) {
      return `this.onerror=function(){this.onerror=function(){this.onerror=null;this.src='${defaultHeadshot}'};this.src='${mfl}'};this.src='${college}'`;
    }
    if (college) {
      return `this.onerror=function(){this.onerror=null;this.src='${defaultHeadshot}'};this.src='${college}'`;
    }
    return `this.onerror=null;this.src='${defaultHeadshot}'`;
  }
  // Hero-only onerror: the spotlight shows ESPN images exclusively. If the NFL
  // headshot 404s we try the ESPN college headshot (still an ESPN image), then
  // HIDE the foreground rather than falling back to the MFL photo / "no photo"
  // placeholder the table rows use.
  function buildHeroOnerror(espnId) {
    // espnId is a numeric MFL/ESPN id; enforce that before splicing it into the
    // inline handler string so nothing unexpected can break out of the literal.
    const safe = /^\d+$/.test(String(espnId)) ? String(espnId) : null;
    const college = safe ? `https://a.espncdn.com/i/headshots/college-football/players/full/${safe}.png` : null;
    if (college) {
      return `this.onerror=function(){this.onerror=null;this.style.visibility='hidden'};this.src='${college}'`;
    }
    return `this.onerror=null;this.style.visibility='hidden'`;
  }
  function escapeAttr(s) {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // ── Hero spotlight (top player of the current filter/sort) ──
  const spotlightEl = document.getElementById('hero-spotlight');
  const spotlightLogoEl = document.getElementById('hero-spotlight-logo');
  const spotlightHeadEl = document.getElementById('hero-spotlight-head');
  const spotlightCaptionEl = document.getElementById('hero-spotlight-caption');
  const spotlightLabelEl = document.getElementById('hero-spotlight-label');
  const spotlightNameEl = document.getElementById('hero-spotlight-name');
  const spotlightMetaEl = document.getElementById('hero-spotlight-meta');
  let spotlightPlayerId = null;

  // ── DEF face rotation ──
  // AFL DEF is team defenses only — a DEF free agent has no headshot. DEF_SPOTLIGHT
  // maps each team to a ranked pool of its marquee defenders; when a DEF is
  // spotlighted we show one defender's ESPN headshot over the logo watermark and
  // (unless reduced-motion) rotate through the pool so it doesn't feel static.
  const DEF_SPOTLIGHT = JSON.parse(defSpotlightJson);
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DEF_ROTATE_MS = 4500;
  let defRotateTimer = null;
  let defRotateIdx = 0;

  function stopDefRotation() {
    if (defRotateTimer) {
      clearInterval(defRotateTimer);
      defRotateTimer = null;
    }
  }

  // Swap the spotlight headshot + name to a specific defender, replaying the
  // entrance animation. Used for the initial face and every rotation tick.
  function applyDefFace(player) {
    // Every mapped defender carries an espnId; bail if one somehow doesn't rather
    // than build a `.../null.png` headshot URL.
    if (!player || !player.espnId) return;
    if (spotlightHeadEl) {
      spotlightHeadEl.onerror = null;
      spotlightHeadEl.style.visibility = '';
      spotlightHeadEl.setAttribute('onerror', buildHeroOnerror(player.espnId));
      spotlightHeadEl.src = getHeadshotUrl(null, player.espnId);
      spotlightHeadEl.style.animation = 'none';
      // eslint-disable-next-line no-unused-expressions
      spotlightHeadEl.offsetHeight; // force reflow so the animation restarts
      spotlightHeadEl.style.animation = '';
    }
    if (spotlightNameEl) spotlightNameEl.textContent = player.name;
  }

  function startDefRotation(players) {
    stopDefRotation();
    // Random starting face so repeat visits don't always open on the same player.
    defRotateIdx = players.length > 1 ? Math.floor(Math.random() * players.length) : 0;
    applyDefFace(players[defRotateIdx]);
    if (players.length > 1 && !prefersReducedMotion) {
      defRotateTimer = setInterval(() => {
        defRotateIdx = (defRotateIdx + 1) % players.length;
        applyDefFace(players[defRotateIdx]);
      }, DEF_ROTATE_MS);
    }
  }

  function updateSpotlight(p) {
    if (!spotlightEl) return;
    if (!p) {
      stopDefRotation();
      spotlightPlayerId = null;
      spotlightEl.setAttribute('data-def', 'false');
      spotlightEl.setAttribute('data-def-player', 'false');
      if (spotlightLogoEl) spotlightLogoEl.src = '/assets/nfl-logos/NFL.svg';
      if (spotlightCaptionEl) spotlightCaptionEl.style.display = 'none';
      if (spotlightHeadEl) spotlightHeadEl.style.visibility = 'hidden';
      return;
    }
    if (spotlightCaptionEl) spotlightCaptionEl.style.display = '';
    // Team defense → its rotating pool of marquee defenders.
    const isDef = p.position === 'DEF';
    const defPlayers = isDef ? (DEF_SPOTLIGHT[p.team] || []) : [];
    const hasDefFace = defPlayers.length > 0;
    // NB: headshot visibility is set inside the image-swap branches below, NOT
    // here — doing it before the same-player early-return would re-reveal a
    // headshot we'd hidden because its ESPN image 404'd (same #1 player across a
    // re-sort), flashing the broken image back in.
    spotlightEl.setAttribute('data-def', isDef ? 'true' : 'false');
    spotlightEl.setAttribute('data-def-player', hasDefFace ? 'true' : 'false');

    if (spotlightLabelEl) {
      spotlightLabelEl.textContent = activePosition && activePosition !== 'ALL'
        ? 'Top ' + (activePosition === 'PK' ? 'K' : activePosition)
        : 'Top Free Agent';
    }
    // For a mapped DEF the rotating defender name is set by applyDefFace(); the
    // meta row still carries the DEF unit's context (DEF · TEAM · pts).
    if (!hasDefFace && spotlightNameEl) spotlightNameEl.textContent = p.name;
    if (spotlightMetaEl) {
      const pos = p.position === 'PK' ? 'K' : p.position;
      const teamPart = p.team && p.team !== 'FA' ? ` · ${p.team}` : '';
      const projPart = p.projected != null ? ` · ${p.projected.toFixed(1)} pts` : '';
      spotlightMetaEl.textContent = `${pos}${teamPart}${projPart}`;
    }

    // The image swap is skipped when the #1 player is unchanged. For a DEF, the
    // unit id is the stable anchor while the defender FACE rotates within it via
    // applyDefFace(), so keeping the running rotation here is correct.
    if (p.id === spotlightPlayerId) return;
    spotlightPlayerId = p.id;
    stopDefRotation();

    const logo = getNflLogo(p.team);
    if (spotlightLogoEl) spotlightLogoEl.src = logo;

    if (hasDefFace) {
      // DEF with a mapped pool → rotate through the defenders' headshots.
      startDefRotation(defPlayers);
    } else if (spotlightHeadEl) {
      spotlightHeadEl.onerror = null;
      if (isDef) {
        // Unmapped DEF → logo becomes the hero (head kept hidden by CSS).
        spotlightHeadEl.removeAttribute('onerror');
        spotlightHeadEl.style.visibility = '';
        spotlightHeadEl.src = logo;
      } else if (p.espnId) {
        // Offensive player with an ESPN headshot → show it (hero-only onerror
        // hides the foreground if the ESPN image 404s, never falls back to MFL).
        spotlightHeadEl.style.visibility = '';
        spotlightHeadEl.setAttribute('onerror', buildHeroOnerror(p.espnId));
        spotlightHeadEl.src = `https://a.espncdn.com/i/headshots/nfl/players/full/${p.espnId}.png`;
      } else {
        // No ESPN image → keep the spotlight headshot hidden (no MFL/placeholder).
        spotlightHeadEl.removeAttribute('onerror');
        spotlightHeadEl.style.visibility = 'hidden';
        return;
      }
      // Restart the entrance animation for the new headshot.
      spotlightHeadEl.style.animation = 'none';
      // eslint-disable-next-line no-unused-expressions
      spotlightHeadEl.offsetHeight; // force reflow to restart animation
      spotlightHeadEl.style.animation = '';
    }
  }

  // ── Sorting ──
  function sortPlayers() {
    filteredPlayers.sort((a, b) => {
      let aVal, bVal;
      switch (currentSort) {
        case 'name':
          return sortDirection === 'asc'
            ? a.name.localeCompare(b.name)
            : b.name.localeCompare(a.name);
        case 'college': {
          const aC = a.college || '';
          const bC = b.college || '';
          return sortDirection === 'asc' ? aC.localeCompare(bC) : bC.localeCompare(aC);
        }
        case 'age':      aVal = a.age ?? 999; bVal = b.age ?? 999; break;
        case 'exp':      aVal = a.exp ?? -1; bVal = b.exp ?? -1; break;
        case 'draftRd':  aVal = a.draftRd ?? 999; bVal = b.draftRd ?? 999; break;
        case 'height':   aVal = a.height ?? -1; bVal = b.height ?? -1; break;
        case 'weight':   aVal = a.weight ?? -1; bVal = b.weight ?? -1; break;
        case 'adpDyn':   aVal = a.adpDyn ?? 9999; bVal = b.adpDyn ?? 9999; break;
        case 'lastYrPts': aVal = a.lastYrPts ?? -1; bVal = b.lastYrPts ?? -1; break;
        case 'projected': aVal = a.projected ?? -1; bVal = b.projected ?? -1; break;
        default:         aVal = a.projected ?? -1; bVal = b.projected ?? -1;
      }
      const diff = aVal - bVal;
      return sortDirection === 'desc' ? -diff : diff;
    });
  }

  // ── Filtering ──
  function passesAdvancedFilters(p) {
    if (filterTeam && p.team !== filterTeam) return false;
    if (filterAgeMin != null && (p.age == null || p.age < filterAgeMin)) return false;
    if (filterAgeMax != null && (p.age == null || p.age > filterAgeMax)) return false;
    if (filterExp) {
      const exp = p.exp;
      switch (filterExp) {
        case 'rookie': if (!p.rookie) return false; break;
        case '1-2': if (exp == null || exp < 1 || exp > 2) return false; break;
        case '3-5': if (exp == null || exp < 3 || exp > 5) return false; break;
        case '6-10': if (exp == null || exp < 6 || exp > 10) return false; break;
        case '10+': if (exp == null || exp < 10) return false; break;
      }
    }
    if (filterDraft) {
      switch (filterDraft) {
        case '1': if (p.draftRd !== 1) return false; break;
        case '2': if (p.draftRd !== 2) return false; break;
        case '3': if (p.draftRd !== 3) return false; break;
        case '4+': if (p.draftRd == null || p.draftRd < 4) return false; break;
        case 'udfa': if (p.draftRd != null) return false; break;
      }
    }
    if (filterHtMin != null && (p.height == null || p.height < filterHtMin)) return false;
    if (filterHtMax != null && (p.height == null || p.height > filterHtMax)) return false;
    if (filterWtMin != null && (p.weight == null || p.weight < filterWtMin)) return false;
    if (filterWtMax != null && (p.weight == null || p.weight > filterWtMax)) return false;
    return true;
  }

  function countActiveFilters() {
    let count = 0;
    if (filterTeam) count++;
    if (filterAgeMin != null || filterAgeMax != null) count++;
    if (filterHtMin != null || filterHtMax != null) count++;
    if (filterWtMin != null || filterWtMax != null) count++;
    if (filterExp) count++;
    if (filterDraft) count++;
    if (showRostered) count++;
    if (showRookies) count++;
    return count;
  }

  function updateFilterBadge() {
    const badge = document.getElementById('filter-badge');
    const count = countActiveFilters();
    if (badge) {
      badge.textContent = String(count);
      badge.style.display = count > 0 ? '' : 'none';
    }
    const btn = document.getElementById('filter-toggle-btn');
    if (btn) btn.classList.toggle('has-filters', count > 0);
  }

  function matchesBaseFilters(p, query) {
    if (!showRostered && p.rostered) return false;
    if (!showRookies && p.rookie) return false;
    if (!passesAdvancedFilters(p)) return false;
    if (query) {
      return p.name.toLowerCase().includes(query) || p.team.toLowerCase().includes(query);
    }
    return true;
  }

  function filterPlayers() {
    const query = searchQuery.toLowerCase();
    filteredPlayers = players.filter(p => {
      if (activePosition !== 'ALL' && p.position !== activePosition) return false;
      return matchesBaseFilters(p, query);
    });

    // Update pill counts (ignore the active position filter)
    const pool = players.filter(p => matchesBaseFilters(p, query));
    const counts = { ALL: pool.length };
    for (const p of pool) counts[p.position] = (counts[p.position] || 0) + 1;
    for (const pos of ['ALL', 'QB', 'RB', 'WR', 'TE', 'PK', 'DEF']) {
      const el = document.getElementById(`count-${pos}`);
      if (el) el.textContent = String(counts[pos] || 0);
    }

    updateFilterBadge();
    sortPlayers();
    visibleCount = BATCH_SIZE;
    render();
  }

  function render() {
    const tbody = document.getElementById('player-table-body');
    if (!tbody) return;

    const total = filteredPlayers.length;
    const end = Math.min(visibleCount, total);
    const pageData = filteredPlayers.slice(0, end);

    const showingCountEl = document.getElementById('showing-count');
    const totalEl = document.getElementById('total-players');
    const showMoreWrapper = document.getElementById('show-more-wrapper');
    if (showingCountEl) showingCountEl.textContent = String(end);
    if (totalEl) totalEl.textContent = String(total);
    if (showMoreWrapper) showMoreWrapper.style.display = end < total ? '' : 'none';

    let html = '';
    for (let i = 0; i < pageData.length; i++) {
      const p = pageData[i];
      const rank = i + 1;
      const isDef = p.position === 'DEF';
      const headshot = isDef ? getNflLogo(p.team) : getHeadshotUrl(p.id, p.espnId);
      const logo = getNflLogo(p.team);
      const posLabel = p.position === 'PK' ? 'K' : p.position;
      const rosteredClass = p.rostered ? ' row--rostered' : '';

      const modalJson = escapeAttr(JSON.stringify({
        id: p.id, espnId: p.espnId || null, name: p.name,
        position: p.position, nflTeam: p.team,
        college: p.college || null, height: p.height || null,
        weight: p.weight || null, number: p.jersey || null,
        birthdate: p.birthdate || null, experience: p.exp != null ? p.exp : null,
        draftYear: p.draftYear || null, draftTeam: p.draftTeam || null,
        draftRound: p.draftRd || null, draftPick: p.draftPick || null,
        points: p.projected != null ? p.projected : (p.lastYrPts != null ? p.lastYrPts : null),
      }));
      const rosteredDot = p.rostered ? '<span class="rostered-dot" title="Rostered"></span>' : '';

      const htDisplay = p.height ? Math.floor(p.height / 12) + "'" + (p.height % 12) + '"' : '-';
      const wtDisplay = p.weight ? p.weight + '' : '-';

      html += `<tr class="${rosteredClass}" data-pos="${p.position.toLowerCase()}" data-player-id="${p.id}">
        <td class="cell-rank">${rank}</td>
        <td class="cell-player">
          <div class="player-cell">
            <div class="player-cell__avatar${isDef ? ' player-cell__avatar--def' : ''}"${isDef ? '' : getAvatarStyle(p.team)}>
              <img src="${headshot}" alt="" loading="lazy" decoding="async" onerror="${escapeAttr(buildOnerror(p.id, p.espnId))}" />
            </div>
            <div class="player-cell__info">
              <strong class="player-cell__name player-cell__name--clickable" data-player-modal="${modalJson}">${escapeAttr(p.name)}${rosteredDot}</strong>
              <div class="player-meta">
                ${isDef ? '' : `<img src="${logo}" alt="${escapeAttr(p.team)}" class="player-meta__logo" />`}<span class="player-meta__pos">${posLabel}</span>
              </div>
            </div>
          </div>
        </td>
        <td class="cell-age">${p.age ?? '-'}</td>
        <td class="cell-sm">${p.exp != null ? p.exp : '-'}</td>
        <td class="cell-sm">${p.draftRd != null ? 'Rd ' + p.draftRd : '<span class="na">-</span>'}</td>
        <td class="cell-college">${p.collegeLogo ? `<img src="${p.collegeLogo}" alt="${escapeAttr(p.college || '')}" title="${escapeAttr(p.college || '')}" class="college-logo" loading="lazy" decoding="async" />` : (p.college ? escapeAttr(p.college) : '<span class="na">-</span>')}</td>
        <td class="cell-sm">${htDisplay}</td>
        <td class="cell-sm">${wtDisplay}</td>`;

      if (hasAdp) {
        html += `<td class="cell-num">${p.adpDyn != null ? p.adpDyn.toFixed(1) : '<span class="na">-</span>'}</td>`;
      }
      if (hasLastYrPts) {
        html += `<td class="cell-num">${p.lastYrPts != null ? p.lastYrPts.toFixed(1) : '<span class="na">-</span>'}</td>`;
      }
      if (hasProjected) {
        html += `<td class="cell-num cell-pts col-projected">${p.projected != null ? p.projected.toFixed(1) : '<span class="na">-</span>'}</td>`;
      }
      html += `</tr>`;
    }

    tbody.innerHTML = html;

    // Sort indicators
    document.querySelectorAll('.players-table th.sortable').forEach(th => {
      const content = th.querySelector('.th-content');
      const existingArrow = th.querySelector('.sort-arrow');
      const sortKey = th.getAttribute('data-sort');
      if (sortKey === currentSort) {
        th.classList.add('sorted');
        if (!existingArrow && content) {
          const arrow = document.createElement('span');
          arrow.className = 'sort-arrow';
          arrow.textContent = sortDirection === 'asc' ? '▲' : '▼';
          content.appendChild(arrow);
        } else if (existingArrow) {
          existingArrow.textContent = sortDirection === 'asc' ? '▲' : '▼';
        }
      } else {
        th.classList.remove('sorted');
        if (existingArrow) existingArrow.remove();
      }
    });

    const noDataEl = document.getElementById('no-data');
    if (noDataEl) noDataEl.style.display = players.length === 0 ? 'block' : 'none';

    updateSpotlight(filteredPlayers[0] || null);
  }

  // Columns that default to descending on first click
  const descDefaults = new Set(['projected', 'exp', 'height', 'weight', 'lastYrPts']);
  // Columns that default to ascending (lower = better)
  const ascDefaults = new Set(['adpDyn', 'draftRd', 'age']);

  function init() {
    const table = document.getElementById('players-table');
    if (!table || table.dataset.init) return;
    table.dataset.init = 'true';

    // Position pills
    const tabsEl = document.getElementById('category-tabs');
    if (tabsEl) {
      tabsEl.addEventListener('click', (e) => {
        const tab = e.target.closest('.pos-pill');
        if (!tab) return;
        activePosition = tab.getAttribute('data-pos');
        tabsEl.querySelectorAll('.pos-pill').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        filterPlayers();
      });
    }

    // Search
    const searchInput = document.getElementById('player-search');
    if (searchInput) {
      let debounceTimer;
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          searchQuery = e.target.value.trim();
          filterPlayers();
        }, 150);
      });
    }

    // Sort headers
    document.querySelectorAll('.players-table th.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const key = th.getAttribute('data-sort');
        if (key === 'rank') return;
        if (currentSort === key) {
          sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort = key;
          if (key === 'name' || key === 'college') sortDirection = 'asc';
          else if (ascDefaults.has(key)) sortDirection = 'asc';
          else sortDirection = 'desc';
        }
        sortPlayers();
        visibleCount = BATCH_SIZE;
        render();
      });
    });

    // Filter toggle
    const filterToggle = document.getElementById('filter-toggle-btn');
    const filtersPanel = document.getElementById('filters-panel');
    if (filterToggle && filtersPanel) {
      filterToggle.addEventListener('click', () => {
        filtersOpen = !filtersOpen;
        filtersPanel.classList.toggle('open', filtersOpen);
        filterToggle.classList.toggle('active', filtersOpen);
      });
    }

    // Advanced filter inputs
    const numOrNull = (v) => {
      const n = parseInt(v, 10);
      return Number.isFinite(n) ? n : null;
    };
    const bind = (id, handler, evt = 'input') => {
      const el = document.getElementById(id);
      if (el) el.addEventListener(evt, handler);
    };
    bind('filter-team', (e) => { filterTeam = e.target.value; filterPlayers(); }, 'change');
    bind('filter-age-min', (e) => { filterAgeMin = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-age-max', (e) => { filterAgeMax = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-ht-min', (e) => { filterHtMin = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-ht-max', (e) => { filterHtMax = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-wt-min', (e) => { filterWtMin = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-wt-max', (e) => { filterWtMax = numOrNull(e.target.value); filterPlayers(); });
    bind('filter-exp', (e) => { filterExp = e.target.value; filterPlayers(); }, 'change');
    bind('filter-draft', (e) => { filterDraft = e.target.value; filterPlayers(); }, 'change');
    bind('show-rostered', (e) => { showRostered = e.target.checked; filterPlayers(); }, 'change');
    bind('show-rookies', (e) => { showRookies = e.target.checked; filterPlayers(); }, 'change');

    // Clear filters
    const clearBtn = document.getElementById('filter-clear-btn');
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        filterTeam = ''; filterAgeMin = null; filterAgeMax = null;
        filterHtMin = null; filterHtMax = null; filterWtMin = null; filterWtMax = null;
        filterExp = ''; filterDraft = ''; showRostered = false; showRookies = false;
        ['filter-team', 'filter-age-min', 'filter-age-max', 'filter-ht-min', 'filter-ht-max',
         'filter-wt-min', 'filter-wt-max', 'filter-exp', 'filter-draft'].forEach(id => {
          const el = document.getElementById(id);
          if (el) el.value = '';
        });
        ['show-rostered', 'show-rookies'].forEach(id => {
          const el = document.getElementById(id);
          if (el) el.checked = false;
        });
        filterPlayers();
      });
    }

    // Show more
    const showMoreBtn = document.getElementById('show-more-btn');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', () => {
        visibleCount += BATCH_SIZE;
        render();
      });
    }

    filterPlayers();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  // Cleanup on navigation (View Transitions) — stop the DEF rotation timer so it
  // can't keep mutating detached hero nodes or stack a second interval on return.
  document.addEventListener('astro:before-swap', function () {
    stopDefRotation();
  }, { once: true });
  // Astro view transitions
  document.addEventListener('astro:page-load', init);
</script>

<!-- Player modal trigger (delegated, survives re-renders) -->
<script>
  import { initPlayerModalTrigger } from '../../utils/player-modal-trigger';
  function initModalTrigger() {
    const tbody = document.getElementById('player-table-body');
    if (tbody && !tbody.dataset.modalInit) {
      tbody.dataset.modalInit = 'true';
      initPlayerModalTrigger(tbody);
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModalTrigger);
  } else {
    initModalTrigger();
  }
  document.addEventListener('astro:page-load', initModalTrigger);
</script>

<style>
  /* =============================================
     AFL FREE AGENTS PAGE
     Lean sibling of /theleague/players — shared visual system,
     no cap / contract / auction / value columns.
     ============================================= */

  .players-page {
    max-width: 100%;
    padding-bottom: 3rem;
  }

  /* Remove gap between nav header and hero */
  :global(.container-header) {
    margin-bottom: 0 !important;
    padding-bottom: 0.5rem !important;
  }

  /* ── Hero ── */
  .players-hero {
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-900, #111827);
    padding: 1.75rem 1.5rem 1.5rem;
    border-radius: var(--radius-lg, 1rem);
    margin: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--content-border, #e2e8f0);
  }

  /* Hero spotlight (broadcast diagonal cut: top-FA headshot + team logo) */
  .hero-spotlight {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    overflow: hidden;
    pointer-events: none;
    clip-path: polygon(20% 0, 110% 0, 90% 100%, 0% 100%);
    background:
      radial-gradient(120% 120% at 80% 20%, rgba(196, 30, 58, 0.12) 0%, transparent 60%),
      #eef1f6;
  }
  :global(html.dark) .hero-spotlight {
    background:
      radial-gradient(120% 120% at 80% 20%, rgba(196, 30, 58, 0.5) 0%, transparent 60%),
      #111827;
  }
  .hero-spotlight::before {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 100%;
    z-index: 3;
    background: linear-gradient(to bottom, var(--league-accent, #c41e3a) 0%, rgba(196, 30, 58, 0.6) 100%);
    clip-path: polygon(20% 0, 22.5% 0, 2.5% 100%, 0% 100%);
    pointer-events: none;
  }
  .hero-spotlight::after {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 100%;
    z-index: 3;
    background: linear-gradient(to bottom, rgba(196, 30, 58, 0.6) 0%, var(--league-accent, #c41e3a) 100%);
    clip-path: polygon(110% 0, 107.5% 0, 87.5% 100%, 90% 100%);
    pointer-events: none;
  }
  .hero-spotlight__logo {
    position: absolute;
    top: 50%;
    left: 58%;
    transform: translate(-50%, -50%);
    width: 78%;
    height: auto;
    max-height: 150%;
    object-fit: contain;
    opacity: 0.16;
    filter: grayscale(0.1);
    z-index: 1;
    transition: opacity 0.35s ease;
  }
  .hero-spotlight__head {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: 60% 100%;
    padding: 0.5rem 0 0;
    filter: brightness(1.02) contrast(1.05) saturate(1.1) drop-shadow(0 4px 10px rgba(0, 0, 0, 0.35));
    z-index: 2;
    opacity: 0;
    animation: spotlightIn 0.45s ease forwards;
  }
  /* Team defense has no headshot — make the crest the hero */
  .hero-spotlight[data-def='true'] .hero-spotlight__head {
    display: none;
  }
  .hero-spotlight[data-def='true'] .hero-spotlight__logo {
    opacity: 0.92;
    filter: none;
    width: 62%;
    left: 60%;
  }
  /* DEF with a mapped marquee defender: bring the headshot back as the foreground
     hero (styled like a normal contained/bottom-anchored player photo) and drop
     the team logo back to its faint background watermark. */
  .hero-spotlight[data-def='true'][data-def-player='true'] .hero-spotlight__head {
    display: block;
  }
  .hero-spotlight[data-def='true'][data-def-player='true'] .hero-spotlight__logo {
    opacity: 0.16;
    filter: grayscale(0.1);
    width: 78%;
    left: 58%;
  }
  @keyframes spotlightIn {
    from { opacity: 0; transform: scale(1.04); }
    to   { opacity: 1; transform: scale(1); }
  }

  .hero-spotlight-caption {
    position: absolute;
    right: 1rem;
    bottom: 0.85rem;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.05rem;
    max-width: 60%;
    text-align: right;
    pointer-events: none;
    padding: 0.35rem 0.6rem 0.4rem;
    border-radius: var(--radius-md, 0.5rem);
    background: rgba(255, 255, 255, 0.72);
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }
  :global(html.dark) .hero-spotlight-caption {
    padding: 0.4rem 0.65rem 0.45rem 1.75rem;
    border-radius: 0;
    background: radial-gradient(130% 150% at 100% 100%, rgba(0, 0, 0, 0.62) 0%, rgba(0, 0, 0, 0.3) 48%, transparent 78%);
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    box-shadow: none;
    text-shadow: 0 1px 5px rgba(0, 0, 0, 0.6);
  }
  .hero-spotlight__label {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #6b7280;
  }
  :global(html.dark) .hero-spotlight__label { color: rgba(255, 255, 255, 0.75); }
  .hero-spotlight__name {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.15;
    color: #111827;
    letter-spacing: -0.01em;
