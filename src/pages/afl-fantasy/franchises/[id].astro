---
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import aflConfig from '../../../../data/afl-fantasy/afl.config.json';
import { getAuthUser } from '../../../utils/auth';
import { getLeagueBySlug } from '../../../config/leagues';
import {
  getFranchiseTrophyCase,
  getFranchiseTrophyRoom,
  getFranchiseTitleProgress,
  getFranchiseTrophyRank,
  getFranchiseTierRank,
  attributeAwardYear,
  getCurrentOwnerSince,
  type AwardSlug,
  type AwardTier,
  type TrophyCaseItem,
} from '../../../utils/afl-awards';
import { stampBadgeYear } from '../../../utils/afl-badge';
import { getCurrentSeasonYear } from '../../../utils/league-year';

// Badge art loaded raw so the editable year can be stamped per win (an <img>
// can't be edited per instance). These are build-time repo assets only — safe
// to inject via set:html. Keyed by filename.
const badgeSvgRaw = import.meta.glob<string>(
  '../../../../public/assets/afl/awards/*.svg',
  { query: '?raw', import: 'default', eager: true }
);
const BADGE_SVG: Record<string, string> = {};
for (const [p, raw] of Object.entries(badgeSvgRaw)) {
  BADGE_SVG[p.split('/').pop() as string] = raw;
}
// Stamp the win year (or blank it with '' for a locked placeholder) and make
// the #yearArc id unique per instance. Pure transform lives in afl-badge.ts.
function renderBadge(badge: string, year?: number | string, uid = ''): string {
  return stampBadgeYear(BADGE_SVG[badge] ?? '', year, uid);
}

export const prerender = false;

// Optional championship history — graceful when not yet committed (PR #207).
const champHistoryGlob = import.meta.glob<{
  default: {
    championships?: Array<{
      year: number;
      champion: string;
      runnerUp: string;
      championName: string;
      runnerUpName: string;
    }>;
  };
}>('../../../../data/afl-fantasy/championship-history.json', { eager: true });

const championshipHistory =
  Object.values(champHistoryGlob)[0]?.default?.championships ?? [];

// SSR: route is /afl-fantasy/franchises/:id where :id is the franchiseId
// (e.g. "0001"). Rendered per-request so we can detect the viewer's
// auth state and reveal owner-only CTAs (Manage roster / Open trade
// builder) without hydrating a client component.
const { id } = Astro.params;

const team = (aflConfig.teams as Array<any>).find(
  (t) => t.franchiseId === id
);

if (!team) {
  return Astro.redirect('/afl-fantasy/franchises');
}

// Championships won/lost, following ownerHistory so a title from a franchise
// ID this owner has since left off (or moved onto) attributes correctly —
// see attributeAwardYear in afl-awards.ts.
const wonYears = championshipHistory
  .filter((c) => attributeAwardYear(c.champion, c.year) === id)
  .map((c) => c.year)
  .sort((a, b) => b - a);

const lostYears = championshipHistory
  .filter((c) => attributeAwardYear(c.runnerUp, c.year) === id)
  .map((c) => c.year)
  .sort((a, b) => b - a);

// Conference + division metadata
const conference = (aflConfig.conferences ?? []).find(
  (c: any) => c.code === team.conference
);
const conferenceName = conference?.name ?? team.conference;

// Trophy case — only awards this franchise actually won. Dated majors (AFL
// Championship, AFL Cup, NIT, Premier League, D-League) expand to one
// year-stamped badge per win; undated awards (divisions, conference) show once
// with a win count. Sourced from data/afl-fantasy/awards-history.json (2016+).
const trophyCase: TrophyCaseItem[] = getFranchiseTrophyCase(id);
const totalBadges = trophyCase.reduce(
  (sum, t) => sum + (t.dated ? 1 : t.years.length),
  0
);

// The team's own division + conference titles also show as locked placeholders
// when unwon. Map the current config assignment to award slugs.
const DIVISION_SLUG_BY_NAME: Record<string, AwardSlug> = {
  North: 'al-north',
  South: 'al-south',
  East: 'nl-east',
  West: 'nl-west',
};
const divisionSlug = DIVISION_SLUG_BY_NAME[team.division as string];
const conferenceSlug: AwardSlug = team.conference === '00' ? 'al-champion' : 'nl-champion';
const trophyTiers = getFranchiseTrophyRoom(id, { divisionSlug, conferenceSlug });

// Title-type progress — how many of the six title TYPES (AFL, Premier,
// Conference, Division, D-League, NIT) this franchise has won at least one of.
// Rendered as a segmented progress bar under the Trophy wall headline.
const titleProgress = getFranchiseTitleProgress(id);
// Full accessible summary so the per-type detail isn't mouse-only (the visual
// pips carry it via `title`): which types are won (+ count) and which aren't.
const wonTypeSummary = titleProgress.types
  .filter((t) => t.won)
  .map((t) => `${t.label} (won ${t.years.length})`)
  .join(', ');
const unwonTypeSummary = titleProgress.types
  .filter((t) => !t.won)
  .map((t) => t.label)
  .join(', ');
const titlePipsLabel =
  `Title types won: ${titleProgress.wonCount} of ${titleProgress.total}.` +
  (wonTypeSummary ? ` Won: ${wonTypeSummary}.` : '') +
  (unwonTypeSummary ? ` Not yet won: ${unwonTypeSummary}.` : '');

// Trophy-count rank across all AFL franchises (descending total trophies,
// standard competition ranking for ties). A zero-trophy case is left
// "unranked" — we hide the chip rather than show a meaningless "T-22nd".
const trophyRank = getFranchiseTrophyRank(id);
function ordinal(n: number): string {
  const mod100 = n % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${n}th`;
  switch (n % 10) {
    case 1: return `${n}st`;
    case 2: return `${n}nd`;
    case 3: return `${n}rd`;
    default: return `${n}th`;
  }
}
const rankLabel =
  trophyRank.count > 0
    ? `${trophyRank.tied ? 'T-' : ''}${ordinal(trophyRank.rank)} of ${trophyRank.totalFranchises}`
    : null;

// Per-tier rank for each trophy-room section header ("Division Titles ·
// 1st of 24"). Same hide-when-empty rule as the overall rank — a tier the
// franchise has nothing in carries no chip.
function tierRankLabel(tier: AwardTier): string | null {
  const r = getFranchiseTierRank(id, tier);
  if (r.count === 0) return null;
  return `${r.tied ? 'T-' : ''}${ordinal(r.rank)} of ${r.totalFranchises}`;
}

// "No X" overlay text for an unwon (locked) badge.
function lockedLabel(t: TrophyCaseItem): string {
  switch (t.slug) {
    case 'afl-championship':
      return 'No AFL Championships';
    case 'premier-league':
      return 'No Premier League Championships';
    case 'dleague-champion':
      return 'No D-League Championships';
    case 'nit':
      return 'No NIT Championships';
  }
  if (t.category === 'conference') return 'No conference titles';
  if (t.category === 'division') return 'No division titles';
  return 'Not yet won';
}

// Auth — surface owner-only CTAs at the top of the page when the
// viewer matches this franchise.
const authUser = getAuthUser(Astro.request);
const isOwner =
  !!authUser &&
  authUser.leagueId === getLeagueBySlug('afl-fantasy')!.id &&
  authUser.franchiseId === id;

// Name history — every era this OWNER has played under, oldest first,
// ending with the current identity. When the team has `ownerHistory`, the
// timeline follows the owner across franchise IDs (e.g. Highclimbers on
// 0011 in 2003-04 merges into franchise 0004's page once that owner took
// over 0004 in 2023) instead of just this franchise ID's own name changes —
// matching the same attribution `attributeAwardYear` uses for stats.
// `rebrandGroup` (from config `rebrand`/`currentRebrand` tags) marks a
// punitive last-place rename; a shared group value clusters eras that
// belong to one owner's rebrand lineage, purely for display.
type NameEra = {
  name: string;
  yearStart: number;
  yearEnd: number;
  icon?: string;
  banner?: string;
  isCurrent: boolean;
  rebrandGroup?: string;
  sourceFranchiseId?: string | null;
};

// Season year (Labor Day rollover), not calendar year — from January to
// kickoff the "current" era should still label the season actually played.
const CURRENT_YEAR = getCurrentSeasonYear();

// Build the identity segments for one franchise ID within [rangeStart, rangeEnd],
// filling any years not covered by its own `history` with its current name.
function segmentsForFranchiseRange(
  franchiseId: string,
  rangeStart: number,
  rangeEnd: number,
  finalSegmentIsCurrent: boolean
): NameEra[] {
  const t = (aflConfig.teams as any[]).find((x) => x.franchiseId === franchiseId);
  if (!t) return [];
  const isForeignSlot = franchiseId !== id;
  const hist = Array.isArray(t.history)
    ? [...t.history].sort((a: any, b: any) => a.yearStart - b.yearStart)
    : [];

  const clipped: NameEra[] = [];
  for (const h of hist) {
    const s = Math.max(h.yearStart, rangeStart);
    const e = Math.min(h.yearEnd, rangeEnd);
    if (s > e) continue;
    clipped.push({
      name: h.name,
      yearStart: s,
      yearEnd: e,
      icon: h.icon,
      banner: h.banner,
      isCurrent: false,
      rebrandGroup: h.rebrand?.group,
      sourceFranchiseId: isForeignSlot ? franchiseId : null,
    });
  }

  const segments: NameEra[] = [];
  let cursor = rangeStart;
  for (const seg of clipped) {
    if (cursor < seg.yearStart) {
      segments.push({
        name: t.name,
        yearStart: cursor,
        yearEnd: seg.yearStart - 1,
        icon: t.icon,
        banner: t.banner,
        isCurrent: false,
        rebrandGroup: t.currentRebrand?.group,
        sourceFranchiseId: isForeignSlot ? franchiseId : null,
      });
    }
    segments.push(seg);
    cursor = seg.yearEnd + 1;
  }
  if (cursor <= rangeEnd) {
    segments.push({
      name: t.name,
      yearStart: cursor,
      yearEnd: finalSegmentIsCurrent ? 9999 : rangeEnd,
      icon: t.icon,
      banner: t.banner,
      isCurrent: finalSegmentIsCurrent,
      rebrandGroup: t.currentRebrand?.group,
      sourceFranchiseId: isForeignSlot ? franchiseId : null,
    });
  } else if (finalSegmentIsCurrent && segments.length > 0) {
    // The last history entry runs through the current season (e.g. a punitive
    // rename covering this year), so no trailing gap-fill segment was emitted —
    // the final clipped era IS the current identity. Tag it so the page still
    // shows a "Current" era.
    segments[segments.length - 1].isCurrent = true;
  }
  return segments;
}

// The current OWNER's lineage (nameEras) and, separately, this slot's eras
// that belonged to previous owners (priorOwnerEras). The boundary matches
// stat attribution exactly: ownerHistory claims when present, otherwise
// getCurrentOwnerSince (the same inference afl-awards uses).
let nameEras: NameEra[] = [];
let priorOwnerEras: NameEra[] = [];
if (Array.isArray((team as any).ownerHistory) && (team as any).ownerHistory.length > 0) {
  const sortedOwner = [...(team as any).ownerHistory].sort((a: any, b: any) => a.yearStart - b.yearStart);
  sortedOwner.forEach((entry: any, idx: number) => {
    const cap = entry.yearEnd >= 9999 ? CURRENT_YEAR : entry.yearEnd;
    const isFinalEntry = idx === sortedOwner.length - 1 && entry.yearEnd >= 9999;
    nameEras.push(...segmentsForFranchiseRange(entry.franchiseId, entry.yearStart, cap, isFinalEntry));
  });
  // Anything in THIS slot's own history outside the owner's own-slot claims
  // belonged to a previous owner — keep those names visible on this page.
  // Subtract the claimed ranges from each entry (rather than all-or-nothing)
  // so an entry spanning a claim boundary contributes only its unclaimed
  // years here and never renders the same season in both lists.
  const ownSlotClaims = sortedOwner.filter((o: any) => o.franchiseId === id);
  const subtractClaims = (ys: number, ye: number): Array<[number, number]> => {
    let ranges: Array<[number, number]> = [[ys, ye]];
    for (const o of ownSlotClaims) {
      const next: Array<[number, number]> = [];
      for (const [s, e] of ranges) {
        if (o.yearEnd < s || o.yearStart > e) { next.push([s, e]); continue; }
        if (s < o.yearStart) next.push([s, o.yearStart - 1]);
        if (e > o.yearEnd) next.push([o.yearEnd + 1, e]);
      }
      ranges = next;
    }
    return ranges;
  };
  if (Array.isArray(team.history)) {
    for (const h of team.history as any[]) {
      for (const [s, e] of subtractClaims(h.yearStart, h.yearEnd)) {
        priorOwnerEras.push({
          name: h.name,
          yearStart: s,
          yearEnd: e,
          icon: h.icon,
          banner: h.banner,
          isCurrent: false,
          rebrandGroup: h.rebrand?.group,
        });
      }
    }
  }
} else if (Array.isArray(team.history) && team.history.length > 0) {
  // Current owner's run: from ownerSince (or the earliest recorded year when
  // the owner has been here throughout) to today, gap-filling uncovered years
  // with the current name — e.g. The Show 2022-24 before the Cock Gobbler
  // punishment year. Years before ownerSince stay raw (no speculative fill)
  // and render under "Previous owners".
  const earliestYear = Math.min(...(team.history as any[]).map((h: any) => h.yearStart));
  const ownerSince = getCurrentOwnerSince(id!);
  const lineageStart = ownerSince ?? earliestYear;
  nameEras.push(...segmentsForFranchiseRange(id!, lineageStart, CURRENT_YEAR, true));
  for (const h of team.history as any[]) {
    // Clip an entry spanning the ownership boundary so its pre-ownerSince
    // years still show under "Previous owners" instead of vanishing.
    if (ownerSince != null && h.yearStart < ownerSince) {
      priorOwnerEras.push({
        name: h.name,
        yearStart: h.yearStart,
        yearEnd: Math.min(h.yearEnd, ownerSince - 1),
        icon: h.icon,
        banner: h.banner,
        isCurrent: false,
        rebrandGroup: h.rebrand?.group,
      });
    }
  }
} else {
  nameEras.push({
    name: team.name,
    yearStart: CURRENT_YEAR,
    yearEnd: 9999,
    icon: team.icon,
    banner: team.banner,
    isCurrent: true,
    rebrandGroup: (team as any).currentRebrand?.group,
  });
}
nameEras.sort((a, b) => a.yearStart - b.yearStart);
priorOwnerEras.sort((a, b) => a.yearStart - b.yearStart);

// Other franchises whose history shares one of this franchise's rebrand
// groups — surfaced as "same owner, different franchise ID" cross-links.
const rebrandGroups = new Set(nameEras.map((e) => e.rebrandGroup).filter(Boolean));
const relatedRebrands: Array<{ franchiseId: string; teamName: string; eraName: string; group: string }> = [];
const seenRelated = new Set<string>();
const pushRelated = (r: { franchiseId: string; teamName: string; eraName: string; group: string }) => {
  const key = `${r.franchiseId}:${r.eraName}`;
  if (seenRelated.has(key)) return;
  seenRelated.add(key);
  relatedRebrands.push(r);
};
if (rebrandGroups.size > 0) {
  for (const t of aflConfig.teams as any[]) {
    if (t.franchiseId === id) continue;
    if (t.currentRebrand?.group && rebrandGroups.has(t.currentRebrand.group)) {
      pushRelated({ franchiseId: t.franchiseId, teamName: t.name, eraName: t.name, group: t.currentRebrand.group });
    }
    if (Array.isArray(t.history)) {
      for (const h of t.history) {
        if (h.rebrand?.group && rebrandGroups.has(h.rebrand.group)) {
          pushRelated({ franchiseId: t.franchiseId, teamName: t.name, eraName: h.name, group: h.rebrand.group });
        }
      }
    }
  }
}

// This franchise ID's years may have been claimed by a DIFFERENT current
// franchise via that team's ownerHistory (e.g. Highclimbers/0011's 2003-04
// now lives on 0004's page). Surface a forward link so this page still
// points at where that owner's stats actually ended up.
const claimedBy: Array<{ franchiseId: string; teamName: string }> = [];
for (const t of aflConfig.teams as any[]) {
  if (t.franchiseId === id) continue;
  if (Array.isArray(t.ownerHistory) && t.ownerHistory.some((o: any) => o.franchiseId === id)) {
    claimedBy.push({ franchiseId: t.franchiseId, teamName: t.name });
  }
}
---

<TheLeagueLayout title={`${team.name} | AFL Franchise`}>
  <div class="franchise-detail">
    <header class="franchise-hero">
      <a class="franchise-hero__back" href="/afl-fantasy/franchises">
        ← All franchises
      </a>

      <!-- Single header lockup: banner + identity + actions as one unit. -->
      <div class="franchise-lockup">
        {team.banner ? (
          <img class="franchise-lockup__banner" src={team.banner} alt="" loading="lazy" />
        ) : null}

        <div class="franchise-lockup__bar">
          <div class="franchise-lockup__meta">
            <h1 class="franchise-lockup__name" data-visual={team.banner ? 'hidden' : 'shown'}>
              {team.name}
            </h1>
            <span
              class:list={[
                'franchise-hero__tier-pill',
                team.tier === 'Premier League'
                  ? 'franchise-hero__tier-pill--premier'
                  : 'franchise-hero__tier-pill--dleague',
              ]}
            >
              {team.tier}
            </span>
            <span class="franchise-hero__div">{conferenceName} {team.division}</span>
            {team.aliases?.length ? (
              <span class="franchise-lockup__aliases">aka {team.aliases.join(', ')}</span>
            ) : null}
          </div>

          <!-- Action bar: owner-only CTAs + universal roster link -->
          <div class="franchise-actions">
        <a class="franchise-action franchise-action--primary" href={`/afl-fantasy/rosters?franchise=${id}`}>
          <span class="franchise-action__icon" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M9 5H5a2 2 0 00-2 2v12a2 2 0 002 2h14a2 2 0 002-2V7a2 2 0 00-2-2h-4M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          View roster
        </a>
        {isOwner && (
          <>
            <a class="franchise-action" href={`/afl-fantasy/rosters?franchise=${id}&view=planner`}>
              <span class="franchise-action__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              Keeper planner
            </a>
            <a class="franchise-action" href={`/afl-fantasy/trade-builder?from=${id}`}>
              <span class="franchise-action__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M7 17l-4-4m0 0l4-4m-4 4h18m-4-4l4 4m0 0l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              Open trade builder
            </a>
          </>
        )}
          </div>

          <!-- Compact trophy summary: label + count + on-brand title-type pips,
               on one line directly under the identity row. -->
          <div class="lockup-trophies">
            <a class="lockup-trophies__label" href="#trophy-wall">Trophy wall</a>
            <span class="lockup-trophies__count">
              {totalBadges} {totalBadges === 1 ? 'trophy' : 'trophies'}
            </span>
            {rankLabel && (
              <span
                class="lockup-trophies__rank"
                title={`Ranked ${rankLabel} among all AFL franchises by total trophies won`}
              >
                {rankLabel}
              </span>
            )}
            <span class="lockup-trophies__pip-group">
              <span class="lockup-trophies__pips-caption" aria-hidden="true">Complete trophy set</span>
              <span class="title-pips" role="img" aria-label={titlePipsLabel}>
                {titleProgress.types.map((t) => (
                  <span
                    class="title-pips__pip"
                    data-won={t.won ? 'true' : 'false'}
                    title={t.won
                      ? `${t.label} — won ${t.years.length} (${t.years.join(', ')})`
                      : `${t.label} — not yet won`}
                  />
                ))}
                <span class="title-pips__ratio">
                  {titleProgress.wonCount}<span class="title-pips__total">/{titleProgress.total}</span>
                </span>
              </span>
            </span>
          </div>
        </div>
      </div>
    </header>

    <section class="franchise-section trophy-room" id="trophy-wall">
      <h2 class="sr-only">Trophy wall</h2>
      {trophyTiers.length === 0 ? (
        <p class="badge-wall__empty">
          No hardware yet — this case is waiting for its first trophy.
        </p>
      ) : (
        <div class="trophy-tiers">
          {trophyTiers.map((tier) => (
            <section class="trophy-tier" data-tier={tier.key}>
              <h3 class="trophy-tier__title">
                {team.icon ? (
                  <img class="trophy-tier__icon" src={team.icon} alt="" loading="lazy" />
                ) : null}
                <span>{tier.label}</span>
                {tierRankLabel(tier.key) && (
                  <span
                    class="trophy-tier__rank"
                    title={`Ranked ${tierRankLabel(tier.key)} among all AFL franchises in ${tier.label.toLowerCase()}`}
                  >
                    {tierRankLabel(tier.key)}
                  </span>
                )}
              </h3>
              <div class="badge-wall">
                {tier.items.map((t) => (
                  <div
                    class="badge-card"
                    data-category={t.category}
                    data-locked={t.locked ? 'true' : 'false'}
                    role="img"
                    aria-label={t.locked
                      ? lockedLabel(t)
                      : t.dated ? `${t.label} ${t.year}` : `${t.label} ${t.years.join(', ')}`}
                  >
                    <div
                      class="badge-card__art"
                      set:html={renderBadge(
                        t.badge,
                        t.locked ? '' : t.year,
                        t.locked ? `lock-${t.slug}` : t.dated ? `${t.slug}-${t.year}` : t.slug
                      )}
                    />
                    {t.locked ? <span class="badge-card__locked">{lockedLabel(t)}</span> : null}
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
    </section>

    {(nameEras.length > 1 || priorOwnerEras.length > 0) && (
      <section class="franchise-section name-history" id="name-history">
        <h2>Team Name History</h2>
        <ul class="name-history__list">
          {nameEras.slice().reverse().map((era) => (
            <li class:list={['name-history__item', era.rebrandGroup && 'name-history__item--rebrand']}>
              {era.icon ? (
                <img class="name-history__icon" src={era.icon} alt="" loading="lazy" />
              ) : null}
              <div class="name-history__meta">
                <span class="name-history__name">
                  {era.name}
                  {era.isCurrent && <span class="current-tag">Current</span>}
                  {era.sourceFranchiseId && (
                    <span class="prior-franchise-tag">as franchise {era.sourceFranchiseId}</span>
                  )}
                  {era.rebrandGroup && <span class="rebrand-tag" title="Punitive last-place rename">💀 Last-Place Rebrand</span>}
                </span>
                <span class="name-history__years">
                  {era.yearStart}–{era.yearEnd >= 9999 ? 'present' : era.yearEnd}
                </span>
              </div>
            </li>
          ))}
        </ul>
        {relatedRebrands.length > 0 && (
          <p class="name-history__related">
            Same owner, different franchise ID:{' '}
            {relatedRebrands.map((r, i) => (
              <>
                <a href={`/afl-fantasy/franchises/${r.franchiseId}`}>{r.eraName}</a>
                {i < relatedRebrands.length - 1 ? ', ' : ''}
              </>
            ))}
          </p>
        )}
        {claimedBy.length > 0 && (
          <p class="name-history__related">
            Some of this slot's past seasons are credited to:{' '}
            {claimedBy.map((c, i) => (
              <>
                <a href={`/afl-fantasy/franchises/${c.franchiseId}`}>{c.teamName}</a>
                {i < claimedBy.length - 1 ? ', ' : ''}
              </>
            ))}
          </p>
        )}
        {priorOwnerEras.length > 0 && (
          <>
            <h3 class="name-history__subheading">Previous owners of this franchise</h3>
            <ul class="name-history__list name-history__list--prior">
              {priorOwnerEras.slice().reverse().map((era) => (
                <li class:list={['name-history__item', era.rebrandGroup && 'name-history__item--rebrand']}>
                  {era.icon ? (
                    <img class="name-history__icon" src={era.icon} alt="" loading="lazy" />
                  ) : null}
                  <div class="name-history__meta">
                    <span class="name-history__name">
                      {era.name}
                      {era.rebrandGroup && <span class="rebrand-tag" title="Punitive last-place rename">💀 Last-Place Rebrand</span>}
                    </span>
                    <span class="name-history__years">
                      {era.yearStart}–{era.yearEnd >= 9999 ? 'present' : era.yearEnd}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </>
        )}
      </section>
    )}

    <section class="franchise-section">
      <h2>Quick links</h2>
      <div class="quick-links">
        <a class="quick-link" href={`/afl-fantasy/standings?myteam=${id}`}>
          📊 Standings (highlight this team)
        </a>
      </div>
    </section>
  </div>
</TheLeagueLayout>

