      color: var(--content-text-muted, #6b7280);
      text-align: center;
    }

    .tb-submit-hint[data-kind="ok"] { color: #166534; }
    .tb-submit-hint[data-kind="err"] { color: #991b1b; }

    @media (max-width: 1024px) {
      .tb-panels {
        grid-template-columns: 1fr;
      }

      .tb-center {
        position: static;
        order: -1;
      }
    }

    /* Dark mode — the light-tinted red/green pills and semantic text colors
       above are literal hexes with no direct token equivalent; override them
       here rather than change the light-mode fallback (which must stay
       pixel-identical). */
    :global(html.dark) .tb-picker__item.is-selected {
      background: rgba(220, 38, 38, 0.12);
      border-color: rgba(220, 38, 38, 0.35);
    }
    :global(html.dark) .tb-picker__add {
      background: rgba(16, 185, 129, 0.15);
      color: #6ee7b7;
    }
    :global(html.dark) .tb-picker__add:hover {
      background: rgba(16, 185, 129, 0.25);
    }
    :global(html.dark) .tb-picker__item.is-selected .tb-picker__add,
    :global(html.dark) .tb-asset__remove {
      background: rgba(220, 38, 38, 0.15);
      color: #fca5a5;
    }
    :global(html.dark) .tb-asset__remove:hover {
      background: rgba(220, 38, 38, 0.25);
    }
    :global(html.dark) .tb-balance__bar {
      background: rgba(220, 38, 38, 0.15);
    }
    :global(html.dark) .tb-balance__bar-fill {
      background: rgba(16, 185, 129, 0.35);
    }
    :global(html.dark) .tb-balance__verdict[data-kind="ok"],
    :global(html.dark) .tb-submit-hint[data-kind="ok"] {
      color: #6ee7b7;
    }
    :global(html.dark) .tb-balance__verdict[data-kind="warn"],
    :global(html.dark) .tb-submit-hint[data-kind="err"] {
      color: #fca5a5;
    }
    :global(html.dark) .tb-balance__verdict[data-kind="good"] {
      color: #7dd3fc;
    }

    /* Dark mode for the trade block is handled entirely by re-pointing the
       --tb-block-* custom properties on :global(html.dark) .tb-block above. */
  </style>
</TheLeagueLayout>
