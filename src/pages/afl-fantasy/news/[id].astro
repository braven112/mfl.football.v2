---
/**
 * Schefter Article Detail Page — AFL Fantasy.
 *
 * AFL previously had no full-article route (feed cards linked nowhere), which
 * blocked longform article types like The Gauntlet. Mirrors the TheLeague
 * route for content articles; AFL has no auction-grade articles, so the
 * grade-card branch is deliberately omitted.
 * Server-rendered so the afl-fantasy.com middleware rewrite works correctly.
 */

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import SchefterReactionBar from '../../../components/shared/SchefterReactionBar.tsx';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import feedData from '../../../../data/afl-fantasy/schefter-feed.json';
import type { SchefterFeed } from '../../../types/schefter';
import '../../../styles/schefter-feed.css';
import StrengthTable from '../../../components/shared/schedule-strength/StrengthTable.astro';
import ScheduleLuckCallout from '../../../components/shared/schedule-strength/ScheduleLuckCallout.astro';
import TrapWeeksStrip from '../../../components/shared/schedule-strength/TrapWeeksStrip.astro';
import { resolveGauntletView, type GauntletDerived } from '../../../utils/schedule-strength';
import aflConfig from '../../../../data/afl-fantasy/afl.config.json';
import '../../../styles/schedule-strength.css';

// Lazy glob: only the one matching issue is imported, and only for posts that
// carry a scheduleStrength pointer — plain articles pay nothing.
const gauntletFiles = import.meta.glob<GauntletDerived>(
  '../../../../data/afl-fantasy/derived/schedule-strength-*.json',
  { import: 'default' }
);

const { id } = Astro.params;
const feed = feedData as SchefterFeed;
const post = feed.posts.find(p => p.type === 'article' && p.id === id && p.content);

if (!post) {
  return Astro.redirect('/afl-fantasy/news');
}
const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
const imagePath = post.image ? `/assets/schefter/${post.image}` : null;
const formattedDate = new Date(post.timestamp).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const gauntletRef = post.scheduleStrength ?? null;
let gauntletView = null;
if (gauntletRef) {
  const suffix = `schedule-strength-${gauntletRef.year}-w${String(gauntletRef.week).padStart(2, '0')}.json`;
  const key = Object.keys(gauntletFiles).find(file => file.endsWith(suffix));
  const derived = key ? await gauntletFiles[key]() : null;
  if (key && derived) {
    gauntletView = resolveGauntletView({
      files: { [key]: derived },
      teams: aflConfig.teams,
      baseUrl: '/afl-fantasy',
      pagePath: '/afl-fantasy/schedule-strength',
      requestedYear: String(gauntletRef.year),
    });
  }
}
---

<TheLeagueLayout title={`${post.headline} — The Schefter Report`}>
  <div class="sf-article">

    <Breadcrumbs items={[
      { label: 'AFL Fantasy', href: '/afl-fantasy' },
      { label: 'The Schefter Report', href: '/afl-fantasy/news' },
      { label: post.headline },
    ]} />

    <div class="sf-article__card">
      {imagePath && (
        <div class="sf-article__hero-wrap">
          <img
            src={imagePath}
            alt={post.imageAlt ?? post.headline}
            class="sf-article__hero-img"
            loading="eager"
          />
        </div>
      )}

      <div class="sf-article__header">
        <div class="sf-article__meta">
          <span class="sf-article__badge">Article</span>
          <span class="sf-article__meta-dot" aria-hidden="true"></span>
          <time class="sf-article__date" datetime={post.timestamp}>{formattedDate}</time>
        </div>

        <h1 class="sf-article__title">{post.headline}</h1>

        <div class="sf-article__author">
          <img class="sf-article__author-avatar" src="/assets/claude-schefter-avatar.webp" alt="" aria-hidden="true" width="32" height="32" />
          <div>
            <span class="sf-article__author-name">Claude Schefter</span>
            <span class="sf-article__author-handle">@schefter</span>
          </div>
        </div>
      </div>

      <div class="sf-article__body">
        {post.content?.map(paragraph => (
          <p set:html={paragraph} />
        ))}
      </div>

      <!-- The Gauntlet: rankings from the shared derived data -->
      {gauntletView?.data && (
        <div class="sf-gauntlet gauntlet-theme">
          {gauntletView.runIn.length > 0 && (
            <section class="sf-gauntlet__section">
              <h2 class="sf-gauntlet__title">The Run-In</h2>
              <StrengthTable
                variant="run-in"
                rows={gauntletView.runIn}
                caption={`Remaining schedule difficulty, hardest first — Week ${gauntletView.data.week}`}
              />
            </section>
          )}
          {gauntletView.scheduleLuck.length > 0 && (
            <section class="sf-gauntlet__section">
              <h2 class="sf-gauntlet__title">Schedule Luck</h2>
              <ScheduleLuckCallout rows={gauntletView.scheduleLuck} />
            </section>
          )}
          {gauntletView.trapWeeks.length > 0 && (
            <section class="sf-gauntlet__section">
              <h2 class="sf-gauntlet__title">Trap Weeks</h2>
              <TrapWeeksStrip trapWeeks={gauntletView.trapWeeks} />
            </section>
          )}
          <a class="sf-gauntlet__cta" href={r('/afl-fantasy/schedule-strength')}>
            Full dashboard: week-by-week heat map →
          </a>
        </div>
      )}

      <div class="sf-article__reactions">
        <SchefterReactionBar
          client:visible
          postId={post.id}
          isAuthenticated={false}
        />
      </div>

      <div class="sf-article__footer">
        <a href={r('/afl-fantasy/news')} class="sf-article__footer-link">
          ← More from The Schefter Report
        </a>
      </div>
    </div>
  </div>
</TheLeagueLayout>

<style>
  .sf-article {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .sf-gauntlet {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 0 1.25rem 1.25rem;
  }

  .sf-gauntlet__section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sf-gauntlet__title {
    margin: 0;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
    border-left: 3px solid var(--color-primary, #1c497c);
    padding-left: 0.6rem;
  }

  .sf-gauntlet__cta {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--link-color, var(--color-primary, #1c497c));
    text-decoration: none;
  }
  .sf-gauntlet__cta:hover { text-decoration: underline; }
</style>
