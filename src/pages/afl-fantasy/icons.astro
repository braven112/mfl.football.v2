---
import fs from 'fs';
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';

// Resolve to the project-level public folder
const spritePath = new URL('../../public/assets/icons/sprite.svg', import.meta.url);
const spriteContent = fs.readFileSync(spritePath, 'utf-8');
const iconEntries = Array.from(spriteContent.matchAll(/<symbol[^>]+id="([^"]+)"[^>]*viewBox="([^"]+)"/g)).map(match => ({
  id: match[1],
  viewBox: match[2],
}));
// Deduplicate by id, keeping first occurrence
const seen = new Set<string>();
const uniqueIconEntries = iconEntries.filter(entry => {
  if (seen.has(entry.id)) return false;
  seen.add(entry.id);
  return true;
}).sort((a, b) => a.id.localeCompare(b.id));

const spriteUrl = '/assets/icons/sprite.svg';

// Synonym map for search — each icon gets related keywords
const synonyms: Record<string, string[]> = {
  'icon-activity': ['pulse', 'heartbeat', 'health', 'vital', 'status', 'active'],
  'icon-align-left': ['text', 'paragraph', 'format', 'left-align', 'justify'],
  'icon-ambulance': ['emergency', 'medical', 'hospital', 'injury', 'hurt', 'ir'],
  'icon-ambulance-2': ['emergency', 'medical', 'hospital', 'injury', 'hurt', 'ir'],
  'icon-banknote': ['money', 'cash', 'salary', 'pay', 'currency', 'dollar', 'cap', 'contract'],
  'icon-bar-chart': ['graph', 'stats', 'statistics', 'analytics', 'data', 'chart'],
  'icon-beer': ['drink', 'pub', 'bar', 'cheers', 'celebrate', 'party', 'alcohol'],
  'icon-beer-1': ['drink', 'pub', 'bar', 'cheers', 'celebrate', 'party', 'alcohol'],
  'icon-bookmark': ['save', 'favorite', 'flag', 'mark', 'tag', 'saved', 'watchlist'],
  'icon-calendar': ['date', 'schedule', 'event', 'time', 'week', 'month', 'day'],
  'icon-calendar-2': ['date', 'schedule', 'event', 'time', 'week', 'month', 'day'],
  'icon-calendar-3': ['date', 'schedule', 'event', 'time', 'week', 'month', 'day'],
  'icon-cash': ['money', 'dollar', 'salary', 'pay', 'currency', 'bills', 'cap', 'contract'],
  'icon-chalkboard': ['board', 'teach', 'lesson', 'strategy', 'playbook', 'presentation'],
  'icon-champ': ['champion', 'winner', 'trophy', 'first', 'gold', 'victory', 'title', 'playoffs', 'championship'],
  'icon-cheer': ['celebrate', 'fan', 'crowd', 'pom-pom', 'support', 'spirit', 'cheerleader'],
  'icon-chevron-left': ['arrow', 'back', 'previous', 'navigate', 'left', 'nav'],
  'icon-chevron-right': ['arrow', 'forward', 'next', 'navigate', 'right', 'nav'],
  'icon-clipboard': ['copy', 'paste', 'notes', 'list', 'tasks', 'document'],
  'icon-commenting': ['chat', 'message', 'talk', 'speech', 'bubble', 'comment', 'discuss'],
  'icon-comments': ['chat', 'message', 'talk', 'discussion', 'forum', 'board', 'conversation'],
  'icon-dollar': ['money', 'cash', 'salary', 'pay', 'currency', 'price', 'cost', 'cap'],
  'icon-draft-podium': ['draft', 'podium', 'stage', 'pick', 'selection', 'rookie'],
  'icon-exchange': ['trade', 'swap', 'transfer', 'arrows', 'switch', 'deal'],
  'icon-eye': ['view', 'visible', 'watch', 'see', 'show', 'look', 'preview'],
  'icon-eye-slash': ['hidden', 'invisible', 'hide', 'private', 'blind', 'secret'],
  'icon-fans': ['crowd', 'audience', 'spectators', 'supporters', 'people', 'game-day'],
  'icon-file-text': ['document', 'page', 'paper', 'report', 'article', 'rules', 'text'],
  'icon-fingerprint': ['identity', 'auth', 'biometric', 'security', 'login', 'unique', 'verify'],
  'icon-football': ['ball', 'nfl', 'pigskin', 'game', 'sports', 'gridiron'],
  'icon-football-2': ['ball', 'nfl', 'pigskin', 'game', 'sports', 'gridiron'],
  'icon-gavel': ['judge', 'auction', 'bid', 'hammer', 'law', 'rule', 'ruling', 'commish'],
  'icon-goals': ['score', 'scoring', 'points', 'live', 'touchdown', 'field-goal', 'target'],
  'icon-helmet': ['player', 'equipment', 'head', 'gear', 'football', 'protection', 'team'],
