  'icon-home': ['house', 'main', 'start', 'dashboard', 'landing', 'nav', 'homepage'],
  'icon-house': ['home', 'main', 'start', 'dashboard', 'landing', 'nav', 'homepage'],
  'icon-kick': ['punt', 'field-goal', 'kicker', 'boot', 'leg', 'special-teams'],
  'icon-line-chart': ['graph', 'trend', 'analytics', 'data', 'stats', 'growth', 'chart'],
  'icon-lineup': ['roster', 'starters', 'formation', 'submit', 'set', 'starting', 'players'],
  'icon-lion': ['mascot', 'animal', 'pride', 'brave', 'courage', 'premier', 'english'],
