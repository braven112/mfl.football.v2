  'icon-scoreboard-2': ['score', 'board', 'display', 'live', 'points', 'game', 'results'],
  'icon-shield': ['defense', 'protect', 'guard', 'security', 'badge', 'crest', 'team', 'logo'],
  'icon-shield-2': ['defense', 'protect', 'guard', 'security', 'badge', 'crest', 'team', 'logo'],
  'icon-sign-in': ['login', 'enter', 'access', 'authenticate', 'account', 'door'],
  'icon-sort': ['order', 'arrange', 'filter', 'ascending', 'descending', 'organize'],
  'icon-sort-alpha-asc': ['alphabetical', 'a-z', 'order', 'arrange', 'ascending', 'sort'],
  'icon-sort-alpha-desc': ['alphabetical', 'z-a', 'order', 'arrange', 'descending', 'sort'],
  'icon-sort-amount-asc': ['order', 'arrange', 'ascending', 'low-high', 'smallest', 'sort'],
  'icon-sort-amount-desc': ['order', 'arrange', 'descending', 'high-low', 'largest', 'sort'],
  'icon-stadium': ['field', 'arena', 'venue', 'game-day', 'stands', 'crowd', 'football'],
  'icon-standings': ['leaderboard', 'rank', 'table', 'position', 'record', 'wins', 'losses'],
  'icon-standings-2': ['leaderboard', 'rank', 'table', 'position', 'record', 'chart', 'graph'],
  'icon-star': ['favorite', 'rating', 'best', 'top', 'featured', 'highlight', 'mvp', 'playoffs', 'championship'],
  'icon-submit': ['send', 'upload', 'confirm', 'lineup', 'publish', 'save', 'done'],
  'icon-toilet': ['bathroom', 'sacko', 'loser', 'last', 'punishment', 'toilet-bowl', 'worst', 'playoffs', 'championship'],
  'icon-touchdowns': ['td', 'score', 'endzone', 'celebration', 'points', 'six'],
  'icon-transactions-2': ['trade', 'deal', 'handshake', 'swap', 'transfer', 'agreement', 'move'],
  'icon-trophy': ['winner', 'champion', 'award', 'prize', 'cup', 'first', 'gold', 'playoffs', 'championship'],
  'icon-trophy-1': ['winner', 'champion', 'award', 'prize', 'cup', 'first', 'gold', 'playoffs', 'championship'],
  'icon-user': ['person', 'profile', 'account', 'member', 'player', 'owner'],
  'icon-user-md': ['doctor', 'medical', 'injury', 'health', 'ir', 'injured-reserve'],
  'icon-user-plus': ['add', 'new-member', 'invite', 'join', 'register', 'signup', 'pickup'],
  'icon-user-secret': ['spy', 'hidden', 'anonymous', 'incognito', 'private', 'secret', 'mystery'],
  'icon-user-times': ['remove', 'delete', 'drop', 'cut', 'release', 'waiver', 'kick'],
  'icon-users': ['team', 'group', 'people', 'members', 'league', 'owners', 'roster'],
  'icon-whistle': ['referee', 'ref', 'official', 'call', 'foul', 'penalty', 'flag'],
  'icon-whistle-2': ['referee', 'ref', 'official', 'call', 'foul', 'penalty', 'flag'],
  'icon-wrench': ['settings', 'tools', 'config', 'options', 'preferences', 'fix', 'repair', 'admin'],
  'icon-yards': ['distance', 'yardage', 'field', 'measure', 'gain', 'receiving', 'stats'],
};

// Category tags — icons can belong to multiple categories
const categories: Record<string, string[]> = {
  trades: [
    'icon-exchange', 'icon-transactions', 'icon-transactions-2', 'icon-chevron-left', 'icon-chevron-right',
    'icon-clipboard', 'icon-file-text', 'icon-history',
  ],
  transactions: [
    'icon-exchange', 'icon-transactions', 'icon-transactions-2', 'icon-plus', 'icon-user-plus', 'icon-user-times',
    'icon-banknote', 'icon-cash', 'icon-dollar', 'icon-money-bag', 'icon-history',
    'icon-clipboard', 'icon-file-text',
  ],
  waivers: [
    'icon-plus', 'icon-user-plus', 'icon-user-times', 'icon-clipboard',
    'icon-file-text', 'icon-history', 'icon-eye', 'icon-eye-slash',
    'icon-calendar', 'icon-calendar-2', 'icon-calendar-3',
  ],
  auction: [
    'icon-gavel', 'icon-banknote', 'icon-cash', 'icon-dollar', 'icon-money-bag',
    'icon-users', 'icon-chalkboard', 'icon-history', 'icon-bar-chart',
    'icon-line-chart', 'icon-star', 'icon-power',
  ],
  draft: [
    'icon-draft-podium', 'icon-podium-empty', 'icon-podium-persona', 'icon-clipboard',
    'icon-football', 'icon-football-2', 'icon-helmet', 'icon-helmet-2',
    'icon-exchange', 'icon-history', 'icon-rank', 'icon-numberone',
    'icon-calendar', 'icon-calendar-2', 'icon-calendar-3', 'icon-star',
  ],
};

// Invert: build a set of categories per icon
const iconCategories: Record<string, string[]> = {};
for (const [cat, ids] of Object.entries(categories)) {
  for (const id of ids) {
    if (!iconCategories[id]) iconCategories[id] = [];
    iconCategories[id].push(cat);
  }
}

const allCategories = Object.keys(categories);

// Build search data: icon id words + synonyms + categories joined into a single searchable string per icon
const searchData: Record<string, string> = {};
for (const { id } of uniqueIconEntries) {
  const idWords = id.replace('icon-', '').replace(/-/g, ' ');
  const syns = synonyms[id] || [];
  const cats = iconCategories[id] || [];
  searchData[id] = [idWords, ...syns, ...cats].join(' ').toLowerCase();
}
---

<TheLeagueLayout title="Sprite Icon Gallery">
  <section class="icon-gallery">
    <header class="icon-gallery__header">
      <h1>Sprite Icon Gallery</h1>
      <p>All {uniqueIconEntries.length} symbols currently registered in <code>public/assets/icons/sprite.svg</code>.</p>
      <div class="icon-gallery__actions">
        <div class="search-wrapper">
          <input
            type="search"
            class="icon-search"
            placeholder="Search icons... (e.g. money, trade, roster)"
            autocomplete="off"
          />
          <span class="search-count">{uniqueIconEntries.length} icons</span>
        </div>
      </div>
    </header>

    <nav class="category-filters" aria-label="Filter by category">
      {allCategories.map(cat => (
        <button class="category-chip" data-category={cat} type="button">
          {cat}
        </button>
      ))}
    </nav>

    <div class="icon-grid">
      {uniqueIconEntries.map(({ id, viewBox }) => (
        <article
          class="icon-card"
          data-icon-id={id}
          data-search={searchData[id]}
          data-categories={(iconCategories[id] || []).join(' ')}
        >
          <p class="icon-name">{id}</p>
          {(iconCategories[id] || []).length > 0 && (
            <div class="icon-tags">
              {(iconCategories[id] || []).map(cat => (
                <span class="icon-tag" data-tag-category={cat}>{cat}</span>
              ))}
            </div>
          )}
          <div class="icon-preview">
            <svg viewBox={viewBox} role="img" aria-label={id}>
              <use href={`${spriteUrl}#${id}`}></use>
            </svg>
          </div>
        </article>
      ))}
    </div>

    <p class="no-results" style="display:none;">No icons match your search.</p>
  </section>
</TheLeagueLayout>

<style>
  .icon-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .icon-gallery__header h1 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
    color: #0f172a;
  }

  .icon-gallery__header p {
    margin: 0;
    color: #475569;
  }

  .icon-gallery__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 240px;
  }

  .icon-search {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #0f172a;
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
    max-width: 400px;
  }

  .icon-search:focus {
    border-color: #3b82f6;
  }

  .icon-search::placeholder {
    color: #94a3b8;
  }

  .search-count {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 600;
    white-space: nowrap;
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-chip {
    padding: 0.35rem 0.85rem;
    border: 2px solid #e2e8f0;
    border-radius: 20px;
    background: #fff;
    color: #475569;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    text-transform: capitalize;
  }

  .category-chip:hover {
    border-color: #94a3b8;
    color: #0f172a;
  }

  .category-chip.active {
    background: #0f172a;
    border-color: #0f172a;
    color: #fff;
  }

  .icon-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    justify-content: center;
  }

  .icon-tag {
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: #f1f5f9;
    color: #64748b;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .icon-tag[data-tag-category="trades"] { background: #dbeafe; color: #1e40af; }
  .icon-tag[data-tag-category="transactions"] { background: #dcfce7; color: #166534; }
  .icon-tag[data-tag-category="waivers"] { background: #fef3c7; color: #92400e; }
  .icon-tag[data-tag-category="auction"] { background: #fce7f3; color: #9d174d; }
  .icon-tag[data-tag-category="draft"] { background: #ede9fe; color: #5b21b6; }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .icon-card {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    background: #ffffff;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
  }

  .icon-card[hidden] {
    display: none;
  }

  .icon-name {
    margin: 0;
    font-weight: 700;
    color: #0f172a;
    font-size: 0.8rem;
    word-break: break-all;
    text-align: center;
  }

  .icon-preview {
    display: grid;
    place-items: center;
    padding: 0.75rem;
    border-radius: 10px;
    background: #f8fafc;
    min-height: 140px;
  }

  .icon-preview svg {
    width: 72px;
    height: 72px;
    fill: #0f172a;
    color: #0f172a;
  }

  @media (max-width: 640px) {
    .icon-preview {
      min-height: 110px;
    }
    .icon-preview svg {
      width: 56px;
      height: 56px;
    }
    .icon-gallery__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .search-wrapper {
      min-width: 0;
    }
    .icon-search {
      max-width: none;
    }
  }


  .no-results {
    text-align: center;
    color: #64748b;
    font-size: 1rem;
    padding: 2rem 0;
  }
</style>

<script>
  // Search + category filter
  const searchInput = document.querySelector('.icon-search') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('.icon-card');
  const chips = document.querySelectorAll<HTMLButtonElement>('.category-chip');
  const countEl = document.querySelector('.search-count') as HTMLSpanElement;
  const noResults = document.querySelector('.no-results') as HTMLParagraphElement;
  const total = cards.length;
  let activeCategory: string | null = null;

  function filterIcons() {
    const query = searchInput?.value.trim().toLowerCase() || '';
    let visible = 0;

    cards.forEach(card => {
      const searchStr = card.dataset.search || '';
      const iconId = (card.dataset.iconId || '').toLowerCase();
      const cardCats = card.dataset.categories || '';

      const matchesSearch = !query || iconId.includes(query) || searchStr.includes(query);
      const matchesCategory = !activeCategory || cardCats.includes(activeCategory);

      const show = matchesSearch && matchesCategory;
      card.hidden = !show;
      if (show) visible++;
    });

    const hasFilter = query || activeCategory;
    if (countEl) {
      countEl.textContent = hasFilter ? `${visible} of ${total} icons` : `${total} icons`;
    }
    if (noResults) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }
  }

  searchInput?.addEventListener('input', filterIcons);

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const cat = chip.dataset.category || '';
      if (activeCategory === cat) {
        // Deselect
        activeCategory = null;
        chip.classList.remove('active');
      } else {
        // Select new
        chips.forEach(c => c.classList.remove('active'));
        activeCategory = cat;
        chip.classList.add('active');
      }
      filterIcons();
    });
  });
</script>
