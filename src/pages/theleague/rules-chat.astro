---
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import { getAuthUser } from '../../utils/auth';
import RulesChat from '../../components/theleague/rules-chat/RulesChat';
import seedData from '../../data/rules-qa-seeds.json';

const authUser = getAuthUser(Astro.request);
const isAuthenticated = !!authUser;
---

<TheLeagueLayout title="Ask Roger">
  <div class="rqa-page">
    <!-- ── Left: Main Column ── -->
    <div class="rqa-main">
      <header class="rqa-hero">
        <div class="rqa-hero__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div class="rqa-hero__text">
          <div class="rqa-section-title">Ask Roger</div>
          <p class="rqa-hero__sub">Roger is our AI rules expert. He's read the constitution so you don't have to. His answers are <em>probably</em> right — for definitive rulings, ask the actual Commissioner.</p>
        </div>
      </header>

      <div class="rqa-body">
        <RulesChat
          client:load
          preSeeded={seedData}
          isAuthenticated={isAuthenticated}
        />
      </div>
    </div>

    <!-- ── Right: Sticky Sidebar ── -->
    <aside class="rqa-sidebar">
      <div class="rqa-sidebar__inner">
        <!-- Roger's personality card -->
        <div class="rqa-roger-card">
          <img
            src="/assets/commissioner-avatar.webp?v=5"
            alt="Roger — AI Rules Expert"
            class="rqa-roger-card__avatar"
            width="80"
            height="80"
            loading="eager"
          />
          <div class="rqa-roger-card__name">Roger</div>
          <div class="rqa-roger-card__role">AI Rules Expert</div>
          <p class="rqa-roger-card__bio">He's read the constitution cover to cover — all 27 sections, every footnote, and the fine print about compensatory picks that even the Commissioner forgot about.</p>
        </div>

        <!-- Disclaimer -->
        <div class="rqa-sidebar__section">
          <div class="rqa-sidebar__label">Disclaimer</div>
          <p class="rqa-sidebar__disclaimer">
            Roger is an AI chatbot. His answers are based on the <a href="/theleague/rules">official rules</a> and are <em>probably</em> right — but not guaranteed. When in doubt, the Commissioner's word is final.
          </p>
        </div>

        <!-- Tip Roger -->
        <div class="rqa-sidebar__section">
          <div class="rqa-sidebar__label">Support</div>
          <p class="rqa-sidebar__tip-text">
            If Roger saved you a trip to the rulebook, consider giving him a hug. If you're not the hugging type, PayPal works too — each question costs about 10 cents.
          </p>
          <div class="rqa-donate-btns">
            <a href="https://paypal.me/mfladdons" target="_blank" rel="noopener noreferrer" class="rqa-donate-btn">
              <svg class="rqa-donate-btn__icon" aria-hidden="true"><use href="/assets/icons/sprite.svg#icon-paypal" /></svg>
              PayPal
            </a>
            <a href="https://venmo.com/braven112" target="_blank" rel="noopener noreferrer" class="rqa-donate-btn">
              <svg class="rqa-donate-btn__icon" aria-hidden="true"><use href="/assets/icons/sprite.svg#icon-venmo" /></svg>
              Venmo
            </a>
          </div>
        </div>
      </div>
    </aside>
  </div>
</TheLeagueLayout>

<style>
  /* ── 2-Column Blog Layout ── */
  .rqa-page {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 1.5rem;
    max-width: 1080px;
    margin: 0 auto;
    align-items: start;
  }

  /* ── Left: Main Column ── */
  .rqa-main {
    display: flex;
    flex-direction: column;
    gap: var(--padding-lg, 1.5rem);
    min-width: 0;
  }

  /* Hero */
  .rqa-hero {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 2rem;
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
  }
  .rqa-hero__icon {
    width: 56px;
    height: 56px;
    min-width: 56px;
    border-radius: var(--radius-full, 9999px);
    background: var(--color-gray-100, #f3f4f6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary, #1c497c);
  }
  .rqa-section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
    color: var(--color-gray-900, #111827);
  }
  .rqa-hero__sub {
    font-size: 0.875rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0.25rem 0 0 0;
    padding-left: 0.625rem;
  }

  /* Body */
  .rqa-body {
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    padding: 1.5rem;
  }

  /* ── Right: Sticky Sidebar ── */
  .rqa-sidebar {
    position: sticky;
    top: 1rem;
  }
  .rqa-sidebar__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Roger personality card */
  .rqa-roger-card {
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    padding: 1.5rem 1.25rem;
    text-align: center;
  }
  .rqa-roger-card__avatar {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-full, 9999px);
    object-fit: cover;
    border: 3px solid var(--color-gray-100, #f3f4f6);
    margin-bottom: 0.75rem;
  }
  .rqa-roger-card__name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    line-height: 1;
  }
  .rqa-roger-card__role {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary, #1c497c);
    margin-top: 0.25rem;
  }
  .rqa-roger-card__bio {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-gray-400, #9ca3af);
    margin: 0.75rem 0 0 0;
  }

  /* Sidebar sections */
  .rqa-sidebar__section {
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    padding: 1rem 1.25rem;
  }
  .rqa-sidebar__label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    padding-left: 0.5rem;
    border-left: 2px solid var(--color-gray-200, #e5e7eb);
    margin-bottom: 0.625rem;
  }
  .rqa-sidebar__disclaimer {
    font-size: 0.6875rem;
    line-height: 1.55;
    color: var(--color-gray-500, #6b7280);
    margin: 0;
  }
  .rqa-sidebar__disclaimer a {
    color: var(--color-primary, #1c497c);
    text-decoration: none;
  }
  .rqa-sidebar__disclaimer a:hover {
    text-decoration: underline;
  }
  .rqa-sidebar__tip-text {
    font-size: 0.6875rem;
    line-height: 1.55;
    color: var(--color-gray-500, #6b7280);
    margin: 0 0 0.75rem 0;
  }

  /* Donate buttons */
  .rqa-donate-btns {
    display: flex;
    gap: 0.375rem;
  }
  .rqa-donate-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    flex: 1;
    padding: 0.4rem 0.75rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.6875rem;
    font-weight: 600;
    white-space: nowrap;
    color: var(--color-gray-600, #4b5563);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .rqa-donate-btn:hover {
    border-color: var(--color-primary, #1c497c);
    box-shadow: 0 0 0 3px rgba(28, 73, 124, 0.08);
    text-decoration: none;
  }
  .rqa-donate-btn__icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    fill: currentColor;
  }

  /* ── Mobile: Single Column ── */
  @media (max-width: 860px) {
    .rqa-page {
      grid-template-columns: 1fr;
      max-width: 800px;
    }
    .rqa-sidebar {
      position: static;
      order: 1;
    }
    .rqa-main {
      order: 0;
    }
    .rqa-sidebar__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .rqa-roger-card {
      grid-column: 1 / -1;
      display: flex;
      align-items: center;
      gap: 1rem;
      text-align: left;
      padding: 1rem 1.25rem;
    }
    .rqa-roger-card__avatar {
      width: 56px;
      height: 56px;
      margin-bottom: 0;
      flex-shrink: 0;
    }
    .rqa-roger-card__bio {
      margin-top: 0.375rem;
    }
  }

  @media (max-width: 600px) {
    .rqa-hero {
      padding: 1.25rem;
      gap: 0.75rem;
    }
    .rqa-hero__icon {
      width: 44px;
      height: 44px;
      min-width: 44px;
    }
    .rqa-body {
      padding: 1rem;
    }
    .rqa-sidebar__inner {
      grid-template-columns: 1fr;
    }
    .rqa-roger-card {
      flex-direction: column;
      text-align: center;
    }
    .rqa-roger-card__avatar {
      width: 64px;
      height: 64px;
    }
    .rqa-donate-btns {
      justify-content: center;
    }
  }
</style>

<!-- Component styles (global so React components can use them) -->
<style is:global>
  /* ── Ask Input ── */
  .rqa-input {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-gray-100, #f3f4f6);
  }
  .rqa-input__field-wrap {
    position: relative;
  }
  .rqa-input__field {
    width: 100%;
    padding: 0.75rem;
    padding-right: 4rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--text-color, #1f2937);
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-gray-300, #d1d5db);
    border-radius: var(--radius-sm, 0.25rem);
    box-sizing: border-box;
    resize: none;
    overflow: hidden;
    min-height: 44px;
    max-height: 160px;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .rqa-input__field::placeholder {
    color: var(--color-gray-400, #9ca3af);
  }
  .rqa-input__field:focus-visible {
    outline: none;
    border-color: var(--color-primary, #1c497c);
    border-left-color: var(--color-primary, #1c497c);
    box-shadow: 0 0 0 3px rgba(28, 73, 124, 0.1);
    background: var(--color-white, #fff);
  }
  .rqa-input__count {
    position: absolute;
    right: 0.75rem;
    bottom: 0.5rem;
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    font-variant-numeric: tabular-nums;
  }
  .rqa-input__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--color-primary, #1c497c);
    color: #fff;
    border: none;
    border-radius: var(--radius-md, 0.5rem);
    font-size: 0.8125rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s ease, opacity 0.15s ease;
    align-self: flex-end;
  }
  .rqa-input__submit:hover:not(:disabled) {
    background: var(--color-primary-dark, #164066);
  }
  .rqa-input__submit:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .rqa-input__submit:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }
  .rqa-input__spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: rqa-spin 0.6s linear infinite;
  }
  @keyframes rqa-spin {
    to { transform: rotate(360deg); }
  }
  .rqa-input__hint {
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0;
    font-style: italic;
  }

  /* ── Login Prompt ── */
  .rqa-login-prompt {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
    margin-bottom: 1.5rem;
  }

  /* ── Error ── */
  .rqa-error {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 0.75rem;
    background: var(--color-error-light, #fef2f2);
    border: 1px solid var(--color-error-border, #fecaca);
    border-radius: var(--radius-sm, 0.25rem);
    color: var(--color-error, #dc2626);
    font-size: 0.8125rem;
    margin-bottom: 1rem;
  }

  /* ── Q&A List ── */
  .rqa-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .rqa-empty {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-gray-400, #9ca3af);
    font-size: 0.875rem;
  }
  .rqa-count {
    text-align: center;
    padding-top: 1rem;
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  /* ── QA Card ── */
  .rqa-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-gray-100, #f3f4f6);
    transition: background 0.3s ease;
  }
  .rqa-card:first-child {
    padding-top: 0;
  }
  .rqa-card:last-child {
    border-bottom: none;
  }
  .rqa-card--new {
    animation: rqa-highlight 2s ease-out;
  }
  @keyframes rqa-highlight {
    0% { background: rgba(28, 73, 124, 0.06); }
    100% { background: transparent; }
  }
  .rqa-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .rqa-card__avatar {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: var(--radius-full, 9999px);
    background: var(--color-primary, #1c497c);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .rqa-card__avatar--office {
    background: var(--color-gray-200, #e5e7eb);
    color: var(--color-gray-500, #6b7280);
  }
  .rqa-card__meta {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .rqa-card__asker {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gray-700, #374151);
  }
  .rqa-card__time {
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    font-variant-numeric: tabular-nums;
  }
  .rqa-card__question {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-gray-900, #111827);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .rqa-card__answer {
    font-size: 0.8125rem;
    color: var(--color-gray-600, #4b5563);
    line-height: 1.6;
  }
  .rqa-card__answer .rqa-card__para {
    margin: 0 0 0.5rem 0;
  }
  .rqa-card__answer .rqa-card__para:last-child {
    margin-bottom: 0;
  }
  .rqa-card__answer a {
    color: var(--color-primary, #1c497c);
    text-decoration: none;
  }
  .rqa-card__answer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .rqa-card {
      padding: 1rem 0;
    }
    .rqa-card__question {
      font-size: 0.875rem;
    }
    .rqa-card__answer {
      font-size: 0.8125rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rqa-card--new { animation: none; }
    .rqa-input__spinner { animation: none; }
    .rqa-input__field { transition: none; }
    .rqa-input__submit { transition: none; }
  }
</style>
