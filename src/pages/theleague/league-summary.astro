---
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import LeagueSummaryTable from '../../components/theleague/LeagueSummaryTable.astro';
import leagueConfig from '../../data/theleague.config.json';
import { SALARY_YEARS } from '../../utils/salary-calculations';
import {
  computeLeagueSummary,
  parseSalaryAdjustment,
  CATEGORY_DEFINITIONS,
  type SalaryPlayer,
  type TeamConfig,
} from '../../utils/league-summary-utils';
import { getDraftCapitalFromDraftResults } from '../../utils/future-draft-picks-utils';
import { chooseTeamName } from '../../utils/team-names';
import { parseNumber } from '../../utils/formatters';
import { getPlayerMap } from '../../utils/player-map';
import { getCachedRosters } from '../../utils/mfl-roster-cache';

export const prerender = false;

// ---------------------------------------------------------------------------
// Data loading — same patterns as league-comparison.astro and rosters.astro
// ---------------------------------------------------------------------------

const rosterModules = import.meta.glob('../../data/mfl-player-salaries-*.json', {
  eager: true,
});

const salaryAdjustmentFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/salaryAdjustments.json',
  { eager: true }
);

const draftResultsFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/draftResults.json',
  { eager: true }
);

const playerFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/players.json',
  { eager: true }
);

const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const extractSeason = (filepath: string): string | null => {
  const match = filepath.match(/(\d{4})\.json$/);
  return match ? match[1] : null;
};

const extractFeedSeason = (filepath: string): string | null => {
  const match = filepath.match(/mfl-feeds\/(\d{4})\//);
  return match ? match[1] : null;
};

// Get latest roster data
const rosterEntries = Object.entries(rosterModules)
  .map(([path, mod]) => ({
    season: extractSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season && item.data)
  .sort((a, b) => parseInt(b.season!) - parseInt(a.season!));

const latestRoster = rosterEntries[0]?.data || {};
const currentYear = rosterEntries[0]?.season || String(SALARY_YEARS[0]);

// Get salary adjustments for the current year
const adjustmentEntries = Object.entries(salaryAdjustmentFeeds)
  .map(([path, mod]) => ({
    season: extractFeedSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season === currentYear && item.data);

const adjustmentData = adjustmentEntries[0]?.data || {};
const rawAdjustments = adjustmentData.salaryAdjustments?.salaryAdjustment || [];

// Get draft capital from the current year's draftResults API.
// Unlike futureDraftPicks (which only has *future* years), draftResults shows
// the current year's draft board with live ownership after trades.
const draftResultsEntries = Object.entries(draftResultsFeeds)
  .map(([path, mod]) => ({
    season: extractFeedSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season === currentYear && item.data);

const draftResultsData = draftResultsEntries[0]?.data || null;
const draftCapitalMap = getDraftCapitalFromDraftResults(draftResultsData);

// Build player metadata lookup from raw MFL players feed so we can fill in
// name/position for players in Redis that aren't in the static salary file yet.
const playerFeedEntries = Object.entries(playerFeeds)
  .map(([path, mod]) => ({
    season: extractFeedSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season === currentYear && item.data);

const rawPlayerFeed = playerFeedEntries[0]?.data?.players?.player ?? [];
const lsPlayerIdentityMap = getPlayerMap(parseInt(currentYear) || 2026);
const playerMetaById = new Map<string, { name: string; position: string }>();
for (const p of Array.isArray(rawPlayerFeed) ? rawPlayerFeed : [rawPlayerFeed]) {
  if (p?.id) {
    const identity = lsPlayerIdentityMap.get(p.id);
    playerMetaById.set(p.id, {
      name: identity?.name ?? p.name ?? `Player ${p.id}`,
      position: identity?.position ?? p.position ?? '',
    });
  }
}

// ---------------------------------------------------------------------------
// Build team configs from league config
// ---------------------------------------------------------------------------

const teamConfigs: TeamConfig[] = (leagueConfig.teams ?? []).map((team: any) => ({
  franchiseId: team.franchiseId,
  name: team.name,
  nameMedium: team.nameMedium,
  nameShort: team.nameShort,
  abbrev: team.abbrev,
  icon: team.icon,
  division: team.division,
}));

// ---------------------------------------------------------------------------
// Build flat player array from salary data
// ---------------------------------------------------------------------------

const players: SalaryPlayer[] = (latestRoster.players ?? []).map((p: any) => ({
  id: p.id,
  name: p.name,
  position: p.position ?? '',
  salary: parseNumber(p.salary),
  franchiseId: p.franchiseId ?? '',
  status: p.status ?? 'ROSTER',
  contractYear: p.contractYear ?? '0',
  points: parseNumber(p.points),
  birthdate: parseNumber(p.birthdate),
}));

// ---------------------------------------------------------------------------
// Overlay Redis-cached roster data for near-real-time freshness (SWR, ~2 min)
// Same pattern as rosters.astro — static files are the baseline, Redis overlays
// the latest salary/contract/status/franchise assignments on top.
// ---------------------------------------------------------------------------
const cachedRosterPlayers = await getCachedRosters(currentYear, '13522');
if (cachedRosterPlayers) {
  const playerById = new Map(players.map((p) => [p.id, p]));
  for (const [playerId, cached] of Object.entries(cachedRosterPlayers)) {
    const existing = playerById.get(playerId);
    if (existing) {
      // Update mutable roster fields from the fresher Redis data
      existing.salary = parseNumber(cached.salary);
      existing.contractYear = cached.contractYear ?? existing.contractYear;
      existing.status = cached.status ?? existing.status;
      existing.franchiseId = cached.franchiseId ?? existing.franchiseId;
    } else {
      // Players in Redis but not in static file — look up metadata from raw feed
      const meta = playerMetaById.get(playerId);
      if (meta) {
        players.push({
          id: playerId,
          name: meta.name,
          position: meta.position,
          salary: parseNumber(cached.salary),
          franchiseId: cached.franchiseId ?? '',
          status: cached.status ?? 'ROSTER',
          contractYear: cached.contractYear ?? '1',
          points: 0,
          birthdate: 0,
        });
      }
    }
  }
}

// ---------------------------------------------------------------------------
// Compute summary data
// ---------------------------------------------------------------------------

const teamSummaries = computeLeagueSummary(
  players,
  rawAdjustments,
  draftCapitalMap,
  teamConfigs,
);

// Apply team name display rules
// Limit to 4 projected years
const displayYears = SALARY_YEARS.slice(0, 4);

const teamsForDisplay = teamSummaries.map((team) => {
  const config = teamConfigs.find((t) => t.franchiseId === team.franchiseId);
  const nameOpts = {
    fullName: team.teamName,
    nameMedium: config?.nameMedium,
    nameShort: config?.nameShort,
    abbrev: config?.abbrev,
  };
  return {
    ...team,
    teamName: chooseTeamName(nameOpts, 'default'),
    teamNameShort: chooseTeamName(nameOpts, 'short'),
  };
});

---

<TheLeagueLayout title="League Summary">
  <div class="league-summary-container">
    <h1>League Summary <span class="subtitle">{displayYears[0]}–{displayYears[displayYears.length - 1]}</span></h1>

    <LeagueSummaryTable
      teams={teamsForDisplay}
      years={displayYears}
      categories={CATEGORY_DEFINITIONS}
    />
  </div>
</TheLeagueLayout>

<style>
  .league-summary-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.25rem 1.125rem;
    background-color: var(--content-bg, #ffffff);
    border-radius: var(--radius-md, 0.5rem);
    overflow: visible;
    box-sizing: border-box;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-gray-900, #111827);
    line-height: 1.2;
  }

  .subtitle {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-gray-400, #9ca3af);
    margin-left: 0.5rem;
  }
</style>
