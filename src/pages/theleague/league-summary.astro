---
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import LeagueSummaryTable from '../../components/theleague/LeagueSummaryTable.astro';
import leagueConfig from '../../data/theleague.config.json';
import { SALARY_YEARS } from '../../utils/salary-calculations';
import {
  computeLeagueSummary,
  parseSalaryAdjustment,
  CATEGORY_DEFINITIONS,
  type SalaryPlayer,
  type TeamConfig,
} from '../../utils/league-summary-utils';
import { chooseTeamName } from '../../utils/team-names';
import { parseNumber } from '../../utils/formatters';

export const prerender = true;

// ---------------------------------------------------------------------------
// Data loading — same patterns as league-comparison.astro and rosters.astro
// ---------------------------------------------------------------------------

const rosterModules = import.meta.glob('../../data/mfl-player-salaries-*.json', {
  eager: true,
});

const salaryAdjustmentFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/salaryAdjustments.json',
  { eager: true }
);

const futureDraftPicksFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/futureDraftPicks.json',
  { eager: true }
);

const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const extractSeason = (filepath: string): string | null => {
  const match = filepath.match(/(\d{4})\.json$/);
  return match ? match[1] : null;
};

const extractFeedSeason = (filepath: string): string | null => {
  const match = filepath.match(/mfl-feeds\/(\d{4})\//);
  return match ? match[1] : null;
};

// Get latest roster data
const rosterEntries = Object.entries(rosterModules)
  .map(([path, mod]) => ({
    season: extractSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season && item.data)
  .sort((a, b) => parseInt(b.season!) - parseInt(a.season!));

const latestRoster = rosterEntries[0]?.data || {};
const currentYear = rosterEntries[0]?.season || String(SALARY_YEARS[0]);

// Get salary adjustments for the current year
const adjustmentEntries = Object.entries(salaryAdjustmentFeeds)
  .map(([path, mod]) => ({
    season: extractFeedSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season === currentYear && item.data);

const adjustmentData = adjustmentEntries[0]?.data || {};
const rawAdjustments = adjustmentData.salaryAdjustments?.salaryAdjustment || [];

// Get future draft picks — MFL's futureDraftPicks API only returns picks for
// drafts that haven't happened yet. So the current year's draft pick ownership
// (SALARY_YEARS[0]) is stored in the *previous* year's feed, where it was still
// considered "future."
const draftPicksFeedYear = String(SALARY_YEARS[0] - 1);
const draftPicksEntries = Object.entries(futureDraftPicksFeeds)
  .map(([path, mod]) => ({
    season: extractFeedSeason(path),
    data: getModuleData(mod),
  }))
  .filter((item) => item.season === draftPicksFeedYear && item.data);

const futureDraftPicksData = draftPicksEntries[0]?.data || null;

// ---------------------------------------------------------------------------
// Build team configs from league config
// ---------------------------------------------------------------------------

const teamConfigs: TeamConfig[] = (leagueConfig.teams ?? []).map((team: any) => ({
  franchiseId: team.franchiseId,
  name: team.name,
  nameMedium: team.nameMedium,
  nameShort: team.nameShort,
  abbrev: team.abbrev,
  icon: team.icon,
  division: team.division,
}));

// ---------------------------------------------------------------------------
// Build flat player array from salary data
// ---------------------------------------------------------------------------

const players: SalaryPlayer[] = (latestRoster.players ?? []).map((p: any) => ({
  id: p.id,
  name: p.name,
  position: p.position ?? '',
  salary: parseNumber(p.salary),
  franchiseId: p.franchiseId ?? '',
  status: p.status ?? 'ROSTER',
  contractYear: p.contractYear ?? '0',
  points: parseNumber(p.points),
  birthdate: parseNumber(p.birthdate),
}));

// ---------------------------------------------------------------------------
// Compute summary data
// ---------------------------------------------------------------------------

const teamSummaries = computeLeagueSummary(
  players,
  rawAdjustments,
  futureDraftPicksData,
  teamConfigs,
);

// Apply team name display rules
// Limit to 4 projected years
const displayYears = SALARY_YEARS.slice(0, 4);

const teamsForDisplay = teamSummaries.map((team) => {
  const config = teamConfigs.find((t) => t.franchiseId === team.franchiseId);
  const nameOpts = {
    fullName: team.teamName,
    nameMedium: config?.nameMedium,
    nameShort: config?.nameShort,
    abbrev: config?.abbrev,
  };
  return {
    ...team,
    teamName: chooseTeamName(nameOpts, 'default'),
    teamNameShort: chooseTeamName(nameOpts, 'short'),
  };
});

---

<TheLeagueLayout title="League Summary">
  <div class="league-summary-container">
    <h1>League Summary</h1>
    <p class="subtitle">
      Compare all 16 teams across cap, roster, and contract metrics — projected {displayYears[0]}–{displayYears[displayYears.length - 1]}
    </p>

    <LeagueSummaryTable
      teams={teamsForDisplay}
      years={displayYears}
      categories={CATEGORY_DEFINITIONS}
    />
  </div>
</TheLeagueLayout>

<style>
  .league-summary-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 0.5rem;
    background-color: var(--content-bg);
    border-radius: var(--radius-md);
    overflow-x: hidden;
    box-sizing: border-box;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
    padding-inline: 1.5rem;
  }

  .subtitle {
    font-size: 1rem;
    color: #64748b;
    margin-bottom: 5rem;
    padding-inline: 1.5rem;
  }
</style>
