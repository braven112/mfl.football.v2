---
export const prerender = true;

import fs from 'fs';
import path from 'path';
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';

// Use process.cwd() so the path resolves correctly during both dev and prerender build
const spritePath = path.join(process.cwd(), 'public/assets/icons/sprite.svg');
const spriteContent = fs.readFileSync(spritePath, 'utf-8');
const iconEntries = Array.from(spriteContent.matchAll(/<symbol[^>]+id="([^"]+)"[^>]*viewBox="([^"]+)"/g)).map(match => ({
  id: match[1],
  viewBox: match[2],
}));
// Deduplicate by id, keeping first occurrence
const seen = new Set<string>();
const uniqueIconEntries = iconEntries.filter(entry => {
  if (seen.has(entry.id)) return false;
  seen.add(entry.id);
  return true;
}).sort((a, b) => a.id.localeCompare(b.id));

// Cache-bust the sprite URL so browsers always fetch the latest version
const spriteHash = spriteContent.length.toString(36) + uniqueIconEntries.length.toString(36);
const spriteUrl = `/assets/icons/sprite.svg?v=${spriteHash}`;

// Synonym map for search — each icon gets related keywords
const synonyms: Record<string, string[]> = {
