---
import fs from 'fs';
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';

// Resolve to the project-level public folder (src/pages/theleague -> ../../../public)
const spritePath = new URL('../../../public/assets/icons/sprite.svg', import.meta.url);
const spriteContent = fs.readFileSync(spritePath, 'utf-8');
const iconEntries = Array.from(spriteContent.matchAll(/<symbol[^>]+id="([^"]+)"[^>]*viewBox="([^"]+)"/g)).map(match => ({
  id: match[1],
  viewBox: match[2],
}));
// Deduplicate by id, keeping first occurrence
const seen = new Set<string>();
const uniqueIconEntries = iconEntries.filter(entry => {
  if (seen.has(entry.id)) return false;
  seen.add(entry.id);
  return true;
}).sort((a, b) => a.id.localeCompare(b.id));

// Cache-bust the sprite URL so browsers always fetch the latest version
const spriteHash = spriteContent.length.toString(36) + uniqueIconEntries.length.toString(36);
const spriteUrl = `/assets/icons/sprite.svg?v=${spriteHash}`;
---

<TheLeagueLayout title="Sprite Icon Gallery">
  <section class="icon-gallery">
    <header class="icon-gallery__header">
      <h1>Sprite Icon Gallery</h1>
      <p>All {uniqueIconEntries.length} symbols currently registered in <code>public/assets/icons/sprite.svg</code>.</p>
      <button class="copy-sprite-btn" data-sprite-url={spriteUrl} type="button">Copy Full SVG Sprite</button>
    </header>

    <div class="icon-grid">
      {uniqueIconEntries.map(({ id, viewBox }) => (
        <article class="icon-card">
          <p class="icon-name">{id}</p>
          <div class="icon-preview">
            <svg viewBox={viewBox} role="img" aria-label={id}>
              <use href={`${spriteUrl}#${id}`}></use>
            </svg>
          </div>
        </article>
      ))}
    </div>
  </section>
</TheLeagueLayout>

<style>
  .icon-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .icon-gallery__header h1 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
    color: #0f172a;
  }

  .icon-gallery__header p {
    margin: 0;
    color: #475569;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .icon-card {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    background: #ffffff;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
  }

  .icon-name {
    margin: 0;
    font-weight: 700;
    color: #0f172a;
    font-size: 0.95rem;
    word-break: break-all;
    text-align: center;
  }

  .icon-preview {
    display: grid;
    place-items: center;
    padding: 0.75rem;
    border-radius: 10px;
    background: #f8fafc;
    min-height: 140px;
  }

  .icon-preview svg {
    width: 72px;
    height: 72px;
    fill: #0f172a;
    color: #0f172a;
  }

  @media (max-width: 640px) {
    .icon-preview {
      min-height: 110px;
    }
    .icon-preview svg {
      width: 56px;
      height: 56px;
    }
  }
  .copy-sprite-btn {
    margin-top: 0.75rem;
    padding: 0.5rem 1.25rem;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    align-self: flex-start;
  }

  .copy-sprite-btn:hover {
    background: #1e293b;
  }
</style>

<script>
  const btn = document.querySelector('.copy-sprite-btn') as HTMLButtonElement;
  btn?.addEventListener('click', async () => {
    const url = btn.dataset.spriteUrl;
    if (!url) return;
    try {
      const res = await fetch(url);
      const text = await res.text();
      await navigator.clipboard.writeText(text);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    } catch {
      btn.textContent = 'Failed to copy';
      setTimeout(() => { btn.textContent = 'Copy Full SVG Sprite'; }, 2000);
    }
  });
</script>
