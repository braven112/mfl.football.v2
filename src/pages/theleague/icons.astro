  'icon-touchdowns': ['td', 'score', 'endzone', 'celebration', 'points', 'six'],
  'icon-transactions': ['trade', 'deal', 'handshake', 'swap', 'transfer', 'agreement', 'move'],
  'icon-trophy': ['winner', 'champion', 'award', 'prize', 'cup', 'first', 'gold'],
  'icon-trophy-1': ['winner', 'champion', 'award', 'prize', 'cup', 'first', 'gold'],
  'icon-user': ['person', 'profile', 'account', 'member', 'player', 'owner'],
  'icon-user-md': ['doctor', 'medical', 'injury', 'health', 'ir', 'injured-reserve'],
  'icon-user-plus': ['add', 'new-member', 'invite', 'join', 'register', 'signup', 'pickup'],
  'icon-user-secret': ['spy', 'hidden', 'anonymous', 'incognito', 'private', 'secret', 'mystery'],
  'icon-user-times': ['remove', 'delete', 'drop', 'cut', 'release', 'waiver', 'kick'],
  'icon-users': ['team', 'group', 'people', 'members', 'league', 'owners', 'roster'],
  'icon-whistle': ['referee', 'ref', 'official', 'call', 'foul', 'penalty', 'flag'],
  'icon-whistle-2': ['referee', 'ref', 'official', 'call', 'foul', 'penalty', 'flag'],
  'icon-wrench': ['settings', 'tools', 'config', 'options', 'preferences', 'fix', 'repair', 'admin'],
  'icon-yards': ['distance', 'yardage', 'field', 'measure', 'gain', 'receiving', 'stats'],
};

// Build search data: icon id words + synonyms joined into a single searchable string per icon
const searchData: Record<string, string> = {};
for (const { id } of uniqueIconEntries) {
  const idWords = id.replace('icon-', '').replace(/-/g, ' ');
  const syns = synonyms[id] || [];
  searchData[id] = [idWords, ...syns].join(' ').toLowerCase();
}
---

<TheLeagueLayout title="Sprite Icon Gallery">
  <section class="icon-gallery">
    <header class="icon-gallery__header">
      <h1>Sprite Icon Gallery</h1>
      <p>All {uniqueIconEntries.length} symbols currently registered in <code>public/assets/icons/sprite.svg</code>.</p>
      <div class="icon-gallery__actions">
        <div class="search-wrapper">
          <input
            type="search"
            class="icon-search"
            placeholder="Search icons... (e.g. money, trade, roster)"
            autocomplete="off"
          />
          <span class="search-count">{uniqueIconEntries.length} icons</span>
        </div>
        <button class="copy-sprite-btn" data-sprite-url={spriteUrl} type="button">Copy Full SVG Sprite</button>
      </div>
    </header>

    <div class="icon-grid">
      {uniqueIconEntries.map(({ id, viewBox }) => (
        <article class="icon-card" data-icon-id={id} data-search={searchData[id]}>
          <p class="icon-name">{id}</p>
          <div class="icon-preview">
            <svg viewBox={viewBox} role="img" aria-label={id}>
              <use href={`${spriteUrl}#${id}`}></use>
            </svg>
          </div>
        </article>
      ))}
    </div>

    <p class="no-results" style="display:none;">No icons match your search.</p>
  </section>
</TheLeagueLayout>

<style>
  .icon-gallery {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  .icon-gallery__header h1 {
    margin: 0 0 0.35rem;
    font-size: 2rem;
    color: #0f172a;
  }

  .icon-gallery__header p {
    margin: 0;
    color: #475569;
  }

  .icon-gallery__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 240px;
  }

  .icon-search {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #0f172a;
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
    max-width: 400px;
  }

  .icon-search:focus {
    border-color: #3b82f6;
  }

  .icon-search::placeholder {
    color: #94a3b8;
  }

  .search-count {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 600;
    white-space: nowrap;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .icon-card {
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    background: #ffffff;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
  }

  .icon-card[hidden] {
    display: none;
  }

  .icon-name {
    margin: 0;
    font-weight: 700;
    color: #0f172a;
    font-size: 0.8rem;
    word-break: break-all;
    text-align: center;
  }

  .icon-preview {
    display: grid;
    place-items: center;
    padding: 0.75rem;
    border-radius: 10px;
    background: #f8fafc;
    min-height: 140px;
  }

  .icon-preview svg {
    width: 72px;
    height: 72px;
    fill: #0f172a;
    color: #0f172a;
  }

  @media (max-width: 640px) {
    .icon-preview {
      min-height: 110px;
    }
    .icon-preview svg {
      width: 56px;
      height: 56px;
    }
    .icon-gallery__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .search-wrapper {
      min-width: 0;
    }
    .icon-search {
      max-width: none;
    }
  }

  .copy-sprite-btn {
    padding: 0.5rem 1.25rem;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .copy-sprite-btn:hover {
    background: #1e293b;
  }

  .no-results {
    text-align: center;
    color: #64748b;
    font-size: 1rem;
    padding: 2rem 0;
  }
</style>

<script>
  // Copy sprite button
  const btn = document.querySelector('.copy-sprite-btn') as HTMLButtonElement;
  btn?.addEventListener('click', async () => {
    const url = btn.dataset.spriteUrl;
    if (!url) return;
    try {
      const res = await fetch(url);
      const text = await res.text();
      await navigator.clipboard.writeText(text);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    } catch {
      btn.textContent = 'Failed to copy';
      setTimeout(() => { btn.textContent = 'Copy Full SVG Sprite'; }, 2000);
    }
  });

  // Search / filter
  const searchInput = document.querySelector('.icon-search') as HTMLInputElement;
  const cards = document.querySelectorAll<HTMLElement>('.icon-card');
  const countEl = document.querySelector('.search-count') as HTMLSpanElement;
  const noResults = document.querySelector('.no-results') as HTMLParagraphElement;
  const total = cards.length;

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.trim().toLowerCase();
    let visible = 0;

    cards.forEach(card => {
      if (!query) {
        card.hidden = false;
        visible++;
        return;
      }
      const searchStr = card.dataset.search || '';
      const iconId = (card.dataset.iconId || '').toLowerCase();
      const match = iconId.includes(query) || searchStr.includes(query);
      card.hidden = !match;
      if (match) visible++;
    });

    if (countEl) {
      countEl.textContent = query ? `${visible} of ${total} icons` : `${total} icons`;
    }
    if (noResults) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }
  });
</script>
