---
/**
 * Trade Builder
 * Simulate trades between two franchises and see cap impact
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import leagueConfigData from '../../data/theleague.config.json';
import TradeBuilder from '../../components/theleague/trade-builder/TradeBuilder';
import {
  parseNumber,
} from '../../utils/formatters';
import {
  SALARY_CAP,
  ROSTER_LIMIT,
  SALARY_YEARS,
  normalizeStatus,
  getCapPercent,
  calculateCapCharges,
  aggregateDeadMoney,
  getFrozenSalaryAveragesYear,
} from '../../utils/salary-calculations';
import {
  getTheLeaguePreference,
  resolveTeamSelection,
} from '../../utils/team-preferences';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { chooseTeamName } from '../../utils/team-names';
import { calculatePlayerCapHitByYear } from '../../utils/trade-calculations';
import { getPlayerHeadshot, getNflLogoUrl, DEFAULT_HEADSHOT_URL } from '../../constants/roster-constants';
import { loadFeed, loadSrcData } from '../../utils/feed-loader';

export const prerender = false;

const leagueYear = getCurrentLeagueYear();
const leagueYearStr = String(leagueYear);

// Load data feeds for the current league year — direct reads instead of glob
const rostersData = loadFeed<any>('theleague', 'rosters.json', leagueYear);
const playersData = loadFeed<any>('theleague', 'players.json', leagueYear);
const salaryAdjData = loadFeed<any>('theleague', 'salaryAdjustments.json', leagueYear);
const draftPickData = loadFeed<any>('theleague', 'futureDraftPicks.json', leagueYear);
const draftResultsData = loadFeed<any>('theleague', 'draftResults.json', leagueYear);
const tradeBaitRaw = loadFeed<any>('theleague', 'tradeBait.json', leagueYear);
const currentTradeBaitIds = new Set<string>(Array.isArray(tradeBaitRaw) ? tradeBaitRaw : []);
// Feb 15–28/29: transition window after the league year rolls over (Feb 14 @ 8:45 PT).
// A team uses its current year trade bait if any of its rostered players appear there;
// otherwise it falls back to previous year. Outside this window, only current year is used.
const now = new Date();
const isTransitionWindow = now.getMonth() === 1 && now.getDate() >= 15; // Feb 15–end of Feb
const prevTradeBaitIds = (() => {
  if (!isTransitionWindow) return new Set<string>();
  const prev = loadFeed<any>('theleague', 'tradeBait.json', leagueYear - 1);
  return new Set<string>(Array.isArray(prev) ? prev : []);
})();

// Use previous season's frozen (week 14) salary averages for extension/franchise tag calculations.
// Post-rollover data has 10% escalation already applied, which would double-dip with the extension formula.
// Check current year first; if it hasn't reached freeze week, fall back to previous year.
const currentSalaryAvg = loadSrcData<any>(`mfl-salary-averages-${leagueYear}.json`);
const prevSalaryAvg = loadSrcData<any>(`mfl-salary-averages-${leagueYear - 1}.json`);
const salaryAvgYear = (() => {
  if (currentSalaryAvg?.metadata) {
    const meta = currentSalaryAvg.metadata;
    if (meta.week >= (meta.freezeWeek || 14)) return leagueYear;
  }
  return leagueYear - 1;
})();
let salaryAvgData = salaryAvgYear === leagueYear ? currentSalaryAvg : prevSalaryAvg;
// Fallback: use whichever is available
if (!salaryAvgData) {
  salaryAvgData = currentSalaryAvg || prevSalaryAvg;
}

// Build player lookup from players.json
const rawPlayers = playersData?.players?.player ?? [];
const playerMap = new Map<string, any>();
for (const p of rawPlayers) {
  playerMap.set(p.id, p);
}

// Build team config lookup
const teamConfigMap = new Map(
  (leagueConfigData.teams ?? []).map((t: any) => [t.franchiseId, t])
);

// Normalize NFL team codes
const normalizeTeamCode = (team: string) => {
  const map: Record<string, string> = {
    NEP: 'NE', CLV: 'CLE', JAC: 'JAX', KCC: 'KC', LVR: 'LV', OAK: 'LV',
    SD: 'LAC', ARZ: 'ARI', SFO: 'SF', STL: 'LAR', LA: 'LAR', GBP: 'GB',
    NOR: 'NO', NOS: 'NO', TBB: 'TB', WSH: 'WAS',
  };
  if (!team) return '';
  const upper = team.toUpperCase();
  return map[upper] ?? upper;
};

// Salary adjustments
const rawAdjustments = salaryAdjData?.salaryAdjustments?.salaryAdjustment ?? [];

// Future draft picks
const rawDraftPicks = draftPickData?.futureDraftPicks?.franchise ?? [];

// Build team name → franchise ID reverse lookup for trade comment parsing
const teamNameToId = new Map<string, string>();
for (const team of (leagueConfigData.teams ?? []) as any[]) {
  const name = (team.name as string).toLowerCase().trim();
  teamNameToId.set(name, team.franchiseId);
  if (name.startsWith('the ')) {
    teamNameToId.set(name.slice(4), team.franchiseId);
  } else {
    teamNameToId.set('the ' + name, team.franchiseId);
  }
  for (const alias of (team.aliases ?? []) as string[]) {
    teamNameToId.set(alias.toLowerCase().trim(), team.franchiseId);
  }
  for (const hist of (team.history ?? []) as any[]) {
    if (hist.name) {
      const hname = (hist.name as string).toLowerCase().trim();
      teamNameToId.set(hname, team.franchiseId);
    }
  }
}

// Extract current-year draft picks from draftResults (undrafted picks only)
const draftUnit = draftResultsData?.draftResults?.draftUnit;
const rawDraftResultPicks: any[] = (() => {
  const picks = draftUnit?.draftPick;
  if (!picks) return [];
  return Array.isArray(picks) ? picks : [picks];
})();

const currentYearPicksByFranchise = new Map<string, any[]>();
for (const pick of rawDraftResultPicks) {
  if (pick.player) continue; // Skip already-drafted picks

  const currentOwner = pick.franchise;
  const round = String(parseInt(pick.round, 10)); // Normalize "01" → "1"

  // Determine original pick owner from trade comments
  const comment = pick.comments ?? '';
  const tradeMatch = comment.match(/\[Pick traded (?:from )?(.+?)\.?\]/);
  let originalPickFor = currentOwner;

  if (tradeMatch) {
    const tradedFromName = tradeMatch[1].toLowerCase().trim();
    const foundId = teamNameToId.get(tradedFromName);
    if (foundId) {
      originalPickFor = foundId;
    }
  }

  const origTeamConfig = teamConfigMap.get(originalPickFor) as any;
  const originalTeamName = origTeamConfig
    ? chooseTeamName({
        fullName: origTeamConfig.name,
        nameMedium: origTeamConfig.nameMedium,
        nameShort: origTeamConfig.nameShort,
        abbrev: origTeamConfig.abbrev,
      }, 'short')
    : `Team ${originalPickFor}`;

  const draftPick = {
    year: leagueYearStr,
    round,
    originalPickFor,
    originalTeamName,
  };

  if (!currentYearPicksByFranchise.has(currentOwner)) {
    currentYearPicksByFranchise.set(currentOwner, []);
  }
  currentYearPicksByFranchise.get(currentOwner)!.push(draftPick);
}

// Position salary averages for rookie extension calc
const positionAverages: Record<string, { top3Average: number; top5Average: number }> = {};
if (salaryAvgData?.positions) {
  for (const [pos, data] of Object.entries(salaryAvgData.positions as Record<string, any>)) {
    positionAverages[pos] = {
      top3Average: data.top3Average ?? 0,
      top5Average: data.top5Average ?? 0,
    };
  }
}

// Process all 16 teams
const franchises = rostersData?.rosters?.franchise ?? [];

const teams = franchises.map((franchise: any) => {
  const config = teamConfigMap.get(franchise.id) as any;
  const teamName = config
    ? chooseTeamName({
        fullName: config.name,
        nameMedium: config.nameMedium,
        nameShort: config.nameShort,
        abbrev: config.abbrev,
      })
    : `Team ${franchise.id}`;

  // Process players
  const rawRosterPlayers = Array.isArray(franchise.player) ? franchise.player : [];
  // Per-team trade bait: use current year if any rostered player is on it, else fall back to previous year
  const teamPlayerIds = rawRosterPlayers.map((rp: any) => String(rp.id));
  const teamHasCurrentBait = teamPlayerIds.some((id: string) => currentTradeBaitIds.has(id));
  const tradeBaitSet = teamHasCurrentBait ? currentTradeBaitIds : prevTradeBaitIds;
  const players = rawRosterPlayers.map((rp: any) => {
    const pData = playerMap.get(rp.id);
    const salary = parseNumber(rp.salary);
    const contractYears = parseInt(rp.contractYear ?? '0', 10) || 0;
    const contractInfo = rp.contractInfo ?? '';
    const status = rp.status ?? 'ROSTER';
    const norm = normalizeStatus(status);
    const position = pData?.position ?? 'N/A';
    const nflTeam = normalizeTeamCode(pData?.team ?? '');

    return {
      id: rp.id,
      name: pData?.name ?? `Player ${rp.id}`,
      position,
      salary,
      contractYears,
      contractInfo,
      status,
      normalizedStatus: norm,
      nflTeam,
      headshot: getPlayerHeadshot(rp.id, pData?.espn_id),
      nflLogo: getNflLogoUrl(nflTeam),
      isRookie: contractInfo.startsWith('R'),
      isFranchiseTagged: contractInfo === 'F',
      tradeBait: tradeBaitSet.has(String(rp.id)),
      capHitByYear: calculatePlayerCapHitByYear(salary, contractYears, norm),
    };
  });

  // Cap charges and dead money
  const capPlayers = players.map((p: any) => ({
    salary: p.salary,
    contractYears: p.contractYears,
    displayTag: p.normalizedStatus === 'PRACTICE' ? 'practice'
      : p.normalizedStatus === 'INJURED' ? 'injured'
      : 'active',
  }));
  const capCharges = calculateCapCharges(capPlayers);

  // Dead money for this franchise
  const teamAdjustments = rawAdjustments
    .filter((adj: any) => adj.franchise_id === franchise.id)
    .map((adj: any) => ({
      franchiseId: adj.franchise_id,
      amount: adj.amount,
    }));
  const deadMoney = aggregateDeadMoney(teamAdjustments);

  const currentCapSpace = SALARY_CAP - capCharges[0] - (deadMoney[0] ?? 0);
  const totalSalary = players.reduce((sum: number, p: any) => sum + p.salary, 0);

  // Draft picks: merge current-year (from draftResults) with future (from futureDraftPicks)
  const picksFranchise = rawDraftPicks.find((f: any) => f.id === franchise.id);
  const rawPicks = picksFranchise?.futureDraftPick ?? [];
  const futurePicks = (Array.isArray(rawPicks) ? rawPicks : [rawPicks]).map((dp: any) => {
    const origTeamConfig = teamConfigMap.get(dp.originalPickFor) as any;
    return {
      year: dp.year,
      round: dp.round,
      originalPickFor: dp.originalPickFor,
      originalTeamName: origTeamConfig
        ? chooseTeamName({
            fullName: origTeamConfig.name,
            nameMedium: origTeamConfig.nameMedium,
            nameShort: origTeamConfig.nameShort,
            abbrev: origTeamConfig.abbrev,
          }, 'short')
        : `Team ${dp.originalPickFor}`,
    };
  });
  const currentYearPicks = currentYearPicksByFranchise.get(franchise.id) ?? [];
  const draftPicks = [...currentYearPicks, ...futurePicks];

  return {
    franchiseId: franchise.id,
    name: config?.name ?? `Team ${franchise.id}`,
    nameMedium: config?.nameMedium ?? teamName,
    nameShort: config?.nameShort ?? teamName,
    abbrev: config?.abbrev ?? franchise.id,
    icon: config?.icon ?? '',
    division: config?.division ?? '',
    players,
    draftPicks,
    capCharges,
    deadMoney,
    currentCapSpace,
    totalSalary,
    rosterCount: players.length,
  };
});

// Determine default team from user preferences
const theLeaguePref = getTheLeaguePreference(Astro.cookies);
const myTeamParam = Astro.url.searchParams.get('myteam');
const cookiePref = theLeaguePref?.franchiseId;
const hasPreference = !!(myTeamParam || cookiePref);
const defaultTeam = hasPreference
  ? resolveTeamSelection({
      myTeamParam,
      cookiePreference: cookiePref,
      defaultTeam: '0001',
    })
  : '';

const pageData = {
  teams,
  salaryYears: SALARY_YEARS,
  salaryCap: SALARY_CAP,
  rosterLimit: ROSTER_LIMIT,
  leagueYear,
  positionAverages,
};
---

<TheLeagueLayout title="Trade Builder | The League">
  <TradeBuilder
    client:load
    pageData={JSON.stringify(pageData)}
    defaultTeamId={defaultTeam}
  />
</TheLeagueLayout>
