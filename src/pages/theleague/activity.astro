---
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import leagueConfig from '../../data/theleague.config.json';
import { chooseTeamName } from '../../utils/team-names';
import {
	getAllActivity,
	getDailyPageViews,
	getGlobalPagePopularity,
	getAllOwnerPagePopularity,
	getActivityLevel,
	getActivityLabel,
	formatLastSeenLong,
	type ActivityLevel,
} from '../../utils/owner-activity';
import { getTeamColor } from '../../utils/team-colors';
import { getCurrentLeagueYear } from '../../utils/league-year';
import pageDirectory from '../../data/page-directory.json';

const PAGE_NAMES: Record<string, string> = Object.fromEntries(
	pageDirectory.map((p: { path: string; title: string }) => [p.path, p.title])
);
function pageName(path: string): string {
	return PAGE_NAMES[path] || path.replace(/^\//, '').replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()) || 'Homepage';
}

const leagueId = '13522';
const franchiseIds = leagueConfig.teams.map((t: any) => t.franchiseId);
let activityMap: Record<string, number> = {};
let pageViewData: { dates: string[]; data: Record<string, Record<string, number>> } = { dates: [], data: {} };
let globalPages: { page: string; count: number }[] = [];
let ownerPages: Record<string, { page: string; count: number }[]> = {};

// Mock data for local development — ?mock=true enables it
const useMock = Astro.url.searchParams.has('mock');

if (useMock) {
	// Seeded random for deterministic output
	const seed = (s: number) => () => { s = (s * 16807 + 0) % 2147483647; return (s - 1) / 2147483646; };

	// Activity levels: some very active, some idle, some dormant
	const activityProfiles: Record<string, { baseViews: number; lastSeenHoursAgo: number }> = {
		'0001': { baseViews: 18, lastSeenHoursAgo: 0.5 },   // power user
		'0002': { baseViews: 14, lastSeenHoursAgo: 2 },      // very active
		'0003': { baseViews: 3, lastSeenHoursAgo: 72 },       // idle
		'0004': { baseViews: 11, lastSeenHoursAgo: 4 },       // active
		'0005': { baseViews: 7, lastSeenHoursAgo: 12 },       // active
		'0006': { baseViews: 1, lastSeenHoursAgo: 240 },      // dormant
		'0007': { baseViews: 5, lastSeenHoursAgo: 36 },       // idle
		'0008': { baseViews: 16, lastSeenHoursAgo: 1 },       // power user
		'0009': { baseViews: 9, lastSeenHoursAgo: 8 },        // active
		'0010': { baseViews: 12, lastSeenHoursAgo: 3 },       // very active
		'0011': { baseViews: 2, lastSeenHoursAgo: 168 },      // dormant
		'0012': { baseViews: 6, lastSeenHoursAgo: 48 },       // idle
		'0013': { baseViews: 8, lastSeenHoursAgo: 18 },       // active
		'0014': { baseViews: 0, lastSeenHoursAgo: -1 },       // never seen
		'0015': { baseViews: 4, lastSeenHoursAgo: 96 },       // idle
		'0016': { baseViews: 10, lastSeenHoursAgo: 6 },       // active
	};

	// Last seen timestamps
	for (const [fid, profile] of Object.entries(activityProfiles)) {
		if (profile.lastSeenHoursAgo >= 0) {
			activityMap[fid] = Date.now() - profile.lastSeenHoursAgo * 3600_000;
		}
	}

	// Daily page views for 30 days
	const dates: string[] = [];
	for (let i = 29; i >= 0; i--) {
		const d = new Date(); d.setDate(d.getDate() - i);
		dates.push(d.toISOString().slice(0, 10));
	}
	const pvData: Record<string, Record<string, number>> = {};
	for (const date of dates) {
		pvData[date] = {};
		for (const [fid, profile] of Object.entries(activityProfiles)) {
			if (profile.baseViews === 0) continue;
			const rng = seed(parseInt(fid) * 1000 + parseInt(date.replace(/-/g, '')));
			// Add some variance: weekends are busier, recent days trend up
			const dayOfWeek = new Date(date).getDay();
			const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
			const recencyBoost = 1 + (dates.indexOf(date) / dates.length) * 0.5;
			const weekendBoost = isWeekend ? 1.4 : 1;
			const views = Math.max(0, Math.round(profile.baseViews * recencyBoost * weekendBoost * (0.3 + rng() * 1.4)));
			if (views > 0) pvData[date][fid] = views;
		}
	}
	pageViewData = { dates, data: pvData };

	// Global page popularity
	const pageWeights = [
		{ page: '/rosters', weight: 320 },
		{ page: '/players', weight: 185 },
		{ page: '/trade-builder', weight: 142 },
		{ page: '/standings', weight: 128 },
		{ page: '/salary', weight: 97 },
		{ page: '/league-summary', weight: 84 },
		{ page: '/draft-predictor', weight: 72 },
		{ page: '/playoffs', weight: 61 },
		{ page: '/contracts/manage', weight: 55 },
		{ page: '/calendar', weight: 43 },
		{ page: '/dead-money', weight: 38 },
		{ page: '/mvp', weight: 31 },
		{ page: '/whats-new', weight: 27 },
		{ page: '/activity', weight: 22 },
		{ page: '/rules', weight: 14 },
	];
	globalPages = pageWeights.map(({ page, weight }) => ({ page, count: weight }));

	// Per-owner page popularity
	ownerPages = {};
	for (const fid of franchiseIds) {
		const profile = activityProfiles[fid];
		if (!profile || profile.baseViews === 0) { ownerPages[fid] = []; continue; }
		const rng = seed(parseInt(fid) * 7919);
		ownerPages[fid] = pageWeights
			.slice(0, 6 + Math.floor(rng() * 5))
			.map(({ page, weight }) => ({
				page,
				count: Math.max(1, Math.round(weight * (profile.baseViews / 10) * (0.5 + rng()))),
			}))
			.sort((a, b) => b.count - a.count);
	}
} else {
	try {
		[activityMap, pageViewData, globalPages, ownerPages] = await Promise.all([
			getAllActivity(leagueId),
			getDailyPageViews(leagueId, 30),
			getGlobalPagePopularity(leagueId),
			getAllOwnerPagePopularity(leagueId, franchiseIds),
		]);
	} catch { /* Redis unavailable */ }
}

// ── Transaction data ──
interface TxCounts { trades: number; freeAgents: number; auctionWins: number; total: number; }
const txCountMap: Record<string, TxCounts> = {};
const ensureFranchise = (id: string) => {
	if (!txCountMap[id]) txCountMap[id] = { trades: 0, freeAgents: 0, auctionWins: 0, total: 0 };
};

// import.meta.glob must be at the top level (Vite requirement)
const txFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/transactions.json', { eager: true });

if (useMock) {
	// Mock transaction counts tied to activityProfiles intensity
	const mockTxProfiles: Record<string, { trades: number; fa: number; auctions: number }> = {
		'0001': { trades: 4, fa: 7, auctions: 12 },
		'0002': { trades: 3, fa: 5, auctions: 9 },
		'0003': { trades: 1, fa: 2, auctions: 3 },
		'0004': { trades: 3, fa: 4, auctions: 8 },
		'0005': { trades: 2, fa: 3, auctions: 6 },
		'0006': { trades: 0, fa: 1, auctions: 1 },
		'0007': { trades: 1, fa: 3, auctions: 4 },
		'0008': { trades: 5, fa: 6, auctions: 11 },
		'0009': { trades: 2, fa: 4, auctions: 7 },
		'0010': { trades: 3, fa: 5, auctions: 10 },
		'0011': { trades: 0, fa: 1, auctions: 2 },
		'0012': { trades: 1, fa: 2, auctions: 5 },
		'0013': { trades: 2, fa: 3, auctions: 6 },
		'0014': { trades: 0, fa: 0, auctions: 0 },
		'0015': { trades: 1, fa: 2, auctions: 3 },
		'0016': { trades: 2, fa: 4, auctions: 8 },
	};
	for (const [fid, p] of Object.entries(mockTxProfiles)) {
		txCountMap[fid] = { trades: p.trades, freeAgents: p.fa, auctionWins: p.auctions, total: p.trades + p.fa + p.auctions };
	}
} else {
	const leagueYear = getCurrentLeagueYear();
	const txFeedKey = Object.keys(txFeeds).find(p => p.includes(`/${leagueYear}/`));
	const txMod: any = txFeedKey ? txFeeds[txFeedKey] : null;
	const txData = txMod && typeof txMod === 'object' && 'default' in txMod ? txMod.default : txMod;
	const rawTx: any[] = txData?.transactions?.transaction
		? (Array.isArray(txData.transactions.transaction) ? txData.transactions.transaction : [txData.transactions.transaction])
		: [];

	for (const tx of rawTx) {
		if (tx.type === 'TRADE') {
			ensureFranchise(tx.franchise); ensureFranchise(tx.franchise2);
			txCountMap[tx.franchise].trades++; txCountMap[tx.franchise].total++;
			txCountMap[tx.franchise2].trades++; txCountMap[tx.franchise2].total++;
		} else if (tx.type === 'FREE_AGENT') {
			ensureFranchise(tx.franchise);
			txCountMap[tx.franchise].freeAgents++; txCountMap[tx.franchise].total++;
		} else if (tx.type === 'AUCTION_WON') {
			ensureFranchise(tx.franchise);
			txCountMap[tx.franchise].auctionWins++; txCountMap[tx.franchise].total++;
		}
	}
}

const txLeaderboard = leagueConfig.teams
	.map((team: any) => ({
		franchiseId: team.franchiseId,
		name: chooseTeamName({ fullName: team.name, nameMedium: team.nameMedium, nameShort: team.nameShort, abbrev: team.abbrev }),
		icon: team.icon,
		counts: txCountMap[team.franchiseId] || { trades: 0, freeAgents: 0, auctionWins: 0, total: 0 },
	}))
	.sort((a, b) => b.counts.total - a.counts.total);

const globalTotal = globalPages.reduce((s, p) => s + p.count, 0);

interface TeamActivity {
	franchiseId: string;
	name: string;
	icon: string;
	lastVisit: number | null;
	level: ActivityLevel;
	label: string;
	timeAgo: string;
}

const teams: TeamActivity[] = leagueConfig.teams.map((team) => {
	const ts = activityMap[team.franchiseId] ?? null;
	const level = getActivityLevel(ts);
	return {
		franchiseId: team.franchiseId,
		name: chooseTeamName({
			fullName: team.name,
			nameMedium: team.nameMedium,
			nameShort: team.nameShort,
			abbrev: team.abbrev,
		}),
		icon: team.icon,
		lastVisit: ts,
		level,
		label: getActivityLabel(level),
		timeAgo: formatLastSeenLong(ts),
	};
});

// Sort by most recent visit (nulls/never-seen last)
teams.sort((a, b) => (b.lastVisit ?? 0) - (a.lastVisit ?? 0));

const hasAnyData = teams.some((t) => t.lastVisit !== null);

// Build chart series data: one series per team with daily page view counts
const chartTeams = leagueConfig.teams.map((team) => ({
	id: team.franchiseId,
	name: chooseTeamName({
		fullName: team.name,
		nameMedium: team.nameMedium,
		nameShort: team.nameShort,
		abbrev: team.abbrev,
	}, 'short'),
	color: getTeamColor(team.franchiseId),
	icon: team.icon,
	values: pageViewData.dates.map((d) => pageViewData.data[d]?.[team.franchiseId] ?? 0),
}));
const chartDates = pageViewData.dates;
const hasChartData = chartTeams.some((t) => t.values.some((v) => v > 0));
---

<TheLeagueLayout title="Owner Activity">
	<section class="activity-page" aria-labelledby="activity-page-title">
		<div class="activity-page__header">
			<h1 class="activity-page__title" id="activity-page-title">Owner Activity</h1>
			<p class="activity-page__subtitle">Last time each owner visited the site</p>
		</div>

		<!-- Daily Page Views Chart -->
		<div class="chart-section">
			<div class="section-header">
				<h2 class="section-header__title">Daily Page Views</h2>
				<p class="section-header__sub">Pages viewed per owner over the last 30 days</p>
			</div>

			{!hasChartData ? (
				<div class="chart-empty">
					<p>Chart data will appear as owners browse the site.</p>
				</div>
			) : (
				<div class="chart-container" id="activityChart" aria-label="Line chart showing daily page views per owner"></div>
			)}

			<div class="chart-legend" id="chartLegend">
				{chartTeams.map((team) => (
					<button class="chart-legend__item" data-franchise={team.id} data-active="true" type="button" title={`Toggle ${team.name}`}>
						<span class="chart-legend__swatch" style={`background:${team.color}`}></span>
						<img src={team.icon} alt="" class="chart-legend__icon" width="16" height="16" loading="lazy" />
						<span class="chart-legend__name">{team.name}</span>
					</button>
				))}
			</div>
		</div>

		<!-- Popular Pages -->
		<div class="popular-pages" style="margin-top:2rem">
			<div class="section-header">
				<h2 class="section-header__title">Popular Pages</h2>
				<p class="section-header__sub">Most visited pages across all owners</p>
			</div>

			{globalPages.length === 0 ? (
				<div class="chart-empty">
					<p>Page analytics will appear as owners browse the site.</p>
				</div>
			) : (
				<div class="popular-pages__grid">
					<div class="popular-pages__global">
						<h3 class="popular-pages__heading">All Owners</h3>
						<ol class="page-rank-list">
							{globalPages.slice(0, 16).map((entry) => (
								<li class="page-rank-list__item">
									<span class="page-rank-list__name">{pageName(entry.page)}</span>
									<span class="page-rank-list__bar-wrap">
										<span
											class="page-rank-list__bar"
											style={`width:${Math.round((entry.count / (globalPages[0]?.count || 1)) * 100)}%`}
										></span>
									</span>
									<span class="page-rank-list__count">{entry.count}</span>
								</li>
							))}
						</ol>
					</div>

					<div class="popular-pages__owners">
						<h3 class="popular-pages__heading">By Owner</h3>
						<div class="owner-pages-accordion" id="ownerPagesAccordion">
							{[...teams].sort((a, b) => {
							const aViews = (ownerPages[a.franchiseId] || []).reduce((s, p) => s + p.count, 0);
							const bViews = (ownerPages[b.franchiseId] || []).reduce((s, p) => s + p.count, 0);
							return bViews - aViews;
						}).map((team) => {
								const pages = ownerPages[team.franchiseId] || [];
								if (pages.length === 0) return null;
								return (
									<details class="owner-pages-detail">
										<summary class="owner-pages-summary">
											<img src={team.icon} alt="" class="owner-pages-icon" width="20" height="20" loading="lazy" />
											<span>{team.name}</span>
											<span class="owner-pages-total">{pages.reduce((s, p) => s + p.count, 0)} views</span>
										</summary>
										<ol class="page-rank-list page-rank-list--compact">
											{pages.slice(0, 8).map((entry) => (
												<li class="page-rank-list__item">
													<span class="page-rank-list__name">{pageName(entry.page)}</span>
													<span class="page-rank-list__count">{entry.count}</span>
												</li>
											))}
										</ol>
									</details>
								);
							})}
						</div>
					</div>
				</div>
			)}
		</div>

		<!-- Transaction Activity -->
		<div class="section-header" style="margin-top:2rem">
			<h2 class="section-header__title">Transaction Activity</h2>
			<p class="section-header__sub">Trades, free agent moves, and auction wins this season</p>
		</div>

		{txLeaderboard.every(t => t.counts.total === 0) ? (
			<div class="chart-empty">
				<p>No transactions recorded yet this season.</p>
			</div>
		) : (
			<table class="activity-table" aria-label="Transaction activity leaderboard">
				<thead>
					<tr>
						<th scope="col" class="activity-table__th activity-table__th--rank">#</th>
						<th scope="col" class="activity-table__th activity-table__th--team">Team</th>
						<th scope="col" class="activity-table__th activity-table__th--stat">Trades</th>
						<th scope="col" class="activity-table__th activity-table__th--stat">FA</th>
						<th scope="col" class="activity-table__th activity-table__th--stat">Auctions</th>
						<th scope="col" class="activity-table__th activity-table__th--stat">Total</th>
					</tr>
				</thead>
				<tbody>
					{txLeaderboard.map((team, i) => (
						<tr class="activity-table__row">
							<td class="activity-table__td activity-table__td--rank">{i + 1}</td>
							<td class="activity-table__td activity-table__td--team">
								<div class="activity-team">
									<img src={team.icon} alt="" class="activity-team__icon" width="32" height="32" loading="lazy" />
									<span class="activity-team__name">{team.name}</span>
								</div>
							</td>
							<td class="activity-table__td activity-table__td--stat">{team.counts.trades}</td>
							<td class="activity-table__td activity-table__td--stat">{team.counts.freeAgents}</td>
							<td class="activity-table__td activity-table__td--stat">{team.counts.auctionWins}</td>
							<td class="activity-table__td activity-table__td--stat">{team.counts.total}</td>
						</tr>
					))}
				</tbody>
			</table>
		)}

		<!-- Last Seen Table -->
		<div class="section-header" style="margin-top:2rem">
			<h2 class="section-header__title">Last Seen</h2>
			<p class="section-header__sub">Ranked by most recent visit</p>
		</div>

		{!hasAnyData ? (
			<div class="activity-page__empty" role="status">
				<p>No activity data yet. Visit tracking begins once owners start logging in.</p>
			</div>
		) : (
			<table class="activity-table" aria-label="Owner activity ranked by most recent visit">
				<thead>
					<tr>
						<th scope="col" class="activity-table__th activity-table__th--rank">#</th>
						<th scope="col" class="activity-table__th activity-table__th--team">Team</th>
						<th scope="col" class="activity-table__th activity-table__th--time">Last Seen</th>
						<th scope="col" class="activity-table__th activity-table__th--status">Status</th>
					</tr>
				</thead>
				<tbody>
					{teams.map((team, index) => (
						<tr class="activity-table__row" data-level={team.level}>
							<td class="activity-table__td activity-table__td--rank">
								{index + 1}
							</td>
							<td class="activity-table__td activity-table__td--team">
								<div class="activity-team">
									<img
										src={team.icon}
										alt=""
										class="activity-team__icon"
										width="32"
										height="32"
										loading="lazy"
									/>
									<span class="activity-team__name">{team.name}</span>
								</div>
							</td>
							<td class="activity-table__td activity-table__td--time">
								{team.timeAgo}
							</td>
							<td
								class="activity-table__td activity-table__td--status"
								data-level={team.level}
								aria-label={`Status: ${team.label}`}
							>
								<div class="activity-status">
									<span class="activity-dot" aria-hidden="true"></span>
									<span class="activity-label">{team.label}</span>
								</div>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		)}
	</section>
</TheLeagueLayout>

<script type="application/json" id="chart-data" set:html={JSON.stringify({ dates: chartDates, teams: chartTeams })}></script>

<script>
	function renderChart() {
		const el = document.getElementById('activityChart');
		const dataEl = document.getElementById('chart-data');
		if (!el || !dataEl) return;

		const { dates, teams } = JSON.parse(dataEl.textContent || '{}') as {
			dates: string[];
			teams: { id: string; name: string; color: string; values: number[] }[];
		};

		if (!dates?.length || !teams?.length) return;

		const W = 800;
		const H = 300;
		const PAD = { top: 16, right: 16, bottom: 40, left: 40 };
		const plotW = W - PAD.left - PAD.right;
		const plotH = H - PAD.top - PAD.bottom;

		const activeFranchises = new Set(teams.map((t) => t.id));

		function getYMax() {
			let max = 0;
			for (const t of teams) {
				if (!activeFranchises.has(t.id)) continue;
				for (const v of t.values) if (v > max) max = v;
			}
			return Math.max(max, 1);
		}

		function buildSVG() {
			const yMax = getYMax();
			const xStep = plotW / Math.max(dates.length - 1, 1);

			const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
			svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
			svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
			svg.setAttribute('class', 'chart-svg');
			svg.setAttribute('role', 'img');
			svg.setAttribute('aria-label', 'Daily page views line chart');

			// Grid lines + Y labels
			const ticks = 5;
			for (let i = 0; i <= ticks; i++) {
				const y = PAD.top + plotH - (i / ticks) * plotH;
				const val = Math.round((i / ticks) * yMax);
				const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
				line.setAttribute('x1', String(PAD.left));
				line.setAttribute('y1', String(y));
				line.setAttribute('x2', String(W - PAD.right));
				line.setAttribute('y2', String(y));
				line.setAttribute('stroke', '#e5e7eb');
				line.setAttribute('stroke-width', '0.5');
				svg.appendChild(line);

				const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
				label.setAttribute('x', String(PAD.left - 8));
				label.setAttribute('y', String(y + 3));
				label.setAttribute('text-anchor', 'end');
				label.setAttribute('fill', '#9ca3af');
				label.setAttribute('font-size', '10');
				label.textContent = String(val);
				svg.appendChild(label);
			}

			// X-axis labels
			const labelInterval = Math.max(1, Math.floor(dates.length / 7));
			for (let i = 0; i < dates.length; i++) {
				if (i % labelInterval !== 0 && i !== dates.length - 1) continue;
				const x = PAD.left + i * xStep;
				const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
				label.setAttribute('x', String(x));
				label.setAttribute('y', String(H - 6));
				label.setAttribute('text-anchor', 'middle');
				label.setAttribute('fill', '#9ca3af');
				label.setAttribute('font-size', '10');
				label.textContent = dates[i].slice(5); // MM-DD
				svg.appendChild(label);
			}

			// Polylines per team
			for (const t of teams) {
				if (!activeFranchises.has(t.id)) continue;
				const points = t.values
					.map((v, i) => `${PAD.left + i * xStep},${PAD.top + plotH - (v / yMax) * plotH}`)
					.join(' ');
				const polyline = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
				polyline.setAttribute('points', points);
				polyline.setAttribute('fill', 'none');
				polyline.setAttribute('stroke', t.color);
				polyline.setAttribute('stroke-width', '2');
				polyline.setAttribute('stroke-linejoin', 'round');
				polyline.setAttribute('stroke-linecap', 'round');
				polyline.setAttribute('opacity', '0.85');
				polyline.setAttribute('data-franchise', t.id);
				svg.appendChild(polyline);
			}

			// Invisible hover columns
			for (let i = 0; i < dates.length; i++) {
				const cx = PAD.left + i * xStep;
				const colW = xStep;
				const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
				rect.setAttribute('x', String(Math.max(PAD.left, cx - colW / 2)));
				rect.setAttribute('y', String(PAD.top));
				rect.setAttribute('width', String(colW));
				rect.setAttribute('height', String(plotH));
				rect.setAttribute('fill', 'transparent');
				rect.setAttribute('data-col', String(i));
				rect.setAttribute('class', 'chart-hover-col');
				svg.appendChild(rect);
			}

			el.replaceChildren(svg);

			// Re-create tooltip div
			const tip = document.createElement('div');
			tip.className = 'chart-tooltip';
			tip.id = 'chartTooltip';
			tip.style.display = 'none';
			el.appendChild(tip);
		}

		buildSVG();

		// Tooltip
		el.addEventListener('mouseover', (e) => {
			const target = (e.target as Element).closest('[data-col]');
			const tooltip = document.getElementById('chartTooltip');
			if (!target || !tooltip) return;
			const idx = Number(target.getAttribute('data-col'));
			const date = dates[idx];
			const entries = teams
				.filter((t) => activeFranchises.has(t.id) && t.values[idx] > 0)
				.sort((a, b) => b.values[idx] - a.values[idx]);
			if (!entries.length) { tooltip.style.display = 'none'; return; }

			// Build tooltip with DOM methods
			tooltip.replaceChildren();
			const dateDiv = document.createElement('div');
			dateDiv.className = 'chart-tooltip__date';
			dateDiv.textContent = date;
			tooltip.appendChild(dateDiv);
			for (const t of entries) {
				const row = document.createElement('div');
				row.className = 'chart-tooltip__row';
				const dot = document.createElement('span');
				dot.className = 'chart-tooltip__dot';
				dot.style.background = t.color;
				row.appendChild(dot);
				row.appendChild(document.createTextNode(`${t.name}: `));
				const strong = document.createElement('strong');
				strong.textContent = String(t.values[idx]);
				row.appendChild(strong);
				tooltip.appendChild(row);
			}
			tooltip.style.display = '';
		});
		el.addEventListener('mouseleave', () => {
			const tooltip = document.getElementById('chartTooltip');
			if (tooltip) tooltip.style.display = 'none';
		});

		// Legend toggle
		document.getElementById('chartLegend')?.addEventListener('click', (e) => {
			const btn = (e.target as Element).closest('[data-franchise]') as HTMLElement | null;
			if (!btn) return;
			const id = btn.getAttribute('data-franchise')!;
			const isActive = btn.getAttribute('data-active') === 'true';
			btn.setAttribute('data-active', isActive ? 'false' : 'true');
			if (isActive) activeFranchises.delete(id);
			else activeFranchises.add(id);
			buildSVG();
		});
	}

	document.addEventListener('astro:page-load', renderChart);
</script>

