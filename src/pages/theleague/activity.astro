---
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import leagueConfig from '../../data/theleague.config.json';
import { chooseTeamName } from '../../utils/team-names';
import {
	getAllActivity,
	getActivityLevel,
	getActivityLabel,
	formatLastSeenLong,
	type ActivityLevel,
} from '../../utils/owner-activity';

const leagueId = '13522';
let activityMap: Record<string, number> = {};
try { activityMap = await getAllActivity(leagueId); } catch { /* Redis unavailable */ }

interface TeamActivity {
	franchiseId: string;
	name: string;
	icon: string;
	lastVisit: number | null;
	level: ActivityLevel;
	label: string;
	timeAgo: string;
}

const teams: TeamActivity[] = leagueConfig.teams.map((team) => {
	const ts = activityMap[team.franchiseId] ?? null;
	const level = getActivityLevel(ts);
	return {
		franchiseId: team.franchiseId,
		name: chooseTeamName({
			fullName: team.name,
			nameMedium: team.nameMedium,
			nameShort: team.nameShort,
			abbrev: team.abbrev,
		}),
		icon: team.icon,
		lastVisit: ts,
		level,
		label: getActivityLabel(level),
		timeAgo: formatLastSeenLong(ts),
	};
});

// Sort by most recent visit (nulls/never-seen last)
teams.sort((a, b) => (b.lastVisit ?? 0) - (a.lastVisit ?? 0));

const hasAnyData = teams.some((t) => t.lastVisit !== null);
---

<TheLeagueLayout title="Owner Activity">
	<section class="activity-page" aria-labelledby="activity-page-title">
		<div class="activity-page__header">
			<h1 class="activity-page__title" id="activity-page-title">Owner Activity</h1>
			<p class="activity-page__subtitle">Last time each owner visited the site</p>
		</div>

		{!hasAnyData ? (
			<div class="activity-page__empty" role="status">
				<p>No activity data yet. Visit tracking begins once owners start logging in.</p>
			</div>
		) : (
			<table class="activity-table" aria-label="Owner activity ranked by most recent visit">
				<thead>
					<tr>
						<th scope="col" class="activity-table__th activity-table__th--rank">#</th>
						<th scope="col" class="activity-table__th activity-table__th--team">Team</th>
						<th scope="col" class="activity-table__th activity-table__th--time">Last Seen</th>
						<th scope="col" class="activity-table__th activity-table__th--status">Status</th>
					</tr>
				</thead>
				<tbody>
					{teams.map((team, index) => (
						<tr class="activity-table__row" data-level={team.level}>
							<td class="activity-table__td activity-table__td--rank">
								{index + 1}
							</td>
							<td class="activity-table__td activity-table__td--team">
								<div class="activity-team">
									<img
										src={team.icon}
										alt=""
										class="activity-team__icon"
										width="32"
										height="32"
										loading="lazy"
									/>
									<span class="activity-team__name">{team.name}</span>
								</div>
							</td>
							<td class="activity-table__td activity-table__td--time">
								{team.timeAgo}
							</td>
							<td
								class="activity-table__td activity-table__td--status"
								data-level={team.level}
								aria-label={`Status: ${team.label}`}
							>
								<div class="activity-status">
									<span class="activity-dot" aria-hidden="true"></span>
									<span class="activity-label">{team.label}</span>
								</div>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		)}
	</section>
</TheLeagueLayout>

<style>
	.activity-page {
		max-width: 44rem;
		margin: 0 auto;
		padding: 1.5rem 1rem 3rem;
	}

	.activity-page__header {
		margin-bottom: 1.5rem;
	}

	.activity-page__title {
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-gray-900, #111827);
		margin: 0 0 0.25rem;
	}

	.activity-page__subtitle {
		font-size: 0.8125rem;
		color: var(--color-gray-500, #6b7280);
		margin: 0;
	}

	.activity-page__empty {
		background: var(--color-gray-50, #f9fafb);
		border-radius: 0.5rem;
		padding: 2rem;
		text-align: center;
		color: var(--color-gray-500, #6b7280);
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}

	/* ── Table ── */
	.activity-table {
		width: 100%;
		border-collapse: separate;
		border-spacing: 0;
		font-size: 0.875rem;
	}

	.activity-table__th {
		font-size: 0.625rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-gray-400, #9ca3af);
		background: var(--color-gray-50, #f9fafb);
		padding: 0.625rem 0.75rem;
		text-align: left;
		position: sticky;
		top: 0;
		z-index: 1;
		border-bottom: 1px solid var(--color-gray-200, #e5e7eb);
	}

	.activity-table__th:first-child {
		border-radius: 0.25rem 0 0 0;
	}

	.activity-table__th:last-child {
		border-radius: 0 0.25rem 0 0;
	}

	.activity-table__th--rank {
		width: 2.5rem;
		text-align: center;
	}

	.activity-table__th--status {
		width: 6rem;
	}

	/* ── Rows ── */
	.activity-table__row {
		transition: background 0.15s ease;
	}

	.activity-table__row:hover {
		background: var(--color-gray-50, #f9fafb);
	}

	.activity-table__td {
		padding: 0.625rem 0.75rem;
		border-bottom: 1px solid var(--color-gray-100, #f3f4f6);
		vertical-align: middle;
	}

	.activity-table__td--rank {
		text-align: center;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		color: var(--color-gray-500, #6b7280);
	}

	.activity-table__td--time {
		font-variant-numeric: tabular-nums;
		color: var(--color-gray-700, #374151);
		white-space: nowrap;
	}

	/* ── Team cell ── */
	.activity-team {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.activity-team__icon {
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		object-fit: cover;
		background: var(--color-gray-100, #f3f4f6);
		flex-shrink: 0;
	}

	.activity-team__name {
		font-weight: 500;
		color: var(--color-gray-700, #374151);
	}

	/* ── Status cell ── */
	.activity-status {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.activity-dot {
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		flex-shrink: 0;
	}

	[data-level='active'] .activity-dot {
		background: var(--activity-green, #16a34a);
	}
	[data-level='idle'] .activity-dot {
		background: var(--activity-yellow, #ca8a04);
	}
	[data-level='dormant'] .activity-dot {
		background: var(--activity-red, #dc2626);
	}
	[data-level='unknown'] .activity-dot {
		background: var(--activity-gray, #6b7280);
	}

	.activity-label {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--color-gray-600, #4b5563);
	}

	.activity-table__row:last-child .activity-table__td {
		border-bottom: none;
	}

	/* ── Desktop ── */
	@media (min-width: 640px) {
		.activity-page {
			padding: 2rem 1.5rem 3rem;
		}

		.activity-team__icon {
			width: 2.5rem;
			height: 2.5rem;
		}

		.activity-table__th,
		.activity-table__td {
			padding: 0.75rem 1rem;
		}
	}

	/* ── Mobile: hide status text label, keep dot ── */
	@media (max-width: 639px) {
		.activity-label {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}

		.activity-table__th--status {
			width: 2rem;
		}

		.activity-team__name {
			max-width: 9rem;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}
	}
</style>
