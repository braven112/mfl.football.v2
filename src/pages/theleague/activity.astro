---
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import OwnerActivityReport from '../../components/theleague/OwnerActivityReport.astro';
import leagueConfig from '../../data/theleague.config.json';
import { chooseTeamName } from '../../utils/team-names';
import {
	getAllActivity,
	getDailyPageViews,
	getGlobalPagePopularity,
	getAllOwnerPagePopularity,
	getActivityLevel,
	getActivityLabel,
	formatLastSeenLong,
	type ActivityLevel,
} from '../../utils/owner-activity';
import { getTeamColor } from '../../utils/team-colors';
import { getCurrentLeagueYear } from '../../utils/league-year';

const leagueId = '13522';
const franchiseIds = leagueConfig.teams.map((t: any) => t.franchiseId);
let activityMap: Record<string, number> = {};
let pageViewData: { dates: string[]; data: Record<string, Record<string, number>> } = { dates: [], data: {} };
let globalPages: { page: string; count: number }[] = [];
let ownerPages: Record<string, { page: string; count: number }[]> = {};

// Mock data for local development — ?mock=true enables it
const useMock = Astro.url.searchParams.has('mock');

if (useMock) {
	// Seeded random for deterministic output
	const seed = (s: number) => () => { s = (s * 16807 + 0) % 2147483647; return (s - 1) / 2147483646; };

	// Activity levels: some very active, some idle, some dormant
	const activityProfiles: Record<string, { baseViews: number; lastSeenHoursAgo: number }> = {
		'0001': { baseViews: 18, lastSeenHoursAgo: 0.5 },   // power user
		'0002': { baseViews: 14, lastSeenHoursAgo: 2 },      // very active
		'0003': { baseViews: 3, lastSeenHoursAgo: 72 },       // idle
		'0004': { baseViews: 11, lastSeenHoursAgo: 4 },       // active
		'0005': { baseViews: 7, lastSeenHoursAgo: 12 },       // active
		'0006': { baseViews: 1, lastSeenHoursAgo: 240 },      // dormant
		'0007': { baseViews: 5, lastSeenHoursAgo: 36 },       // idle
		'0008': { baseViews: 16, lastSeenHoursAgo: 1 },       // power user
		'0009': { baseViews: 9, lastSeenHoursAgo: 8 },        // active
		'0010': { baseViews: 12, lastSeenHoursAgo: 3 },       // very active
		'0011': { baseViews: 2, lastSeenHoursAgo: 168 },      // dormant
		'0012': { baseViews: 6, lastSeenHoursAgo: 48 },       // idle
		'0013': { baseViews: 8, lastSeenHoursAgo: 18 },       // active
		'0014': { baseViews: 0, lastSeenHoursAgo: -1 },       // never seen
		'0015': { baseViews: 4, lastSeenHoursAgo: 96 },       // idle
		'0016': { baseViews: 10, lastSeenHoursAgo: 6 },       // active
	};

	// Last seen timestamps
	for (const [fid, profile] of Object.entries(activityProfiles)) {
		if (profile.lastSeenHoursAgo >= 0) {
			activityMap[fid] = Date.now() - profile.lastSeenHoursAgo * 3600_000;
		}
	}

	// Daily page views for 30 days
	const dates: string[] = [];
	for (let i = 29; i >= 0; i--) {
		const d = new Date(); d.setDate(d.getDate() - i);
		dates.push(d.toISOString().slice(0, 10));
	}
	const pvData: Record<string, Record<string, number>> = {};
	for (const date of dates) {
		pvData[date] = {};
		for (const [fid, profile] of Object.entries(activityProfiles)) {
			if (profile.baseViews === 0) continue;
			const rng = seed(parseInt(fid) * 1000 + parseInt(date.replace(/-/g, '')));
			// Add some variance: weekends are busier, recent days trend up
			const dayOfWeek = new Date(date).getDay();
			const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
			const recencyBoost = 1 + (dates.indexOf(date) / dates.length) * 0.5;
			const weekendBoost = isWeekend ? 1.4 : 1;
			const views = Math.max(0, Math.round(profile.baseViews * recencyBoost * weekendBoost * (0.3 + rng() * 1.4)));
			if (views > 0) pvData[date][fid] = views;
		}
	}
	pageViewData = { dates, data: pvData };

	// Global page popularity
	const pageWeights = [
		{ page: '/rosters', weight: 320 },
		{ page: '/players', weight: 185 },
		{ page: '/trade-builder', weight: 142 },
		{ page: '/standings', weight: 128 },
		{ page: '/salary', weight: 97 },
		{ page: '/league-summary', weight: 84 },
		{ page: '/draft-predictor', weight: 72 },
		{ page: '/playoffs', weight: 61 },
		{ page: '/contracts/manage', weight: 55 },
		{ page: '/calendar', weight: 43 },
		{ page: '/dead-money', weight: 38 },
		{ page: '/mvp', weight: 31 },
		{ page: '/whats-new', weight: 27 },
		{ page: '/activity', weight: 22 },
		{ page: '/rules', weight: 14 },
	];
	globalPages = pageWeights.map(({ page, weight }) => ({ page, count: weight }));

	// Per-owner page popularity
	ownerPages = {};
	for (const fid of franchiseIds) {
		const profile = activityProfiles[fid];
		if (!profile || profile.baseViews === 0) { ownerPages[fid] = []; continue; }
		const rng = seed(parseInt(fid) * 7919);
		ownerPages[fid] = pageWeights
			.slice(0, 6 + Math.floor(rng() * 5))
			.map(({ page, weight }) => ({
				page,
				count: Math.max(1, Math.round(weight * (profile.baseViews / 10) * (0.5 + rng()))),
			}))
			.sort((a, b) => b.count - a.count);
	}
} else {
	try {
		[activityMap, pageViewData, globalPages, ownerPages] = await Promise.all([
			getAllActivity(leagueId),
			getDailyPageViews(leagueId, 30),
			getGlobalPagePopularity(leagueId),
			getAllOwnerPagePopularity(leagueId, franchiseIds),
		]);
	} catch { /* Redis unavailable */ }
}

// ── Transaction data ──
interface TxCounts { trades: number; freeAgents: number; thirdStat: number; total: number; }
const txCountMap: Record<string, TxCounts> = {};
const ensureFranchise = (id: string) => {
	if (!txCountMap[id]) txCountMap[id] = { trades: 0, freeAgents: 0, thirdStat: 0, total: 0 };
};

// import.meta.glob must be at the top level (Vite requirement)
const txFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/transactions.json', { eager: true });

if (useMock) {
	// Mock transaction counts tied to activityProfiles intensity
	const mockTxProfiles: Record<string, { trades: number; fa: number; auctions: number }> = {
		'0001': { trades: 4, fa: 7, auctions: 12 },
		'0002': { trades: 3, fa: 5, auctions: 9 },
		'0003': { trades: 1, fa: 2, auctions: 3 },
		'0004': { trades: 3, fa: 4, auctions: 8 },
		'0005': { trades: 2, fa: 3, auctions: 6 },
		'0006': { trades: 0, fa: 1, auctions: 1 },
		'0007': { trades: 1, fa: 3, auctions: 4 },
		'0008': { trades: 5, fa: 6, auctions: 11 },
		'0009': { trades: 2, fa: 4, auctions: 7 },
		'0010': { trades: 3, fa: 5, auctions: 10 },
		'0011': { trades: 0, fa: 1, auctions: 2 },
		'0012': { trades: 1, fa: 2, auctions: 5 },
		'0013': { trades: 2, fa: 3, auctions: 6 },
		'0014': { trades: 0, fa: 0, auctions: 0 },
		'0015': { trades: 1, fa: 2, auctions: 3 },
		'0016': { trades: 2, fa: 4, auctions: 8 },
	};
	for (const [fid, p] of Object.entries(mockTxProfiles)) {
		txCountMap[fid] = { trades: p.trades, freeAgents: p.fa, thirdStat: p.auctions, total: p.trades + p.fa + p.auctions };
	}
} else {
	const leagueYear = getCurrentLeagueYear();
	const txFeedKey = Object.keys(txFeeds).find(p => p.includes(`/${leagueYear}/`));
	const txMod: any = txFeedKey ? txFeeds[txFeedKey] : null;
	const txData = txMod && typeof txMod === 'object' && 'default' in txMod ? txMod.default : txMod;
	const rawTx: any[] = txData?.transactions?.transaction
		? (Array.isArray(txData.transactions.transaction) ? txData.transactions.transaction : [txData.transactions.transaction])
		: [];

	for (const tx of rawTx) {
		if (tx.type === 'TRADE') {
			ensureFranchise(tx.franchise); ensureFranchise(tx.franchise2);
			txCountMap[tx.franchise].trades++; txCountMap[tx.franchise].total++;
			txCountMap[tx.franchise2].trades++; txCountMap[tx.franchise2].total++;
		} else if (tx.type === 'FREE_AGENT') {
			ensureFranchise(tx.franchise);
			txCountMap[tx.franchise].freeAgents++; txCountMap[tx.franchise].total++;
		} else if (tx.type === 'AUCTION_WON') {
			ensureFranchise(tx.franchise);
			txCountMap[tx.franchise].thirdStat++; txCountMap[tx.franchise].total++;
		}
	}
}

const txLeaderboard = leagueConfig.teams
	.map((team: any) => ({
		franchiseId: team.franchiseId,
		name: chooseTeamName({ fullName: team.name, nameMedium: team.nameMedium, nameShort: team.nameShort, abbrev: team.abbrev }),
		icon: team.icon,
		counts: txCountMap[team.franchiseId] || { trades: 0, freeAgents: 0, thirdStat: 0, total: 0 },
	}))
	.sort((a, b) => b.counts.total - a.counts.total);

interface TeamActivity {
	franchiseId: string;
	name: string;
	icon: string;
	lastVisit: number | null;
	level: ActivityLevel;
	label: string;
	timeAgo: string;
}

const teams: TeamActivity[] = leagueConfig.teams.map((team) => {
	const ts = activityMap[team.franchiseId] ?? null;
	const level = getActivityLevel(ts);
	return {
		franchiseId: team.franchiseId,
		name: chooseTeamName({
			fullName: team.name,
			nameMedium: team.nameMedium,
			nameShort: team.nameShort,
			abbrev: team.abbrev,
		}),
		icon: team.icon,
		lastVisit: ts,
		level,
		label: getActivityLabel(level),
		timeAgo: formatLastSeenLong(ts),
	};
});

// Sort by most recent visit (nulls/never-seen last)
teams.sort((a, b) => (b.lastVisit ?? 0) - (a.lastVisit ?? 0));

// Build chart series data: one series per team with daily page view counts
const chartTeams = leagueConfig.teams.map((team) => ({
	id: team.franchiseId,
	name: chooseTeamName({
		fullName: team.name,
		nameMedium: team.nameMedium,
		nameShort: team.nameShort,
		abbrev: team.abbrev,
	}, 'short'),
	color: getTeamColor(team.franchiseId),
	icon: team.icon,
	values: pageViewData.dates.map((d) => pageViewData.data[d]?.[team.franchiseId] ?? 0),
}));
const chartDates = pageViewData.dates;
---

<TheLeagueLayout title="Owner Activity">
	<OwnerActivityReport
		leagueName="The League"
		leagueHref="/theleague"
		teams={teams}
		txLeaderboard={txLeaderboard}
		globalPages={globalPages}
		ownerPages={ownerPages}
		chartTeams={chartTeams}
		chartDates={chartDates}
	/>
</TheLeagueLayout>
