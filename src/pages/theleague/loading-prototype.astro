---
/**
 * Loading System — prototype / reference page.
 *
 * Phase 1 deliverable: a visual gallery of every loading tier under both
 * league skins, with a live league switcher, a reduced-motion toggle, and a
 * duration-escalation simulator. Not in the nav or page directory — this is a
 * dev/reference route to react to before migration begins.
 *
 * See docs/claude/loading-standards.md.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import Spinner from '../../components/shared/loading/Spinner.astro';
import Skeleton from '../../components/shared/loading/Skeleton.astro';
import ThinkingDots from '../../components/shared/loading/ThinkingDots.astro';
import BrandedLoader from '../../components/shared/loading/BrandedLoader.astro';
---

<TheLeagueLayout title="Loading System — Prototype">
  <main class="lp">
    <header class="lp__hero">
      <h1 class="lp__title">Loading System</h1>
      <p class="lp__lede">
        One duration-keyed ladder, two league skins. The structure (timing,
        placement, ARIA, motion) is identical across leagues — only the accent
        color changes. Flip the league switch and watch everything reskin at
        once; that's the whole thesis.
      </p>
    </header>

    <!-- ── Control bar ─────────────────────────────────────────────── -->
    <div class="lp__controls" role="region" aria-label="Prototype controls">
      <div class="lp__control">
        <span class="lp__control-label">League skin</span>
        <div class="lp__segmented" role="group" aria-label="League skin">
          <button type="button" class="lp__seg is-active" data-league-btn="theleague">TheLeague</button>
          <button type="button" class="lp__seg" data-league-btn="afl">AFL Fantasy</button>
        </div>
      </div>

      <div class="lp__control">
        <span class="lp__control-label">Reduced motion</span>
        <button type="button" class="lp__toggle" data-reduced-motion aria-pressed="false">
          <span class="lp__toggle-track"><span class="lp__toggle-thumb"></span></span>
          <span class="lp__toggle-text">Off</span>
        </button>
      </div>

      <div class="lp__control lp__control--accent">
        <span class="lp__control-label">Active accent</span>
        <span class="lp__swatch" aria-hidden="true"></span>
        <code class="lp__accent-name" data-accent-name>TheLeague blue</code>
      </div>
    </div>

    <!-- ── Side-by-side skin comparison (no JS required) ──────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Two Skins, One Structure</h2>
        <p class="section-header__sub">
          The same components, side by side. Only the accent differs — that's
          the whole idea. (This comparison needs no JavaScript; the switch above
          does the same thing live for the rest of the page.)
        </p>
      </div>
      <div class="lp__skins">
        <div class="lp__skin">
          <div class="lp__skin-head"><span class="lp__swatch"></span> TheLeague</div>
          <div class="lp__skin-body">
            <div class="lp__skin-row"><Spinner label="Loading" /><span class="lp__skin-tag">spinner</span></div>
            <div class="lp__skin-row">
              <button type="button" class="lp__btn lp__btn--primary loading-btn loading-btn--on-accent is-loading" aria-busy="true" aria-label="Submitting" disabled>Submit</button>
              <span class="lp__skin-tag">button</span>
            </div>
            <div class="lp__skin-row"><ThinkingDots label="On the wire" /><span class="lp__skin-tag">dots</span></div>
            <div class="lp__skin-stack"><Skeleton variant="title" /><Skeleton variant="text" /><Skeleton variant="text" width="70%" /></div>
            <div class="lp__skin-branded"><BrandedLoader title="Schefter is working" narration={["Checking sources…"]} /></div>
          </div>
        </div>
        <div class="lp__skin lp-skin-afl">
          <div class="lp__skin-head"><span class="lp__swatch"></span> AFL Fantasy</div>
          <div class="lp__skin-body">
            <div class="lp__skin-row"><Spinner label="Loading" /><span class="lp__skin-tag">spinner</span></div>
            <div class="lp__skin-row">
              <button type="button" class="lp__btn lp__btn--primary loading-btn loading-btn--on-accent is-loading" aria-busy="true" aria-label="Submitting" disabled>Submit</button>
              <span class="lp__skin-tag">button</span>
            </div>
            <div class="lp__skin-row"><ThinkingDots label="On the wire" /><span class="lp__skin-tag">dots</span></div>
            <div class="lp__skin-stack"><Skeleton variant="title" /><Skeleton variant="text" /><Skeleton variant="text" width="70%" /></div>
            <div class="lp__skin-branded"><BrandedLoader title="Schefter is working" narration={["Checking sources…"]} /></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Escalation simulator ───────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">The Rule, Live</h2>
        <p class="section-header__sub">
          The indicator is chosen by how long the user actually waits — not by
          the screen. Run a wait and watch it climb the ladder.
        </p>
      </div>

      <div class="lp__sim">
        <div class="lp__sim-controls">
          <button type="button" class="lp__btn lp__btn--primary" data-sim-start>Run a 12-second wait</button>
          <div class="lp__segmented" role="group" aria-label="Wait context">
            <button type="button" class="lp__seg is-active" data-ctx-btn="content">Content load</button>
            <button type="button" class="lp__seg" data-ctx-btn="discreteAction">Discrete action</button>
          </div>
        </div>

        <div class="lp__sim-readout">
          <div class="lp__sim-meter">
            <span class="lp__sim-elapsed" data-sim-elapsed>0.0s</span>
            <span class="lp__sim-tier" data-sim-tier>Idle</span>
          </div>
          <div class="lp__sim-stage" data-sim-stage aria-live="polite">
            <span class="lp__muted">Press “Run a wait” to begin.</span>
          </div>
        </div>

        <ul class="lp__ladder">
          <li data-ladder="none"><b>&lt; 0.3s</b> — Nothing</li>
          <li data-ladder="optimistic"><b>0.3–1s</b> — Optimistic</li>
          <li data-ladder="skeleton"><b>1–10s · content</b> — Skeleton</li>
          <li data-ladder="buttonSpinner"><b>1–10s · action</b> — Button spinner</li>
          <li data-ladder="branded"><b>10s+ · AI</b> — Branded moment</li>
        </ul>
      </div>
    </section>

    <!-- ── Tier 2/3 — Spinner ─────────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Spinner</h2>
        <p class="section-header__sub">Tier 2/3 · discrete actions, inline waits. Accent skins per league.</p>
      </div>
      <div class="lp__gallery">
        <div class="lp__card">
          <div class="lp__demo"><Spinner size="compact" label="Loading" /></div>
          <code class="lp__caption">compact</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo"><Spinner label="Loading" /></div>
          <code class="lp__caption">default</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo"><Spinner size="large" label="Loading" /></div>
          <code class="lp__caption">large</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo lp__demo--row">
            <span class="lp__inline-text">Fetching latest news</span>
            <Spinner size="compact" label="Loading news" />
          </div>
          <code class="lp__caption">inline with text</code>
        </div>
      </div>
    </section>

    <!-- ── Tier 3 — Button loading ─────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Button Loading</h2>
        <p class="section-header__sub">Tier 3 · submit / login / send. Spinner replaces the label, button disables to block double-submit.</p>
      </div>
      <div class="lp__gallery">
        <div class="lp__card">
          <div class="lp__demo">
            <button type="button" class="lp__btn lp__btn--primary loading-btn loading-btn--on-accent is-loading" aria-busy="true" aria-label="Submitting lineup" disabled>Submit Lineup</button>
          </div>
          <code class="lp__caption">primary · loading</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo">
            <button type="button" class="lp__btn loading-btn is-loading" aria-busy="true" aria-label="Sending" disabled>Send Proposal</button>
          </div>
          <code class="lp__caption">secondary · loading</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo">
            <button type="button" class="lp__btn lp__btn--primary" data-toggle-btn>Click to load</button>
          </div>
          <code class="lp__caption">interactive (click me)</code>
        </div>
      </div>
    </section>

    <!-- ── Tier 4 — Skeleton ──────────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Skeleton</h2>
        <p class="section-header__sub">Tier 4 · content loads with predictable shape. Brand-neutral by design.</p>
      </div>
      <div class="lp__gallery lp__gallery--wide">
        <div class="lp__card">
          <div class="lp__demo lp__demo--block">
            <Skeleton variant="title" />
            <Skeleton variant="text" />
            <Skeleton variant="text" width="80%" />
          </div>
          <code class="lp__caption">text block</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo lp__demo--block">
            <div class="lp__row">
              <Skeleton variant="circle" height="40px" />
              <div class="lp__row-lines">
                <Skeleton variant="text" width="60%" />
                <Skeleton variant="text" width="40%" />
              </div>
            </div>
            <div class="lp__row">
              <Skeleton variant="circle" height="40px" />
              <div class="lp__row-lines">
                <Skeleton variant="text" width="55%" />
                <Skeleton variant="text" width="35%" />
              </div>
            </div>
          </div>
          <code class="lp__caption">player-lockup skeleton</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo lp__demo--block">
            <Skeleton height="5rem" count={3} label="Loading trades" />
          </div>
          <code class="lp__caption">card list (count=3)</code>
        </div>
      </div>
    </section>

    <!-- ── Tier 5 — Thinking dots ─────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Thinking Dots</h2>
        <p class="section-header__sub">Tier 5 · the AI “voice is working” wait. Dots take the league accent.</p>
      </div>
      <div class="lp__gallery">
        <div class="lp__card">
          <div class="lp__demo"><ThinkingDots label="Schefter is on the wire" /></div>
          <code class="lp__caption">with text</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo"><ThinkingDots label="Roger is reading the rules" /></div>
          <code class="lp__caption">with text</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo"><ThinkingDots /></div>
          <code class="lp__caption">dots only</code>
        </div>
      </div>
    </section>

    <!-- ── Tier 5 — Branded moment ────────────────────────────────── -->
    <section class="lp__section">
      <div class="section-header">
        <h2 class="section-header__title">Branded Moment</h2>
        <p class="section-header__sub">Tier 5 · 10s+ AI waits. The one tier that carries league character — narration cycles, accent skins.</p>
      </div>
      <div class="lp__gallery lp__gallery--wide">
        <div class="lp__card">
          <div class="lp__demo lp__demo--branded">
            <BrandedLoader
              title="Schefter is working the phones"
              narration={["Checking the Rolodex…", "Confirming with sources…", "Almost got it…"]}
            />
          </div>
          <code class="lp__caption">inline panel</code>
        </div>
        <div class="lp__card">
          <div class="lp__demo lp__demo--branded lp__demo--overlay-host">
            <div class="lp__fake-content">
              <Skeleton variant="title" />
              <Skeleton variant="text" />
              <Skeleton variant="text" width="70%" />
            </div>
            <BrandedLoader
              overlay
              title="Asking Roger"
              narration={["Reading the constitution…", "Cross-checking precedent…"]}
            />
          </div>
          <code class="lp__caption">overlay (frosted backdrop)</code>
        </div>
      </div>
    </section>
  </main>
</TheLeagueLayout>

<style>
  .lp {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }

  .lp__hero { margin-bottom: 1.5rem; }
  .lp__title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-gray-900, #111827);
    margin: 0 0 0.5rem;
  }
  .lp__lede {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-gray-600, #4b5563);
    max-width: 60ch;
    margin: 0;
  }

  /* Controls */
  .lp__controls {
    position: sticky;
    top: 0.5rem;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    padding: 0.875rem 1rem;
    margin-bottom: 2rem;
    background: var(--content-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-lg, 16px);
    box-shadow: var(--shadow-md, 0 4px 6px rgba(0, 0, 0, 0.07));
  }
  .lp__control { display: flex; align-items: center; gap: 0.625rem; }
  .lp__control-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
  }
  .lp__control--accent { margin-left: auto; }
  .lp__swatch {
    width: 16px; height: 16px;
    border-radius: var(--radius-full, 9999px);
    background: var(--league-accent, #1c497c);
    border: 1px solid rgba(0, 0, 0, 0.1);
  }
  .lp__accent-name { font-size: 0.75rem; color: var(--color-gray-600, #4b5563); }

  /* Segmented control */
  .lp__segmented {
    display: inline-flex;
    padding: 2px;
    background: var(--color-gray-100, #f3f4f6);
    border-radius: var(--radius-md, 8px);
  }
  .lp__seg {
    appearance: none;
    border: none;
    background: transparent;
    font: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius-sm, 6px);
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    transition: background var(--transition-fast, 150ms ease), color var(--transition-fast, 150ms ease);
  }
  .lp__seg.is-active {
    background: var(--content-bg, #fff);
    color: var(--league-accent, var(--color-primary, #1c497c));
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(0, 0, 0, 0.08));
  }

  /* Toggle */
  .lp__toggle {
    display: inline-flex; align-items: center; gap: 0.5rem;
    appearance: none; border: none; background: transparent; font: inherit;
    cursor: pointer; padding: 0;
  }
  .lp__toggle-track {
    width: 34px; height: 20px;
    border-radius: var(--radius-full, 9999px);
    background: var(--color-gray-300, #d1d5db);
    position: relative;
    transition: background var(--transition-fast, 150ms ease);
  }
  .lp__toggle-thumb {
    position: absolute; top: 2px; left: 2px;
    width: 16px; height: 16px;
    border-radius: var(--radius-full, 9999px);
    background: #fff;
    transition: transform var(--transition-fast, 150ms ease);
  }
  .lp__toggle[aria-pressed="true"] .lp__toggle-track { background: var(--league-accent, #1c497c); }
  .lp__toggle[aria-pressed="true"] .lp__toggle-thumb { transform: translateX(14px); }
  .lp__toggle-text { font-size: 0.8125rem; font-weight: 600; color: var(--color-gray-600, #4b5563); }

  /* Skin comparison.
     Demo-only: force the AFL accent on a wrapper so both skins show at once
     without flipping <html data-league>. Mirrors the AFL value from
     tokens.css (html[data-league="afl"] { --league-accent: #c41e3a }).
     The real app never sets this inline — it relies on the token cascade. */
  .lp-skin-afl { --league-accent: #c41e3a; }

  .lp__skins {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .lp__skin {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-lg, 16px);
    background: var(--content-bg, #fff);
    overflow: hidden;
  }
  .lp__skin-head {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.8125rem; font-weight: 700;
    color: var(--color-gray-800, #1f2937);
    border-bottom: 1px solid var(--content-border, #e2e8f0);
    background: var(--content-bg-muted, #f8fafc);
  }
  .lp__skin-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
  .lp__skin-row { display: flex; align-items: center; gap: 0.75rem; min-height: 40px; }
  .lp__skin-tag {
    font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
  }
  .lp__skin-stack { display: flex; flex-direction: column; gap: 0.5rem; }
  .lp__skin-branded {
    border: 1px dashed var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 8px);
  }
  @media (max-width: 640px) { .lp__skins { grid-template-columns: 1fr; } }

  /* Sections */
  .lp__section { margin-bottom: 2.5rem; }
  .section-header { border-left: 2px solid var(--league-accent, var(--color-primary, #1c497c)); padding-left: 0.625rem; margin-bottom: 1rem; }
  .section-header__title {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--color-gray-900, #111827); margin: 0;
  }
  .section-header__sub { font-size: 0.8125rem; color: var(--color-gray-400, #9ca3af); margin: 0.25rem 0 0; }

  /* Galleries */
  .lp__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .lp__gallery--wide { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .lp__card {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 8px);
    background: var(--content-bg, #fff);
    overflow: hidden;
  }
  .lp__demo {
    min-height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1.25rem;
    background: var(--content-bg-muted, #f8fafc);
  }
  .lp__demo--row { flex-direction: row; }
  .lp__demo--block { flex-direction: column; align-items: stretch; gap: 0.6rem; }
  .lp__demo--branded { padding: 0; min-height: 200px; }
  .lp__demo--overlay-host { position: relative; align-items: stretch; }
  .lp__fake-content { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; width: 100%; }
  .lp__inline-text { font-size: 0.875rem; color: var(--color-gray-600, #4b5563); }
  .lp__caption {
    display: block;
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--content-border, #e2e8f0);
  }
  .lp__row { display: flex; align-items: center; gap: 0.75rem; }
  .lp__row-lines { display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }

  /* Buttons */
  .lp__btn {
    appearance: none;
    font: inherit; font-size: 0.875rem; font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md, 8px);
    border: 1px solid var(--color-gray-300, #d1d5db);
    background: var(--content-bg, #fff);
    color: var(--color-gray-800, #1f2937);
    cursor: pointer;
  }
  .lp__btn--primary {
    background: var(--league-accent, var(--color-primary, #1c497c));
    border-color: var(--league-accent, var(--color-primary, #1c497c));
    color: #fff;
  }

  /* Simulator */
  .lp__sim {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-lg, 16px);
    background: var(--content-bg, #fff);
    padding: 1.25rem;
  }
  .lp__sim-controls { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .lp__sim-readout {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1rem;
    align-items: stretch;
  }
  .lp__sim-meter {
    display: flex; flex-direction: column; justify-content: center; gap: 0.25rem;
    padding: 1rem;
    background: var(--content-bg-muted, #f8fafc);
    border-radius: var(--radius-md, 8px);
    text-align: center;
  }
  .lp__sim-elapsed { font-size: 1.75rem; font-weight: 700; font-variant-numeric: tabular-nums; color: var(--color-gray-900, #111827); }
  .lp__sim-tier {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--league-accent, var(--color-primary, #1c497c));
  }
  .lp__sim-stage {
    display: flex; align-items: center; justify-content: center;
    min-height: 110px;
    padding: 1rem;
    background: var(--content-bg-muted, #f8fafc);
    border-radius: var(--radius-md, 8px);
  }
  .lp__muted { color: var(--color-gray-400, #9ca3af); font-size: 0.875rem; }

  .lp__ladder {
    list-style: none;
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin: 1rem 0 0; padding: 0;
  }
  .lp__ladder li {
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-full, 9999px);
    transition: all var(--transition-fast, 150ms ease);
  }
  .lp__ladder li b { color: var(--color-gray-700, #374151); }
  .lp__ladder li.is-active {
    border-color: var(--league-accent, #1c497c);
    background: color-mix(in srgb, var(--league-accent, #1c497c) 10%, transparent);
  }
  .lp__ladder li.is-active b { color: var(--league-accent, #1c497c); }

  /* Demo-only reduced-motion: re-declare the loading.css guards keyed on a
     class the toggle adds, so it works without changing OS settings. */
  :global(html.lp-reduced-motion) :global(.loading-spinner) { animation: none; opacity: 0.85; border-color: var(--spinner-accent); }
  :global(html.lp-reduced-motion) :global(.loading-skeleton) { animation: none; background-image: none; }
  :global(html.lp-reduced-motion) :global(.loading-dots__dot) { animation: none; transform: none; opacity: 0.7; }
  :global(html.lp-reduced-motion) :global(.loading-btn.is-loading::after),
  :global(html.lp-reduced-motion) :global(.loading-branded__mark::before) { animation: none; }

  @media (max-width: 640px) {
    .lp__sim-readout { grid-template-columns: 1fr; }
    .lp__control--accent { margin-left: 0; }
  }
</style>

<script>
  import { resolveLoadingTier, type LoadingContext, type LoadingTier } from '../../utils/loading-tier';
  import { buildSpinnerHTML, buildSkeletonHTML, buildThinkingDotsHTML } from '../../utils/loading-html';

  const ACCENT_NAMES: Record<string, string> = {
    theleague: 'TheLeague blue',
    afl: 'AFL red',
  };

  function initPrototype() {
    const root = document.documentElement;

    // ── League switcher ──
    const leagueBtns = document.querySelectorAll<HTMLButtonElement>('[data-league-btn]');
    const accentName = document.querySelector<HTMLElement>('[data-accent-name]');
    leagueBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const league = btn.dataset.leagueBtn!;
        root.dataset.league = league;
        leagueBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
        if (accentName) accentName.textContent = ACCENT_NAMES[league] ?? league;
      });
    });

    // ── Reduced-motion toggle ──
    const rmBtn = document.querySelector<HTMLButtonElement>('[data-reduced-motion]');
    rmBtn?.addEventListener('click', () => {
      const on = root.classList.toggle('lp-reduced-motion');
      rmBtn.setAttribute('aria-pressed', String(on));
      const text = rmBtn.querySelector('.lp__toggle-text');
      if (text) text.textContent = on ? 'On' : 'Off';
    });

    // ── Interactive button-loading demo ──
    document.querySelectorAll<HTMLButtonElement>('[data-toggle-btn]').forEach((btn) => {
      const original = btn.textContent;
      btn.addEventListener('click', () => {
        btn.classList.add('loading-btn', 'loading-btn--on-accent', 'is-loading');
        btn.setAttribute('aria-busy', 'true');
        btn.setAttribute('disabled', 'true');
        window.setTimeout(() => {
          btn.classList.remove('is-loading');
          btn.removeAttribute('aria-busy');
          btn.removeAttribute('disabled');
          btn.textContent = original;
        }, 2000);
      });
    });

    // ── Escalation simulator ──
    const startBtn = document.querySelector<HTMLButtonElement>('[data-sim-start]');
    const elapsedEl = document.querySelector<HTMLElement>('[data-sim-elapsed]');
    const tierEl = document.querySelector<HTMLElement>('[data-sim-tier]');
    const stageEl = document.querySelector<HTMLElement>('[data-sim-stage]');
    const ctxBtns = document.querySelectorAll<HTMLButtonElement>('[data-ctx-btn]');
    const ladderItems = document.querySelectorAll<HTMLElement>('[data-ladder]');

    let context: LoadingContext = 'content';
    ctxBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        context = btn.dataset.ctxBtn as LoadingContext;
        ctxBtns.forEach((b) => b.classList.toggle('is-active', b === btn));
      });
    });

    const TIER_LABEL: Record<LoadingTier, string> = {
      none: 'Nothing',
      optimistic: 'Optimistic',
      skeleton: 'Skeleton',
      buttonSpinner: 'Button spinner',
      branded: 'Branded moment',
    };

    function renderTier(tier: LoadingTier): string {
      switch (tier) {
        case 'none':
          return '<span class="lp__muted">Nothing — feels instant.</span>';
        case 'optimistic':
          return '<span class="lp__muted">Optimistic — result shown, reconciling…</span>';
        case 'skeleton':
          return buildSkeletonHTML({ height: '4.5rem', count: 2, label: 'Loading content' });
        case 'buttonSpinner':
          return `<button class="lp__btn lp__btn--primary loading-btn loading-btn--on-accent is-loading" aria-busy="true" aria-label="Submitting" disabled>Submit</button>`;
        case 'branded':
          return (
            `<div class="loading-branded" role="status" aria-live="polite" aria-label="Working on it">` +
            `<div class="loading-branded__mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M3 12h4l2-7 4 14 2-7h6" stroke="var(--league-accent,#1c497c)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>` +
            `<p class="loading-branded__title">Schefter is on the wire</p>` +
            buildThinkingDotsHTML({}) +
            `</div>`
          );
      }
    }

    let raf = 0;
    let startedAt = 0;
    const DURATION = 12_000;

    function tick(now: number) {
      const elapsed = now - startedAt;
      const clamped = Math.min(elapsed, DURATION);
      const tier = resolveLoadingTier(clamped, context);

      if (elapsedEl) elapsedEl.textContent = `${(clamped / 1000).toFixed(1)}s`;
      if (tierEl) tierEl.textContent = TIER_LABEL[tier];
      if (stageEl && stageEl.dataset.tier !== tier) {
        stageEl.dataset.tier = tier;
        stageEl.innerHTML = renderTier(tier);
      }
      ladderItems.forEach((li) => li.classList.toggle('is-active', li.dataset.ladder === tier));

      if (elapsed < DURATION) {
        raf = window.requestAnimationFrame(tick);
      }
    }

    startBtn?.addEventListener('click', () => {
      window.cancelAnimationFrame(raf);
      if (stageEl) delete stageEl.dataset.tier;
      startedAt = performance.now();
      raf = window.requestAnimationFrame(tick);
    });
  }

  initPrototype();
  document.addEventListener('astro:page-load', initPrototype);
</script>
