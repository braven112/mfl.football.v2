---
/**
 * 2026 RSP Rookie Rankings
 * Matt Waldman's Rookie Scouting Portfolio — Pre-Draft Edition
 * Fully static page — all data processed at build time.
 */

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import PlayerCell from '../../components/theleague/PlayerCell.astro';
import rspData from '../../../data/fantasy-expert/sources/rsp/2026-pre-draft.json';
import rsp2025 from '../../../data/fantasy-expert/sources/rsp/2025-post-draft.json';
import rsp2024 from '../../../data/fantasy-expert/sources/rsp/2024-post-draft.json';
import sleeperData from '../../../data/fantasy-expert/sleeper-watchlist/2026-class.json';
import espnCollegeIds from '../../../data/theleague/espn-college-ids.json';
import fbgData from '../../../data/fantasy-expert/sources/fbg/2026-rookies.json';
import fbgDynastyData from '../../../data/fantasy-expert/sources/fbg/2026-dynasty.json';
import pigskinRoster from '../../../data/theleague/pigskins-roster-2026.json';
import leagueOwnership from '../../../data/theleague/rsp-league-ownership.json';
import rspPlayerIds from '../../../data/theleague/rsp-player-ids.json';

// Build name → { mflId, espnId } lookup for RSP 2024/2025 NFL players
const rspIdsByName = new Map<string, { mflId: string; espnId?: string }>();
for (const [name, ids] of Object.entries(rspPlayerIds.players)) {
  const entry = ids as { mflId: string; espnId?: string };
  rspIdsByName.set(name.toLowerCase(), entry);
}
function getRspIds(name: string): { mflId: string; espnId?: string } | undefined {
  return rspIdsByName.get(name.toLowerCase());
}
function getRspHeadshot(name: string): string | undefined {
  const ids = getRspIds(name);
  if (!ids) return undefined;
  if (ids.espnId) return `https://a.espncdn.com/i/headshots/nfl/players/full/${ids.espnId}.png`;
  return `https://www49.myfantasyleague.com/player_photos_big_2014/${ids.mflId}_thumb.jpg`;
}

// Build name → espnCollegeId lookup from the MFL-matched data
const espnCollegeByName = new Map<string, string>();
for (const entry of Object.values(espnCollegeIds.players)) {
  const e = entry as { name: string; espnCollegeId?: string };
  if (e.name && e.espnCollegeId) {
    espnCollegeByName.set(e.name.toLowerCase(), e.espnCollegeId);
  }
}

function getCollegeHeadshot(name: string): string | undefined {
  const id = espnCollegeByName.get(name.toLowerCase());
  return id ? `https://a.espncdn.com/i/headshots/college-football/players/full/${id}.png` : undefined;
}

// Build FBG rank lookup (2026 rookies only — name normalized for fuzzy match)
function normalizeFbgName(name: string): string {
  return name.toLowerCase().replace(/\s+(jr\.?|sr\.?|ii|iii|iv)$/i, '').trim();
}
const fbgRankByName = new Map<string, number>();
const fbgTierByName = new Map<string, string>();
for (const p of fbgData.players) {
  fbgRankByName.set(p.name.toLowerCase(), p.rank);
  fbgRankByName.set(normalizeFbgName(p.name), p.rank);
  fbgTierByName.set(p.name.toLowerCase(), p.tier);
  fbgTierByName.set(normalizeFbgName(p.name), p.tier);
}
function getFbgRank(name: string): number | undefined {
  return fbgRankByName.get(name.toLowerCase()) ?? fbgRankByName.get(normalizeFbgName(name));
}
function getFbgTier(name: string): string | undefined {
  return fbgTierByName.get(name.toLowerCase()) ?? fbgTierByName.get(normalizeFbgName(name));
}

// Build FBG dynasty rank lookup (all players — covers 2024/2025/2026 classes)
const fbgDynastyRankByName = new Map<string, number>();
const fbgDynastyTierByName = new Map<string, string>();
for (const p of fbgDynastyData.players) {
  fbgDynastyRankByName.set(p.name.toLowerCase(), p.rank);
  fbgDynastyRankByName.set(normalizeFbgName(p.name), p.rank);
  fbgDynastyTierByName.set(p.name.toLowerCase(), p.tier);
  fbgDynastyTierByName.set(normalizeFbgName(p.name), p.tier);
}
function getFbgDynastyRank(name: string): number | undefined {
  return fbgDynastyRankByName.get(name.toLowerCase()) ?? fbgDynastyRankByName.get(normalizeFbgName(name));
}
function getFbgDynastyTier(name: string): string | undefined {
  return fbgDynastyTierByName.get(name.toLowerCase()) ?? fbgDynastyTierByName.get(normalizeFbgName(name));
}

// Sort all players by DoT score and take top 50 (with FBG rank merged in)
const top50 = [...rspData.players]
  .sort((a, b) => b.preDraftScore - a.preDraftScore)
  .slice(0, 50)
  .map(p => ({ ...p, fbgRank: getFbgRank(p.name), fbgTier: getFbgTier(p.name) }));

// Metrics
const totalProspects = rspData.players.length;
const topDotScore = top50[0].preDraftScore.toFixed(1);
const sleeperCount = sleeperData.sleepers.length;
const highPrioritySleepers = sleeperData.sleepers.filter(s => s.priority === 'HIGH').length;

// Waldman overviews
const { qb, rb, wr, te } = rspData.waldmanOverview;

// RSP Class Comparison — ownership lookup and per-class data
type PigskinEntry = { mflId: string; name: string; position: string; nflTeam: string; salary: number; contractYear: number };
const pigskinsByName = new Map<string, PigskinEntry>();
for (const [key, data] of Object.entries(pigskinRoster.players)) {
  pigskinsByName.set(key.toLowerCase(), data as PigskinEntry);
}
function getPigskinOwnership(name: string): PigskinEntry | undefined {
  return pigskinsByName.get(name.toLowerCase());
}

type LeagueOwner = { franchiseId: string; franchiseName: string; franchiseSlug: string; iconPath: string; salary: number; contractYear: number };
const ownershipByName = leagueOwnership.ownership as Record<string, LeagueOwner>;
function getLeagueOwner(name: string): LeagueOwner | undefined {
  // Try exact match first, then case-insensitive scan
  const direct = ownershipByName[name];
  if (direct) return direct;
  const lower = name.toLowerCase();
  for (const [k, v] of Object.entries(ownershipByName)) {
    if (k.toLowerCase() === lower) return v;
  }
  return undefined;
}

type AffinityEntry = { name: string; slug: string; iconPath: string; abCount: number; totalRsp: number; totalPlayers: number; abPct: number; affinity: string };
const affinityData = leagueOwnership.affinity as unknown as Record<string, AffinityEntry>;
const affinitySorted = Object.entries(affinityData).sort((a, b) => b[1].abCount - a[1].abCount);

const compare2026 = [...rspData.players].sort((a, b) => b.preDraftScore - a.preDraftScore);
const compare2025 = [...rsp2025.players].sort((a, b) => a.rank - b.rank);
const compare2024 = [...rsp2024.players].sort((a, b) => a.rank - b.rank);

const ownedIn2025 = compare2025.filter(p => getPigskinOwnership(p.name)).length;
const ownedIn2024 = compare2024.filter(p => getPigskinOwnership(p.name)).length;
const totalRspOwned = ownedIn2025 + ownedIn2024;

// Unified 3-year RSP ranking — tier-based sort (A→E), newest class first within tier
const TIER_ORDER: Record<string, number> = {
  'A': 1, 'B': 2, 'C': 3, 'D': 4, 'E': 5,
  'Franchise': 1, 'Starter': 2,
  'Rotational Starter': 3, 'Contributor': 3,
  'Reserve': 4, 'Developmental': 5, 'Street': 5,
};
const GRADE_TO_TIER: Record<string, string> = {
  'Franchise': 'A', 'Starter': 'B',
  'Rotational Starter': 'C', 'Contributor': 'C',
  'Reserve': 'D', 'Developmental': 'E', 'Street': 'E',
};
const TIER_LABELS: Record<string, string> = {
  'A': 'Elite',
  'B': 'Starter Caliber',
  'C': 'Rotational / Contributor',
  'D': 'Reserve',
  'E': 'Developmental',
};

type CombinedRspPlayer = {
  classYear: number; rank: number; name: string; position: string;
  nflTeam?: string; school?: string;
  tier: string; rawGrade: string; tierOrder: number;
  value?: string; notes?: string;
  owner?: LeagueOwner;
  isPigskins?: boolean;
  headshot?: string; mflId?: string; espnId?: string;
  fbgRank?: number;
  dynastyRank?: number; dynastyTier?: string;
};

const allRspPlayers: CombinedRspPlayer[] = [];

compare2026.forEach((p, i) => {
  const tier = GRADE_TO_TIER[p.preDraftGrade] ?? 'E';
  const espnCollegeId = espnCollegeByName.get(p.name.toLowerCase());
  allRspPlayers.push({
    classYear: 2026, rank: i + 1, name: p.name, position: p.position,
    school: p.school ?? undefined, tier, rawGrade: p.preDraftGrade,
    tierOrder: TIER_ORDER[p.preDraftGrade] ?? 5,
    notes: p.notes,
    headshot: espnCollegeId ? `https://a.espncdn.com/i/headshots/college-football/players/full/${espnCollegeId}.png` : undefined,
    espnId: espnCollegeId,
    fbgRank: getFbgRank(p.name),
    dynastyRank: getFbgDynastyRank(p.name),
    dynastyTier: getFbgDynastyTier(p.name),
  });
});

compare2025.forEach(p => {
  const pos = p.position.includes('/') ? p.position.split('/')[0] : p.position;
  const ids = getRspIds(p.name);
  const pigskinEntry = getPigskinOwnership(p.name);
  const owner = getLeagueOwner(p.name);
  allRspPlayers.push({
    classYear: 2025, rank: p.rank, name: p.name, position: pos,
    nflTeam: p.team, tier: p.tier, rawGrade: p.tier,
    tierOrder: TIER_ORDER[p.tier] ?? 5,
    value: p.value, notes: p.notes,
    owner, isPigskins: !!pigskinEntry,
    headshot: getRspHeadshot(p.name) ?? (pigskinEntry ? `https://www49.myfantasyleague.com/player_photos_big_2014/${pigskinEntry.mflId}_thumb.jpg` : undefined),
    mflId: ids?.mflId ?? pigskinEntry?.mflId,
    espnId: ids?.espnId,
    dynastyRank: getFbgDynastyRank(p.name),
    dynastyTier: getFbgDynastyTier(p.name),
  });
});

compare2024.forEach(p => {
  const ids = getRspIds(p.name);
  const pigskinEntry = getPigskinOwnership(p.name);
  const owner = getLeagueOwner(p.name);
  allRspPlayers.push({
    classYear: 2024, rank: p.rank, name: p.name, position: p.position,
    nflTeam: p.team, tier: p.tier, rawGrade: p.tier,
    tierOrder: TIER_ORDER[p.tier] ?? 5,
    value: p.value, notes: p.notes,
    owner, isPigskins: !!pigskinEntry,
    headshot: getRspHeadshot(p.name) ?? (pigskinEntry ? `https://www49.myfantasyleague.com/player_photos_big_2014/${pigskinEntry.mflId}_thumb.jpg` : undefined),
    mflId: ids?.mflId ?? pigskinEntry?.mflId,
    espnId: ids?.espnId,
    dynastyRank: getFbgDynastyRank(p.name),
    dynastyTier: getFbgDynastyTier(p.name),
  });
});

// Sort: tier asc → class year desc (2026 first) → rank asc
allRspPlayers.sort((a, b) => {
  if (a.tierOrder !== b.tierOrder) return a.tierOrder - b.tierOrder;
  if (a.classYear !== b.classYear) return b.classYear - a.classYear;
  return a.rank - b.rank;
});

// Build flat rows with tier separator header rows
type CombinedTierRow = { type: 'tier'; tier: string; tierOrder: number; label: string; total: number; ownedCount: number };
type CombinedPlayerRow = { type: 'player'; overallRank: number } & CombinedRspPlayer;
type CombinedRow = CombinedTierRow | CombinedPlayerRow;

const combinedRows: CombinedRow[] = [];
let lastTierOrder2 = -1;
let overallRank = 0;
for (const p of allRspPlayers) {
  if (p.tierOrder !== lastTierOrder2) {
    lastTierOrder2 = p.tierOrder;
    const tierPlayers = allRspPlayers.filter(x => x.tierOrder === p.tierOrder);
    combinedRows.push({
      type: 'tier', tier: p.tier, tierOrder: p.tierOrder,
      label: TIER_LABELS[p.tier] ?? '',
      total: tierPlayers.length,
      ownedCount: tierPlayers.filter(x => x.owner).length,
    });
  }
  overallRank++;
  combinedRows.push({ type: 'player', overallRank, ...p });
}

---

<TheLeagueLayout title="2026 Rookie Rankings">
  <div class="rsp-page">

    <!-- ─── Hero ──────────────────────────────────────────────────── -->
    <div class="rsp-hero">
      <div class="rsp-hero__eyebrow">Dynasty Scouting</div>
      <h1 class="rsp-hero__title">2026 Rookie Rankings</h1>
      <p class="rsp-hero__meta">
        Matt Waldman's Rookie Scouting Portfolio &middot; Pre-Draft Edition &middot; Published Mar 31, 2026
      </p>
    </div>

    <!-- ─── Metrics strip ─────────────────────────────────────────── -->
    <div class="rsp-metrics">
      <div class="rsp-metrics__card">
        <span class="rsp-metrics__value">{totalProspects}</span>
        <span class="rsp-metrics__label">Prospects Graded</span>
      </div>
      <div class="rsp-metrics__card">
        <span class="rsp-metrics__value">{topDotScore}</span>
        <span class="rsp-metrics__label">Top DoT Score</span>
      </div>
      <div class="rsp-metrics__card">
        <span class="rsp-metrics__value">{sleeperCount}</span>
        <span class="rsp-metrics__label">Sleeper Targets</span>
      </div>
    </div>

    <!-- ─── Tab bar ───────────────────────────────────────────────── -->
    <div class="rsp-tabs" role="tablist" aria-label="Rookie rankings sections">
      <button
        role="tab"
        id="tab-rankings"
        aria-selected="true"
        aria-controls="panel-rankings"
        tabindex="0"
        class="rsp-tab"
      >Top 50 Rankings</button>
      <button
        role="tab"
        id="tab-sleepers"
        aria-selected="false"
        aria-controls="panel-sleepers"
        tabindex="-1"
        class="rsp-tab"
      >Sleeper Watchlist <span class="rsp-tab__badge">{highPrioritySleepers} HIGH</span></button>
      <button
        role="tab"
        id="tab-overview"
        aria-selected="false"
        aria-controls="panel-overview"
        tabindex="-1"
        class="rsp-tab"
      >Waldman's Take</button>
      <button
        role="tab"
        id="tab-compare"
        aria-selected="false"
        aria-controls="panel-compare"
        tabindex="-1"
        class="rsp-tab"
      >3-Year RSP <span class="rsp-tab__badge">{totalRspOwned} Owned</span></button>
    </div>

    <!-- ─── Panel 1: Top 50 Table ─────────────────────────────────── -->
    <section role="tabpanel" id="panel-rankings" aria-labelledby="tab-rankings" tabindex="0" class="rsp-panel">
      <div class="rsp-table-section-header">
        <h2 class="rsp-section-title">Top 50 — Integrated Rankings</h2>
        <p class="rsp-section-sub">Waldman's DoT score with FBG dynasty rookie ranks merged. Click a column header to re-sort.</p>
      </div>
      <div class="rsp-table-scroll">
        <table class="rsp-table" id="top50-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th class="col-player">Player</th>
              <th class="col-fbg sortable" data-sort-key="fbg">FBG<span class="sort-arrow"></span></th>
              <th class="col-dot sortable" data-sort-key="dot">DoT<span class="sort-arrow"> ↓</span></th>
              <th class="col-grade sortable" data-sort-key="grade">Grade<span class="sort-arrow"></span></th>
              <th class="col-comp">Comparison</th>
              <th class="col-notes">Notes</th>
            </tr>
          </thead>
          <tbody id="top50-tbody">
            {top50.map((player, i) => (
              <tr data-dot={player.preDraftScore} data-fbg={player.fbgRank ?? 9999} data-dot-rank={i + 1} data-grade-order={TIER_ORDER[player.preDraftGrade] ?? 5}>
                <td class="col-rank rank-cell" data-label="#">{i + 1}</td>
                <td class="col-player" data-label="Player">
                  <PlayerCell name={player.name} position={player.position} size="compact" headshot={getCollegeHeadshot(player.name)} />
                  {player.school && <span class="player-school">{player.school}</span>}
                </td>
                <td class="col-fbg" data-label="FBG">
                  {player.fbgRank
                    ? <span class="fbg-rank">{player.fbgRank} <span class="fbg-tier-chip">{player.fbgTier?.replace('Tier ', 'T')}</span></span>
                    : <span class="fbg-rank--none">—</span>
                  }
                </td>
                <td class="col-dot" data-label="DoT">{player.preDraftScore.toFixed(1)}</td>
                <td class="col-grade" data-label="Grade">{player.preDraftGrade}</td>
                <td class="col-comp" data-label="Comparison">{player.comparison ?? '—'}</td>
                <td class="col-notes" data-label="Notes">{player.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ─── Panel 2: Sleeper Watchlist ───────────────────────────── -->
    <section role="tabpanel" id="panel-sleepers" aria-labelledby="tab-sleepers" tabindex="0" class="rsp-panel" hidden>
      <div class="rsp-table-section-header">
        <h2 class="rsp-section-title">Sleeper Watchlist</h2>
        <p class="rsp-section-sub">{sleeperCount} targets Waldman grades significantly above market — sorted by priority with TheLeague-specific action plans.</p>
      </div>
      <div class="sleeper-grid">
        {sleeperData.sleepers.map(s => (
          <article class={`sleeper-card sleeper-card--${s.priority.toLowerCase()}`}>
            <div class="sleeper-card__header">
              <div class="sleeper-card__name-block">
                <h3 class="sleeper-card__name">{s.name}</h3>
                <span class="sleeper-card__school">{s.school}</span>
              </div>
              <div class="sleeper-card__badges">
                <span class={`pos-badge pos-badge--${s.position.toLowerCase()}`}>{s.position}</span>
                <span class={`priority-badge priority-badge--${s.priority.toLowerCase()}`}>{s.priority}</span>
              </div>
            </div>

            <div class="sleeper-metrics">
              <div class="sleeper-metric">
                <span class="sleeper-metric__value">{s.preDraftScore.toFixed(1)}</span>
                <span class="sleeper-metric__label">DoT Score</span>
              </div>
              <div class="sleeper-metric">
                <span class="sleeper-metric__value">{s.positionRank}</span>
                <span class="sleeper-metric__label">RSP Rank</span>
              </div>
              <div class="sleeper-metric">
                <span class="sleeper-metric__value">{s.preDraftGrade}</span>
                <span class="sleeper-metric__label">Grade</span>
              </div>
            </div>

            {s.comparison && (
              <div class="sleeper-comp">
                <span class="sleeper-comp__label">Comp</span>
                <span class="sleeper-comp__value">{s.comparison}</span>
              </div>
            )}

            <div class="sleeper-body">
              <div class="sleeper-row">
                <span class="sleeper-row__label">Why a sleeper</span>
                <p class="sleeper-row__text">{s.sleepReason}</p>
              </div>
              <div class="sleeper-row">
                <span class="sleeper-row__label">Action plan</span>
                <p class="sleeper-row__text">{s.actionPlan}</p>
              </div>
              <div class="sleeper-row sleeper-row--league">
                <span class="sleeper-row__label">TheLeague fit</span>
                <p class="sleeper-row__text">{s.leagueAdjustment}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ─── Panel 3: Waldman's Take ──────────────────────────────── -->
    <section role="tabpanel" id="panel-overview" aria-labelledby="tab-overview" tabindex="0" class="rsp-panel" hidden>
      <div class="rsp-table-section-header">
        <h2 class="rsp-section-title">Waldman's Positional Take</h2>
        <p class="rsp-section-sub">Macro picture by position — where the value is and how to approach each group in the draft.</p>
      </div>
      <div class="overview-grid">
        <div class="overview-card">
          <div class="overview-card__header">
            <span class="pos-badge pos-badge--qb">QB</span>
            <span class="overview-card__pos-label">Quarterback</span>
          </div>
          <p class="overview-card__body">{qb}</p>
        </div>
        <div class="overview-card">
          <div class="overview-card__header">
            <span class="pos-badge pos-badge--rb">RB</span>
            <span class="overview-card__pos-label">Running Back</span>
          </div>
          <p class="overview-card__body">{rb}</p>
        </div>
        <div class="overview-card">
          <div class="overview-card__header">
            <span class="pos-badge pos-badge--wr">WR</span>
            <span class="overview-card__pos-label">Wide Receiver</span>
          </div>
          <p class="overview-card__body">{wr}</p>
        </div>
        <div class="overview-card">
          <div class="overview-card__header">
            <span class="pos-badge pos-badge--te">TE</span>
            <span class="overview-card__pos-label">Tight End</span>
          </div>
          <p class="overview-card__body">{te}</p>
        </div>
      </div>
    </section>

    <!-- ─── Panel 4: 3-Year RSP Unified Ranking ─────────────────────── -->
    <section role="tabpanel" id="panel-compare" aria-labelledby="tab-compare" tabindex="0" class="rsp-panel" hidden>
      <div class="rsp-table-section-header">
        <h2 class="rsp-section-title">3-Year RSP — Unified Ranking</h2>
        <p class="rsp-section-sub">{allRspPlayers.length} players across 3 classes — sorted by Waldman tier (A→E), newest class first. FBG dynasty rank shown for 2026 class. 2024 shelf life expires after this season.</p>
      </div>
      <div class="top50-sort-bar">
        <span class="sort-label">Within tier, sort by:</span>
        <button class="sort-btn sort-btn--active" id="rsp-sort-rsp" data-table="rsp" data-sort="rsp">RSP Rank</button>
        <button class="sort-btn" id="rsp-sort-fbg" data-table="rsp" data-sort="fbg">FBG Dynasty Rank</button>
      </div>
      <div class="rsp-table-scroll">
        <table class="rsp-table compare-table" id="rsp-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th class="col-player">Player</th>
              <th class="col-class">Class</th>
              <th class="col-team">NFL / School</th>
              <th class="col-tier">Tier</th>
              <th class="col-fbg">FBG Dyn</th>
              <th class="col-value">Value</th>
              <th class="col-owned">Status</th>
            </tr>
          </thead>
          <tbody id="rsp-tbody">
            {combinedRows.map(row => row.type === 'tier' ? (
              <tr class="tier-row" data-tier-order={row.tierOrder}>
                <td colspan={8} class="tier-label">
                  <span class={`tier-badge tier-badge--${row.tier.toLowerCase()}`}>{row.tier}</span>
                  {row.label}
                  <span class="tier-count">· {row.total} players{row.ownedCount > 0 ? ` · ${row.ownedCount} owned` : ''}</span>
                </td>
              </tr>
            ) : (
              <tr
                class:list={[row.owner && 'rsp-compare-row--taken', row.isPigskins && 'rsp-compare-row--owned']}
                data-tier-order={row.tierOrder}
                data-rsp-rank={row.rank}
                data-fbg={row.dynastyRank ?? 9999}
                data-class={row.classYear}
              >
                <td class="col-rank rank-cell" data-label="#">{row.overallRank}</td>
                <td class="col-player" data-label="Player">
                  <PlayerCell
                    name={row.name}
                    position={row.position}
                    size="compact"
                    nflTeam={row.nflTeam}
                    headshot={row.headshot}
                    mflId={row.mflId}
                    espnId={row.espnId}
                  />
                </td>
                <td class="col-class" data-label="Class">
                  <span class={`class-badge class-badge--${row.classYear}`}>{row.classYear}</span>
                </td>
                <td class="col-team" data-label="NFL / School">
                  {row.nflTeam ?? row.school ?? '—'}
                </td>
                <td class="col-tier" data-label="Tier">
                  <span class={`tier-badge tier-badge--${row.tier.toLowerCase()}`} title={row.rawGrade !== row.tier ? row.rawGrade : undefined}>{row.tier}</span>
                </td>
                <td class="col-fbg" data-label="FBG Dyn">
                  {row.dynastyRank
                    ? <span class="fbg-rank" title={row.dynastyTier}>{row.dynastyRank}</span>
                    : <span class="fbg-rank--none">—</span>
                  }
                </td>
                <td class="col-value" data-label="Value">{row.value ?? '—'}</td>
                <td class="col-owned" data-label="Owner">
                  {row.owner ? (
                    <span class:list={['owner-badge', row.isPigskins && 'owner-badge--pigskins']}>
                      <img src={row.owner.iconPath} alt={row.owner.franchiseName} class="owner-badge__icon" loading="lazy" decoding="async" />
                      <span class="owner-badge__info">
                        <span class="owner-badge__name">{row.owner.franchiseName}</span>
                        <span class="owner-badge__contract">${(row.owner.salary / 1_000_000).toFixed(1)}M · Yr {row.owner.contractYear}</span>
                      </span>
                    </span>
                  ) : <span class="owner-badge--avail">Available</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ─── RSP Affinity Panel ───────────────────────────────────── -->
    <div class="affinity-panel">
      <div class="affinity-panel__header">
        <h3 class="affinity-panel__title">RSP Buyer Likelihood</h3>
        <p class="affinity-panel__sub">Ranked by Waldman <strong>Tier A &amp; B</strong> holdings from the 2024 &amp; 2025 classes — high-grade guys only</p>
      </div>
      <div class="affinity-panel__grid">
        {affinitySorted.map(([fid, info]) => (
          <div class:list={['affinity-card', `affinity-card--${info.affinity}`]}>
            <img src={info.iconPath} alt={info.name} class="affinity-card__icon" loading="lazy" decoding="async" />
            <div class="affinity-card__body">
              <span class="affinity-card__name">{info.name}</span>
              <span class="affinity-card__stat">{info.abCount} A/B · {info.abPct}%</span>
            </div>
            <span class:list={['affinity-chip', `affinity-chip--${info.affinity}`]}>
              {info.affinity === 'high' ? 'Buyer' : info.affinity === 'medium' ? 'Mixed' : 'Skips'}
