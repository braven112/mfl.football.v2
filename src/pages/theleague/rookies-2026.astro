          </div>
        ))}
      </div>
    </div>

    <!-- ─── Grade Scale Legend (always visible) ──────────────────── -->
    <div class="grade-legend">
      <h3 class="grade-legend__title">Grade Scale</h3>
      <div class="grade-legend__grid">
        {Object.entries(rspData.gradeScale).map(([grade, desc]) => {
          const [range, description] = desc.split(' -- ');
          return (
            <div class="grade-legend__item">
              <span class="grade-legend__name">{grade}</span>
              <span class="grade-legend__range">{range}</span>
              <span class="grade-legend__desc">{description}</span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ─── No-JS fallback ───────────────────────────────────────── -->
    <noscript>
      <style>
        .rsp-tabs { display: none !important; }
        .rsp-panel[hidden] { display: block !important; }
      </style>
    </noscript>

  </div>
</TheLeagueLayout>

<!-- ─── Tab keyboard nav + sort scripts ──────────────────────────── -->
<script>
  // ── Tab navigation ────────────────────────────────────────────────
  const tablist = document.querySelector('[role="tablist"]') as HTMLElement;
  if (tablist) {
    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'));

    function activateTab(tab: HTMLButtonElement) {
      tabs.forEach(t => {
        t.setAttribute('aria-selected', 'false');
        t.setAttribute('tabindex', '-1');
        const panelId = t.getAttribute('aria-controls');
        if (panelId) {
          const panel = document.getElementById(panelId);
          if (panel) panel.hidden = true;
        }
      });
      tab.setAttribute('aria-selected', 'true');
      tab.setAttribute('tabindex', '0');
      tab.focus();
      const panelId = tab.getAttribute('aria-controls');
      if (panelId) {
        const panel = document.getElementById(panelId);
        if (panel) panel.hidden = false;
      }
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activateTab(tab));
      tab.addEventListener('keydown', (e: KeyboardEvent) => {
        let nextIndex = i;
        if (e.key === 'ArrowRight') nextIndex = (i + 1) % tabs.length;
        else if (e.key === 'ArrowLeft') nextIndex = (i - 1 + tabs.length) % tabs.length;
        else if (e.key === 'Home') nextIndex = 0;
        else if (e.key === 'End') nextIndex = tabs.length - 1;
        else return;
        e.preventDefault();
        activateTab(tabs[nextIndex]);
      });
    });
  }

  // ── Top 50: header-click sort ─────────────────────────────────────
  const top50Tbody = document.getElementById('top50-tbody');
  const top50Table = document.getElementById('top50-table') as HTMLTableElement | null;

  let top50SortKey = 'dot';
  let top50SortDir: 'asc' | 'desc' = 'desc';

  function sortTop50ByKey(key: string, dir: 'asc' | 'desc') {
    if (!top50Tbody) return;
    const rows = Array.from(top50Tbody.querySelectorAll<HTMLTableRowElement>('tr'));
    rows.sort((a, b) => {
      if (key === 'fbg') {
        const af = parseFloat(a.dataset.fbg ?? '9999');
        const bf = parseFloat(b.dataset.fbg ?? '9999');
        if (af === 9999 && bf === 9999) return 0;
        if (af === 9999) return 1;
        if (bf === 9999) return -1;
        return dir === 'asc' ? af - bf : bf - af;
      }
      if (key === 'dot') {
        const ad = parseFloat(a.dataset.dot ?? '0');
        const bd = parseFloat(b.dataset.dot ?? '0');
        return dir === 'asc' ? ad - bd : bd - ad;
      }
      if (key === 'grade') {
        const ag = parseFloat(a.dataset.gradeOrder ?? '5');
        const bg = parseFloat(b.dataset.gradeOrder ?? '5');
        return dir === 'asc' ? ag - bg : bg - ag;
      }
      return 0;
    });
    rows.forEach((row, i) => {
      const cell = row.querySelector('.rank-cell');
      if (cell) cell.textContent = String(i + 1);
      top50Tbody.appendChild(row);
    });
  }

  function updateTop50Indicators() {
    top50Table?.querySelectorAll<HTMLTableCellElement>('th[data-sort-key]').forEach(th => {
      const arrow = th.querySelector<HTMLElement>('.sort-arrow');
      if (!arrow) return;
      arrow.textContent = th.dataset.sortKey === top50SortKey
        ? (top50SortDir === 'asc' ? ' ↑' : ' ↓')
        : '';
    });
  }

  top50Table?.querySelectorAll<HTMLTableCellElement>('th[data-sort-key]').forEach(th => {
    th.addEventListener('click', () => {
      const key = th.dataset.sortKey!;
      if (key === top50SortKey) {
        top50SortDir = top50SortDir === 'asc' ? 'desc' : 'asc';
      } else {
        top50SortKey = key;
        // DoT: higher = better → default desc; FBG & Grade: lower = better → default asc
        top50SortDir = key === 'dot' ? 'desc' : 'asc';
      }
      sortTop50ByKey(top50SortKey, top50SortDir);
      updateTop50Indicators();
    });
  });

  updateTop50Indicators();

  // ── RSP within-tier sort ──────────────────────────────────────────
  const rspTbody = document.getElementById('rsp-tbody');
  const rspSortBtns = document.querySelectorAll<HTMLButtonElement>('[data-table="rsp"]');

  function sortRsp(key: 'rsp' | 'fbg') {
    if (!rspTbody) return;
    const allRows = Array.from(rspTbody.querySelectorAll<HTMLTableRowElement>('tr'));

    // Group rows into [tierHeaderRow, ...playerRows] segments
    type Segment = { header: HTMLTableRowElement; players: HTMLTableRowElement[] };
    const segments: Segment[] = [];
    let current: Segment | null = null;
    for (const row of allRows) {
      if (row.classList.contains('tier-row')) {
        current = { header: row, players: [] };
        segments.push(current);
      } else if (current) {
        current.players.push(row);
      }
    }

    // Sort players within each segment, then rebuild tbody
    let overallRank = 0;
    for (const seg of segments) {
      if (key === 'fbg') {
        seg.players.sort((a, b) => {
          const af = parseFloat(a.dataset.fbg ?? '9999');
          const bf = parseFloat(b.dataset.fbg ?? '9999');
          // Unranked (9999) go last; within ranked, sort by year desc then fbg asc
          if (af === 9999 && bf === 9999) return 0;
          if (af === 9999) return 1;
          if (bf === 9999) return -1;
          return af - bf;
        });
      } else {
        // RSP: sort by class year desc, then rsp rank asc
        seg.players.sort((a, b) => {
          const ay = parseInt(a.dataset.class ?? '0');
          const by_ = parseInt(b.dataset.class ?? '0');
          if (ay !== by_) return by_ - ay;
          return parseInt(a.dataset.rspRank ?? '0') - parseInt(b.dataset.rspRank ?? '0');
        });
      }
      rspTbody.appendChild(seg.header);
      for (const row of seg.players) {
        overallRank++;
        const cell = row.querySelector('.rank-cell');
        if (cell) cell.textContent = String(overallRank);
        rspTbody.appendChild(row);
      }
    }

    // Update active button
    rspSortBtns.forEach(btn => {
      btn.classList.toggle('sort-btn--active', btn.dataset.sort === key);
    });
  }

  rspSortBtns.forEach(btn => {
    btn.addEventListener('click', () => sortRsp(btn.dataset.sort as 'rsp' | 'fbg'));
  });
</script>

