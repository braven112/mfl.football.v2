---
/**
 * New Homepage Prototype
 *
 * 2-column layout: flexible left column + 380px right sidebar with compact feed.
 * Admin-only, accessible at /theleague/new-hp by direct URL.
 */
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import SchefterFeedCompact from '../../components/shared/SchefterFeedCompact.astro';
import SeasonDailyHero from '../../components/theleague/SeasonDailyHero.astro';
import WhatsNext from '../../components/theleague/WhatsNext.astro';
import HpTeamSnapshot from '../../components/theleague/hp-sections/HpTeamSnapshot.astro';
import HpStandingsCompact from '../../components/theleague/hp-sections/HpStandingsCompact.astro';
import HpUnsignedFaCard from '../../components/theleague/hp-sections/HpUnsignedFaCard.astro';
import HpAuctionsCard from '../../components/theleague/hp-sections/HpAuctionsCard.astro';
import HpQuickLinks from '../../components/theleague/hp-sections/HpQuickLinks.astro';
import PlayerDetailsModal from '../../components/theleague/PlayerDetailsModal.astro';
import { getAuthUser } from '../../utils/auth';
import { resolveHeroState, parseTestDate, isAuctionStripPeriod } from '../../utils/hero-resolver';
import { enrichHeroState, isDraftComplete, getRosteredPlayerIds, getAdpRankedIds, getFranchiseHeadliners, getKickoffGame, getKickoffGameCandidates, selectBreakingStory } from '../../utils/offseason-hero-data';
import { getWhatsNextTimeline } from '../../utils/league-event-resolver';
import { getCurrentLeagueYear, getCurrentSeasonYear } from '../../utils/league-year';
import { getPlayerMap } from '../../utils/player-map';
import { chooseTeamName } from '../../utils/team-names';
import { castFeaturedModel, castTopFreeAgentModel, castRosterModel, castRandomStarterModel, castClosingAuctionModel, castRookiesOnBoard, castStoryModel, castShowcasePanels } from '../../utils/hero-casting';
import type { HeroModel } from '../../utils/hero-casting';
import { normalizePlayoffBracket, buildSeedMaps } from '../../utils/playoffs';
import { isEliminated, buildBracketSummary } from '../../utils/playoff-hero-helpers';
import { buildPlayoffRoundView } from '../../utils/hero-data/playoff-round-data';
import fs from 'node:fs';
import { resolveLeaguePath } from '../../utils/nav-utils';
import { spriteUrl } from '../../utils/sprite-url';
import { SALARY_YEARS } from '../../utils/salary-calculations';
import { computeLeagueSummary, type SalaryPlayer, type TeamConfig } from '../../utils/league-summary-utils';
import { getDraftCapitalFromDraftResults } from '../../utils/future-draft-picks-utils';
import { parseNumber } from '../../utils/formatters';
import { resolveUnsignedFaAlerts, type DashboardPlayerContext } from '../../utils/homepage-dashboard';
import { loadActiveAuctions, type MflPlayerExtras } from '../../utils/homepage-auctions';
import { getCachedRosters } from '../../utils/mfl-roster-cache';
import type { SchefterFeed as FeedType } from '../../types/schefter';
import type { MatchupPairing, TeamInfo } from '../../types/live-scoring';
import type { MFLPlayerInfo, MFLRawTransaction, RosterPlayer } from '../../types/contract-eligibility';
import feedData from '../../data/theleague/schefter-feed.json';
import { getWhatsNewEntriesForLeague } from '../../utils/whats-new-entries';
import leagueConfig from '../../data/theleague.config.json';
import { getRecentMessages, toSchefterPosts, loadTeamConfig } from '../../utils/groupme-storage';
import '../../styles/schefter-feed.css';
import '../../styles/schefter-feed-compact.css';

const authUser = getAuthUser(Astro.request);
const isAuthenticated = !!authUser;
const userFranchiseId = authUser?.franchiseId;

const feed = feedData as FeedType;

// Merge GroupMe messages into the compact sidebar feed (auth-gated)
let compactPosts = feed.posts.slice(0, 30);
if (isAuthenticated) {
  try {
    const gmMessages = await getRecentMessages(30);
    if (gmMessages.length > 0) {
      const teamConfig = await loadTeamConfig();
      const gmPosts = toSchefterPosts(gmMessages, teamConfig);
      const merged = [...feed.posts.slice(0, 50), ...gmPosts];
      merged.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
      compactPosts = merged.slice(0, 30);
    }
  } catch (err) {
    console.warn('[homepage] Failed to load GroupMe messages:', err);
  }
}

// Support ?testDate=YYYY-MM-DD or ?testDate=YYYY-MM-DDTHH:MM for testing hero states
const testDateParam = Astro.url.searchParams.get('testDate');
const effectiveDate = parseTestDate(testDateParam);
const testMode = !!testDateParam;

// Check draft completion for early UDFA window transition
const leagueYear = getCurrentLeagueYear();
const draftComplete = isDraftComplete(leagueYear);

// Resolve hero state (the new state machine) and enrich with off-season data
const hideLeaguePrefix = false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
const timeline = getWhatsNextTimeline(effectiveDate);
// Detect a fresh breaking-tier Schefter story (<48h) and cast its headline
// player BEFORE resolving the hero state, so the resolver stays feed-free and
// just takes a boolean. The model + story ride to SeasonDailyHero below.
// Reuse the already-imported feed (no second sync disk read on the hot path).
// Pass a castability predicate so a newer non-compositable bomb (K/DEF, MFL-only
// photo) doesn't hide an older story whose player actually renders.
const breakingPlayerMap = getPlayerMap(getCurrentSeasonYear());
const breakingStory = selectBreakingStory(
  feed.posts,
  effectiveDate ?? new Date(),
  48,
  (ids) => !!castStoryModel(ids, breakingPlayerMap),
);
const breakingModel = breakingStory
  ? castStoryModel(breakingStory.playerIds, breakingPlayerMap)
  : null;
const hasBreakingStory = !!(breakingStory && breakingModel);

const rawHeroState = resolveHeroState(effectiveDate, testMode, getWhatsNewEntriesForLeague('theleague'), timeline, draftComplete, hasBreakingStory);
const heroState = await enrichHeroState(rawHeroState);

// Auctions card: replaces the legacy compact `AuctionStrip` on the homepage.
// Same visibility rules as the strip — show after the full auction hero ends,
// through the 3rd Sunday of August (FA close).
const now = effectiveDate ?? new Date();
const isAuctionHeroActive = heroState.phase === 'auction-preview' || heroState.phase === 'auction-live';
const showAuctionsCard = !isAuctionHeroActive && isAuctionStripPeriod(now);

// MFL external links for the auctions card
const mflHost = 'www49.myfantasyleague.com';
const mflLeagueId = '13522';
const mflAuctionBase = `https://${mflHost}/${leagueYear}/options?L=${mflLeagueId}`;
const placeBidUrl = `${mflAuctionBase}&O=43`;
const completedAuctionsUrl = `${mflAuctionBase}&O=43`;

// Load team config (used for reply composer + live scoring)
let userTeamName: string | undefined;
let userTeamIcon: string | undefined;
let allTeams: any[] = [];

try {
  const config = await import('../../data/theleague.config.json');
  allTeams = config.default?.teams ?? config.teams ?? [];
  if (userFranchiseId) {
    const team = allTeams.find((t: { franchiseId: string }) => t.franchiseId === userFranchiseId);
    if (team) {
      userTeamName = team.name;
      userTeamIcon = team.icon;
    }
  }
} catch { /* fallback gracefully */ }

// ---------------------------------------------------------------------------
// Homepage sections data: team summaries, standings context, unsigned FA alerts
// ---------------------------------------------------------------------------
const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;
const extractSeason = (fp: string): string | null => {
  const m = fp.match(/(\d{4})\.json$/);
  return m ? m[1] : null;
};
const extractFeedSeason = (fp: string): string | null => {
  const m = fp.match(/mfl-feeds\/(\d{4})\//);
  return m ? m[1] : null;
};

const rosterModules = import.meta.glob('../../data/mfl-player-salaries-*.json', { eager: true });
const salaryAdjustmentFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/salaryAdjustments.json', { eager: true });
const draftResultsFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/draftResults.json', { eager: true });
const playerFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/players.json', { eager: true });
const transactionFeeds = import.meta.glob('../../../data/theleague/mfl-feeds/*/transactions.json', { eager: true });

const rosterEntries = Object.entries(rosterModules)
  .map(([path, mod]) => ({ season: extractSeason(path), data: getModuleData(mod) }))
  .filter((item) => item.season && item.data)
  .sort((a, b) => parseInt(b.season!) - parseInt(a.season!));

const latestRoster = rosterEntries[0]?.data || {};
const currentSalaryYear = rosterEntries[0]?.season || String(SALARY_YEARS[0]);

const adjEntries = Object.entries(salaryAdjustmentFeeds)
  .map(([path, mod]) => ({ season: extractFeedSeason(path), data: getModuleData(mod) }))
  .filter((item) => item.season === currentSalaryYear && item.data);
const rawAdjustments = adjEntries[0]?.data?.salaryAdjustments?.salaryAdjustment || [];

const draftEntries = Object.entries(draftResultsFeeds)
  .map(([path, mod]) => ({ season: extractFeedSeason(path), data: getModuleData(mod) }))
  .filter((item) => item.season === currentSalaryYear && item.data);
const draftCapitalMap = getDraftCapitalFromDraftResults(draftEntries[0]?.data || null);

const playerFeedEntries = Object.entries(playerFeeds)
  .map(([path, mod]) => ({ season: extractFeedSeason(path), data: getModuleData(mod) }))
  .filter((item) => item.season === currentSalaryYear && item.data);
const rawPlayerFeed = playerFeedEntries[0]?.data?.players?.player ?? [];

const transactionEntries = Object.entries(transactionFeeds)
  .map(([path, mod]) => ({ season: extractFeedSeason(path), data: getModuleData(mod) }))
  .filter((item) => item.season === currentSalaryYear && item.data);
const rawTransactions: MFLRawTransaction[] = transactionEntries[0]?.data?.transactions?.transaction
  ? Array.isArray(transactionEntries[0].data.transactions.transaction)
    ? transactionEntries[0].data.transactions.transaction
    : [transactionEntries[0].data.transactions.transaction]
  : [];

const hpPlayerIdentityMap = getPlayerMap(parseInt(currentSalaryYear) || getCurrentLeagueYear());
const playerMetaById = new Map<string, { name: string; position: string }>();
const eligibilityPlayersById = new Map<string, MFLPlayerInfo>();
const playerDisplayById = new Map<string, DashboardPlayerContext>();
const playerExtrasById = new Map<string, MflPlayerExtras>();
for (const p of Array.isArray(rawPlayerFeed) ? rawPlayerFeed : [rawPlayerFeed]) {
  if (!p?.id) continue;
  const identity = hpPlayerIdentityMap.get(p.id);
  playerMetaById.set(p.id, { name: identity?.name ?? p.name ?? `Player ${p.id}`, position: identity?.position ?? p.position ?? '' });
  eligibilityPlayersById.set(p.id, {
    id: p.id,
    name: identity?.name ?? p.name ?? `Player ${p.id}`,
    position: identity?.position ?? p.position ?? '',
    team: identity?.nflTeam ?? p.team ?? '',
    status: p.status,
    draft_year: p.draft_year,
  });
  playerExtrasById.set(p.id, p as MflPlayerExtras);
  if (!playerDisplayById.has(p.id)) {
    playerDisplayById.set(p.id, {
      id: p.id,
      name: identity?.name ?? p.name ?? `Player ${p.id}`,
      position: identity?.position ?? p.position ?? '',
      nflTeam: identity?.nflTeam ?? p.team ?? '',
    });
  }
}

const teamConfigs: TeamConfig[] = (leagueConfig.teams ?? []).map((team: any) => ({
  franchiseId: team.franchiseId,
  name: team.name,
  nameMedium: team.nameMedium,
  nameShort: team.nameShort,
  abbrev: team.abbrev,
  icon: team.icon,
  division: team.division,
}));

interface HomeSalaryPlayer extends SalaryPlayer {
  contractInfo: string;
  headshot?: string;
  nflTeam?: string;
}

const salaryPlayers: HomeSalaryPlayer[] = (latestRoster.players ?? []).map((p: any) => {
  playerDisplayById.set(p.id, {
    id: p.id,
    name: p.name,
    position: p.position ?? '',
    nflTeam: p.team ?? '',
    headshot: p.headshot,
  });

  return {
  id: p.id,
  name: p.name,
  position: p.position ?? '',
  salary: parseNumber(p.salary),
  franchiseId: p.franchiseId ?? '',
  status: p.status ?? 'ROSTER',
  contractYear: p.contractYear ?? '0',
  contractInfo: p.contractInfo ?? '',
  headshot: p.headshot,
  nflTeam: p.team ?? '',
  points: parseNumber(p.points),
  birthdate: parseNumber(p.birthdate),
  };
});

// Overlay Redis-cached roster data for near-real-time freshness
const cachedRosterPlayers = await getCachedRosters(currentSalaryYear, '13522');
if (cachedRosterPlayers) {
  const playerById = new Map(salaryPlayers.map((p) => [p.id, p]));
  for (const [playerId, cached] of Object.entries(cachedRosterPlayers)) {
    const existing = playerById.get(playerId);
    if (existing) {
      existing.salary = parseNumber(cached.salary);
      existing.contractYear = cached.contractYear ?? existing.contractYear;
      existing.contractInfo = cached.contractInfo ?? existing.contractInfo;
      existing.status = cached.status ?? existing.status;
      existing.franchiseId = cached.franchiseId ?? existing.franchiseId;
    } else {
      const meta = playerMetaById.get(playerId);
      if (meta) {
        salaryPlayers.push({
          id: playerId, name: meta.name, position: meta.position,
          salary: parseNumber(cached.salary), franchiseId: cached.franchiseId ?? '',
          status: cached.status ?? 'ROSTER', contractYear: cached.contractYear ?? '1',
          contractInfo: cached.contractInfo ?? '',
          points: 0, birthdate: 0, nflTeam: eligibilityPlayersById.get(playerId)?.team ?? '',
        });
      }
    }
  }
  // Drop salary-file holdovers no longer on any roster — released free agents
  // would otherwise keep their stale franchiseId and inflate that team's cap.
  const rosteredIds = new Set(Object.keys(cachedRosterPlayers));
  for (let i = salaryPlayers.length - 1; i >= 0; i--) {
    if (!rosteredIds.has(salaryPlayers[i].id)) {
      salaryPlayers.splice(i, 1);
    }
  }
}

// Cast the model for the fresh What's New composite hero (hero casting
// rules): a player is cast ONLY when the entry names one (`heroPlayerId`) —
// otherwise the hero shows the entry's own screenshot in a browser frame,
// and entries with neither get the league logo silhouette.
const isFreshFeatureHero =
  heroState.phase === 'offseason-fallback' && heroState.fallbackHero?.source === 'feature';
const isAuctionPhase = heroState.phase === 'auction-preview' || heroState.phase === 'auction-live';

// Roster set for casting (memoized) — live salary data unioned with the
// on-disk MFL rosters feed so the rostered-first preference holds even when
// the Redis roster cache is unavailable (dev).
let _heroRosteredIds: Set<string> | null = null;
const heroRosteredIds = () => {
  if (!_heroRosteredIds) {
    _heroRosteredIds = getRosteredPlayerIds(leagueYear);
    for (const p of salaryPlayers) {
      if (p.franchiseId) _heroRosteredIds.add(p.id);
    }
  }
  return _heroRosteredIds;
};

let featureModel = null;
let auctionModel = null;
let cutWatchModel = null;
// Feature entries with heroArt bring their own artwork, so they skip the
// feature-model cast below (auction casting is independent of heroArt).
if (isAuctionPhase) {
  // Auction hero: the highest-ranked available free agent (dynasty ADP).
  auctionModel = castTopFreeAgentModel(hpPlayerIdentityMap, now, heroRosteredIds(), getAdpRankedIds(leagueYear));
} else if (isFreshFeatureHero && !heroState.fallbackHero?.heroArt) {
  featureModel = castFeaturedModel(
    heroState.fallbackHero?.heroPlayerId,
    hpPlayerIdentityMap,
    heroState.fallbackHero?.heroPlayerDescriptor ?? 'Featured',
  );
}
// UDFA window: the best rookies still on the board, four panels side by side.
// Cast eight — four render, four are spares the component swaps in for any
// rookie whose ESPN headshot 404s.
let udfaModels: ReturnType<typeof castRookiesOnBoard> = [];
if (heroState.phase === 'udfa-window') {
  udfaModels = castRookiesOnBoard(hpPlayerIdentityMap, heroRosteredIds(), getAdpRankedIds(leagueYear), 8, now);
}
// Tagged showcase: one composite panel per franchise-tagged player with a
// usable ESPN cutout. Cast eight — four render, four are spares the component
// swaps in for any player whose headshot 404s. Each panel resolves its tagging
// franchise to a short chip name + crest from the league config.
// CRITICAL: the composite headshot MUST come from the player map (ESPN cutout).
// Do NOT pass `taggedShowcaseProps.taggedPlayers[].headshot` to the hero — that
// is a Sleeper CDN JPG with a baked background, which `isCompositable` rejects
// (it would render an opaque box, not a cutout). castShowcasePanels resolves
// the cutout via hpPlayerIdentityMap; we only borrow franchiseId from the props.
let showcasePanels: Array<{ model: HeroModel; franchiseName: string; franchiseCrest: string }> = [];
if (heroState.phase === 'tagged-showcase' && heroState.taggedShowcaseProps) {
  const candidates = heroState.taggedShowcaseProps.taggedPlayers.map((t) => ({
    playerId: t.playerId,
    franchiseId: t.franchiseId,
  }));
  const franchiseById = new Map(teamConfigs.map((tc) => [tc.franchiseId, tc]));
  showcasePanels = castShowcasePanels(candidates, hpPlayerIdentityMap, 8, 'Tagged').map((panel) => {
    const tc = franchiseById.get(panel.franchiseId);
    return {
      model: panel,
      franchiseName: tc
        ? chooseTeamName(
            { fullName: tc.name, nameMedium: tc.nameMedium, nameShort: tc.nameShort, abbrev: tc.abbrev },
            'short',
          )
        : '',
      franchiseCrest: tc?.icon ?? '',
    };
  });
}
if (heroState.phase === 'cut-watch' && heroState.cutWatchProps) {
  // Cut watch hero: a real bubble player — YOUR suggested cut candidate when
  // your team is over the limit; a league-wide candidate for everyone else.
  const candidates = heroState.cutWatchProps.overLimitTeams.flatMap((team) =>
    team.cutCandidates.map((c) => ({ playerId: c.playerId, franchiseId: team.franchiseId })),
  );
  cutWatchModel = castRosterModel(candidates, hpPlayerIdentityMap, userFranchiseId, now, 'On the Bubble');
}
let preseasonModel = null;
let preseasonModelIsOwn = false;
let kickoffGame = null;
if (heroState.phase === 'preseason-countdown' && heroState.preseasonProps) {
  // Preseason hero: a likely starter in the earliest game of the week (the
  // season opener), rotating daily. Signed-in owners with a player in that
  // game see one of their own likely starters in it instead.
  kickoffGame = getKickoffGame(leagueYear);
  const candidates = getKickoffGameCandidates(leagueYear);
  preseasonModel = castRandomStarterModel(candidates, hpPlayerIdentityMap, userFranchiseId, now, 'Kickoff Night');
  preseasonModelIsOwn =
    !!preseasonModel &&
    !!userFranchiseId &&
    candidates.some((c) => c.franchiseId === userFranchiseId && c.playerId === preseasonModel!.mflId);
  // No opener data (schedule feed missing) → fall back to franchise headliners.
  if (!preseasonModel) {
    const headliners = getFranchiseHeadliners(leagueYear);
    preseasonModel = castRosterModel(headliners, hpPlayerIdentityMap, userFranchiseId, now, 'Headliner');
    preseasonModelIsOwn =
      !!preseasonModel &&
      !!userFranchiseId &&
      headliners.some((h) => h.franchiseId === userFranchiseId && h.playerId === preseasonModel!.mflId);
  }
}

const teamSummaries = computeLeagueSummary(salaryPlayers, rawAdjustments, draftCapitalMap, teamConfigs);
const activeRosterCount = userFranchiseId
  ? salaryPlayers.filter(p => p.franchiseId === userFranchiseId && p.status !== 'INJURED_RESERVE' && p.status !== 'TAXI_SQUAD' && parseNumber(p.contractYear) > 0).length
  : 0;
const userRosterPlayers: RosterPlayer[] = userFranchiseId
  ? salaryPlayers
    .filter((player) => player.franchiseId === userFranchiseId)
    .map((player) => ({
      id: player.id,
      salary: String(player.salary),
      contractYear: player.contractYear,
      contractInfo: player.contractInfo ?? '',
      status: player.status,
    }))
  : [];
const unsignedFaAlerts = resolveUnsignedFaAlerts({
  franchiseId: userFranchiseId,
  rosterPlayers: userRosterPlayers,
  rawTransactions,
  playersMap: eligibilityPlayersById,
  playerContextById: playerDisplayById,
  currentYear: parseInt(currentSalaryYear, 10),
  referenceDate: now,
});

// Active auctions card — only fetch when the card is eligible to show OR the
// auction hero is active (the live hero features the soonest-closing bid).
// Avoids hitting MFL year-round on every homepage render.
const activeAuctions = showAuctionsCard || isAuctionHeroActive
  ? await loadActiveAuctions({
      year: leagueYear,
      leagueId: mflLeagueId,
      playerMap: hpPlayerIdentityMap,
      playerExtras: playerExtrasById,
      teams: (leagueConfig.teams ?? []) as any[],
    })
  : [];

// Live auction hero: the player whose bid clock runs out first replaces the
// ADP best-available model, and the caption carries the high bid.
let auctionClosingBid = null;
if (isAuctionHeroActive && activeAuctions.length > 0) {
  const closingModel = castClosingAuctionModel(activeAuctions, hpPlayerIdentityMap);
  if (closingModel) {
    const row = activeAuctions.find((a) => a.playerId === closingModel.mflId);
    auctionModel = closingModel;
    auctionClosingBid = row
      ? { bid: row.bid, franchiseName: row.franchiseName, endsAtMs: (row.anchorTimestamp + 36 * 3600) * 1000 }
      : null;
  }
}

// Fetch live scoring data when slot is 'live-scoring'
let liveScoring: {
  week: number;
  userFranchiseId?: string;
  matchups: MatchupPairing[];
  teams: Record<string, TeamInfo>;
  initialScores?: Record<string, number>;
  initialRemaining?: Record<string, number>;
} | undefined;

if (heroState.slot === 'live-scoring' && heroState.metadata.week) {
  try {
    const liveUrl = new URL(`/api/live-scoring?week=${heroState.metadata.week}`, Astro.url);
    const liveRes = await fetch(liveUrl);
    const liveData = liveRes.ok ? await liveRes.json() : null;

    // Build teams map from config
    const teamsMap: Record<string, TeamInfo> = {};
    for (const t of allTeams) {
      teamsMap[t.franchiseId] = {
        franchiseId: t.franchiseId,
        name: t.name,
        nameMedium: t.nameMedium,
        nameShort: t.nameShort,
        abbrev: t.abbrev,
        color: t.color ?? '',
        icon: t.icon,
      };
    }

    liveScoring = {
      week: heroState.metadata.week,
      userFranchiseId,
      matchups: liveData?.matchups ?? [],
      teams: teamsMap,
      initialScores: liveData?.scores,
      initialRemaining: liveData?.remaining,
    };
  } catch { /* live scoring is best-effort */ }
}

// Fetch playoff bracket data when slot is 'standings' during the playoff rounds
// (Weeks 15-16) or championship week (Week 17). The round hero picks the live
// round from bracket completion; the legacy bracket list is the fallback.
if ((heroState.phase === 'playoffs' || heroState.phase === 'championship') && heroState.slot === 'standings') {
  try {
    const seasonYear = getCurrentSeasonYear();
    // Read the feeds from disk (not `await import`) so live feed updates aren't
    // masked by Vite's JSON module cache — matches the readJsonFile pattern used
    // across the hero-data helpers, and keeps dev + prod reading the same bytes.
    const feedData = JSON.parse(fs.readFileSync(`data/theleague/mfl-feeds/${seasonYear}/playoff-brackets.json`, 'utf8'));
    const champRaw = feedData?.brackets?.['1'];

    if (champRaw) {
      const champBracket = normalizePlayoffBracket(champRaw, { id: '1', name: 'Championship' });

      if (champBracket) {
        // Build standings + seed maps for resolving bracket references
        const standingsData = JSON.parse(fs.readFileSync(`data/theleague/mfl-feeds/${seasonYear}/standings.json`, 'utf8'));
        const franchiseList = standingsData?.leagueStandings?.franchise
          ? Array.isArray(standingsData.leagueStandings.franchise)
            ? standingsData.leagueStandings.franchise
            : [standingsData.leagueStandings.franchise]
          : [];

        // Build asset map from config
        const assetMap = new Map<string, { icon?: string; banner?: string; aliases?: string[]; name?: string }>();
        for (const t of allTeams) {
          assetMap.set(t.franchiseId, {
            icon: t.icon,
            banner: t.banner,
            aliases: t.aliases,
            name: t.name,
          });
        }

        const seedMaps = buildSeedMaps(franchiseList, assetMap);

        // Build all-teams map for name resolution
        const allTeamsMap = new Map<string, { name: string; icon?: string }>();
        for (const t of allTeams) {
          allTeamsMap.set(t.franchiseId, { name: t.name, icon: t.icon });
        }

        const bracketSummary = buildBracketSummary(champBracket, seedMaps, allTeamsMap);
        const userEliminated = userFranchiseId
          ? isEliminated(userFranchiseId, champBracket)
          : undefined;

        // Resolve the live round to the composite round-hero shape (wild card /
        // semifinals / championship). Falls back to the bracket list if null.
        let roundView = null;
        try {
          const teamAssets = new Map(
            allTeams.map((t: any) => [
              t.franchiseId,
              { name: t.name, nameMedium: t.nameMedium, nameShort: t.nameShort, abbrev: t.abbrev },
            ]),
          );
          roundView = buildPlayoffRoundView({
            seasonYear,
            bracketSummary,
            standingsFranchises: franchiseList,
            teamAssets,
            userFranchiseId,
            currentWeek: heroState.metadata.week,
          });
        } catch { /* round view is optional — falls back to bracket list */ }

        heroState.playoffProps = {
          leagueYear: seasonYear,
          userFranchiseId,
          userIsEliminated: userEliminated,
          bracketSummary,
          roundView,
        };
      }
    }
  } catch { /* bracket data is best-effort */ }
}
