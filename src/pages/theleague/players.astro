---
/**
 * Free Agents Page - Player research tool focused on available players
 *
 * Displays free agents (and optionally rostered players) with sorting by:
 * - Projected Points, Age, Name
 *
 * Data is loaded at build time from MFL feed JSON files.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import PlayerDetailsModal from '../../components/theleague/PlayerDetailsModal.astro';
import { resolveLeaguePath } from '../../utils/nav-utils';
import { positionOrder } from '../../constants/roster-constants';
import { getCurrentLeagueYear, getCurrentSeasonYear } from '../../utils/league-year';
import { getPlayerMap } from '../../utils/player-map';
import { getNthDayOfMonth } from '../../utils/league-event-resolver';
import { buildWeeklyPlayerResults } from '../../utils/weekly-player-results';
import { getFrozenSalaryAveragesYear } from '../../utils/salary-calculations';
import { calculateAllSurplusValues } from '../../utils/surplus-value';
import { getAuthUser, isCommissionerOrAdmin } from '../../utils/auth';
import '../../styles/player-cell.css';
import collegeLogos from '../../data/college-logos.json';
import espnCollegeIds from '../../../data/theleague/espn-college-ids.json';
import leagueConfig from '../../data/theleague.config.json';

// Build franchise ID → short name map for auction high-bidder display
const franchiseNameEntries: [string, string][] = ((leagueConfig as any).teams ?? []).map((t: any) => [
  t.franchiseId,
  t.nameShort || t.nameMedium || t.name || t.franchiseId,
]);
const franchiseNamesJson = JSON.stringify(franchiseNameEntries);

// Build franchise ID → banner URL map for auction bidder column
const franchiseBannerEntries: [string, string][] = ((leagueConfig as any).teams ?? [])
  .filter((t: any) => t.banner)
  .map((t: any) => [t.franchiseId, t.banner]);
const franchiseBannersJson = JSON.stringify(franchiseBannerEntries);

// College logo lookup (case-insensitive)
const collegeLogosNormalized = Object.fromEntries(
  Object.entries(collegeLogos ?? {}).map(([name, data]) => [name.toLowerCase(), data])
);
function getCollegeLogo(collegeName: string | null): string | null {
  if (!collegeName) return null;
  const entry = collegeLogosNormalized[collegeName.toLowerCase()];
  return (entry as any)?.logo ?? null;
}

// MFL team code → local SVG filename normalization
const MFL_TEAM_CODE_MAP: Record<string, string> = {
  GBP: 'GB', KCC: 'KC', NEP: 'NE', NOS: 'NO',
  SFO: 'SF', TBB: 'TB', LVR: 'LV', HST: 'HOU',
  BLT: 'BAL', CLV: 'CLE', ARZ: 'ARI', JAC: 'JAX',
};
function normalizeMflTeam(code: string): string {
  if (!code) return 'FA';
  return MFL_TEAM_CODE_MAP[code] || code;
}

// Load player data
const currentYear = getCurrentLeagueYear();
const playerModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/players.json',
  { eager: true }
);
const projectedScoresModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/projectedScores.json',
  { eager: true }
);
const rostersModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/rosters.json',
  { eager: true }
);

const adpDynastyModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/adp-dynasty.json',
  { eager: true }
);
const adpRedraftModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/adp-redraft.json',
  { eager: true }
);
const lastYearWeeklyModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/weekly-results-raw.json',
  { eager: true }
);
const snapCountModules = import.meta.glob(
  '../../../data/theleague/nfl-cache/snap-counts-*.json',
  { eager: true }
);
const nflScheduleModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/nflSchedule.json',
  { eager: true }
);
const fpaModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/fantasyPointsAllowed.json',
  { eager: true }
);
const leagueModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/league.json',
  { eager: true }
);
const auctionResultsModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/auctionResults.json',
  { eager: true }
);
const salaryAvgModules = import.meta.glob(
  '../../data/mfl-salary-averages-*.json',
  { eager: true }
);
const playerSalaryHistoryModules = import.meta.glob(
  '../../data/mfl-player-salaries-*.json',
  { eager: true }
);

const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const findForYear = (modules: Record<string, any>, yr: number) => {
  const key = Object.keys(modules).find(k => k.includes(`/${yr}/`));
  return key ? getModuleData(modules[key]) : null;
};

const playersData = findForYear(playerModules, currentYear);
const projectedScoresData = findForYear(projectedScoresModules, currentYear);
const rostersData = findForYear(rostersModules, currentYear);

// ADP data — current year only (blank until MFL has data)
function buildAdpMap(modules: Record<string, any>): Map<string, number> {
  const data = findForYear(modules, currentYear);
  const map = new Map<string, number>();
  if (data?.adp?.player) {
    const players = Array.isArray(data.adp.player) ? data.adp.player : [data.adp.player];
    for (const p of players) {
      if (p?.id && p?.averagePick) {
        const pick = parseFloat(p.averagePick);
        if (pick > 0) map.set(p.id, pick);
      }
    }
  }
  return map;
}
const adpDynMap = buildAdpMap(adpDynastyModules);
const adpRdfMap = buildAdpMap(adpRedraftModules);

// Last year total points + games played (from weekly results)
const lastSeasonYear = getCurrentSeasonYear();
const lastYearData = findForYear(lastYearWeeklyModules, lastSeasonYear);
const lastYrPtsMap = new Map<string, number>();
const lastYrGamesMap = new Map<string, number>();
if (Array.isArray(lastYearData)) {
  for (const weekPayload of lastYearData) {
    const matchups = weekPayload?.weeklyResults?.matchup;
    if (!matchups) continue;
    const matchupArr = Array.isArray(matchups) ? matchups : [matchups];
    for (const m of matchupArr) {
      const franchises = m?.franchise ? (Array.isArray(m.franchise) ? m.franchise : [m.franchise]) : [];
      for (const f of franchises) {
        const players = f?.player ? (Array.isArray(f.player) ? f.player : [f.player]) : [];
        for (const p of players) {
          if (!p?.id || !p?.score) continue;
          const score = parseFloat(p.score);
          if (!isNaN(score) && score > 0) {
            lastYrPtsMap.set(p.id, (lastYrPtsMap.get(p.id) || 0) + score);
            lastYrGamesMap.set(p.id, (lastYrGamesMap.get(p.id) || 0) + 1);
          }
        }
      }
    }
  }
}

// Build weekly player results for the modal's Season Results table
const nflScheduleData = findForYear(nflScheduleModules, lastSeasonYear);
const fpaData = findForYear(fpaModules, lastSeasonYear);
const leagueData = findForYear(leagueModules, lastSeasonYear);
const playersDataForSeason = findForYear(playerModules, lastSeasonYear) || playersData;
const weeklyPlayerResults = (nflScheduleData && Array.isArray(lastYearData))
  ? buildWeeklyPlayerResults(lastYearData, nflScheduleData, fpaData, playersDataForSeason, leagueData)
  : {};

// Build snap count lookup (keyed by MFL player ID)
const snapCountMap = new Map<string, { snaps: number, pct: number, games: number }>();
{
  // Find the most recent snap count file
  const snapKeys = Object.keys(snapCountModules).sort().reverse();
  for (const key of snapKeys) {
    const data = getModuleData(snapCountModules[key]);
    if (data?.players) {
      for (const [mflId, stats] of Object.entries(data.players) as [string, any][]) {
        snapCountMap.set(mflId, {
          snaps: stats.offenseSnaps ?? 0,
          pct: stats.offensePct ?? 0,
          games: stats.gamesPlayed ?? 0,
        });
      }
      break; // Use only the most recent file
    }
  }
}
const hasSnapCounts = snapCountMap.size > 0;

// Build projected scores lookup
const projectedMap = new Map<string, number>();
if (projectedScoresData?.projectedScores?.playerScore) {
  const scores = Array.isArray(projectedScoresData.projectedScores.playerScore)
    ? projectedScoresData.projectedScores.playerScore
    : [projectedScoresData.projectedScores.playerScore];
  for (const s of scores) {
    if (s?.id && s?.score) {
      const score = parseFloat(s.score);
      if (score > 0) projectedMap.set(s.id, score);
    }
  }
}

// Build rostered player map with contract info
const rosteredPlayers = new Map<string, { salary: number | null; contractYrs: number | null }>();
if (rostersData?.rosters?.franchise) {
  const franchises = Array.isArray(rostersData.rosters.franchise)
    ? rostersData.rosters.franchise
    : [rostersData.rosters.franchise];
  for (const franchise of franchises) {
    const rosterPlayers = franchise?.player
      ? (Array.isArray(franchise.player) ? franchise.player : [franchise.player])
      : [];
    for (const p of rosterPlayers) {
      if (!p?.id) continue;
      const salary = p.salary ? parseFloat(p.salary) : null;
      const contractYrs = p.contractYear ? parseInt(p.contractYear, 10) : null;
      rosteredPlayers.set(p.id, {
        salary: salary && salary > 0 ? salary : null,
        contractYrs: contractYrs && contractYrs > 0 ? contractYrs : null,
      });
    }
  }
}

// Build surplus value lookup (same pattern as trade-builder.astro)
const surplusMap = new Map<string, { dollarValue: number; estimatedCost: number; surplusValue: number }>();
{
  // Resolve frozen salary averages year
  const salaryAvgYear = String(getFrozenSalaryAveragesYear(salaryAvgModules, getModuleData));
  let salaryAvgData: any = null;
  for (const [path, mod] of Object.entries(salaryAvgModules)) {
    if (path.includes(salaryAvgYear)) {
      salaryAvgData = getModuleData(mod);
      break;
    }
  }
  if (!salaryAvgData) {
    const keys = Object.keys(salaryAvgModules).sort().reverse();
    if (keys.length > 0) salaryAvgData = getModuleData(salaryAvgModules[keys[0]]);
  }

  // Build input arrays for the surplus calculator
  const projScoresArray: Array<{ id: string; score: string }> = [];
  if (projectedScoresData?.projectedScores?.playerScore) {
    const scores = Array.isArray(projectedScoresData.projectedScores.playerScore)
      ? projectedScoresData.projectedScores.playerScore
      : [projectedScoresData.projectedScores.playerScore];
    for (const s of scores) {
      if (s?.id && s?.score) projScoresArray.push({ id: s.id, score: s.score });
    }
  }

  const rawPlayersList = playersData?.players?.player;
  const playersArray: Array<{ id: string; name: string; position: string; team: string; birthdate?: string; draftYear?: number }> = [];
  if (Array.isArray(rawPlayersList)) {
    for (const p of rawPlayersList) {
      if (!p?.id || !p?.name || !p?.position) continue;
      const draftYear = p.draft_year ? parseInt(p.draft_year, 10) : undefined;
      playersArray.push({
        id: p.id,
        name: p.name,
        position: p.position === 'Def' ? 'DEF' : p.position,
        team: p.team || '',
        birthdate: p.birthdate,
        draftYear: Number.isFinite(draftYear) ? draftYear : undefined,
      });
    }
  }

  const rostersArray: Array<{ id: string; player: Array<{ id: string; salary: string; contractYear: string; status: string }> }> = [];
  if (rostersData?.rosters?.franchise) {
    const franchises = Array.isArray(rostersData.rosters.franchise)
      ? rostersData.rosters.franchise
      : [rostersData.rosters.franchise];
    for (const f of franchises) {
      const fPlayers = f?.player ? (Array.isArray(f.player) ? f.player : [f.player]) : [];
      rostersArray.push({
        id: f.id,
        player: fPlayers.map((rp: any) => ({
          id: rp.id,
          salary: rp.salary ?? '0',
          contractYear: rp.contractYear ?? '0',
          status: rp.status ?? 'ROSTER',
        })),
      });
    }
  }

  if (projScoresArray.length > 0 && salaryAvgData) {
    const surplusResults = calculateAllSurplusValues({
      leagueYear: currentYear,
      projectedScores: projScoresArray,
      players: playersArray,
      rosters: rostersArray,
      salaryAverages: salaryAvgData,
      adpDynasty: adpDynMap,
    });
    for (const r of surplusResults) {
      surplusMap.set(r.playerId, {
        dollarValue: r.dollarValue,
        estimatedCost: r.estimatedCost,
        surplusValue: r.surplusValue,
      });
    }
  }
}
const hasSurplusData = surplusMap.size > 0;

// Build auction results lookup (seed from build-time data, updated by polling)
const auctionMap = new Map<string, { bid: number; franchise: string; status: string }>();
{
  const auctionData = findForYear(auctionResultsModules, currentYear);
  const auctionUnit = auctionData?.auctionResults?.auctionUnit;
  if (auctionUnit?.auction) {
    const auctionList = Array.isArray(auctionUnit.auction)
      ? auctionUnit.auction
      : [auctionUnit.auction];
    for (const a of auctionList) {
      if (a?.player && a?.winningBid) {
        auctionMap.set(a.player, {
          bid: parseInt(a.winningBid, 10),
          franchise: a.franchise || '',
          status: 'won',
        });
      }
    }
  }
}
const hasAuctionData = auctionMap.size > 0;

// Auction season: 3rd Thursday of March through 3rd Sunday of August
const auctionStart = getNthDayOfMonth(currentYear, 2, 4, 3); // 3rd Thursday of March (month 2 = March)
const auctionEnd = getNthDayOfMonth(currentYear, 7, 0, 3);   // 3rd Sunday of August (month 7 = August)
auctionEnd.setHours(20, 45, 0, 0); // 8:45 PM PT close
const isAuctionSeason = Date.now() >= auctionStart.getTime() && Date.now() < auctionEnd.getTime();

// Player salary by each of the last 3 completed league years.
const salaryYear1 = currentYear - 1;
const salaryYear2 = currentYear - 2;
const salaryYear3 = currentYear - 3;
const recentSalaryYears = [salaryYear1, salaryYear2, salaryYear3].filter((y) => y > 0);
const recentSalaryYearSet = new Set(recentSalaryYears);
const historicalSalaryByYearMap = new Map<string, Record<number, number>>();
{
  for (const [path, mod] of Object.entries(playerSalaryHistoryModules)) {
    const yearMatch = path.match(/mfl-player-salaries-(\d{4})\.json$/);
    const fileYear = yearMatch ? parseInt(yearMatch[1], 10) : NaN;
    if (!Number.isFinite(fileYear) || !recentSalaryYearSet.has(fileYear)) continue;

    const data = getModuleData(mod);
    const players = Array.isArray(data?.players) ? data.players : [];
    for (const p of players) {
      if (!p?.id) continue;
      const salary = parseFloat(String(p.salary ?? 0));
      if (!Number.isFinite(salary) || salary <= 0) continue;
      const entry = historicalSalaryByYearMap.get(p.id) ?? {};
      entry[fileYear] = salary;
      historicalSalaryByYearMap.set(p.id, entry);
    }
  }
}

// Relevant positions for fantasy
const fantasyPositions = new Set(['QB', 'RB', 'WR', 'TE', 'PK', 'Def', 'DEF']);

// Build combined player list
interface PlayerRow {
  id: string;
  name: string;
  position: string;
  team: string;
  age: number | null;
  espnId: string | null;
  projected: number | null;
  rostered: boolean;
  exp: number | null;
  draftRd: number | null;
  college: string | null;
  collegeLogo: string | null;
  htWt: string | null;
  height: number | null;
  weight: number | null;
  adpDyn: number | null;
  adpRdf: number | null;
  lastYrPts: number | null;
  snaps: number | null;
  snapPct: number | null;
  rookie: boolean;
  birthdate: number | null;
  jersey: string | null;
  draftYear: number | null;
  draftTeam: string | null;
  draftPick: number | null;
  salary: number | null;
  contractYrs: number | null;
  games: number | null;
  ppg: number | null;
  salaryYear1: number | null;
  salaryYear2: number | null;
  salaryYear3: number | null;
  dollarValue: number | null;
  estimatedCost: number | null;
  surplusValue: number | null;
  auctionBid: number | null;
  auctionStatus: string | null;
  auctionBidTime: number | null;
  auctionFranchise: string | null;
  auctionInitTime: number | null;
}

const allPlayers = playersData?.players?.player;
const playerList: PlayerRow[] = [];
const playerIdentityMap = getPlayerMap(currentYear);

if (Array.isArray(allPlayers)) {
  const now = Date.now() / 1000;
  for (const p of allPlayers) {
    if (!p?.id || !p?.name || !p?.position) continue;
    if (!fantasyPositions.has(p.position)) continue;

    const projected = projectedMap.get(p.id) ?? null;
    const isRostered = rosteredPlayers.has(p.id);
    const rosterInfo = rosteredPlayers.get(p.id);

    // Skip only players with zero data relevance (no projections, not rostered, no NFL team)
    // This filters out practice squad/obscure players while keeping real NFL free agents

    let age: number | null = null;
    if (p.birthdate) {
      const birthTimestamp = parseInt(p.birthdate, 10);
      if (birthTimestamp > 0) {
        age = Math.floor((now - birthTimestamp) / (365.25 * 24 * 60 * 60));
      }
    }

    const identity = playerIdentityMap.get(p.id);
    const pos = identity?.position ?? (p.position === 'Def' ? 'DEF' : p.position);
    const displayName = identity?.name ?? (() => {
      const nameParts = p.name.split(', ');
      return nameParts.length === 2 ? `${nameParts[1]} ${nameParts[0]}` : p.name;
    })();

    // Experience (years in NFL)
    const draftYr = p.draft_year ? parseInt(p.draft_year, 10) : null;
    const exp = draftYr && draftYr > 0 ? currentYear - draftYr : null;

    // Draft round
    const draftRd = p.draft_round ? parseInt(p.draft_round, 10) : null;

    // Height/Weight formatting
    let htWt: string | null = null;
    let heightInches: number | null = null;
    let weightLbs: number | null = null;
    if (p.height) {
      const inches = parseInt(p.height, 10);
      if (inches > 0) {
        heightInches = inches;
        const ft = Math.floor(inches / 12);
        const rem = inches % 12;
        htWt = `${ft}'${rem}"`;
        if (p.weight) {
          weightLbs = parseInt(p.weight, 10) || null;
          htWt += ` ${p.weight}`;
        }
      }
    }

    playerList.push({
      id: p.id,
      name: displayName,
      position: pos,
      team: identity?.nflTeam ?? normalizeMflTeam(p.team || ''),
      age: pos === 'DEF' ? 25 : age,
      espnId: identity?.espnId ?? (p.espn_id || (espnCollegeIds as any).players?.[p.id]?.espnCollegeId || null),
      projected,
      rostered: isRostered,
      exp: pos === 'DEF' ? 5 : exp,
      draftRd: (draftRd && draftRd > 0) ? draftRd : null,
      college: p.college || null,
      collegeLogo: getCollegeLogo(p.college),
      htWt,
      height: heightInches,
      weight: weightLbs,
      adpDyn: adpDynMap.get(p.id) ?? null,
      adpRdf: adpRdfMap.get(p.id) ?? null,
      lastYrPts: lastYrPtsMap.has(p.id) ? Math.round((lastYrPtsMap.get(p.id)!) * 10) / 10 : null,
      snaps: snapCountMap.has(p.id) ? snapCountMap.get(p.id)!.snaps : null,
      snapPct: snapCountMap.has(p.id) ? snapCountMap.get(p.id)!.pct : null,
      games: lastYrGamesMap.get(p.id) ?? null,
      rookie: p.status === 'R',
      birthdate: p.birthdate ? parseInt(p.birthdate, 10) : null,
      jersey: p.jersey || null,
      draftYear: draftYr,
      draftTeam: p.draft_team || null,
      draftPick: p.draft_pick ? parseInt(p.draft_pick, 10) : null,
      salary: rosterInfo?.salary ?? null,
      contractYrs: rosterInfo?.contractYrs ?? null,
      ppg: (() => {
        const pts = lastYrPtsMap.get(p.id);
        const gp = lastYrGamesMap.get(p.id);
        return (pts && gp && gp > 0) ? Math.round((pts / gp) * 10) / 10 : null;
      })(),
      salaryYear1: historicalSalaryByYearMap.get(p.id)?.[salaryYear1] ?? null,
      salaryYear2: historicalSalaryByYearMap.get(p.id)?.[salaryYear2] ?? null,
      salaryYear3: historicalSalaryByYearMap.get(p.id)?.[salaryYear3] ?? null,
      dollarValue: surplusMap.get(p.id)?.dollarValue ?? null,
      estimatedCost: surplusMap.get(p.id)?.estimatedCost ?? null,
      surplusValue: surplusMap.get(p.id)?.surplusValue ?? null,
      auctionBid: auctionMap.get(p.id)?.bid ?? null,
      auctionStatus: auctionMap.get(p.id)?.status ?? null,
      auctionBidTime: null,
      auctionFranchise: auctionMap.get(p.id)?.franchise ?? null,
      auctionInitTime: null,
    });
  }
}

// Default sort by projected points (highest first)
playerList.sort((a, b) => {
  const aVal = a.projected ?? -1;
  const bVal = b.projected ?? -1;
  return bVal - aVal;
});

const hasProjected = projectedMap.size > 0;
const hasLastYrPts = lastYrPtsMap.size > 0;

// Count free agents by position for category tabs
const freeAgents = playerList.filter(p => !p.rostered);
const faCounts: Record<string, number> = { ALL: freeAgents.length };
for (const p of freeAgents) {
  faCounts[p.position] = (faCounts[p.position] || 0) + 1;
}

// Build unique NFL teams list for team filter dropdown
const nflTeamsSet = new Set<string>();
for (const p of playerList) {
  if (p.team && p.team !== 'FA') nflTeamsSet.add(p.team);
}
const nflTeamsList = [...nflTeamsSet].sort();

const playerDataJson = JSON.stringify(playerList);
const faCountsJson = JSON.stringify(faCounts);
const nflTeamsJson = JSON.stringify(nflTeamsList);

// Admin gate: Value view is only visible to admin franchises (same auth as nav sidebar)
const authUser = getAuthUser(Astro.request);
const isAdmin = !!authUser && isCommissionerOrAdmin(authUser);

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
---

<TheLeagueLayout title="Free Agents | TheLeague">
  <div class="players-page">
    <!-- Dark Gradient Hero -->
    <div class="players-hero">
      <div class="hero-players-bg" aria-hidden="true">
        <img data-hero-pool data-pos="50% 67%" alt="" class="hero-player-img" data-src="/assets/hero-players/hawks.webp" />
        <img data-hero-pool data-pos="50% 30%" alt="" class="hero-player-img" data-src="/assets/hero-players/puka.webp" />
        <img data-hero-pool data-pos="50% 0%" alt="" class="hero-player-img" data-src="/assets/hero-players/maye.webp" />
        <img data-hero-pool data-pos="70% 10%" alt="" class="hero-player-img" data-src="/assets/hero-players/jefferson.webp" />
        <img data-hero-pool data-pos="50% 20%" alt="" class="hero-player-img" data-src="/assets/hero-players/bijan.webp" />
        <img data-hero-pool data-pos="50% 15%" alt="" class="hero-player-img" data-src="/assets/hero-players/breece.webp" />
        <img data-hero-pool data-pos="50% 20%" alt="" class="hero-player-img" data-src="/assets/hero-players/sam.webp" />
        <img data-hero-pool data-pos="50% 25%" alt="" class="hero-player-img" data-src="/assets/hero-players/lamar.webp" />
        <img data-hero-pool data-pos="50% 15%" alt="" class="hero-player-img" data-src="/assets/hero-players/josh.webp" />
        <img data-hero-pool data-pos="50% 25%" alt="" class="hero-player-img" data-src="/assets/hero-players/pat.webp" />
      </div>
      <script is:inline>
        (function() {
          var imgs = Array.from(document.querySelectorAll('[data-hero-pool]'));
          // Shuffle and pick 3
          for (var i = imgs.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var t = imgs[i]; imgs[i] = imgs[j]; imgs[j] = t;
          }
          var picked = imgs.slice(0, 3);
          var rest = imgs.slice(3);
          rest.forEach(function(img) { img.remove(); });
          picked.forEach(function(img, i) {
            img.src = img.getAttribute('data-src');
            img.style.animationDelay = (i * 10) + 's';
            var pos = img.getAttribute('data-pos');
            if (pos) img.style.objectPosition = pos;
          });
        })();
      </script>
