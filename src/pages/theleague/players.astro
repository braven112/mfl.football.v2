---
/**
 * Free Agents Page - Player research tool focused on available players
 *
 * Displays free agents (and optionally rostered players) with sorting by:
 * - Projected Points, Age, Name
 *
 * Data is loaded at build time from MFL feed JSON files.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import PlayerDetailsModal from '../../components/theleague/PlayerDetailsModal.astro';
import { positionOrder } from '../../constants/roster-constants';
import { getCurrentLeagueYear, getCurrentSeasonYear } from '../../utils/league-year';

// MFL team code → local SVG filename normalization
const MFL_TEAM_CODE_MAP: Record<string, string> = {
  GBP: 'GB', KCC: 'KC', NEP: 'NE', NOS: 'NO',
  SFO: 'SF', TBB: 'TB', LVR: 'LV', HST: 'HOU',
  BLT: 'BAL', CLV: 'CLE', ARZ: 'ARI', JAC: 'JAX',
};
function normalizeMflTeam(code: string): string {
  if (!code) return 'FA';
  return MFL_TEAM_CODE_MAP[code] || code;
}

// Load player data
const currentYear = getCurrentLeagueYear();
const playerModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/players.json',
  { eager: true }
);
const projectedScoresModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/projectedScores.json',
  { eager: true }
);
const rostersModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/rosters.json',
  { eager: true }
);

const adpDynastyModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/adp-dynasty.json',
  { eager: true }
);
const adpRedraftModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/adp-redraft.json',
  { eager: true }
);
const lastYearWeeklyModules = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/weekly-results-raw.json',
  { eager: true }
);
const snapCountModules = import.meta.glob(
  '../../../data/theleague/nfl-cache/snap-counts-*.json',
  { eager: true }
);

const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const findForYear = (modules: Record<string, any>, yr: number) => {
  const key = Object.keys(modules).find(k => k.includes(`/${yr}/`));
  return key ? getModuleData(modules[key]) : null;
};

const playersData = findForYear(playerModules, currentYear);
const projectedScoresData = findForYear(projectedScoresModules, currentYear);
const rostersData = findForYear(rostersModules, currentYear);

// ADP data — current year only (blank until MFL has data)
function buildAdpMap(modules: Record<string, any>): Map<string, number> {
  const data = findForYear(modules, currentYear);
  const map = new Map<string, number>();
  if (data?.adp?.player) {
    const players = Array.isArray(data.adp.player) ? data.adp.player : [data.adp.player];
    for (const p of players) {
      if (p?.id && p?.averagePick) {
        const pick = parseFloat(p.averagePick);
        if (pick > 0) map.set(p.id, pick);
      }
    }
  }
  return map;
}
const adpDynMap = buildAdpMap(adpDynastyModules);
const adpRdfMap = buildAdpMap(adpRedraftModules);

// Last year total points (from weekly results)
const lastSeasonYear = getCurrentSeasonYear();
const lastYearData = findForYear(lastYearWeeklyModules, lastSeasonYear);
const lastYrPtsMap = new Map<string, number>();
if (Array.isArray(lastYearData)) {
  for (const weekPayload of lastYearData) {
    const matchups = weekPayload?.weeklyResults?.matchup;
    if (!matchups) continue;
    const matchupArr = Array.isArray(matchups) ? matchups : [matchups];
    for (const m of matchupArr) {
      const franchises = m?.franchise ? (Array.isArray(m.franchise) ? m.franchise : [m.franchise]) : [];
      for (const f of franchises) {
        const players = f?.player ? (Array.isArray(f.player) ? f.player : [f.player]) : [];
        for (const p of players) {
          if (!p?.id || !p?.score) continue;
          const score = parseFloat(p.score);
          if (!isNaN(score)) {
            lastYrPtsMap.set(p.id, (lastYrPtsMap.get(p.id) || 0) + score);
          }
        }
      }
    }
  }
}

// Build snap count lookup (keyed by MFL player ID)
const snapCountMap = new Map<string, { snaps: number, pct: number, games: number }>();
{
  // Find the most recent snap count file
  const snapKeys = Object.keys(snapCountModules).sort().reverse();
  for (const key of snapKeys) {
    const data = getModuleData(snapCountModules[key]);
    if (data?.players) {
      for (const [mflId, stats] of Object.entries(data.players) as [string, any][]) {
        snapCountMap.set(mflId, {
          snaps: stats.offenseSnaps ?? 0,
          pct: stats.offensePct ?? 0,
          games: stats.gamesPlayed ?? 0,
        });
      }
      break; // Use only the most recent file
    }
  }
}
const hasSnapCounts = snapCountMap.size > 0;

// Build projected scores lookup
const projectedMap = new Map<string, number>();
if (projectedScoresData?.projectedScores?.playerScore) {
  const scores = Array.isArray(projectedScoresData.projectedScores.playerScore)
    ? projectedScoresData.projectedScores.playerScore
    : [projectedScoresData.projectedScores.playerScore];
  for (const s of scores) {
    if (s?.id && s?.score) {
      const score = parseFloat(s.score);
      if (score > 0) projectedMap.set(s.id, score);
    }
  }
}

// Build rostered player set
const rosteredPlayers = new Set<string>();
if (rostersData?.rosters?.franchise) {
  const franchises = Array.isArray(rostersData.rosters.franchise)
    ? rostersData.rosters.franchise
    : [rostersData.rosters.franchise];
  for (const franchise of franchises) {
    const rosterPlayers = franchise?.player
      ? (Array.isArray(franchise.player) ? franchise.player : [franchise.player])
      : [];
    for (const p of rosterPlayers) {
      if (p?.id) rosteredPlayers.add(p.id);
    }
  }
}

// Relevant positions for fantasy
const fantasyPositions = new Set(['QB', 'RB', 'WR', 'TE', 'PK', 'Def', 'DEF']);

// Build combined player list
interface PlayerRow {
  id: string;
  name: string;
  position: string;
  team: string;
  age: number | null;
  espnId: string | null;
  projected: number | null;
  rostered: boolean;
  exp: number | null;
  draftRd: number | null;
  college: string | null;
  htWt: string | null;
  height: number | null;
  weight: number | null;
  adpDyn: number | null;
  adpRdf: number | null;
  lastYrPts: number | null;
  snaps: number | null;
  snapPct: number | null;
  rookie: boolean;
  birthdate: number | null;
  jersey: string | null;
  draftYear: number | null;
  draftTeam: string | null;
  draftPick: number | null;
}

const allPlayers = playersData?.players?.player;
const playerList: PlayerRow[] = [];

if (Array.isArray(allPlayers)) {
  const now = Date.now() / 1000;
  for (const p of allPlayers) {
    if (!p?.id || !p?.name || !p?.position) continue;
    if (!fantasyPositions.has(p.position)) continue;

    const projected = projectedMap.get(p.id) ?? null;
    const isRostered = rosteredPlayers.has(p.id);

    // Skip only players with zero data relevance (no projections, not rostered, no NFL team)
    // This filters out practice squad/obscure players while keeping real NFL free agents

    let age: number | null = null;
    if (p.birthdate) {
      const birthTimestamp = parseInt(p.birthdate, 10);
      if (birthTimestamp > 0) {
        age = Math.floor((now - birthTimestamp) / (365.25 * 24 * 60 * 60));
      }
    }

    const pos = p.position === 'Def' ? 'DEF' : p.position;
    const nameParts = p.name.split(', ');
    const displayName = nameParts.length === 2
      ? `${nameParts[1]} ${nameParts[0]}`
      : p.name;

    // Experience (years in NFL)
    const draftYr = p.draft_year ? parseInt(p.draft_year, 10) : null;
    const exp = draftYr && draftYr > 0 ? currentYear - draftYr : null;

    // Draft round
    const draftRd = p.draft_round ? parseInt(p.draft_round, 10) : null;

    // Height/Weight formatting
    let htWt: string | null = null;
    let heightInches: number | null = null;
    let weightLbs: number | null = null;
    if (p.height) {
      const inches = parseInt(p.height, 10);
      if (inches > 0) {
        heightInches = inches;
        const ft = Math.floor(inches / 12);
        const rem = inches % 12;
        htWt = `${ft}'${rem}"`;
        if (p.weight) {
          weightLbs = parseInt(p.weight, 10) || null;
          htWt += ` ${p.weight}`;
        }
      }
    }

    playerList.push({
      id: p.id,
      name: displayName,
      position: pos,
      team: normalizeMflTeam(p.team || ''),
      age: pos === 'DEF' ? 25 : age,
      espnId: p.espn_id || null,
      projected,
      rostered: isRostered,
      exp: pos === 'DEF' ? 5 : exp,
      draftRd: (draftRd && draftRd > 0) ? draftRd : null,
      college: p.college || null,
      htWt,
      height: heightInches,
      weight: weightLbs,
      adpDyn: adpDynMap.get(p.id) ?? null,
      adpRdf: adpRdfMap.get(p.id) ?? null,
      lastYrPts: lastYrPtsMap.has(p.id) ? Math.round((lastYrPtsMap.get(p.id)!) * 10) / 10 : null,
      snaps: snapCountMap.has(p.id) ? snapCountMap.get(p.id)!.snaps : null,
      snapPct: snapCountMap.has(p.id) ? snapCountMap.get(p.id)!.pct : null,
      rookie: p.status === 'R',
      birthdate: p.birthdate ? parseInt(p.birthdate, 10) : null,
      jersey: p.jersey || null,
      draftYear: draftYr,
      draftTeam: p.draft_team || null,
      draftPick: p.draft_pick ? parseInt(p.draft_pick, 10) : null,
    });
  }
}

// Default sort by projected points (highest first)
playerList.sort((a, b) => {
  const aVal = a.projected ?? -1;
  const bVal = b.projected ?? -1;
  return bVal - aVal;
});

const hasProjected = projectedMap.size > 0;
const hasLastYrPts = lastYrPtsMap.size > 0;

// Count free agents by position for category tabs
const freeAgents = playerList.filter(p => !p.rostered);
const faCounts: Record<string, number> = { ALL: freeAgents.length };
for (const p of freeAgents) {
  faCounts[p.position] = (faCounts[p.position] || 0) + 1;
}

const playerDataJson = JSON.stringify(playerList);
const faCountsJson = JSON.stringify(faCounts);
---

<TheLeagueLayout title="Free Agents | TheLeague">
  <div class="players-page">
    <header class="page-header">
      <h1>Free Agents</h1>
      <p class="page-subtitle">
        {freeAgents.length} available players
      </p>
    </header>

    <!-- Category Tabs -->
    <nav class="category-tabs" id="category-tabs">
      <button class="cat-tab active" data-pos="ALL">
        All
        <span class="cat-count" id="count-ALL">{faCounts.ALL || 0}</span>
      </button>
      {positionOrder.map(pos => (
        <button
          class="cat-tab"
          data-pos={pos}
        >
          {pos === 'PK' ? 'K' : pos}
          <span class="cat-count" id={`count-${pos}`}>{faCounts[pos] || 0}</span>
        </button>
      ))}
    </nav>

    <!-- Search & Toggles -->
    <div class="toolbar">
      <input
        type="search"
        id="player-search"
        class="search-input"
        placeholder="Search players..."
        autocomplete="off"
      />
      <label class="roster-toggle">
        <input type="checkbox" id="show-rostered" />
        <span>Include rostered</span>
      </label>
      <label class="roster-toggle">
        <input type="checkbox" id="show-rookies" />
        <span>Include rookies</span>
      </label>
      <div class="col-group-toggles" id="col-group-toggles" role="group" aria-label="Show columns" style="display: none;">
        <span class="col-group-toggles__label">View:</span>
        <button class="col-group-btn active" data-group="stats" type="button" aria-pressed="true">Stats</button>
        <button class="col-group-btn" data-group="rankings" id="col-group-btn-rankings" type="button" aria-pressed="false">Rankings</button>
      </div>
    </div>

    <!-- Table Controls -->
    <div class="table-controls">
      <div class="showing-count">
        Showing <span id="showing-count">50</span> of <span id="total-players">0</span>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrapper">
      <table class="players-table" id="players-table">
        <thead>
          <tr>
            <th class="sortable col-rank" data-sort="rank">
              <div class="th-content">#</div>
            </th>
            <th class="sortable col-player" data-sort="name">
              <div class="th-content">Player</div>
            </th>
            <th class="sortable col-age" data-sort="age">
              <div class="th-content">Age</div>
            </th>
            <th class="sortable col-sm col-always-profile" data-sort="exp">
              <div class="th-content">Exp</div>
            </th>
            <th class="sortable col-sm col-always-profile" data-sort="draftRd">
              <div class="th-content">Draft</div>
            </th>
            <th class="sortable col-sm col-always-profile" data-sort="height">
              <div class="th-content">Ht</div>
            </th>
            <th class="sortable col-sm col-always-profile" data-sort="weight">
              <div class="th-content">Wt</div>
            </th>
            {hasSnapCounts && (
              <th class="sortable col-num col-group--stats" data-sort="snaps">
                <div class="th-content">Snaps</div>
              </th>
            )}
            {hasSnapCounts && (
              <th class="sortable col-num col-group--stats" data-sort="snapPct">
                <div class="th-content">Snap%</div>
              </th>
            )}
            {hasLastYrPts && (
              <th class="sortable col-num col-group--stats" data-sort="lastYrPts">
                <div class="th-content">Last Yr</div>
              </th>
            )}
            {hasProjected && (
              <th class="sortable col-num col-group--stats" data-sort="projected">
                <div class="th-content">Proj</div>
              </th>
            )}
          </tr>
        </thead>
        <tbody id="player-table-body"></tbody>
      </table>
    </div>

    <!-- Show More -->
    <div class="show-more-wrapper" id="show-more-wrapper">
      <button class="show-more-btn" id="show-more-btn">Show More</button>
    </div>

    <!-- No data -->
    <div class="no-data" id="no-data" style="display: none;">
      <p>No player data available yet.</p>
      <p>Run <code>node scripts/fetch-mfl-feeds.mjs</code> to fetch data.</p>
    </div>
  </div>
  <PlayerDetailsModal />
</TheLeagueLayout>

<script define:vars={{ playerDataJson, hasProjected, hasLastYrPts, hasSnapCounts, faCountsJson }}>
  const players = JSON.parse(playerDataJson);

  // State — default to free agents only
  let filteredPlayers = [];
  let currentSort = 'projected';
  let sortDirection = 'desc';
  let visibleCount = 50;
  let activePosition = 'ALL';
  let searchQuery = '';
  let showRostered = false;
  let showRookies = false;
  const BATCH_SIZE = 50;

  // Rankings lookup — populated by the rankings module script
  let rankingLookup = { byImport: new Map(), columns: [] };

  // Column group visibility — stats and rankings are mutually exclusive
  // 'stats' = show stats columns, 'rankings' = show ranking columns
  let activeView = 'stats';
  let hasRankingColumns = false;

  function loadViewPref() {
    try {
      const saved = localStorage.getItem('playersViewMode');
      if (saved === 'rankings' || saved === 'stats') activeView = saved;
    } catch (_) {}
  }

  function saveViewPref() {
    try {
      localStorage.setItem('playersViewMode', activeView);
    } catch (_) {}
  }

  function applyGroupVisibility() {
    const showStats = activeView === 'stats';
    const showRankings = activeView === 'rankings' && hasRankingColumns;

    document.querySelectorAll('.col-group--stats').forEach(el => {
      el.style.display = showStats ? '' : 'none';
    });
    document.querySelectorAll('.col-group--rankings').forEach(el => {
      el.style.display = showRankings ? '' : 'none';
    });

    // Update button active states
    for (const group of ['stats', 'rankings']) {
      const btn = document.querySelector(`.col-group-btn[data-group="${group}"]`);
      if (btn) {
        const isActive = group === activeView;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      }
    }

    // Show/hide the toggle bar — only visible when rankings are available
    const toggleBar = document.getElementById('col-group-toggles');
    if (toggleBar) {
      toggleBar.style.display = hasRankingColumns ? '' : 'none';
    }
  }

  function setActiveView(view) {
    activeView = view;
    saveViewPref();
    applyGroupVisibility();
  }

  loadViewPref();

  const posOrder = { QB: 1, RB: 2, WR: 3, TE: 4, PK: 5, DEF: 6 };


  function getHeadshotUrl(playerId, espnId) {
    if (espnId) {
      return `https://a.espncdn.com/combiner/i?img=/i/headshots/nfl/players/full/${espnId}.png&w=96&h=70&cb=1`;
    }
    return `https://www49.myfantasyleague.com/player_photos_big_2014/${playerId}_thumb.jpg`;
  }

  function getNflLogo(team) {
    if (!team || team === 'FA') return '/assets/nfl-logos/NFL.svg';
    return `/assets/nfl-logos/${team}.svg`;
  }

  const defaultHeadshot = 'https://www49.myfantasyleague.com/player_photos_2010/no_photo_available.jpg';

  function sortPlayers() {
    filteredPlayers.sort((a, b) => {
      let aVal, bVal;
      switch (currentSort) {
        case 'name':
          return sortDirection === 'asc'
            ? a.name.localeCompare(b.name)
            : b.name.localeCompare(a.name);
        case 'position':
          aVal = posOrder[a.position] || 99;
          bVal = posOrder[b.position] || 99;
          break;
        case 'team':
          return sortDirection === 'asc'
            ? a.team.localeCompare(b.team)
            : b.team.localeCompare(a.team);
        case 'age':
          aVal = a.age ?? 999;
          bVal = b.age ?? 999;
          break;
        case 'exp':
          aVal = a.exp ?? -1;
          bVal = b.exp ?? -1;
          break;
        case 'projected':
          aVal = a.projected ?? -1;
          bVal = b.projected ?? -1;
          break;
        case 'draftRd':
          aVal = a.draftRd ?? 99;
          bVal = b.draftRd ?? 99;
          break;
        case 'height':
          aVal = a.height ?? -1;
          bVal = b.height ?? -1;
          break;
        case 'weight':
          aVal = a.weight ?? -1;
          bVal = b.weight ?? -1;
          break;
        case 'lastYrPts':
          aVal = a.lastYrPts ?? -1;
          bVal = b.lastYrPts ?? -1;
          break;
        case 'snaps':
          aVal = a.snaps ?? -1;
          bVal = b.snaps ?? -1;
          break;
        case 'snapPct':
          aVal = a.snapPct ?? -1;
          bVal = b.snapPct ?? -1;
          break;
        default:
          // Dynamic ranking columns: sort key is "ranking_{importId}"
          if (currentSort.startsWith('ranking_')) {
            const importId = currentSort.slice(8); // skip "ranking_"
            const map = rankingLookup.byImport.get(importId);
            aVal = map?.get(a.id) ?? 9999;
            bVal = map?.get(b.id) ?? 9999;
          } else {
            aVal = a.projected ?? -1;
            bVal = b.projected ?? -1;
          }
      }
      const diff = aVal - bVal;
      return sortDirection === 'desc' ? -diff : diff;
    });
  }

  function filterPlayers() {
    const query = searchQuery.toLowerCase();
    filteredPlayers = players.filter(p => {
      // Free agent filter (default on)
      if (!showRostered && p.rostered) return false;

      // Rookie filter (default on)
      if (!showRookies && p.rookie) return false;

      // Position filter
      if (activePosition !== 'ALL' && p.position !== activePosition) return false;

      // Search
      if (query) {
        return p.name.toLowerCase().includes(query) ||
               p.team.toLowerCase().includes(query);
      }
      return true;
    });

    // Update category counts based on current filters + search
    const pool = players.filter(p => {
      if (!showRostered && p.rostered) return false;
      if (!showRookies && p.rookie) return false;
      if (query) {
        return p.name.toLowerCase().includes(query) ||
               p.team.toLowerCase().includes(query);
      }
      return true;
    });
    const counts = { ALL: pool.length };
    for (const p of pool) {
      counts[p.position] = (counts[p.position] || 0) + 1;
    }
    for (const pos of ['ALL', 'QB', 'RB', 'WR', 'TE', 'PK', 'DEF']) {
      const el = document.getElementById(`count-${pos}`);
      if (el) el.textContent = String(counts[pos] || 0);
    }

    sortPlayers();
    visibleCount = BATCH_SIZE;
    render();
  }

  function render() {
    const tbody = document.getElementById('player-table-body');
    if (!tbody) return;

    const total = filteredPlayers.length;
    const end = Math.min(visibleCount, total);
    const pageData = filteredPlayers.slice(0, end);

    // Update controls
    const showingCountEl = document.getElementById('showing-count');
    const totalEl = document.getElementById('total-players');
    const showMoreWrapper = document.getElementById('show-more-wrapper');

    if (showingCountEl) showingCountEl.textContent = String(end);
    if (totalEl) totalEl.textContent = String(total);
    if (showMoreWrapper) showMoreWrapper.style.display = end < total ? '' : 'none';

    let html = '';
    for (let i = 0; i < pageData.length; i++) {
      const p = pageData[i];
      const rank = i + 1;
      const isDef = p.position === 'DEF';
      const headshot = isDef ? getNflLogo(p.team) : getHeadshotUrl(p.id, p.espnId);
      const logo = getNflLogo(p.team);
      const posLabel = p.position === 'PK' ? 'K' : p.position;
      const rosteredClass = p.rostered ? ' row--rostered' : '';

      html += `<tr class="${rosteredClass}">
        <td class="cell-rank">${rank}</td>
        <td class="cell-player">
          <div class="p-row">
            <div class="p-row__avatar${isDef ? ' p-row__avatar--def' : ''}">
              <img src="${headshot}" alt="" loading="lazy" decoding="async"
                onerror="this.onerror=null;this.src='${defaultHeadshot}';" />
            </div>
            <div class="p-row__info">
              <span class="p-row__name" data-pid="${p.id}" data-espn="${p.espnId||''}" data-pname="${p.name}" data-pos="${p.position}" data-team="${p.team}" data-college="${p.college||''}" data-ht="${p.height||''}" data-wt="${p.weight||''}" data-jersey="${p.jersey||''}" data-bday="${p.birthdate||''}" data-exp="${p.exp!=null?p.exp:''}" data-dyr="${p.draftYear||''}" data-dtm="${p.draftTeam||''}" data-drd="${p.draftRd||''}" data-dpk="${p.draftPick||''}" data-proj="${p.projected!=null?p.projected:''}" data-snaps="${p.snaps!=null?p.snaps:''}" data-snappct="${p.snapPct!=null?p.snapPct:''}" data-lastyr="${p.lastYrPts!=null?p.lastYrPts:''}" data-adprdf="${p.adpRdf!=null?p.adpRdf:''}" data-adpdyn="${p.adpDyn!=null?p.adpDyn:''}">${p.name}${p.rostered ? '<span class="rostered-dot" title="Rostered"></span>' : ''}</span>
              <span class="p-row__meta">
                <img src="${logo}" alt="${p.team}" class="p-row__logo" /><span class="p-row__pos">${posLabel}</span>
              </span>
            </div>
          </div>
        </td>
        <td class="cell-age">${p.age ?? '-'}</td>
        <td class="cell-sm col-always-profile">${p.exp != null ? p.exp : '-'}</td>`;

      const htDisplay = p.height ? Math.floor(p.height / 12) + "'" + (p.height % 12) + '"' : '-';
      const wtDisplay = p.weight ? p.weight + '' : '-';
      html += `<td class="cell-sm col-always-profile">${p.draftRd != null ? 'Rd ' + p.draftRd : '<span class="na">-</span>'}</td>
        <td class="cell-sm col-always-profile">${htDisplay}</td>
        <td class="cell-sm col-always-profile">${wtDisplay}</td>`;

      // Dynamic ranking columns
      for (const col of rankingLookup.columns) {
        const rnk = rankingLookup.byImport.get(col.importId)?.get(p.id);
        html += `<td class="cell-num col-group--rankings">${rnk != null ? rnk : '<span class="na">-</span>'}</td>`;
      }

      if (hasSnapCounts) {
        html += `<td class="cell-num col-group--stats">${p.snaps != null ? p.snaps : '<span class="na">-</span>'}</td>`;
        html += `<td class="cell-num col-group--stats">${p.snapPct != null ? p.snapPct.toFixed(1) + '%' : '<span class="na">-</span>'}</td>`;
      }

      if (hasLastYrPts) {
        html += `<td class="cell-num col-group--stats">${p.lastYrPts != null ? p.lastYrPts.toFixed(1) : '<span class="na">-</span>'}</td>`;
      }

      if (hasProjected) {
        html += `<td class="cell-num cell-pts col-group--stats">${p.projected != null ? p.projected.toFixed(1) : '<span class="na">-</span>'}</td>`;
      }

      html += `</tr>`;
    }

    tbody.innerHTML = html;

    // Update sort indicators — only add arrow span to the actively sorted column
    document.querySelectorAll('.players-table th.sortable').forEach(th => {
      const content = th.querySelector('.th-content');
      const existingArrow = th.querySelector('.sort-arrow');
      const sortKey = th.getAttribute('data-sort');
      if (sortKey === currentSort) {
        th.classList.add('sorted');
        if (!existingArrow && content) {
          const arrow = document.createElement('span');
          arrow.className = 'sort-arrow';
          arrow.textContent = sortDirection === 'asc' ? '\u25B2' : '\u25BC';
          content.appendChild(arrow);
        } else if (existingArrow) {
          existingArrow.textContent = sortDirection === 'asc' ? '\u25B2' : '\u25BC';
        }
      } else {
        th.classList.remove('sorted');
        if (existingArrow) existingArrow.remove();
      }
    });

    const noDataEl = document.getElementById('no-data');
    if (noDataEl) {
      noDataEl.style.display = players.length === 0 ? 'block' : 'none';
    }

    // Re-apply column group visibility after tbody re-render
    applyGroupVisibility();
  }

  // Columns that default to desc when first clicked
  const descDefaults = new Set(['projected', 'exp', 'height', 'weight', 'lastYrPts', 'snaps', 'snapPct']);

  // CustomEvent-based API for the rankings module script to interact with this page.
  // All events use the document as the event bus — no global window properties needed.
  document.addEventListener('rankings:set-lookup', function (e) {
    rankingLookup = e.detail.lookup;
    hasRankingColumns = e.detail.hasColumns;
    // If rankings were removed and user was viewing them, switch back to stats
    if (!e.detail.hasColumns && activeView === 'rankings') {
      activeView = 'stats';
      saveViewPref();
    }
    applyGroupVisibility();
  });

  document.addEventListener('rankings:set-sort', function (e) {
    currentSort = e.detail.key;
    sortDirection = e.detail.dir;
  });

  document.addEventListener('rankings:refresh-table', function () {
    sortPlayers();
    render();
  });

  document.addEventListener('rankings:refilter', function () {
    filterPlayers();
  });

  // Synchronous request for sort state — the module script reads detail after dispatch
  document.addEventListener('rankings:get-sort', function (e) {
    e.detail.currentSort = currentSort;
    e.detail.descDefaults = descDefaults;
  });

  // Signal that the inline script is ready for the module script
  document.dispatchEvent(new CustomEvent('rankings:page-ready'));

  function init() {
    // Prevent duplicate listeners on re-init (Astro view transitions)
    const table = document.getElementById('players-table');
    if (!table || table.dataset.init) return;
    table.dataset.init = 'true';

    // Category tabs
    const tabsEl = document.getElementById('category-tabs');
    if (tabsEl) {
      tabsEl.addEventListener('click', (e) => {
        const tab = e.target.closest('.cat-tab');
        if (!tab) return;
        activePosition = tab.getAttribute('data-pos');
        tabsEl.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        filterPlayers();
      });
    }

    // Search
    const searchInput = document.getElementById('player-search');
    if (searchInput) {
      let debounceTimer;
      searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          searchQuery = e.target.value;
          filterPlayers();
        }, 200);
      });
    }

    // Include rostered toggle
    const rosterCheck = document.getElementById('show-rostered');
    if (rosterCheck) {
      rosterCheck.addEventListener('change', (e) => {
        showRostered = e.target.checked;
        filterPlayers();
      });
    }

    // Include rookies toggle
    const rookieCheck = document.getElementById('show-rookies');
    if (rookieCheck) {
      rookieCheck.addEventListener('change', (e) => {
        showRookies = e.target.checked;
        filterPlayers();
      });
    }

    // Sorting
    document.querySelectorAll('.players-table th.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const sortKey = th.getAttribute('data-sort');
        if (sortKey === currentSort) {
          sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort = sortKey;
          sortDirection = descDefaults.has(sortKey) ? 'desc' : 'asc';
        }
        sortPlayers();
        render();
      });
    });

    // Column group toggles — mutually exclusive stats vs rankings
    const colGroupToggles = document.getElementById('col-group-toggles');
    if (colGroupToggles) {
      colGroupToggles.addEventListener('click', (e) => {
        const btn = e.target.closest('.col-group-btn');
        if (!btn) return;
        const group = btn.getAttribute('data-group');
        if (!group) return;
        setActiveView(group);
      });
    }

    // Show More
    const showMoreBtn = document.getElementById('show-more-btn');
    if (showMoreBtn) {
      showMoreBtn.addEventListener('click', () => {
        visibleCount += BATCH_SIZE;
        render();
      });
    }

    // Player name click → open detail modal
    const tbody = document.getElementById('player-table-body');
    if (tbody) {
      tbody.addEventListener('click', (e) => {
        const nameEl = e.target.closest('.p-row__name');
        if (!nameEl || !window.openPlayerDetailsModal) return;

        const d = nameEl.dataset;
        const parseNum = (v) => v ? parseFloat(v) : null;
        const parseStr = (v) => v || null;

        window.openPlayerDetailsModal({
          id: d.pid,
          espnId: parseStr(d.espn),
          name: d.pname,
          position: d.pos,
          nflTeam: d.team,
          college: parseStr(d.college),
          height: parseNum(d.ht),
          weight: parseNum(d.wt),
          number: parseNum(d.jersey),
          birthdate: parseNum(d.bday),
          experience: parseNum(d.exp),
          draftYear: parseNum(d.dyr),
          draftTeam: parseStr(d.dtm),
          draftRound: parseNum(d.drd),
          draftPick: parseNum(d.dpk),
          points: parseNum(d.proj),
          salary: null,
          contractYears: null,
          totalRemaining: null,
          contractType: null,
          status: null,
          byeWeek: null,
          depthChartPosition: null,
          depthChartOrder: null,
          depthChartAhead: null,
          injuryStatus: null,
          injuryBodyPart: null,
          collegeLogo: null,
          franchiseId: null,
          rosterSlot: null,
          offenseSnaps: parseNum(d.snaps),
          defenseSnaps: null,
          stSnaps: null,
        });
      });
    }

    filterPlayers();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>

<!-- Rankings integration: dynamically injects ranking columns from localStorage imports -->
<script>
  import { buildRankingLookup, onRankingsChanged } from '../../utils/rankings-lookup';

  let unsubscribe: (() => void) | null = null;

  /** Dispatch a CustomEvent on document (synchronous). */
  function emit(name: string, detail?: Record<string, unknown>) {
    document.dispatchEvent(new CustomEvent(name, { detail: detail ?? {} }));
  }

  /** Read current sort state from the inline script via synchronous CustomEvent. */
  function getSortState(): { currentSort: string; descDefaults: Set<string> } {
    const detail: Record<string, unknown> = {};
    document.dispatchEvent(new CustomEvent('rankings:get-sort', { detail }));
    return {
      currentSort: detail.currentSort as string,
      descDefaults: detail.descDefaults as Set<string>,
    };
  }

  function injectRankingColumns() {
    const lookup = buildRankingLookup();

    // Tell the inline script about the new lookup and whether ranking columns exist
    emit('rankings:set-lookup', { lookup, hasColumns: lookup.columns.length > 0 });

    // Remove any previously injected ranking <th> elements
    document.querySelectorAll('.players-table th[data-ranking-col]').forEach(th => th.remove());

    if (lookup.columns.length === 0) {
      emit('rankings:refilter');
      return;
    }

    // Find the Wt header to insert ranking columns after it
    const headerRow = document.querySelector('.players-table thead tr');
    if (!headerRow) return;

    const anchorTh = headerRow.querySelector('[data-sort="weight"]');
    if (!anchorTh) return;

    // Insert ranking <th> elements in reverse order (so they end up in correct order after anchor)
    const columnsReversed = [...lookup.columns].reverse();
    for (const col of columnsReversed) {
      const th = document.createElement('th');
      th.className = 'sortable col-num col-group--rankings';
      th.dataset.sort = `ranking_${col.importId}`;
      th.dataset.rankingCol = 'true';
      th.title = `${col.fullName} (${col.playerCount} players)`;
      th.innerHTML = `<div class="th-content">${col.header}</div>`;

      // Sort click handler
      th.addEventListener('click', () => {
        const sortKey = `ranking_${col.importId}`;
        const { currentSort } = getSortState();
        if (sortKey === currentSort) {
          // Toggle direction — check current arrow to determine state
          const arrow = th.querySelector('.sort-arrow');
          const wasAsc = arrow && arrow.textContent === '\u25B2';
          emit('rankings:set-sort', { key: sortKey, dir: wasAsc ? 'desc' : 'asc' });
        } else {
          // Ranking columns default to ascending (rank 1 = best at top)
          emit('rankings:set-sort', { key: sortKey, dir: 'asc' });
        }
        emit('rankings:refresh-table');
      });

      anchorTh.after(th);
    }

    // Re-render with the new columns
    emit('rankings:refilter');
  }

  function initRankings() {
    // Clean up previous subscription
    if (unsubscribe) {
      unsubscribe();
      unsubscribe = null;
    }

    injectRankingColumns();

    // Subscribe to ranking changes (import/delete on another page or tab)
    unsubscribe = onRankingsChanged(() => {
      injectRankingColumns();
    });
  }

  // Listen for the inline script's ready signal
  document.addEventListener('rankings:page-ready', () => initRankings());

  // Also handle Astro page transitions
  document.addEventListener('astro:page-load', () => {
    // On page load via Astro transitions, the inline script re-runs and fires
    // rankings:page-ready — but if this module script was already loaded and the
    // event was missed, try init after a microtask.
    queueMicrotask(() => {
      // Check if the page script is ready by dispatching get-sort and seeing if it responds
      const detail: Record<string, unknown> = {};
      document.dispatchEvent(new CustomEvent('rankings:get-sort', { detail }));
      if (detail.currentSort !== undefined) {
        initRankings();
      }
    });
  });
</script>

