---
/**
 * Import Rankings
 *
 * Bookmarklet-based rankings import page. Users drag bookmarklets to their
 * bookmarks bar, visit ranking sites, and click to auto-import rankings.
 * All data stored in localStorage only — private per user.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import RankingsImportPage from '../../components/theleague/rankings-import/RankingsImportPage';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getPlayerMap } from '../../utils/player-map';
import bookmarkletManifest from '../../data/bookmarklet-manifest.json';
import { getAuthUser, isCommissionerOrAdmin } from '../../utils/auth';

export const prerender = false;

const user = getAuthUser(Astro.request);
const isAdmin = !!user && isCommissionerOrAdmin(user);

const leagueYear = getCurrentLeagueYear();
const leagueYearStr = String(leagueYear);

// ---------------------------------------------------------------------------
// Load MFL players for fuzzy matching
// ---------------------------------------------------------------------------
const playersFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/players.json',
  { eager: true },
);

const getModuleData = (mod: unknown) =>
  mod && typeof mod === 'object' && 'default' in mod ? (mod as { default: unknown }).default : mod;

const extractFeedSeason = (filepath: string) => {
  const match = filepath.match(/mfl-feeds\/(\d{4})\//);
  return match ? match[1] : null;
};

let playersData: any = null;
for (const [filepath, mod] of Object.entries(playersFeeds)) {
  if (extractFeedSeason(filepath) === leagueYearStr) {
    playersData = getModuleData(mod);
    break;
  }
}

// Build simplified player array for client-side matching using unified identity map
const irPlayerIdentityMap = getPlayerMap(leagueYear);
const rawPlayers = playersData?.players?.player ?? [];
const mflPlayers = rawPlayers
  .filter((p: any) => p.name && p.position)
  .map((p: any) => {
    const identity = irPlayerIdentityMap.get(p.id);
    return {
      id: p.id,
      name: identity?.name ?? p.name,
      position: identity?.position ?? p.position,
      team: identity?.nflTeam ?? p.team ?? '',
    };
  });

// ---------------------------------------------------------------------------
// Site configurations for bookmarklet cards
// ---------------------------------------------------------------------------
const manifest = bookmarkletManifest as Record<string, string>;

const siteConfigs = [
  {
    id: 'fantasypros',
    name: 'FantasyPros',
    description: 'Reads consensus rankings from the page data. One bookmarklet works for both dynasty and redraft — the type is auto-detected from the page.',
    instructions: 'Click a rankings page button below, then click the bookmarklet. Repeat for the other type if needed.',
    bookmarkletUri: manifest.fantasypros || '',
    bookmarkletLabel: 'Export FantasyPros',
    requiresAuth: false,
    defaultType: 'dynasty',
    difficulty: 'easy',
    links: [
      { url: 'https://www.fantasypros.com/nfl/rankings/dynasty-overall.php', label: 'Dynasty', type: 'dynasty' },
      { url: 'https://www.fantasypros.com/nfl/rankings/consensus-cheatsheets.php', label: 'Redraft', type: 'redraft' },
    ],
  },
  {
    id: 'footballguys',
    name: 'FootballGuys',
    description: 'One bookmarklet works for both dynasty and redraft — the type is auto-detected from the URL.',
    instructions: 'Log in, click a rankings page button below, then click the bookmarklet. Repeat for the other type if needed.',
    bookmarkletUri: manifest.footballguys || '',
    bookmarkletLabel: 'Export FBG',
    requiresAuth: true,
    authNote: 'Requires FootballGuys account',
    defaultType: 'dynasty',
    difficulty: 'easy',
    links: [
      { url: 'https://www.footballguys.com/rankings/duration/dynasty', label: 'Dynasty', type: 'dynasty' },
      { url: 'https://www.footballguys.com/rankings', label: 'Redraft', type: 'redraft' },
    ],
  },
  {
    id: 'dlf',
    name: 'Dynasty League Football',
    description: 'Extracts dynasty rankings from the DLF rankings table.',
    instructions: 'Log in, click the Dynasty Rankings button below, then click the bookmarklet.',
    bookmarkletUri: manifest.dlf || '',
    bookmarkletLabel: 'Export DLF',
    requiresAuth: true,
    authNote: 'Requires DLF Premium subscription',
    defaultType: 'dynasty',
    difficulty: 'medium',
    links: [
      { url: 'https://dynastyleaguefootball.com/rankings/dynasty-rankings/', label: 'Dynasty Rankings', type: 'dynasty' },
    ],
  },
  {
    id: 'keeptradecut',
    name: 'KeepTradeCut',
    description: 'Extracts all dynasty values from the KTC rankings page in one click. Includes tier data.',
    instructions: 'Click the Dynasty Rankings button below, then click the bookmarklet.',
    bookmarkletUri: manifest.keeptradecut || '',
    bookmarkletLabel: 'Export KTC',
    requiresAuth: false,
    defaultType: 'dynasty',
    difficulty: 'easy',
    links: [
      { url: 'https://keeptradecut.com/dynasty-rankings', label: 'Dynasty Rankings', type: 'dynasty' },
    ],
  },
  {
    id: 'yahoo',
    name: 'Yahoo',
    description: 'Extracts ADP data from Yahoo Fantasy Football draft analysis.',
    instructions: 'Click the ADP button below to go to Yahoo draft analysis, then click the bookmarklet.',
    bookmarkletUri: manifest.yahoo || '',
    bookmarkletLabel: 'Export Yahoo ADP',
    requiresAuth: false,
    defaultType: 'adp',
    difficulty: 'medium',
    links: [
      { url: 'https://football.fantasysports.yahoo.com/f1/draftanalysis', label: 'ADP', type: 'adp' },
    ],
  },
  {
    id: 'cbs',
    name: 'CBS Sports',
    description: 'Extracts rankings from the CBS Fantasy Football rankings table.',
    instructions: 'Click the Redraft button below to go to CBS rankings, then click the bookmarklet.',
    bookmarkletUri: manifest.cbs || '',
    bookmarkletLabel: 'Export CBS',
    requiresAuth: false,
    defaultType: 'redraft',
    difficulty: 'easy',
    links: [
      { url: 'https://www.cbssports.com/fantasy/football/rankings/', label: 'Redraft', type: 'redraft' },
    ],
  },
];
---

<TheLeagueLayout title="Import Rankings | The League">
  <RankingsImportPage
    client:load
    mflPlayersJson={JSON.stringify(mflPlayers)}
    siteConfigsJson={JSON.stringify(siteConfigs)}
    isAdmin={isAdmin}
  />
</TheLeagueLayout>

<style is:global>
  /* ================================================================
     Rankings Import Page Styles
     ================================================================ */

  .ri-page {
    max-width: 100%;
    padding: 1.5rem 1rem;
  }

  .ri-page__header {
    margin-bottom: 2rem;
  }

  .ri-page__title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--primary-color, #1c497c);
    margin: 0 0 0.5rem;
  }

  .ri-page__subtitle {
    color: var(--text-secondary-color, #64748b);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.5;
  }

  .ri-page__link {
    color: var(--primary-color, #1c497c);
    text-decoration: none;
    font-weight: 600;
  }

  .ri-page__link:hover {
    text-decoration: underline;
  }

  /* ---- Sections ---- */

  .ri-section {
    margin-bottom: 2rem;
    background: var(--primary-content-bg-color, #fff);
    border: 1px solid var(--primary-content-border-color, #e2e8f0);
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .ri-section__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--primary-color, #1c497c);
    margin: 0 0 0.75rem;
  }

  .ri-section__desc {
    color: var(--text-secondary-color, #64748b);
    font-size: 0.9rem;
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .ri-section__note {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.82rem;
    font-style: italic;
    color: var(--text-secondary-color, #64748b);
  }

  .ri-section__empty {
    color: var(--text-secondary-color, #64748b);
    font-style: italic;
    margin: 0;
  }

  /* ---- Direct Import Grid (FantasyCalc + Sleeper) ---- */

  .ri-direct-import-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .ri-direct-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--primary-content-bg-color, #fff);
  }

  .ri-direct-card__badge {
    background: #068050;
    color: #fff;
  }

  .bm-card__badge--dynasty {
    background: #c0d4f5;
    color: #1e40af;
  }

  .bm-card__badge--adp {
    background: #d0c5f5;
    color: #5b21b6;
  }

  .bm-card__badge--redraft {
    background: #fef3c7;
    color: #92400e;
  }

  .ri-sleeper__btn {
    font-size: 0.95rem;
    padding: 0.6rem 1.25rem;
    align-self: flex-start;
  }

  .ri-direct-card .ri-import__result {
    margin-top: 0.5rem;
  }

  .ri-direct-card .ri-import__stats {
    flex-direction: column;
    gap: 0.15rem;
  }

  /* ---- Bookmarklet Grid ---- */

  .bm-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .bm-card {
    border: 1px solid var(--primary-content-border-color, #e2e8f0);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bm-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bm-card__name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--primary-color, #1c497c);
  }

  .bm-card__badges {
    display: flex;
    gap: 0.35rem;
  }

  .bm-card__badge {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .bm-card__badge--auth {
    background: #6366f1;
    color: #fff;
  }

  .bm-card__desc {
    font-size: 0.82rem;
    color: var(--text-secondary-color, #64748b);
    line-height: 1.4;
    margin: 0;
  }

  .bm-card__instructions {
    font-size: 0.8rem;
    color: #475569;
    line-height: 1.4;
  }

  .bm-card__auth-note {
    font-size: 0.78rem;
    color: #6366f1;
    font-style: italic;
    margin: 0;
  }

  .bm-card__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .bm-card__links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bm-card__site-link {
    font-size: 0.78rem;
    color: var(--primary-color, #1c497c);
    text-decoration: none;
    font-weight: 500;
  }

  .bm-card__site-link:hover {
    text-decoration: underline;
  }

  /* Rankings page link buttons (dynasty / redraft) */
  .bm-card__rankings-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: filter 0.15s;
  }

  .bm-card__rankings-btn::after {
    content: '↗';
    font-size: 0.7rem;
    opacity: 0.75;
  }

  .bm-card__rankings-btn:hover {
    filter: brightness(0.9);
  }

  .bm-card__rankings-btn--dynasty {
    background: #c0d4f5;
    color: #1e40af;
  }

  .bm-card__rankings-btn--redraft {
    background: #fef3c7;
    color: #92400e;
  }

  .bm-card__rankings-btn--adp {
    background: #d0c5f5;
    color: #5b21b6;
  }

  .bm-card__rankings-btn--overall {
    background: #e0e7ff;
    color: #4338ca;
  }

  .bm-card__drag-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: var(--primary-color, #1c497c);
    border: 2px dashed rgba(255, 255, 255, 0.4);
    border-radius: 6px;
    color: #fff;
    font-weight: 600;
    font-size: 0.82rem;
    cursor: grab;
    text-decoration: none;
    user-select: none;
    align-self: flex-start;
    transition: background 0.15s;
  }

  .bm-card__drag-link:hover {
    background: #163c65;
  }

  /* ---- Import Section ---- */

  .ri-import__controls {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .ri-import__type-label {
    font-size: 0.85rem;
    color: #475569;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ri-import__type-select {
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--primary-content-border-color, #e2e8f0);
    border-radius: 4px;
    font-size: 0.85rem;
  }

  .ri-import__textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--primary-content-border-color, #e2e8f0);
    border-radius: 6px;
    font-family: var(--font-family-mono);
    font-size: 0.8rem;
    resize: vertical;
    margin-bottom: 0.75rem;
    box-sizing: border-box;
  }

  .ri-import__textarea:focus {
    outline: 2px solid var(--primary-color, #1c497c);
    outline-offset: -1px;
  }

  .ri-import__result {
    margin: 0 0 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-size: 0.9rem;
  }

  .ri-import__result--success {
    background: #ecfdf5;
    border: 1px solid #10b981;
    color: #065f46;
  }

  .ri-import__result--error {
    background: #fef2f2;
    border: 1px solid #ef4444;
    color: #991b1b;
  }

  .ri-import__result p {
    margin: 0 0 0.5rem;
  }

  .ri-import__stats {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
  }

  .ri-import__stat strong {
    font-variant-numeric: tabular-nums;
  }

  .ri-import__unmatched {
    margin-top: 0.5rem;
    font-size: 0.82rem;
  }

  .ri-import__unmatched summary {
    cursor: pointer;
    font-weight: 500;
  }

  .ri-import__unmatched ul {
    margin: 0.25rem 0 0 1rem;
    padding: 0;
  }

  .ri-import__unmatched li {
    line-height: 1.5;
  }

  .ri-import__status {
    font-weight: 500;
    color: var(--text-secondary-color, #64748b);
  }

  .ri-import__manual {
    /* Uses .ri-section base styles for card appearance */
  }

  .ri-import__manual-summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--primary-color, #1c497c);
    list-style: none;
    user-select: none;
  }

  .ri-import__manual-summary::-webkit-details-marker {
    display: none;
  }

  .ri-import__manual-summary::after {
    content: '';
    margin-left: auto;
    width: 0.5rem;
    height: 0.5rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(-45deg);
    transition: transform 0.2s ease;
  }

  .ri-import__manual[open] > .ri-import__manual-summary::after {
    transform: rotate(45deg);
  }

  .ri-import__manual-summary:hover {
    color: var(--primary-hover-color, #163d68);
  }

  .ri-import__manual-content {
    padding-top: 1rem;
  }

  /* ---- Buttons ---- */

  .ri-btn {
    padding: 0.45rem 0.9rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.15s;
  }

  .ri-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ri-btn--primary {
    background: var(--primary-color, #1c497c);
    color: #fff;
    border-color: var(--primary-color, #1c497c);
  }

  .ri-btn--primary:hover:not(:disabled) {
    background: #163c65;
  }

  .ri-btn--secondary {
    background: var(--secondary-color, #2e8743);
    color: #fff;
    border-color: var(--secondary-color, #2e8743);
  }

  .ri-btn--secondary:hover:not(:disabled) {
    background: var(--color-secondary-dark, #26743a);
  }

  .ri-btn--sm {
    padding: 0.25rem 0.55rem;
    font-size: 0.78rem;
    background: #f1f5f9;
    color: #334155;
  }

  .ri-btn--sm:hover {
    background: #e2e8f0;
  }

  .ri-btn--danger {
    color: #dc2626;
    background: #fef2f2;
  }

  .ri-btn--danger:hover {
    background: #fee2e2;
  }

  /* ---- Manage Table ---- */

  .ri-manage__table-wrap {
    overflow-x: auto;
  }

  .ri-manage__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .ri-manage__table th {
    text-align: left;
    font-weight: 600;
    color: var(--primary-color, #1c497c);
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--primary-content-border-color, #e2e8f0);
    white-space: nowrap;
  }

  .ri-manage__table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--primary-content-border-color, #e2e8f0);
  }

  .ri-manage__source {
    font-weight: 500;
  }

  .ri-manage__type {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .ri-manage__type--dynasty {
    background: #c0d4f5;
    color: #1e40af;
  }

  .ri-manage__type--redraft {
    background: #fef3c7;
    color: #92400e;
  }

  .ri-manage__type--adp {
    background: #d0c5f5;
    color: #5b21b6;
  }

  .ri-manage__type--overall {
    background: #e0e7ff;
    color: #4338ca;
  }

  .ri-manage__rate {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .ri-manage__rate--good { color: #059669; }
  .ri-manage__rate--ok { color: #d97706; }
  .ri-manage__rate--low { color: #dc2626; }

  .ri-manage__actions {
    display: flex;
    gap: 0.35rem;
  }

  /* ---- Drag Handle ---- */

  .ri-manage__drag-col {
    width: 32px;
    padding: 0;
  }

  .ri-manage__drag-handle {
    cursor: grab;
    padding: 0.5rem !important;
    color: var(--text-secondary-color, #64748b);
    user-select: none;
    text-align: center;
    touch-action: none;
  }

  .ri-manage__drag-handle:active {
    cursor: grabbing;
  }

  .ri-manage__drag-handle svg {
    display: block;
    margin: 0 auto;
    opacity: 0.35;
    transition: opacity 0.15s;
  }

  .ri-manage__table tr:hover .ri-manage__drag-handle svg {
    opacity: 1;
  }

  .ri-manage__row--dragging {
    background: var(--primary-content-bg-color, #fff);
    box-shadow: var(--shadow-md, 0 4px 6px -1px rgb(0 0 0 / 0.1));
  }

  .ri-manage__row--average {
    background: var(--table-header-bg, #f8f9fa);
    font-style: italic;
  }

  /* ---- Composite (My Rank) ---- */

  .ri-manage__composite-col {
    width: 60px;
    text-align: center;
    font-size: 0.7rem;
    white-space: nowrap;
  }

  .ri-manage__composite-check {
    text-align: center;
    vertical-align: middle;
  }

  .ri-manage__composite-check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--primary-color, #1c497c);
    cursor: pointer;
  }

  .ri-manage__weight-col {
    width: 100px;
    text-align: center;
  }

  .ri-manage__weight {
    text-align: center;
  }

  .ri-manage__weight-picker {
    display: inline-flex;
    gap: 2px;
    background: var(--primary-content-border-color, #e2e8f0);
    border-radius: 4px;
    padding: 2px;
  }

  .ri-manage__weight-btn {
    background: transparent;
    border: none;
    border-radius: 3px;
    padding: 0.125rem 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-secondary-color, #64748b);
    cursor: pointer;
    line-height: 1.2;
    transition: background 0.15s, color 0.15s;
  }

  .ri-manage__weight-btn:hover {
    background: rgba(255, 255, 255, 0.6);
    color: var(--text-primary-color, #1e293b);
  }

  .ri-manage__weight-btn.active {
    background: var(--primary-color, #1c497c);
    color: #fff;
    font-weight: 600;
  }

  .ri-manage__composite-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.5rem;
    background: rgba(28, 73, 124, 0.06);
    border: 1px solid rgba(28, 73, 124, 0.15);
    border-radius: 6px;
    font-size: 0.8125rem;
  }

  .ri-manage__composite-bar-label {
    font-weight: 700;
    color: var(--primary-color, #1c497c);
  }

  .ri-manage__composite-bar-detail {
    color: var(--text-secondary-color, #64748b);
  }

  /* ---- Modal ---- */

  .ri-modal {
    border: none;
    border-radius: 10px;
    padding: 0;
    max-width: 700px;
    width: 90vw;
    max-height: 80vh;
    box-shadow: var(--shadow-lg);
  }

  .ri-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  .ri-modal__content {
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .ri-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--primary-content-border-color, #e2e8f0);
  }

  .ri-modal__header h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--primary-color, #1c497c);
    margin: 0;
    text-transform: capitalize;
  }

