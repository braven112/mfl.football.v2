---
/**
 * What's New - Feature changelog and release history.
 *
 * Displays all feature announcements from whats-new.json in reverse
 * chronological order, grouped by month. Each entry shows a category
 * badge, date, title, description, and optional link.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import type { WhatsNewEntry } from '../../types/whats-new';
import { WHATS_NEW_CATEGORY_LABELS } from '../../types/whats-new';
import entries from '../../data/whats-new.json';

export const prerender = true;

// Sort newest-first (data file should already be ordered, but enforce it)
const sorted = [...(entries as WhatsNewEntry[])].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);

// Group by month/year for section headers
interface MonthGroup {
  label: string;
  entries: WhatsNewEntry[];
}

const groups: MonthGroup[] = [];
let currentLabel = '';

for (const entry of sorted) {
  const date = new Date(entry.date + 'T00:00:00');
  const label = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  if (label !== currentLabel) {
    groups.push({ label, entries: [] });
    currentLabel = label;
  }
  groups[groups.length - 1].entries.push(entry);
}

/** Format a date string for display */
function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

const MULTICOLOR_ICONS = ['nfl'];
---

<TheLeagueLayout title="What's New - The League">
  <main class="whats-new-page">
    <header class="whats-new-page__header">
      <h1 class="whats-new-page__title">What's New</h1>
      <p class="whats-new-page__subtitle">
        New features, improvements, and updates to The League.
      </p>
    </header>

    <div class="whats-new-page__timeline">
      {groups.map((group) => (
        <section class="whats-new-page__month">
          <h2 class="whats-new-page__month-label">{group.label}</h2>
          <div class="whats-new-page__entries">
            {group.entries.map((entry) => {
              const iconId = entry.icon ? `icon-${entry.icon}` : null;
              const isMulticolor = entry.icon ? MULTICOLOR_ICONS.includes(entry.icon) : false;
              return (
                <article class={`whats-new-entry whats-new-entry--${entry.category}`}>
                  <span class={`whats-new-entry__badge whats-new-entry__badge--${entry.category}`}>
                    {WHATS_NEW_CATEGORY_LABELS[entry.category]}
                  </span>
                  <div class="whats-new-entry__header">
                    {iconId && (
                      <svg class={`whats-new-entry__icon${isMulticolor ? ' whats-new-entry__icon--multicolor' : ''}`} aria-hidden="true">
                        <use href={`/assets/icons/sprite.svg#${iconId}`} />
                      </svg>
                    )}
                    <h3 class="whats-new-entry__title">{entry.title}</h3>
                  </div>
                  <p class="whats-new-entry__date">{formatDate(entry.date)}</p>
                  <div class="whats-new-entry__body">
                    {entry.description.map((para) => (
                      <p>{para}</p>
                    ))}
                  </div>
                  {entry.link && (
                    <div class="whats-new-entry__links">
                      <a href={entry.link} class="whats-new-entry__link">
                        {entry.linkLabel ?? 'Check it out'}
                        <span class="whats-new-entry__link-arrow" aria-hidden="true">&rarr;</span>
                      </a>
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </main>
</TheLeagueLayout>

<style>
  /* ── Category color tokens ── */
  :root {
    --cat-new-page: #7c3aed;
    --cat-new-feature: #2e8743;
    --cat-enhancement: #2563eb;
    --cat-league-event: #1c497c;
  }

  .whats-new-page {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl, 2rem);
    padding: var(--spacing-xl, 2rem) 0;
  }

  /* ── Page Header ── */
  .whats-new-page__header {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs, 0.25rem);
  }

  .whats-new-page__title {
    font-size: var(--font-size-2xl, 2rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--primary-link-default-text-color, #1c497c);
    margin: 0;
  }

  .whats-new-page__subtitle {
    font-size: var(--font-size-base, 1rem);
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    line-height: var(--line-height-base, 1.5);
  }

  /* ── Timeline Layout ── */
  .whats-new-page__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl, 3rem);
  }

  .whats-new-page__month {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1rem);
  }

  .whats-new-page__month-label {
    font-size: var(--font-size-lg, 1.25rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    padding-bottom: var(--spacing-xs, 0.25rem);
    border-bottom: 1px solid var(--content-border, #e2e8f0);
  }

  .whats-new-page__entries {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg, 1.5rem);
  }

  /* ── Entry Card ── */
  .whats-new-entry {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 0.5rem);
    padding: var(--spacing-lg, 1.5rem);
    background: var(--content-bg, #fff);
    border-radius: 0.75rem;
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    border-left: 4px solid var(--entry-category-color, var(--cat-new-feature));
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .whats-new-entry:hover {
    box-shadow: var(--box-shadow-hover, 0 4px 12px rgba(0, 0, 0, 0.08));
    transform: translateY(-1px);
  }

  /* Category variants */
  .whats-new-entry--new-page { --entry-category-color: var(--cat-new-page); }
  .whats-new-entry--new-feature { --entry-category-color: var(--cat-new-feature); }
  .whats-new-entry--enhancement { --entry-category-color: var(--cat-enhancement); }
  .whats-new-entry--league-event { --entry-category-color: var(--cat-league-event); }

  /* Badge */
  .whats-new-entry__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    width: fit-content;
    color: #fff;
    background: var(--entry-category-color);
  }

  /* Header (icon + title) */
  .whats-new-entry__header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm, 0.5rem);
  }

  .whats-new-entry__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    fill: currentColor;
    color: var(--entry-category-color);
  }

  .whats-new-entry__icon--multicolor {
    fill: none;
    color: unset;
  }

  .whats-new-entry__title {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold, 700);
    margin: 0;
    color: var(--primary-link-default-text-color, #1c497c);
    line-height: 1.3;
  }

  /* Date */
  .whats-new-entry__date {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--muted-text-color, #6b7280);
    margin: 0;
  }

  /* Description body */
  .whats-new-entry__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 0.5rem);
  }

  .whats-new-entry__body p {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    line-height: var(--line-height-base, 1.5);
  }

  /* Links */
  .whats-new-entry__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm, 0.5rem);
    margin-top: var(--spacing-xs, 0.25rem);
  }

  .whats-new-entry__link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    padding: 0.25rem 0.65rem;
    border-radius: 0.375rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--color-gray-200, #e5e7eb);
    transition: all 0.15s ease;
  }

  .whats-new-entry__link:hover {
    background: var(--entry-category-color);
    color: #fff;
    border-color: var(--entry-category-color);
  }

  .whats-new-entry__link-arrow {
    font-size: 0.9rem;
    transition: transform 0.15s ease;
  }

  .whats-new-entry__link:hover .whats-new-entry__link-arrow {
    transform: translateX(2px);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .whats-new-page__title {
      font-size: var(--font-size-xl, 1.5rem);
    }

    .whats-new-entry {
      padding: var(--spacing-md, 1rem);
    }
  }
</style>
