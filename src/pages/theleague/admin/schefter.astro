---
/**
 * Schefter Operations Dashboard (admin-only)
 *
 * Read-only validation surface for the rumor mill. Lets the commissioner
 * verify that tips are flowing (web + GroupMe + trade-offer), that the
 * marinate/daily-cap gates are in the expected state, and that Claude has
 * actually posted pending-trade announcements.
 *
 * All data comes from /api/admin/schefter-stats which reads Redis + the
 * committed feed JSON. No mutations here.
 */
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import { getAuthUser, isCommissionerOrAdmin } from '../../../utils/auth';

export const prerender = false;

const user = getAuthUser(Astro.request);
if (!user || !isCommissionerOrAdmin(user)) {
  return Astro.redirect('/theleague');
}
---

<TheLeagueLayout title="Schefter Ops — Admin">
  <main class="ops-page">
    <header class="ops-header">
      <div>
        <p class="ops-eyebrow"><a href="/theleague/admin">Admin</a> / Schefter Ops</p>
        <h1 class="ops-title">Schefter Operations</h1>
        <p class="ops-sub">
          Validates the rumor mill is actually consuming tips, GroupMe mentions, and trade proposals —
          and that Claude is announcing pending trades. All counts are read-only.
        </p>
      </div>
      <div class="ops-header__actions">
        <button id="ops-refresh" class="ops-btn" type="button">Refresh</button>
        <span id="ops-updated" class="ops-updated" aria-live="polite">—</span>
      </div>
    </header>

    <section class="ops-env" aria-label="Vercel runtime environment">
      <h2 class="ops-env__title">Vercel runtime env</h2>
      <p class="ops-env__hint">Used by Astro API routes, the tip form, and Redis reads.</p>
      <ul class="ops-env__list" id="ops-vercel-env-list"><li>Loading…</li></ul>
    </section>

    <section class="ops-env" aria-label="GitHub Actions environment">
      <h2 class="ops-env__title">GitHub Actions env <span id="ops-gh-repo" class="ops-env__repo"></span></h2>
      <p class="ops-env__hint">
        Used by the scanners running on a cron. Probed via the GitHub REST API —
        needs a fine-grained PAT on Vercel as <code>GITHUB_ADMIN_TOKEN</code>
        with <em>Actions:Read + Variables:Read + Secrets:Read</em>.
      </p>
      <div id="ops-github-body"><p class="ops-env__hint">Loading…</p></div>
    </section>

    <section class="ops-grid" aria-label="Dashboard stats">
      <article class="ops-card" aria-labelledby="card-queue">
        <h2 id="card-queue" class="ops-card__title">Tips Queue (live)</h2>
        <p class="ops-card__hint">Drained every 15 min by <code>schefter-rumor-scan.mjs</code>.</p>
        <dl class="ops-dl">
          <div><dt>Pending in queue</dt><dd data-k="redis.queueDepth">—</dd></div>
          <div><dt>Marinate started</dt><dd data-k="fmt.marinateStartedAt">—</dd></div>
          <div><dt>Next earliest post</dt><dd data-k="fmt.nextEarliestPostAt">—</dd></div>
          <div><dt>Posts today (cap 3)</dt><dd data-k="redis.postsToday">—</dd></div>
          <div><dt>Last rumor post</dt><dd data-k="fmt.lastRumorPostTs">—</dd></div>
        </dl>
      </article>

      <article class="ops-card" aria-labelledby="card-sources">
        <h2 id="card-sources" class="ops-card__title">Tip Sources (recent archive)</h2>
        <p class="ops-card__hint">
          Sampled from <code>schefter:tips:processed</code> (last ~200 drained tips).
        </p>
        <dl class="ops-dl">
          <div><dt>Sample size</dt><dd data-k="redis.tipSampleSize">—</dd></div>
          <div><dt>Web tips</dt><dd data-k="redis.tipSourceBreakdown.web">—</dd></div>
          <div><dt>GroupMe tips</dt><dd data-k="redis.tipSourceBreakdown.groupme">—</dd></div>
          <div><dt>Trade-offer tips</dt><dd data-k="redis.tipSourceBreakdown.trade_offer">—</dd></div>
          <div><dt>Unknown / unparsed</dt><dd data-k="redis.tipSourceBreakdown.unknown">—</dd></div>
        </dl>
      </article>

      <article class="ops-card" aria-labelledby="card-groupme">
        <h2 id="card-groupme" class="ops-card__title">GroupMe Ingestion</h2>
        <p class="ops-card__hint">Polling cache in <code>groupme:messages</code> ZSET.</p>
        <dl class="ops-dl">
          <div><dt>Messages cached</dt><dd data-k="redis.groupmeMessagesCached">—</dd></div>
          <div><dt>Last message id</dt><dd data-k="redis.groupmeLastMessageId">—</dd></div>
          <div><dt>Last sync</dt><dd data-k="fmt.groupmeLastSyncTs">—</dd></div>
        </dl>
      </article>

      <article class="ops-card" aria-labelledby="card-offers">
        <h2 id="card-offers" class="ops-card__title">Trade Offers Ingested</h2>
        <p class="ops-card__hint">
          Cumulative-probability model: <code>p=0.0075</code>/run (99% cumulative by ~day 6.4).
          In-flight = offers still eligible to post. Posted = offers the rumor mill has already announced.
          Lingering (≥48h) flips the voice to "phones aren't picking up".
        </p>
        <dl class="ops-dl">
          <div><dt>In-flight (eligible)</dt><dd data-k="redis.tradeOffersInFlight">—</dd></div>
          <div><dt>— fresh (&lt;48h)</dt><dd data-k="redis.tradeOffersFresh">—</dd></div>
          <div><dt>— lingering (≥48h)</dt><dd data-k="redis.tradeOffersLingering">—</dd></div>
          <div><dt>Oldest in-flight age</dt><dd data-k="redis.tradeOffersOldestAgeMs" data-fmt="duration">—</dd></div>
          <div><dt>Posted (30d TTL)</dt><dd data-k="redis.tradeOffersPosted">—</dd></div>
          <div><dt>Legacy one-shot burned</dt><dd data-k="redis.tradeOffersSeen">—</dd></div>
          <div><dt>Pending-trade watermark size</dt><dd data-k="feed.pendingTradeWatermarkSize">—</dd></div>
        </dl>
      </article>

      <article class="ops-card ops-card--wide" aria-labelledby="card-live-trades">
        <h2 id="card-live-trades" class="ops-card__title">
          Trade Proposals in MFL (live, league-wide)
          <span id="ops-live-trades-summary" class="ops-card__badge">—</span>
        </h2>
        <p class="ops-card__hint">
          Every open trade proposal right now — your team plus every other franchise.
          Pulled from MFL <code>TYPE=pendingTrades</code> in commish mode.
          If this list is non-empty and <strong>"Pending trade announcements"</strong> stays at 0, the scanner is missing deals.
        </p>
        <div id="ops-live-trades-body" class="ops-live-trades">Loading…</div>
      </article>

      <article class="ops-card ops-card--wide" aria-labelledby="card-posts">
        <h2 id="card-posts" class="ops-card__title">Posts in Feed</h2>
        <p class="ops-card__hint">Counted from <code>schefter-feed.json</code>.</p>
        <dl class="ops-dl ops-dl--cols">
          <div><dt>Total posts</dt><dd data-k="feed.postsTotal">—</dd></div>
          <div><dt>Rumor-mill posts (all-time)</dt><dd data-k="feed.rumorMillTotal">—</dd></div>
          <div><dt>Rumor-mill (7d)</dt><dd data-k="feed.rumorMill7d">—</dd></div>
          <div><dt>Rumor-mill (24h)</dt><dd data-k="feed.rumorMill24h">—</dd></div>
          <div><dt>Pending trade announcements</dt><dd data-k="feed.pendingTradeTotal">—</dd></div>
          <div><dt>Pending trade (7d)</dt><dd data-k="feed.pendingTrade7d">—</dd></div>
          <div><dt>Completed TRADE posts</dt><dd data-k="feed.tradeCompletedTotal">—</dd></div>
          <div><dt>Claude-authored total</dt><dd data-k="feed.claudeAuthoredTotal">—</dd></div>
        </dl>
      </article>

      <article class="ops-card ops-card--wide" aria-labelledby="card-authors">
        <h2 id="card-authors" class="ops-card__title">Posts by Author</h2>
        <p class="ops-card__hint">Every byline that has ever published into the feed.</p>
        <table class="ops-table">
          <thead><tr><th>Author</th><th class="ops-table__num">Count</th></tr></thead>
          <tbody id="ops-authors-body"><tr><td colspan="2">Loading…</td></tr></tbody>
        </table>
      </article>

      <article class="ops-card" aria-labelledby="card-subtypes">
        <h2 id="card-subtypes" class="ops-card__title">Transaction Subtypes</h2>
        <p class="ops-card__hint">Distribution across the feed (rumor_mill / TRADE / TRADE_PENDING / …).</p>
        <table class="ops-table">
          <thead><tr><th>Subtype</th><th class="ops-table__num">Count</th></tr></thead>
          <tbody id="ops-subtypes-body"><tr><td colspan="2">Loading…</td></tr></tbody>
        </table>
      </article>

      <article class="ops-card" aria-labelledby="card-tipsters">
        <h2 id="card-tipsters" class="ops-card__title">Tipster Leaderboard</h2>
        <p class="ops-card__hint">Distinct tipsters ranked this season.</p>
        <dl class="ops-dl">
          <div><dt>Ranked tipsters ({<span data-k="redis.seasonYear">—</span>})</dt><dd data-k="redis.tipsterLeaderboardSize">—</dd></div>
        </dl>
      </article>

      <article class="ops-card" aria-labelledby="card-scan">
        <h2 id="card-scan" class="ops-card__title">Scanner Freshness</h2>
        <p class="ops-card__hint">From the feed JSON watermarks.</p>
        <dl class="ops-dl">
          <div><dt>Last scan</dt><dd data-k="fmt.lastScanTimestamp">—</dd></div>
          <div><dt>Last MFL txn processed</dt><dd data-k="fmt.lastProcessedMflTimestamp">—</dd></div>
        </dl>
      </article>
    </section>

    <p class="ops-foot">
      Auto-refreshes every 60 seconds. Source: <code>/api/admin/schefter-stats</code>.
    </p>
  </main>
</TheLeagueLayout>

<script>
  const endpoint = '/api/admin/schefter-stats';

  function fmtTs(ts: unknown): string {
    if (ts === null || ts === undefined || ts === '' || ts === 0) return '—';
    const n = typeof ts === 'number' ? ts : parseInt(String(ts), 10);
    if (!Number.isFinite(n)) return String(ts);
    const ms = n < 1e12 ? n * 1000 : n;
    return new Date(ms).toLocaleString();
  }

  function fmtRel(ts: unknown): string {
    if (ts === null || ts === undefined || ts === '' || ts === 0) return '—';
    const n = typeof ts === 'number' ? ts : parseInt(String(ts), 10);
    if (!Number.isFinite(n)) return String(ts);
    const ms = n < 1e12 ? n * 1000 : n;
    const diff = Date.now() - ms;
    const absMin = Math.round(Math.abs(diff) / 60000);
    if (absMin < 1) return diff >= 0 ? 'just now' : 'soon';
    if (absMin < 60) return diff >= 0 ? `${absMin}m ago` : `in ${absMin}m`;
    const hrs = Math.round(absMin / 60);
    if (hrs < 48) return diff >= 0 ? `${hrs}h ago` : `in ${hrs}h`;
    const days = Math.round(hrs / 24);
    return diff >= 0 ? `${days}d ago` : `in ${days}d`;
  }

  function lookup(obj: any, path: string): unknown {
    return path.split('.').reduce<any>((acc, k) => (acc == null ? acc : acc[k]), obj);
  }

  function render(data: any) {
    const updated = document.getElementById('ops-updated');
    if (updated) updated.textContent = `Updated ${new Date(data.generatedAt).toLocaleTimeString()}`;

    const marinate = data.redis?.marinateStartedAt ?? null;
    const fmt = {
      marinateStartedAt: marinate ? `${fmtTs(marinate)} (${fmtRel(marinate)})` : '—',
      nextEarliestPostAt: marinate ? fmtTs(marinate + 60 * 60 * 1000) : '—',
      lastRumorPostTs: data.redis?.lastRumorPostTs
        ? `${fmtTs(data.redis.lastRumorPostTs)} (${fmtRel(data.redis.lastRumorPostTs)})`
        : '—',
      groupmeLastSyncTs: data.redis?.groupmeLastSyncTs
        ? `${fmtTs(data.redis.groupmeLastSyncTs)} (${fmtRel(data.redis.groupmeLastSyncTs)})`
        : '—',
      lastScanTimestamp: data.feed?.lastScanTimestamp
        ? `${new Date(data.feed.lastScanTimestamp).toLocaleString()} (${fmtRel(Date.parse(data.feed.lastScanTimestamp))})`
        : '—',
      lastProcessedMflTimestamp: data.feed?.lastProcessedMflTimestamp
        ? `${fmtTs(data.feed.lastProcessedMflTimestamp)} (${fmtRel(data.feed.lastProcessedMflTimestamp)})`
        : '—',
    };

    const fmtDuration = (ms: unknown): string => {
      if (ms === null || ms === undefined) return '—';
      const n = typeof ms === 'number' ? ms : Number(ms);
      if (!Number.isFinite(n) || n < 0) return '—';
      const hours = n / (60 * 60 * 1000);
      if (hours < 1) return `${Math.round(n / 60000)}m`;
      if (hours < 48) return `${hours.toFixed(1)}h`;
      const days = hours / 24;
      return `${days.toFixed(1)}d`;
    };

    const merged = { ...data, fmt };
    document.querySelectorAll<HTMLElement>('[data-k]').forEach((el) => {
      const path = el.dataset.k!;
      const v = lookup(merged, path);
      const fmtMode = el.dataset.fmt;
      if (fmtMode === 'duration') {
        el.textContent = fmtDuration(v);
        return;
      }
      el.textContent = v === null || v === undefined ? '—' : String(v);
    });

    const pill = (state: 'ok' | 'bad' | 'warn', label: string) =>
      `<span class="ops-pill ops-pill--${state}">${label}</span>`;

    const vercel = data.vercelEnv || {};
    const vercelEl = document.getElementById('ops-vercel-env-list');
    if (vercelEl) {
      const labels: Array<[string, string]> = [
        ['upstashConfigured', 'UPSTASH_REDIS_REST_URL + TOKEN'],
        ['groupmeTokenConfigured', 'GROUPME_SERVICE_TOKEN'],
        ['anthropicKeyConfigured', 'ANTHROPIC_API_KEY'],
        ['tipsterSaltConfigured', 'SCHEFTER_TIPSTER_SALT'],
      ];
      const items = labels.map(([k, name]) => {
        const ok = !!vercel[k];
        return `<li class="ops-env__item">${pill(ok ? 'ok' : 'bad', ok ? 'SET' : 'missing')} <code>${name}</code></li>`;
      });
      items.push(
        data.redisAvailable
          ? `<li class="ops-env__item">${pill('ok', 'LIVE')} Upstash Redis</li>`
          : `<li class="ops-env__item">${pill('bad', 'offline')} Upstash Redis — live counters unavailable</li>`,
      );
      vercelEl.innerHTML = items.join('');
    }

    const gh = data.github || {};
    const ghRepoEl = document.getElementById('ops-gh-repo');
    if (ghRepoEl) ghRepoEl.textContent = gh.repo ? ` · ${gh.repo}` : '';
    const ghBody = document.getElementById('ops-github-body');
    if (ghBody) {
      if (!gh.tokenConfigured) {
        ghBody.innerHTML =
          `<p class="ops-env__hint">${pill('warn', 'no PAT')} ${gh.hint || 'GitHub token not configured on Vercel — GitHub validation disabled.'}</p>`;
      } else {
        const variables = gh.variables || {};
        const secrets = gh.secrets || {};
        const workflows = Array.isArray(gh.workflows) ? gh.workflows : [];

        const varRows = Object.entries(variables)
          .map(([name, info]: [string, any]) => {
            if (info?.error) return `<li class="ops-env__item">${pill('warn', 'err')} <code>${name}</code> <span class="ops-env__note">${info.error}</span></li>`;
            if (info?.exists) {
              const preview = info.preview ? ` <span class="ops-env__note">= ${info.preview}</span>` : '';
              return `<li class="ops-env__item">${pill('ok', 'SET')} <code>${name}</code>${preview}</li>`;
            }
            return `<li class="ops-env__item">${pill('bad', 'missing')} <code>${name}</code></li>`;
          })
          .join('');

        const secRows = Object.entries(secrets)
          .map(([name, info]: [string, any]) => {
            if (info?.error) return `<li class="ops-env__item">${pill('warn', 'err')} <code>${name}</code> <span class="ops-env__note">${info.error}</span></li>`;
            if (info?.exists) return `<li class="ops-env__item">${pill('ok', 'SET')} <code>${name}</code></li>`;
            return `<li class="ops-env__item">${pill('bad', 'missing')} <code>${name}</code></li>`;
          })
          .join('');

        const wfRows = workflows
          .map((wf: any) => {
            const r = wf.run || {};
            if (r.error) return `<tr><td>${wf.label}</td><td colspan="3">${pill('warn', 'err')} ${r.error}</td></tr>`;
            if (!r.found) return `<tr><td>${wf.label}</td><td colspan="3">${pill('warn', 'no runs')} — workflow never run</td></tr>`;
            const concl = String(r.conclusion || r.status || 'unknown');
            const conclState = concl === 'success' ? 'ok' : concl === 'in_progress' || concl === 'queued' ? 'warn' : 'bad';
            const ts = r.runStartedAt || r.createdAt;
            const when = ts ? `${new Date(ts).toLocaleString()} (${fmtRel(Date.parse(ts))})` : '—';
            const link = r.htmlUrl ? `<a href="${r.htmlUrl}" target="_blank" rel="noopener">view →</a>` : '';
            return `<tr><td>${wf.label}</td><td>${pill(conclState, concl)}</td><td>${when}</td><td>${link}</td></tr>`;
          })
          .join('');

        ghBody.innerHTML = `
          <div class="ops-env__cols">
            <div>
              <h3 class="ops-env__subtitle">Variables</h3>
              <ul class="ops-env__list">${varRows || '<li>—</li>'}</ul>
            </div>
            <div>
              <h3 class="ops-env__subtitle">Secrets <span class="ops-env__note">(existence only — values never exposed)</span></h3>
              <ul class="ops-env__list">${secRows || '<li>—</li>'}</ul>
            </div>
          </div>
          <h3 class="ops-env__subtitle">Latest workflow runs</h3>
          <table class="ops-table">
            <thead><tr><th>Workflow</th><th>Status</th><th>Ran</th><th></th></tr></thead>
            <tbody>${wfRows || '<tr><td colspan="4">No workflows found.</td></tr>'}</tbody>
          </table>
        `;
      }
    }

    const authors = data.feed?.byAuthor || {};
    const authorsBody = document.getElementById('ops-authors-body');
    if (authorsBody) {
      const rows = Object.entries(authors)
        .sort((a: any, b: any) => b[1] - a[1])
        .map(([name, count]) => `<tr><td>${name}</td><td class="ops-table__num">${count}</td></tr>`)
        .join('');
      authorsBody.innerHTML = rows || '<tr><td colspan="2">No posts yet.</td></tr>';
    }

    const subtypes = data.feed?.bySubType || {};
    const subtypesBody = document.getElementById('ops-subtypes-body');
    if (subtypesBody) {
      const rows = Object.entries(subtypes)
        .sort((a: any, b: any) => b[1] - a[1])
        .map(([k, count]) => `<tr><td><code>${k}</code></td><td class="ops-table__num">${count}</td></tr>`)
        .join('');
      subtypesBody.innerHTML = rows || '<tr><td colspan="2">—</td></tr>';
    }
  }

  async function load() {
    try {
      const res = await fetch(endpoint, { credentials: 'same-origin' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      render(data);
    } catch (err) {
      const updated = document.getElementById('ops-updated');
      if (updated) updated.textContent = `Error: ${(err as Error).message}`;
    }
  }

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!),
    );
  }

  function assetLabels(list: any[]): string {
    if (!Array.isArray(list) || !list.length) return '<em>—</em>';
    return list
      .map((a) => {
        const label = escapeHtml(a?.label || 'Unknown');
        const pos = a?.position ? ` <span class="ops-asset__pos">${escapeHtml(a.position)}</span>` : '';
        return `<li>${label}${pos}</li>`;
      })
      .join('');
  }

  async function loadTradeProposals() {
    const body = document.getElementById('ops-live-trades-body');
    const summary = document.getElementById('ops-live-trades-summary');
    if (!body || !summary) return;
    summary.textContent = '…';
    body.textContent = 'Loading…';
    try {
      const res = await fetch('/api/trades/pending?commish=1', { credentials: 'same-origin' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const payload = await res.json();
      if (!payload?.success) throw new Error(payload?.message || 'fetch failed');

      const mine = Array.isArray(payload.trades) ? payload.trades : [];
      const others = Array.isArray(payload.commishTrades) ? payload.commishTrades : [];
      const total = mine.length + others.length;
      const all = [...mine, ...others].sort((a: any, b: any) => (b.timestamp || 0) - (a.timestamp || 0));

      summary.innerHTML = `<span class="ops-pill ops-pill--${total > 0 ? 'ok' : 'warn'}">${total} open</span>`;

      if (!total) {
        body.innerHTML =
          '<p class="ops-empty">No open trade proposals in MFL right now. If this stays zero for weeks, either the league is quiet or MFL auth is broken (check your login).</p>';
        return;
      }

      const rows = all
        .map((t: any) => {
          const by = escapeHtml(t.offeredByName || t.offeredBy || '?');
          const to = escapeHtml(t.offeredToName || t.offeredTo || '?');
          const ts = t.timestamp ? new Date(t.timestamp * 1000) : null;
          const when = ts ? `${ts.toLocaleString()} (${fmtRel(ts.getTime())})` : '—';
          const give = assetLabels(t.resolvedAssets?.willGiveUp);
          const recv = assetLabels(t.resolvedAssets?.willReceive);
          const comments = t.comments ? `<p class="ops-trade__comments">"${escapeHtml(t.comments)}"</p>` : '';
          return `
            <article class="ops-trade">
              <header class="ops-trade__head">
                <strong>${by}</strong> → <strong>${to}</strong>
                <span class="ops-trade__meta">offer <code>${escapeHtml(t.tradeId || '')}</code> · ${when}</span>
              </header>
              <div class="ops-trade__body">
                <div class="ops-trade__side">
                  <h4>${by} gives</h4>
                  <ul class="ops-asset-list">${give}</ul>
                </div>
                <div class="ops-trade__side">
                  <h4>${to} gives</h4>
                  <ul class="ops-asset-list">${recv}</ul>
                </div>
              </div>
              ${comments}
            </article>`;
        })
        .join('');

      body.innerHTML = rows;
    } catch (err) {
      summary.innerHTML = `<span class="ops-pill ops-pill--bad">err</span>`;
      body.innerHTML = `<p class="ops-empty">Could not load trade proposals: ${escapeHtml((err as Error).message)}. Are you logged in to MFL?</p>`;
    }
  }

  document.getElementById('ops-refresh')?.addEventListener('click', () => {
    load();
    loadTradeProposals();
  });
  load();
  loadTradeProposals();
  setInterval(load, 60_000);
</script>

<style>
  .ops-page { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem 4rem; }

  .ops-header {
    display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;
    flex-wrap: wrap; margin-bottom: 1.5rem;
  }
  .ops-eyebrow { font-size: 0.75rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-text-muted, #64748b); margin: 0 0 0.25rem; }
  .ops-eyebrow a { color: inherit; text-decoration: underline; }
  .ops-title { font-size: 1.75rem; margin: 0 0 0.25rem; color: var(--color-text, #0f172a); }
  .ops-sub { margin: 0; color: var(--color-text-muted, #64748b); max-width: 70ch; font-size: 0.925rem; }

  .ops-header__actions { display: flex; align-items: center; gap: 0.75rem; }
  .ops-btn {
    background: var(--color-accent, #0ea5e9); color: white; border: 0;
