---
/**
 * Schefter Ops — /theleague/admin/schefter
 *
 * Thin wrapper: league-scoped admin gate + layout. The dashboard lives in
 * the shared components/schefter/AdminDashboard.astro; the stats API it
 * fronts is JWT-league-scoped the same way.
 */
export const prerender = false;

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import AdminDashboard from '../../../components/schefter/AdminDashboard.astro';
import { getAuthUser, isCommissionerOrAdmin, isAuthorizedForLeague } from '../../../utils/auth';
import { getLeagueBySlug } from '../../../config/leagues';

// League-scoped gate: commissioner/admin AND the session must belong to
// TheLeague — an AFL commissioner's session must not open TheLeague's ops
// dashboard.
const user = getAuthUser(Astro.request);
const theLeague = getLeagueBySlug('theleague');
if (
  !user ||
  !isCommissionerOrAdmin(user) ||
  !theLeague ||
  !isAuthorizedForLeague(user, theLeague.id)
) {
  return Astro.redirect('/theleague');
}
---

<TheLeagueLayout title="Schefter Ops — Admin">
  <AdminDashboard base="/theleague" navSlug="theleague" />
</TheLeagueLayout>
