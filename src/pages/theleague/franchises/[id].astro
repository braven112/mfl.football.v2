---
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import franchiseHistory from '../../../../data/theleague/derived/franchise-history.json';
import leagueConfig from '../../../data/theleague.config.json';
import { formatTradeAsset } from '../../../utils/franchise-trade-asset';

export const prerender = false;

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;

const { id } = Astro.params;
const fr: any = id ? (franchiseHistory.franchises as any)[id] : null;

if (!fr) {
  return Astro.redirect(resolveLeaguePath('/theleague/franchises', hideLeaguePrefix));
}

const team = (leagueConfig.teams as any[]).find((t) => t.franchiseId === id);

// franchiseId → display name lookup, used by H2H/blowout opponent labels.
const franchiseNameLookup: Record<string, string> = Object.fromEntries(
  (leagueConfig.teams as any[]).map((t) => [
    t.franchiseId,
    t.nameMedium ?? t.name ?? t.franchiseId,
  ])
);

// Many older config history entries point at retired theleague.us/
// mfladdons.com icon URLs that 404. Resolve every year-by-year row to a
// local /assets icon: prefer one whose franchise NAME matches the row
// (so a "Midwestside Connection" row rendered for 0011's 2010-2015
// stint on franchise 0010 still gets the Midwestside icon), otherwise
// fall back to the row's source franchise per-id icon.
const normalize = (s: string): string =>
  (s || '').trim().toLowerCase().replace(/^the\s+/, '').replace(/\s+/g, ' ');

const localIcon = (path: string | undefined): boolean =>
  !!path && path.startsWith('/assets/');

const nameToIconLookup: Record<string, string> = {};
for (const t of leagueConfig.teams as any[]) {
  if (localIcon(t.icon)) nameToIconLookup[normalize(t.name)] = t.icon;
}

const resolveRowIcon = (s: any): string => {
  if (localIcon(s.icon)) return s.icon!;
  const byName = nameToIconLookup[normalize(s.name || '')];
  if (byName) return byName;
  const sourceId = s.sourceFranchiseId ?? id;
  return `/assets/theleague/icons/${sourceId}.png`;
};

// Build eras keyed by NAME CHANGES only — config history entries that share
// the current name (or each other) are banner refreshes, not real eras, so
// they get merged into one continuous span.
type Era = {
  name: string;
  nameMedium?: string;
  yearStart: number;
  yearEnd: number;
  banner?: string;
  icon?: string;
  isCurrent: boolean;
  sourceFranchiseId?: string | null;
};

// Resolve the identity (name/banner/icon) for a given franchise ID + year by
// reading its config history. Used when one team's owner held a different
// franchise ID for some years.
const lookupIdentityFor = (franchiseId: string, year: number) => {
  const t = (leagueConfig.teams as any[]).find((x) => x.franchiseId === franchiseId);
  if (!t) return null;
  if (Array.isArray(t.history)) {
    for (const h of t.history) {
      if (year >= h.yearStart && year <= h.yearEnd) {
        return { name: h.name, nameMedium: h.nameMedium ?? h.name, banner: h.banner, icon: h.icon };
      }
    }
  }
  return { name: t.name, nameMedium: t.nameMedium ?? t.name, banner: t.banner, icon: t.icon };
};
const normalizeIdentity = (s: string): string =>
  (s || '').trim().toLowerCase().replace(/^the\s+/, '').replace(/\s+/g, ' ');

const eras: Era[] = [];
const yearsForFranchise = fr.yearByYear.map((y: any) => y.year);
const minYear = Math.min(...yearsForFranchise);
const maxYear = Math.max(...yearsForFranchise);
const currentNorm = normalizeIdentity(team?.name ?? '');

// Group history entries by ownerEra (when set) so multiple aliases under one
// owner collapse to a single era card with a combined name like "Poker in
// the Rear / Generals". Entries without ownerEra fall back to name-grouping.
type EraGroup = { entries: any[]; key: string };
const groupHistory = (history: any[]): EraGroup[] => {
  const groups: EraGroup[] = [];
  for (const h of history) {
    const key = h.ownerEra != null ? `era:${h.ownerEra}` : `name:${normalizeIdentity(h.name)}`;
    const last = groups[groups.length - 1];
    if (last && last.key === key) {
      last.entries.push(h);
    } else {
      groups.push({ key, entries: [h] });
    }
  }
  return groups;
};

const buildEraFromGroup = (group: EraGroup): Era => {
  const tally = new Map<string, number>();
  for (const e of group.entries) {
    const span = e.yearEnd - e.yearStart + 1;
    tally.set(e.name, (tally.get(e.name) || 0) + span);
  }
  const sortedNames = Array.from(tally.entries()).sort((a, b) => b[1] - a[1]);
  const dominantName = sortedNames[0][0];
  const displayName =
    sortedNames.length > 1
      ? sortedNames.map(([n]) => n).join(' / ')
      : dominantName;
  const dominantEntry = group.entries.find((e) => e.name === dominantName) ?? group.entries[0];
  return {
    name: displayName,
    nameMedium: displayName,
    yearStart: Math.min(...group.entries.map((e: any) => e.yearStart)),
    yearEnd: Math.max(...group.entries.map((e: any) => e.yearEnd)),
    banner: dominantEntry.banner,
    icon: dominantEntry.icon,
    isCurrent: normalizeIdentity(dominantName) === currentNorm,
  };
};

const pushOrExtend = (entry: Era) => {
  const last = eras[eras.length - 1];
  // Only merge if the name AND the underlying franchise are the same — two
  // separate stints that share a name (e.g. Midwestside on 0010 then on
  // 0011) should remain visually distinct so the gap between them is
  // visible.
  if (
    last &&
    normalizeIdentity(last.name) === normalizeIdentity(entry.name) &&
    (last.sourceFranchiseId ?? null) === (entry.sourceFranchiseId ?? null)
  ) {
    last.yearEnd = Math.max(last.yearEnd, entry.yearEnd);
    last.yearStart = Math.min(last.yearStart, entry.yearStart);
    if (entry.isCurrent) last.isCurrent = true;
    last.banner = entry.banner ?? last.banner;
    last.icon = entry.icon ?? last.icon;
    return;
  }
  eras.push(entry);
};

if (Array.isArray(team?.ownerHistory) && team.ownerHistory.length > 0) {
  // Owner-driven era construction — one era per ownerHistory entry, with
  // the identity sourced from the relevant franchise's history config.
  // Keeps both stints (e.g. Midwestside Connection on 0010 in 2012-2015
  // and on 0011 in 2019+) on the same page.
  const sortedOwner = [...team.ownerHistory].sort((a: any, b: any) => a.yearStart - b.yearStart);
  for (const entry of sortedOwner) {
    const cap = Math.min(entry.yearEnd, maxYear, new Date().getFullYear());
    if (cap < entry.yearStart) continue;
    const midYear = entry.yearStart + Math.floor((cap - entry.yearStart) / 2);
    const ident = lookupIdentityFor(entry.franchiseId, midYear);
    if (!ident) continue;
    pushOrExtend({
      name: ident.name,
      nameMedium: ident.nameMedium,
      yearStart: entry.yearStart,
      yearEnd: entry.yearEnd >= 9999 ? 9999 : entry.yearEnd,
      banner: ident.banner ?? team.banner,
      icon: ident.icon ?? team.icon,
      isCurrent: entry.franchiseId === team.franchiseId && entry.yearEnd >= 9999,
      sourceFranchiseId: entry.franchiseId !== team.franchiseId ? entry.franchiseId : null,
    });
  }
} else if (Array.isArray(team?.history) && team.history.length > 0) {
  for (const group of groupHistory(team.history)) {
    pushOrExtend(buildEraFromGroup(group));
  }
  const earliestHistoryYear = Math.min(...team.history.map((h: any) => h.yearStart));
  const latestHistoryYear = Math.max(...team.history.map((h: any) => h.yearEnd));
  // Append a current era covering the years after the latest config entry.
  // If the current name matches the most recent history entry, this just
  // extends that era's yearEnd via pushOrExtend.
  if (latestHistoryYear < maxYear || latestHistoryYear < new Date().getFullYear()) {
    pushOrExtend({
      name: team.name,
      nameMedium: team.nameMedium ?? team.name,
      yearStart: latestHistoryYear + 1,
      yearEnd: 9999,
      banner: team.banner,
      icon: team.icon,
      isCurrent: true,
    });
  }
  if (minYear < earliestHistoryYear) {
    eras.unshift({
      name: 'Earlier eras',
      nameMedium: 'Earlier eras',
      yearStart: minYear,
      yearEnd: earliestHistoryYear - 1,
      banner: undefined,
      icon: undefined,
      isCurrent: false,
    });
  }
} else if (team) {
  eras.push({
    name: team.name,
    nameMedium: team.nameMedium ?? team.name,
    yearStart: minYear,
    yearEnd: 9999,
    banner: team.banner,
    icon: team.icon,
    isCurrent: true,
  });
}
eras.sort((a, b) => a.yearStart - b.yearStart);

function eraForYear(year: number): Era | null {
  return eras.find((e) => year >= e.yearStart && year <= e.yearEnd) ?? null;
}

// Career derived stats
const totalGames = fr.careerWins + fr.careerLosses + fr.careerTies;
const winPct = totalGames
  ? ((fr.careerWins + fr.careerTies * 0.5) / totalGames).toFixed(3).replace(/^0/, '')
  : '.000';
const recordString = fr.careerTies > 0
  ? `${fr.careerWins}-${fr.careerLosses}-${fr.careerTies}`
  : `${fr.careerWins}-${fr.careerLosses}`;

const ppg = totalGames ? (fr.careerPointsFor / totalGames).toFixed(1) : '0.0';

// Per-era career stats
const eraStats = eras.map((era) => {
  const seasons = fr.yearByYear.filter((y: any) => y.year >= era.yearStart && y.year <= era.yearEnd);
  const w = seasons.reduce((s: number, y: any) => s + y.wins, 0);
  const l = seasons.reduce((s: number, y: any) => s + y.losses, 0);
  const t = seasons.reduce((s: number, y: any) => s + y.ties, 0);
  const pf = seasons.reduce((s: number, y: any) => s + y.pointsFor, 0);
  const champs = fr.championships.filter((y: number) => y >= era.yearStart && y <= era.yearEnd);
  const divTitles = fr.divisionTitles.filter((d: any) => d.year >= era.yearStart && d.year <= era.yearEnd);
  const mvps = fr.mvpAwards.filter((a: any) => a.year >= era.yearStart && a.year <= era.yearEnd);
  const jerrys = fr.jerryJonesAwards.filter((a: any) => a.year >= era.yearStart && a.year <= era.yearEnd);
  const osweilers = fr.brockOsweilerAwards.filter((a: any) => a.year >= era.yearStart && a.year <= era.yearEnd);
  return { era, seasons, w, l, t, pf, champs, divTitles, mvps, jerrys, osweilers };
});

const playoffResultLabel: Record<string, string> = {
  'champion': '🏆 Champion',
  'runner-up': '🥈 Runner-up',
  'third-place': '🥉 3rd place',
  'playoffs': 'Playoffs',
  'missed': '—',
};

const formatRecord = (w: number, l: number, t: number) =>
  t > 0 ? `${w}-${l}-${t}` : `${w}-${l}`;

const formatCurrency = (n: number) => `$${(n / 1_000_000).toFixed(1)}M`;

// Top rivals — opponents with the most-intense shared history under the
// current owners. Scoring blends total games, win/loss closeness, and a
// playoff-meeting bonus; a 4-game floor filters out one-off matchups.
type RivalEntry = {
  opponentId: string;
  wins: number;
  losses: number;
  ties: number;
  games: number;
  playoffGames: number;
  intensity: number;
};
const rivalEntries: RivalEntry[] = [];
const matchupHistory: Record<string, any[]> = (fr.matchupHistory || {}) as any;
for (const oppId of Object.keys(matchupHistory)) {
  if (oppId === id) continue; // skip self-matches caused by ownerHistory cross-attribution
  const meetings = (matchupHistory[oppId] || []).filter((m) => m.bothAttributed);
  if (meetings.length < 4) continue;
  let wins = 0, losses = 0, ties = 0, playoffGames = 0;
  for (const m of meetings) {
    if (m.score > m.opponentScore) wins++;
    else if (m.score < m.opponentScore) losses++;
    else ties++;
    if (m.isPlayoff) playoffGames++;
  }
  const totalDecided = wins + losses + ties;
  const closeness = totalDecided > 0 ? 1 - Math.abs(wins - losses) / totalDecided : 0;
  const intensity = closeness * Math.log2(1 + meetings.length + playoffGames * 3);
  rivalEntries.push({
    opponentId: oppId,
    wins, losses, ties,
    games: meetings.length,
    playoffGames,
    intensity,
  });
}
rivalEntries.sort((a, b) => b.intensity - a.intensity);
const topRivals = rivalEntries.slice(0, 5);

const opponentMeta: Record<string, any> = Object.fromEntries(
  (leagueConfig.teams as any[]).map((t) => [
    t.franchiseId,
    {
      name: t.name,
      nameMedium: t.nameMedium ?? t.name,
      nameShort: t.nameShort ?? t.nameMedium ?? t.name,
      icon: t.icon,
      color: t.color,
    },
  ])
);

const canonicalRivalryPair = (a: string, b: string): string =>
  [a, b].sort().join('-vs-');

// Trade ledger — every trade involving this franchise, grouped by year for
// rendering. Trades are stored in `fr.trades` oldest-first (see
// scripts/compute-franchise-history.mjs); display newest-first.
const playerNames = ((franchiseHistory as any).playerNames ?? {}) as Record<
  string,
  { name: string; position?: string; team?: string }
>;
const franchiseShortName = (fid: string): string => {
  const meta = opponentMeta[fid];
  return meta?.nameShort ?? meta?.nameMedium ?? meta?.name ?? fid;
};
const formatAsset = (code: string) => formatTradeAsset(code, playerNames, franchiseShortName);

type FranchiseTrade = {
  year: number;
  timestamp: number;
  partnerId: string;
  gaveUp: string[];
  received: string[];
  comments: string;
  bothAttributed: boolean;
};
const allTrades: FranchiseTrade[] = ((fr.trades as FranchiseTrade[]) || []).filter(
  (t) => t.partnerId !== id
);
const tradesByYear = new Map<number, FranchiseTrade[]>();
for (const t of allTrades) {
  if (!tradesByYear.has(t.year)) tradesByYear.set(t.year, []);
  tradesByYear.get(t.year)!.push(t);
}
const tradeYearGroups = Array.from(tradesByYear.entries())
  .map(([year, trades]) => ({
    year,
    trades: trades.slice().sort((a, b) => b.timestamp - a.timestamp),
  }))
  .sort((a, b) => b.year - a.year);

const tradeDateLabel = (t: FranchiseTrade): string => {
  if (!t.timestamp) return String(t.year);
  return new Date(t.timestamp * 1000).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

// Draft + auction history (Phase 4). Both are pre-sorted oldest-first by the
// aggregator; we display newest year first with the most recent year auto-
// expanded, matching the trade-ledger layout.
type FranchiseDraftPick = {
  year: number;
  round: number;
  pick: number;
  playerId: string;
  viaTrade: boolean;
  comments: string;
  timestamp: number;
};
type FranchiseAuctionWin = {
  year: number;
  playerId: string;
  winningBid: number;
  timestamp: number;
};

const groupByYearDesc = <T extends { year: number }>(items: T[]): { year: number; items: T[] }[] => {
  const m = new Map<number, T[]>();
  for (const it of items) {
    if (!m.has(it.year)) m.set(it.year, []);
    m.get(it.year)!.push(it);
  }
  return Array.from(m.entries())
    .map(([year, items]) => ({ year, items }))
    .sort((a, b) => b.year - a.year);
};

const draftPicks: FranchiseDraftPick[] = (fr.draftPicks as FranchiseDraftPick[]) || [];
const draftYearGroups = groupByYearDesc(draftPicks).map((g) => ({
  year: g.year,
  items: g.items.slice().sort((a, b) => a.round - b.round || a.pick - b.pick),
}));

const auctionWins: FranchiseAuctionWin[] = (fr.auctionWins as FranchiseAuctionWin[]) || [];
const auctionYearGroups = groupByYearDesc(auctionWins).map((g) => ({
  year: g.year,
  items: g.items.slice().sort((a, b) => b.winningBid - a.winningBid),
  totalSpend: g.items.reduce((s, a) => s + a.winningBid, 0),
}));

const formatPlayerLabel = (playerId: string): string => {
  const meta = playerNames[playerId];
  if (meta) return `${meta.name}${meta.position ? ` (${meta.position})` : ''}`;
  return `Player #${playerId}`;
};

const formatBid = (n: number): string => {
  if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `$${(n / 1_000).toFixed(0)}K`;
  return `$${n}`;
};
---

<TheLeagueLayout title={`${fr.currentName} — Franchise History`}>
  <article class="franchise-detail" style={fr.currentColor ? `--accent: ${fr.currentColor};` : ''}>
    <Breadcrumbs items={[
      { label: 'The League', href: '/theleague' },
      { label: 'Franchises', href: '/theleague/franchises' },
      { label: fr.currentNameMedium || fr.currentName },
    ]} />

    <header class="hero">
      {fr.currentBanner && (
        <div class="hero-banner">
          <img src={fr.currentBanner} alt="" />
          {fr.championships.length > 0 && (
            <div class="crown" title={`${fr.championships.length}x Champion`}>
              <span class="crown-icon" aria-hidden="true">🏆</span>
              <span class="crown-count">{fr.championships.length}</span>
            </div>
          )}
        </div>
      )}
      <div class="hero-text">
        <h1>{fr.currentName}</h1>
        {fr.currentDivision && <p class="meta">{fr.currentDivision} Division · est. {minYear}</p>}
        <ul class="badges-bar">
          {fr.championships.length > 0 && (
            <li class="badge badge--championship">
              <span aria-hidden="true">🏆</span>
              {fr.championships.length}x League Title{fr.championships.length > 1 ? 's' : ''}
              <span class="badge-detail">{fr.championships.join(', ')}</span>
            </li>
          )}
          {fr.runnerUps?.length > 0 && (
            <li class="badge badge--runnerup">
              <span aria-hidden="true">🥈</span>
              {fr.runnerUps.length}x Runner-up
              <span class="badge-detail">{fr.runnerUps.join(', ')}</span>
            </li>
          )}
          {fr.divisionTitles.length > 0 && (
            <li class="badge badge--division">
              <span aria-hidden="true">🛡</span>
              {fr.divisionTitles.length}x Division Title{fr.divisionTitles.length > 1 ? 's' : ''}
            </li>
          )}
          {fr.mvpAwards.length > 0 && (
            <li class="badge badge--mvp">
              <span aria-hidden="true">⭐</span>
              {fr.mvpAwards.length}x MVP
            </li>
          )}
          {fr.jerryJonesAwards.length > 0 && (
            <li class="badge badge--jerry">
              <span aria-hidden="true">💸</span>
              {fr.jerryJonesAwards.length}x Jerry Jones
            </li>
          )}
          {fr.brockOsweilerAwards.length > 0 && (
            <li class="badge badge--osweiler">
              <span aria-hidden="true">📉</span>
              {fr.brockOsweilerAwards.length}x Brock Osweiler
            </li>
          )}
        </ul>
      </div>
    </header>

    <section class="quick-stats">
      <div class="stat">
        <div class="stat-label">All-Time Record</div>
        <div class="stat-value">{recordString}</div>
        <div class="stat-sub">{winPct} win pct</div>
      </div>
      <div class="stat">
        <div class="stat-label">Seasons</div>
        <div class="stat-value">{fr.yearsActive}</div>
        <div class="stat-sub">{minYear}–{maxYear}</div>
      </div>
      <div class="stat">
        <div class="stat-label">Total Points</div>
        <div class="stat-value">{Math.round(fr.careerPointsFor).toLocaleString()}</div>
        <div class="stat-sub">{ppg} ppg</div>
      </div>
      <div class="stat">
        <div class="stat-label">Playoff Apps</div>
        <div class="stat-value">{fr.playoffAppearances}</div>
        <div class="stat-sub">{fr.championships.length} title{fr.championships.length === 1 ? '' : 's'}</div>
      </div>
    </section>

    {(fr.highlights?.highestSingleGame || fr.highlights?.lowestSingleGame || fr.highlights?.biggestBlowoutWin || fr.highlights?.biggestBlowoutLoss) && (
      <section class="highlights">
        <h2>Single-Game Highlights</h2>
        <div class="highlight-grid">
          {fr.highlights.highestSingleGame && (
            <div class="highlight">
              <div class="hl-label">Highest Score</div>
              <div class="hl-value">{fr.highlights.highestSingleGame.score.toFixed(2)}</div>
              <div class="hl-context">Week {fr.highlights.highestSingleGame.week}, {fr.highlights.highestSingleGame.year}</div>
            </div>
          )}
          {fr.highlights.lowestSingleGame && (
            <div class="highlight">
              <div class="hl-label">Lowest Score</div>
              <div class="hl-value">{fr.highlights.lowestSingleGame.score.toFixed(2)}</div>
              <div class="hl-context">Week {fr.highlights.lowestSingleGame.week}, {fr.highlights.lowestSingleGame.year}</div>
            </div>
          )}
          {fr.highlights.biggestBlowoutWin && (
            <div class="highlight highlight--win">
              <div class="hl-label">Biggest Blowout Win</div>
              <div class="hl-value">+{fr.highlights.biggestBlowoutWin.margin.toFixed(2)}</div>
              <div class="hl-context">
                {fr.highlights.biggestBlowoutWin.score.toFixed(1)}–{fr.highlights.biggestBlowoutWin.opponentScore.toFixed(1)}
                {' vs '}
                {franchiseNameLookup[fr.highlights.biggestBlowoutWin.opponentFranchiseId] ?? fr.highlights.biggestBlowoutWin.opponentFranchiseId}
                <br />Week {fr.highlights.biggestBlowoutWin.week}, {fr.highlights.biggestBlowoutWin.year}
              </div>
            </div>
          )}
          {fr.highlights.biggestBlowoutLoss && (
            <div class="highlight highlight--loss">
              <div class="hl-label">Biggest Blowout Loss</div>
              <div class="hl-value">−{fr.highlights.biggestBlowoutLoss.margin.toFixed(2)}</div>
              <div class="hl-context">
                {fr.highlights.biggestBlowoutLoss.score.toFixed(1)}–{fr.highlights.biggestBlowoutLoss.opponentScore.toFixed(1)}
                {' vs '}
                {franchiseNameLookup[fr.highlights.biggestBlowoutLoss.opponentFranchiseId] ?? fr.highlights.biggestBlowoutLoss.opponentFranchiseId}
                <br />Week {fr.highlights.biggestBlowoutLoss.week}, {fr.highlights.biggestBlowoutLoss.year}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    {topRivals.length > 0 && (
      <section class="rivals">
        <h2>Top Rivals</h2>
        <p class="dim small">
          Most-intense shared history under the current owners — closeness, total meetings, and playoff stakes weighted.
        </p>
        <ul class="rivals-list">
          {topRivals.map((r) => {
            const meta = opponentMeta[r.opponentId];
            const name = meta?.nameShort || meta?.nameMedium || meta?.name || r.opponentId;
            const iconSrc = meta?.icon || `/assets/theleague/icons/${r.opponentId}.png`;
            return (
              <li>
                <a class="rival-card" href={resolveLeaguePath(`/theleague/rivalries/${canonicalRivalryPair(id!, r.opponentId)}`, hideLeaguePrefix)}>
                  <img src={iconSrc} alt="" class="rival-icon" loading="lazy" />
                  <div class="rival-text">
                    <div class="rival-name">{name}</div>
                    <div class="rival-record">
                      {formatRecord(r.wins, r.losses, r.ties)}
                      <span class="dim"> · {r.games} game{r.games === 1 ? '' : 's'}</span>
                    </div>
                    {r.playoffGames > 0 && (
                      <div class="rival-playoff">
                        🔥 {r.playoffGames} playoff
                      </div>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
        <p class="dim small">
          <a href={resolveLeaguePath('/theleague/rivalries', hideLeaguePrefix)}>See full rivalry matrix →</a>
        </p>
      </section>
    )}

    {allTrades.length > 0 && (
      <section class="trades-section">
        <h2>Trade Ledger ({allTrades.length})</h2>
        <p class="dim small">
          Every trade involving the current owner — grouped by year, newest first.
        </p>
        {tradeYearGroups.map((group) => (
          <details class="trade-year" open={group === tradeYearGroups[0]}>
            <summary>
              <span class="trade-year-label">{group.year}</span>
              <span class="dim small">{group.trades.length} trade{group.trades.length === 1 ? '' : 's'}</span>
            </summary>
            <ul class="trade-list">
              {group.trades.map((t) => {
                const partnerMeta = opponentMeta[t.partnerId];
                const partnerName =
                  partnerMeta?.nameShort ?? partnerMeta?.nameMedium ?? partnerMeta?.name ?? t.partnerId;
                const partnerIcon = partnerMeta?.icon ?? `/assets/theleague/icons/${t.partnerId}.png`;
                const rivalryHref = resolveLeaguePath(
                  `/theleague/rivalries/${canonicalRivalryPair(id!, t.partnerId)}`,
                  hideLeaguePrefix
                );
                return (
                  <li class="trade">
                    <div class="trade-head">
                      <a class="trade-partner" href={rivalryHref} title={`Rivalry vs ${partnerName}`}>
                        <img src={partnerIcon} alt="" class="partner-icon" loading="lazy" />
                        <span class="partner-name">{partnerName}</span>
                      </a>
                      <span class="dim small trade-date">{tradeDateLabel(t)}</span>
                    </div>
                    <div class="trade-cols">
                      <div class="trade-col">
                        <div class="t-name">Sent</div>
                        {t.gaveUp.length > 0 ? (
                          <ul>{t.gaveUp.map((c) => <li>{formatAsset(c)}</li>)}</ul>
                        ) : (
                          <p class="dim small">—</p>
                        )}
                      </div>
                      <div class="trade-col">
                        <div class="t-name">Received</div>
                        {t.received.length > 0 ? (
                          <ul>{t.received.map((c) => <li>{formatAsset(c)}</li>)}</ul>
                        ) : (
                          <p class="dim small">—</p>
                        )}
                      </div>
                    </div>
                    {t.comments && <p class="trade-comments dim small">"{t.comments}"</p>}
                  </li>
                );
              })}
            </ul>
          </details>
        ))}
      </section>
    )}

    {draftPicks.length > 0 && (
      <section class="draft-section">
        <h2>Draft History ({draftPicks.length})</h2>
        <p class="dim small">
          Every rookie draft pick made by the current owner — grouped by year, in draft order.
        </p>
        {draftYearGroups.map((group) => (
          <details class="year-group" open={group === draftYearGroups[0]}>
            <summary>
              <span class="year-label">{group.year}</span>
              <span class="dim small">{group.items.length} pick{group.items.length === 1 ? '' : 's'}</span>
            </summary>
            <ol class="pick-list">
              {group.items.map((p) => (
                <li class="pick-row">
                  <span class="pick-slot">{p.round}.{String(p.pick).padStart(2, '0')}</span>
                  <span class="pick-player">{formatPlayerLabel(p.playerId)}</span>
                  {p.viaTrade && <span class="pick-tag" title="Pick acquired via trade">via trade</span>}
                </li>
              ))}
            </ol>
          </details>
        ))}
      </section>
    )}

    {auctionWins.length > 0 && (
      <section class="auction-section">
        <h2>Auction History ({auctionWins.length})</h2>
        <p class="dim small">
          Every auction win by the current owner — grouped by year, biggest bid first.
        </p>
        {auctionYearGroups.map((group) => (
          <details class="year-group" open={group === auctionYearGroups[0]}>
            <summary>
              <span class="year-label">{group.year}</span>
              <span class="dim small">{group.items.length} win{group.items.length === 1 ? '' : 's'} · {formatBid(group.totalSpend)} spent</span>
            </summary>
            <ol class="pick-list">
              {group.items.map((a) => (
                <li class="pick-row">
                  <span class="pick-bid">{formatBid(a.winningBid)}</span>
                  <span class="pick-player">{formatPlayerLabel(a.playerId)}</span>
                </li>
              ))}
            </ol>
          </details>
        ))}
      </section>
    )}

    {fr.yearByYear && fr.yearByYear.length > 0 && (
      <section class="scoring-chart-section">
        <h2>Points by Season</h2>
        {(() => {
          const seasons = [...fr.yearByYear].sort((a: any, b: any) => a.year - b.year);
          const max = Math.max(...seasons.map((s: any) => s.pointsFor));
          const min = Math.min(...seasons.map((s: any) => s.pointsFor));
          const span = max - min || 1;
          const barWidth = 100 / seasons.length;
          return (
            <div class="scoring-chart" role="img" aria-label="Points scored per season">
              {seasons.map((s: any) => {
                const heightPct = ((s.pointsFor - min) / span) * 90 + 10;
                const isChamp = fr.championships.includes(s.year);
                const isRunnerUp = fr.runnerUps?.includes(s.year);
                return (
                  <div
                    class={`bar ${isChamp ? 'bar--champ' : ''} ${isRunnerUp ? 'bar--runnerup' : ''}`}
                    style={`height: ${heightPct.toFixed(1)}%; width: ${barWidth.toFixed(2)}%;`}
                    title={`${s.year}: ${Math.round(s.pointsFor)} pts (${formatRecord(s.wins, s.losses, s.ties)})${isChamp ? ' 🏆' : isRunnerUp ? ' 🥈' : ''}`}
                  >
                    <span class="bar-label">{String(s.year).slice(-2)}</span>
                  </div>
                );
              })}
            </div>
          );
        })()}
        <p class="dim small">Bar height = points-for. 🏆 = championship · 🥈 = runner-up. Hover/tap for season detail.</p>
      </section>
    )}

    <section class="awards">
      <h2>Awards Honor Roll</h2>
      <div class="awards-grid">
        {fr.championships.length > 0 && (
          <div class="award-card award--championship">
            <h3>🏆 League Titles ({fr.championships.length})</h3>
            <ul>{fr.championships.map((y: number) => <li>{y}</li>)}</ul>
          </div>
        )}
        {fr.runnerUps?.length > 0 && (
          <div class="award-card award--runnerup">
            <h3>🥈 Runners-up ({fr.runnerUps.length})</h3>
            <ul>{fr.runnerUps.map((y: number) => <li>{y}</li>)}</ul>
          </div>
        )}
        {fr.divisionTitles.length > 0 && (
          <div class="award-card award--division">
            <h3>🛡 Division Titles ({fr.divisionTitles.length})</h3>
            <ul>{fr.divisionTitles.map((d: any) => <li>{d.year} · {d.divisionName}</li>)}</ul>
          </div>
        )}
        {fr.mvpAwards.length > 0 && (
          <div class="award-card award--mvp">
            <h3>⭐ MVP Awards ({fr.mvpAwards.length})</h3>
            <ul>
              {fr.mvpAwards.map((a: any) => (
                <li>{a.year} · {a.playerName} ({a.position}) · {a.points.toFixed(1)} pts at {formatCurrency(a.salary)}</li>
              ))}
            </ul>
          </div>
        )}
        {fr.jerryJonesAwards.length > 0 && (
          <div class="award-card award--jerry">
            <h3>💸 Jerry Jones Awards ({fr.jerryJonesAwards.length})</h3>
            <p class="award-note dim small">Worst team starting-lineup cost-per-point that season.</p>
            <ul>
              {fr.jerryJonesAwards.map((a: any) => (
                <li>{a.year} · {formatCurrency(a.totalSalary)} for {a.totalPoints.toFixed(0)} pts</li>
              ))}
            </ul>
          </div>
        )}
        {fr.brockOsweilerAwards.length > 0 && (
          <div class="award-card award--osweiler">
            <h3>📉 Brock Osweiler Awards ({fr.brockOsweilerAwards.length})</h3>
            <p class="award-note dim small">Worst single player $/point at $1.5M+ salary that season.</p>
            <ul>
              {fr.brockOsweilerAwards.map((a: any) => (
                <li>{a.year} · {a.playerName} ({a.position}) · {a.points.toFixed(1)} pts at {formatCurrency(a.salary)}</li>
              ))}
            </ul>
          </div>
        )}
        {fr.championships.length === 0 && fr.divisionTitles.length === 0
          && fr.mvpAwards.length === 0 && fr.jerryJonesAwards.length === 0
          && fr.brockOsweilerAwards.length === 0 && (
          <div class="award-card empty">
            <p class="dim">No award honors yet.</p>
          </div>
        )}
      </div>
    </section>

    {fr.badges && fr.badges.length > 0 && (
      <section class="badges-section">
        <h2>Badges</h2>
        <p class="dim small">
          Career milestones, single-season feats, and league records held by this franchise.
        </p>
        {['career', 'season', 'game', 'trade'].map((tier) => {
          const tierBadges = fr.badges.filter((b: any) => b.tier === tier);
          if (tierBadges.length === 0) return null;
          const tierLabel = tier === 'career'
            ? 'Career'
            : tier === 'season'
            ? 'Single-Season'
            : tier === 'game'
            ? 'Single-Game'
            : 'Trade';
          return (
            <div class="badge-tier">
              <h3 class="badge-tier-label">{tierLabel}</h3>
              <ul class="badge-grid">
                {tierBadges.map((b: any) => (
                  <li class={`badge-card badge-card--${b.tier}`} title={b.description}>
                    <span class="badge-icon" aria-hidden="true">{b.icon}</span>
                    <div class="badge-text">
                      <div class="badge-name">{b.name}</div>
                      <div class="badge-awards">
                        {b.awards.map((a: any, i: number) => {
                          const parts = [];
                          if (a.year) parts.push(a.year);
                          if (a.week) parts.push(`Wk ${a.week}`);
                          if (a.value != null) parts.push(`${a.value}${a.suffix ? ' ' + a.suffix : ''}`);
                          if (a.label && parts.length === 0) parts.push(a.label);
                          else if (a.label) parts.push(`(${a.label})`);
                          return (
                            <span class="badge-award" key={i}>{parts.join(' · ') || '—'}</span>
                          );
                        })}
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </section>
    )}

    <section class="eras">
      <h2>Era History</h2>
      {eraStats
        .filter(({ seasons }) => seasons.length > 0)
        .map(({ era, seasons, w, l, t, pf, champs, divTitles, mvps, jerrys, osweilers }) => (
        <div class="era" id={`era-${era.yearStart}`}>
          <div class="era-header">
            {era.icon && <img src={resolveRowIcon(era)} alt="" class="era-icon" />}
            <div>
              <h3>
                {era.name}
                {era.isCurrent && <span class="current-tag">Current</span>}
                {era.sourceFranchiseId && (
                  <span class="prior-franchise-tag">as franchise {era.sourceFranchiseId}</span>
                )}
              </h3>
              <p class="meta">
                {era.yearStart === era.yearEnd || era.yearEnd === 9999
                  ? `${era.yearStart}–${era.yearEnd === 9999 ? 'present' : era.yearEnd}`
                  : `${era.yearStart}–${era.yearEnd}`}
                {seasons.length > 0 && ` · ${seasons.length} season${seasons.length === 1 ? '' : 's'} · ${formatRecord(w, l, t)}`}
              </p>
            </div>
          </div>
          {seasons.length > 0 ? (
            <div class="year-by-year-scroll">
            <table class="year-by-year">
              <thead>
                <tr>
                  <th>Year</th>
                  <th>Identity</th>
                  <th>Record</th>
                  <th>Points</th>
                  <th>Reg. Rank</th>
                  <th>Result</th>
                </tr>
              </thead>
              <tbody>
                {seasons.sort((a: any, b: any) => b.year - a.year).map((s: any) => (
                  <tr>
                    <td>{s.year}</td>
                    <td>
                      <img src={resolveRowIcon(s)} alt="" class="row-icon" loading="lazy" />
                      {s.nameMedium || s.name}
                    </td>
                    <td>{formatRecord(s.wins, s.losses, s.ties)}</td>
                    <td>{Math.round(s.pointsFor).toLocaleString()}</td>
                    <td>{s.regSeasonRank ? `#${s.regSeasonRank}` : '—'}</td>
                    <td>
                      {playoffResultLabel[s.playoffResult] ?? '—'}
                      {s.wonDivision && <span class="div-tag">🛡 {s.divisionName}</span>}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
            </div>
          ) : (
            <p class="dim">No games played in this era yet.</p>
          )}
          {(champs.length > 0 || divTitles.length > 0 || mvps.length > 0 || jerrys.length > 0 || osweilers.length > 0) && (
            <div class="era-awards">
              {champs.length > 0 && <span class="era-award">🏆 {champs.length} title{champs.length === 1 ? '' : 's'}</span>}
              {divTitles.length > 0 && <span class="era-award">🛡 {divTitles.length} division</span>}
              {mvps.length > 0 && <span class="era-award">⭐ {mvps.length} MVP</span>}
              {jerrys.length > 0 && <span class="era-award">💸 {jerrys.length} Jerry Jones</span>}
              {osweilers.length > 0 && <span class="era-award">📉 {osweilers.length} Osweiler</span>}
            </div>
          )}
        </div>
      ))}
    </section>

    <p class="footnote">
      <a href={resolveLeaguePath('/theleague/franchises', hideLeaguePrefix)}>← All franchises</a>
    </p>
  </article>
</TheLeagueLayout>

