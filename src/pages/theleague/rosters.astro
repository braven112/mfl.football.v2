  /* Eligible: blue left-border chip — the primary interactive state */
  :global(.yrs-chip--eligible) {
    cursor: pointer;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid rgba(28, 73, 124, 0.15);
