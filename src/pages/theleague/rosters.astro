              _rawPlayer: rawPlayer,
            });
          });
        });


        // Eligible years cell clicks — open declaration modal
        applyEligibilityStyling();

        // Injury indicator buttons
        document.querySelectorAll('.injury-indicator').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
