          const injuryBadge = player.injuryStatus
            ? `<button class="injury-indicator" data-player-id="${player.id}" data-player-name="${player.name}" data-injury-status="${player.injuryStatus}" data-injury-body-part="${player.injuryBodyPart || ''}" title="${player.injuryStatus}${player.injuryBodyPart ? ` - ${player.injuryBodyPart}` : ''}">(${player.injuryStatus.substring(0, 1)})</button>`
