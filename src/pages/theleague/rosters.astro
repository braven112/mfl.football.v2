    const getSortValue = (player, key) => {
      switch (key) {
        case 'oppRank': return player.oppStats?.rank ?? Infinity;
        case 'spreadAmount': return parseFloat(player.gameOdds?.spreadAmount) || 0;
        case 'overUnder': return parseFloat(player.gameOdds?.overUnder) || 0;
        case 'temperature': return player.gameOdds?.weather?.temperature ?? 0;
        case 'avgRecent': return parseFloat(player.avgRecent) || 0;
        case 'avgSeason': return parseFloat(player.avgSeason) || 0;
        case 'oppAvg': return parseFloat(player.oppStats?.avg) || 0;
        case 'projectedPoints': return parseFloat(player.projectedPoints) || 0;
        case 'topRanking': {
          // Use the top ranking from imported rankings (stored in window.__rosterRankingLookup)
          const rl = window.__rosterRankingLookup;
          if (!rl || !rl.columns.length) return Infinity;
          const rank = rl.byImport.get(rl.columns[0].importId)?.get(player.id);
          return rank ?? Infinity;
        }
        case 'contractYears': {
          const yrs = player.contractYears ?? 0;
          // 0 years = UFA/no contract → push to bottom
          return yrs > 0 ? yrs : Infinity;
        }
        case 'salary': {
          const sal = player.salary ?? 0;
          // No salary → push to bottom
          return sal > 0 ? sal : Infinity;
        }
        default: {
          // Handle salary_N keys (e.g. salary_0, salary_1, ...)
          const salaryMatch = key.match(/^salary_(\d+)$/);
          if (salaryMatch) {
            const yearIndex = parseInt(salaryMatch[1], 10);
            const yrs = player.contractYears ?? 0;
            const baseSal = player.salary ?? 0;
            const isUfa = !(yrs > yearIndex);
            const isFirstYearUfa = isUfa && yrs === yearIndex;
            const isFutureUfa = isUfa && yrs < yearIndex;
            if (isFutureUfa) {
              // Dash (—) → sort absolute last
              return Number.MAX_SAFE_INTEGER;
            }
            if (isFirstYearUfa) {
              // UFA → sort after real salaries but before dashes
              return Number.MAX_SAFE_INTEGER - 1;
            }
            // Has salary for this year — use escalated value
            return baseSal * Math.pow(1.10, yearIndex);
          }
          return 0;
        }
      }
    };

    const sortWithinGroups = (rows, sortKey, direction) => {
      // Default sort: re-sort by position then salary (original order)
      if (sortKey === 'position') {
        const tierOrder = ['active', 'practice', 'injured'];
        const tiers = {};
        tierOrder.forEach(t => tiers[t] = []);
        rows.forEach(player => {
          const tier = player.displayTag ?? 'active';
          if (!tiers[tier]) tiers[tier] = [];
          tiers[tier].push(player);
        });
        const sorted = [];
        tierOrder.forEach(tier => {
          tiers[tier].sort((a, b) => {
            const diff = getPositionRank(a.position ?? '') - getPositionRank(b.position ?? '');
            if (diff !== 0) return diff;
            return (b.salary ?? 0) - (a.salary ?? 0);
          });
          sorted.push(...tiers[tier]);
        });
        return annotateActiveStriping(
          annotateTierDividers(annotatePositionDividers(sorted))
        );
      }

      const tierOrder = ['active', 'practice', 'injured'];

      // Group by tier, then by position within each tier
      const tiers = {};
      tierOrder.forEach(t => tiers[t] = {});

      rows.forEach(player => {
        const tier = player.displayTag ?? 'active';
        const pos = (player.position ?? '').toUpperCase();
        if (!tiers[tier]) tiers[tier] = {};
        if (!tiers[tier][pos]) tiers[tier][pos] = [];
        tiers[tier][pos].push(player);
      });

      // Sort within each position group
      const multiplier = direction === 'desc' ? -1 : 1;
      const sorted = [];

      tierOrder.forEach(tier => {
        // Maintain position order within each tier
        const positions = Object.keys(tiers[tier]).sort((a, b) =>
          getPositionRank(a) - getPositionRank(b)
        );
        positions.forEach(pos => {
          tiers[tier][pos].sort((a, b) => {
            const aVal = getSortValue(a, sortKey);
            const bVal = getSortValue(b, sortKey);
            // Push sentinel values (Infinity, MAX_SAFE_INTEGER, MAX_SAFE_INTEGER-1) to end always
            const SENTINEL = Number.MAX_SAFE_INTEGER - 1;
            const aIsSentinel = aVal >= SENTINEL || aVal === Infinity;
            const bIsSentinel = bVal >= SENTINEL || bVal === Infinity;
            if (aIsSentinel && bIsSentinel) return aVal - bVal; // UFA before dash
            if (aIsSentinel) return 1;
            if (bIsSentinel) return -1;
            return (aVal - bVal) * multiplier;
          });
          sorted.push(...tiers[tier][pos]);
        });
      });

      // Re-annotate dividers and striping
      return annotateActiveStriping(
        annotateTierDividers(annotatePositionDividers(sorted))
      );
    };

    const updateSortIndicators = (activeKey, direction) => {
