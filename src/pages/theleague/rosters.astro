                    </Fragment>
                  </PlayerCell>
                </td>

                {/* Coach Mode Cells */}
                <td data-label="Opp Rank" data-column="oppRank" class="coach-col" style="display:none">
                  {player.oppStats ? (
                    <span class={`rank-badge rank-tier-${Math.ceil(player.oppStats.rank / 8)}`}>
                      #{player.oppStats.rank}
                    </span>
                  ) : '-'}
                </td>
                <td data-label="Opponent" data-column="opponent" class="coach-col" style="display:none">
                  {player.opponent !== 'BYE' && player.gameOdds ? (
                    <div class="opponent-cell">
                      <div class="opponent-info">
                        <span class="vs-at">{player.gameOdds.isHome ? 'vs' : '@'}</span>
                        <img
                          src={getNflLogoUrl(player.gameOdds.opponent)}
                          alt={player.gameOdds.opponent}
                          class="opponent-logo"
                        />
                        <span class={`spread-badge ${!player.gameOdds.spreadAmount ? 'spread-neutral' : player.gameOdds.favoredTeam === player.gameOdds.opponent ? 'spread-underdog' : 'spread-favorite'}`}>
                        {!player.gameOdds.spreadAmount ? '-' : (player.gameOdds.favoredTeam === player.gameOdds.opponent ? '-' : '+') + player.gameOdds.spreadAmount}
                      </span>
                      </div>
                    </div>
                  ) : (
                    <span class="opponent-bye">BYE</span>
                  )}
                </td>
                <td data-label="O/U" data-column="ou" class="coach-col" style="display:none">
                  {player.gameOdds ? (
                    <span class="odds-total">{player.gameOdds.overUnder === 'N/A' ? '-' : player.gameOdds.overUnder}</span>
                  ) : (
                    <span class="odds-empty">-</span>
                  )}
                </td>
                <td data-label="Weather" data-column="weather" class="coach-col" style="display:none">
                  {player.gameOdds?.weather ? (
                    <div class="weather-cell">
                      <span class="weather-temp">{player.gameOdds.weather.temperature}°</span>
                      <span class="weather-icon" title={player.gameOdds.weather.displayValue}>
                        {getWeatherIcon(player.gameOdds.weather.displayValue)}
                      </span>
                    </div>
                  ) : (
                    <span class="weather-empty">-</span>
                  )}
                </td>
                {player.recentScores.map(scoreData => {
                  const score = parseFloat(scoreData.score);
                  const avg = parseFloat(player.avgSeason);
                  const isBetter = !isNaN(score) && !isNaN(avg) && score > avg;
                  const isWorse = !isNaN(score) && !isNaN(avg) && score < avg;

                  return (
                    <td data-label={`Wk ${scoreData.week}`} data-column={`trend-${scoreData.week}`} class="coach-col trend-week-col trend-cell" style="display:none">
                      <div class="trend-value">
                        {scoreData.score}
                        {isBetter && <span class="trend-arrow trend-arrow--up">↑</span>}
                        {isWorse && <span class="trend-arrow trend-arrow--down">↓</span>}
                      </div>
                    </td>
                  );
                })}
                <td data-label="Avg (L3)" data-column="avgRecent" class="coach-col" style="display:none; text-align: right;">
                  {(() => {
                    const recent = parseFloat(player.avgRecent);
                    const season = parseFloat(player.avgSeason);
                    const isBetter = !isNaN(recent) && !isNaN(season) && recent > season;
                    const isWorse = !isNaN(recent) && !isNaN(season) && recent < season;

                    return (
                      <div class="trend-value">
                        <span class="avg-points">{player.avgRecent}</span>
                        {isBetter && <span class="trend-arrow trend-arrow--up">↑</span>}
                        {isWorse && <span class="trend-arrow trend-arrow--down">↓</span>}
                      </div>
                    );
                  })()}
                </td>
                <td data-label="Avg (Szn)" data-column="avgSeason" class="coach-col" style="display:none; text-align: right;">
                  <span class="avg-points">{player.avgSeason}</span>
                </td>
                <td data-label="Opp Avg" data-column="oppAvg" class="coach-col" style="display:none">
                  <div class="trend-value">
                    {player.gameOdds?.opponent && (
                      <img
                        src={getNflLogoUrl(player.gameOdds.opponent)}
                        alt={player.gameOdds.opponent}
                        class="opponent-logo"
                        onerror="this.style.display='none'"
                      />
                    )}
                    {player.oppStats ? player.oppStats.avg : '-'}
                  </div>
                </td>
                <td data-label="Projected" data-column="projected" class="coach-col" style="display:none; text-align: right;">
                  <span class="proj-points">{player.projectedPoints}</span>
                </td>

                {/* GM Mode Cells */}
                <td data-label="Rank" data-column="rank" class="gm-col ranking-col ranking-cell"></td>
                <td data-label="Yrs" data-column="years" class="gm-col years-cell" data-player-id={player.id}>{player.contractYears || 0}</td>
                <td data-label="Actions" data-column="actions" class="actions-cell gm-col">
                  <button
                    class="ufa-action-btn"
                    data-player-id={player.id}
                    data-player-name={player.name}
                    data-player-position={player.position || ''}
                    data-player-nfl-team={player.nflTeam || ''}
                    data-player-nfl-logo={player.nflLogo || ''}
                    data-player-headshot={player.headshot || ''}
                    data-player-salary={player.salary || 0}
                    data-player-years={player.contractYears || 1}
                    data-player-injury-status={player.injuryStatus || ''}
                    data-player-franchise-id={player.franchiseId || ''}
                    title="Manage Contract"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
                    </svg>
                  </button>
                </td>
                {SALARY_YEARS.map((year, index) => {
                  const isUfa = !(player.contractYears > index);
                  const isFirstYearUfa = isUfa && player.contractYears === index;
                  const isFutureUfa = isUfa && player.contractYears < index;
                  const isTO = (player as any).contractInfo === 'TO';
                  const hasOptionWindow = isTO && (player.contractYears ?? 0) >= 2;
                  const isOptionExpired = isTO && (player.contractYears ?? 0) === 1;

                  let displayValue: any;
                  let cellClass = 'salary-cell gm-col';
                  let toOptionSalary: string | null = null;

                  if (isFirstYearUfa && hasOptionWindow) {
                    // Eligible TO slot — show "TO" badge, clickable in client-side
                    displayValue = 'TO';
                    cellClass += ' salary-cell--team-option salary-cell--team-option-eligible';
                  } else if (isFirstYearUfa && isOptionExpired) {
                    // Option window closed — show greyed-out top-10 salary (what was forfeited)
                    const pos = (player.position ?? '').toUpperCase();
                    const optSalary = frozenSalaryAverages?.teamOptionSalaries?.[pos] ?? 0;
                    displayValue = optSalary > 0 ? formatCurrency(optSalary) : 'UFA';
                    cellClass += ' salary-cell--team-option salary-cell--team-option-expired';
                  } else if (isFirstYearUfa) {
                    displayValue = 'UFA';
                    cellClass += ' salary-cell--ufa';
                  } else if (isFutureUfa) {
                    displayValue = '—';
                    cellClass += ' salary-cell--future-ufa';
                  } else {
                    // Apply 10% annual salary escalation for multi-year contracts
                    const baseSalary = player.salary ?? 0;
                    const escalatedSalary = baseSalary * Math.pow(1.10, index);
                    displayValue = formatCurrency(escalatedSalary);
                  }

                  return (
                    <td
                      data-label={year}
                      data-column={`year${index + 1}`}
                      class={cellClass}
                      data-player-id={isFirstYearUfa && hasOptionWindow ? player.id : undefined}
                    >
                      {displayValue}
                    </td>
                  );
                })}
              </tr>
            ))
          ) : (
            <tr>
              <td colspan={4 + SALARY_YEARS.length} class="roster-empty">
                This franchise has no players recorded for this season snapshot.
              </td>
            </tr>
          )}
          </tbody>
        </table>
      </div>
      <div class="roster-legend">
        <span>
          <span class="legend-swatch legend-swatch--active"></span>
