  /* --- YRS Chip: Interactive Contract Year Indicator --- */
  :global(.years-cell) {
    position: relative;
    white-space: nowrap;
  }

  :global(.yrs-chip) {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-variant-numeric: tabular-nums;
    font-family: inherit;
    font-size: inherit;
    border: none;
    background: transparent;
    padding: 0;
    cursor: default;
    line-height: 1;
  }

  :global(.yrs-chip__value) {
    color: var(--color-gray-700, #374151);
    font-weight: 400;
  }

  /* Eligible: blue left-border chip — the primary interactive state */
  :global(.yrs-chip--eligible) {
    cursor: pointer;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid rgba(28, 73, 124, 0.15);
    border-left: 2.5px solid var(--color-primary, #1c497c);
    border-radius: 4px;
    padding: 0.1875rem 0.375rem 0.1875rem 0.3125rem;
    transition: all 0.18s ease;
  }

  :global(.yrs-chip--eligible:hover) {
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border-color: rgba(28, 73, 124, 0.3);
    border-left-color: var(--color-primary, #1c497c);
    box-shadow: 0 1px 4px rgba(28, 73, 124, 0.15);
  }

  :global(.yrs-chip--eligible .yrs-chip__value) {
    color: var(--color-primary, #1c497c);
    font-weight: 700;
  }

  /* Pending: amber left-border chip — editable until deadline */
  :global(.yrs-chip--pending) {
    cursor: pointer;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 1px solid rgba(217, 119, 6, 0.15);
    border-left: 2.5px solid #d97706;
    border-radius: 4px;
    padding: 0.1875rem 0.375rem 0.1875rem 0.3125rem;
    transition: all 0.18s ease;
  }

  :global(.yrs-chip--pending:hover) {
    background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
    border-color: rgba(217, 119, 6, 0.3);
    border-left-color: #d97706;
    box-shadow: 0 1px 4px rgba(217, 119, 6, 0.15);
  }

  :global(.yrs-chip--pending .yrs-chip__value) {
    color: #92400e;
    font-weight: 700;
  }

  /* Approved: green accent, non-interactive */
  :global(.yrs-chip--approved .yrs-chip__value) {
    color: #059669;
    font-weight: 600;
  }

