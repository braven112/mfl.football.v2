---
/**
 * Team Rosters — Thin Shell
 *
 * Renders the page shell (team card, team icons, skeleton roster table) immediately.
 * Heavy data fetching and all client-side scripts are deferred via RosterDataIsland
 * using Astro 5 Server Islands (server:defer) so the shell appears instantly.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import { resolveLeaguePath } from '../../utils/nav-utils';
import leagueAssets from '../../data/theleague.assets.json';
import PlayerDetailsModal from '../../components/theleague/PlayerDetailsModal.astro';
import PlayerInjuryModal from '../../components/theleague/PlayerInjuryModal.astro';
import ContractDeclarationModal from '../../components/theleague/ContractDeclarationModal.astro';
import ContractDemoOverlay from '../../components/theleague/ContractDemoOverlay.astro';
import RosterDataIsland from '../../components/theleague/RosterDataIsland.astro';
import { spriteUrl } from '../../utils/sprite-url';
import {
  SALARY_YEARS,
  SALARY_CAP,
  ROSTER_LIMIT,
} from '../../utils/salary-calculations';
import {
  getTheLeaguePreference,
  setTheLeaguePreference,
  resolveTeamSelection,
} from '../../utils/team-preferences';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getAuthUser } from '../../utils/auth';

// Static team config — no API calls needed
const divisionOrder = ['Northwest', 'Southwest', 'Central', 'East'];

const teamsList = (leagueAssets.teams ?? [])
  .map((team) => ({
    id: team.id,
    name: team.name,
    division: team.division ?? '',
    icon: team.assets?.icons?.[0]?.relativePath ?? '',
  }))
  .sort((a, b) => {
    const divIndexA = divisionOrder.indexOf(a.division);
    const divIndexB = divisionOrder.indexOf(b.division);
    if (divIndexA !== divIndexB) return divIndexA - divIndexB;
    return a.name.localeCompare(b.name);
  });

const teamLookup = Object.fromEntries(teamsList.map((team) => [team.id, team]));

const currentLeagueYear = getCurrentLeagueYear();
const defaultSeason = String(currentLeagueYear);

// Auth + team resolution (quick — cookie/header checks only)
const authUser = getAuthUser(Astro.request);
const userFranchiseId = authUser?.franchiseId
  ? String(authUser.franchiseId).trim().padStart(4, '0')
  : null;

const myTeamParam = Astro.url?.searchParams?.get('myteam');
const franchiseParam =
  Astro.url?.searchParams?.get('franchise') ??
  Astro.url?.searchParams?.get('team') ??
  Astro.url?.searchParams?.get('franchiseId');

if (myTeamParam) {
  setTheLeaguePreference(Astro.cookies, myTeamParam);
}

const cookiePreference = getTheLeaguePreference(Astro.cookies);

const defaultTeamId = resolveTeamSelection({
  myTeamParam,
  franchiseParam,
  cookiePreference: cookiePreference?.franchiseId,
  authUserFranchise: userFranchiseId,
  defaultTeam: teamsList[Math.floor(Math.random() * teamsList.length)]?.id || '0001',
});

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

// Skeleton row count
const SKELETON_ROWS = 12;
---

<TheLeagueLayout title="Team Rosters">
  <section class="roster-page">
    <!-- Team Header Card (renders immediately — static data only) -->
      <div class="team-card" data-team-identity>
        {teamLookup[defaultTeamId]?.icon && (
          <img
            src={teamLookup[defaultTeamId]?.icon}
            alt={`${teamLookup[defaultTeamId]?.name ?? 'Team'} icon`}
          />
        )}
        <div>
          <p class="team-card__label" data-view-label>Roster & Salary Cap</p>
          <h2 data-team-name>
            {teamLookup[defaultTeamId]?.name ?? 'Franchise'}
          </h2>
          <p data-team-meta>
            {teamLookup[defaultTeamId]?.division ?? 'Independent'}
          </p>
        </div>
        <div class="team-card__actions">
          <div class="view-tabs">
            <button class="view-tab" data-view="roster" data-active="true" aria-label="Roster View" title="Roster View">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="view-tab__icon">
                <use href={`${spriteUrl}#icon-banknote`}></use>
              </svg>
              <span class="view-tab__label">Roster</span>
            </button>
            <button class="view-tab" data-view="analytics" data-active="false" aria-label="Analytics View" title="Analytics View">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="view-tab__icon">
                <use href={`${spriteUrl}#icon-bar-chart`}></use>
              </svg>
              <span class="view-tab__label">Analytics</span>
            </button>
            <button class="view-tab" data-view="nextyear" data-active="false" aria-label="League Planner" title="League Planner">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="view-tab__icon">
                <use href={`${spriteUrl}#icon-chalkboard`}></use>
              </svg>
              <span class="view-tab__label">Planner</span>
            </button>
          </div>
        </div>
        <div class="team-card__navigation">
          <button
            class="team-nav-toggle"
            data-accordion-toggle="team-nav"
            aria-expanded="false"
            aria-controls="team-nav-content"
            aria-label="Toggle team navigation"
          >
            <div class="team-nav-toggle__chevron">
              <svg width="32" height="32" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          </button>

          <div
            id="team-nav-content"
            class="team-nav-accordion__content collapsed"
            aria-hidden="true"
          >
            <div class="team-icon-nav">
              {divisionOrder.map((division) => {
                const divisionTeams = teamsList.filter(team => team.division === division);
                return divisionTeams.length > 0 ? (
                  <div class="division-group">
                    <div class="division-label">{division}</div>
                    <div class="division-teams">
                      {divisionTeams.map((team) => (
                        <button
                          class="team-icon-btn"
                          data-team-id={team.id}
                          data-active={team.id === defaultTeamId}
                          title={team.name}
                          aria-label={`View ${team.name} roster`}
                        >
                          {team.icon && (
                            <img
                              src={team.icon}
                              alt={`${team.name} icon`}
                              class="team-icon-img"
                            />
                          )}
                        </button>
                      ))}
                    </div>
                  </div>
                ) : null;
              })}
            </div>
          </div>
        </div>
    </div>

    <!-- Loading Progress Bar — shows estimated load time, hidden once data arrives -->
    <div class="roster-loading-bar" id="rosterLoadingBar">
      <div class="roster-loading-bar__track">
        <div class="roster-loading-bar__fill" id="rosterLoadingFill"></div>
      </div>
      <span class="roster-loading-bar__label" id="rosterLoadingLabel">Loading roster data…</span>
    </div>

    <!-- Roster View (skeleton — populated by deferred scripts) -->
    <div class="view-container" data-view-content="roster">
      <div class="roster-table-card">
        <div class="roster-controls">
          <input type="hidden" id="rosterSeasonSelect" value={defaultSeason} />
          <input type="hidden" id="rosterTeamSelect" value={defaultTeamId} />

          <div class="mode-toggle">
            <button class="mode-btn active" data-mode="gm" title="GM Mode: Contracts & Salary Cap">
              <svg class="mode-icon"><use href={`${spriteUrl}#icon-banknote`}></use></svg> GM
            </button>
            <button class="mode-btn" data-mode="coach" title="Coach Mode: Matchups & Odds">
              <svg class="mode-icon"><use href={`${spriteUrl}#icon-submit`}></use></svg> Coach
            </button>
          </div>
        </div>
      <div class="roster-table-wrapper">
        <table class="roster-table" data-hidden-columns="">
          <thead>
            <tr>
              <th scope="col" data-column="player" data-sortable data-sort-key="position">Player <span class="sort-arrow"></span></th>
              <!-- Coach Mode Columns (hidden by default) -->
              <th scope="col" data-column="oppRank" class="coach-col" style="display:none">Opp #</th>
              <th scope="col" data-column="opponent" class="coach-col" style="display:none">Opponent</th>
              <th scope="col" data-column="ou" class="coach-col" style="display:none">O/U</th>
              <th scope="col" data-column="weather" class="coach-col" style="display:none">Weather</th>
              <th scope="col" data-column="avgRecent" class="coach-col trend-toggle-header" style="display:none; text-align: right;">
                <span>Trend</span>
              </th>
              <th scope="col" data-column="avgSeason" class="coach-col" style="display:none; text-align: right;">Avg</th>
              <th scope="col" data-column="oppAvg" class="coach-col" style="display:none">Opp Avg</th>
              <th scope="col" data-column="projected" class="coach-col" style="display:none; text-align: right;">Proj</th>
              <!-- GM Mode Columns -->
              <th scope="col" data-column="rank" class="gm-col ranking-col" data-sortable data-sort-key="topRanking" id="rankColHeader">Rank <span class="sort-arrow"></span></th>
              <th scope="col" data-column="years" class="gm-col" data-sortable data-sort-key="contractYears">Yrs <span class="sort-arrow"></span></th>
              <th scope="col" data-column="actions" class="actions-column gm-col" title="Contract Actions">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="Actions" style="opacity:0.5;vertical-align:middle;">
                  <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
                </svg>
              </th>
              {SALARY_YEARS.map((year, index) => (
                <th scope="col" data-column={`year${index + 1}`} class="gm-col" data-sortable data-sort-key={`salary_${index}`}>{year} <span class="sort-arrow"></span></th>
              ))}
            </tr>
          </thead>
          <tfoot>
            <tr class="roster-totals roster-totals--dead gm-row">
              <td data-column="player" class="roster-totals__label">Dead Money</td>
              <td data-column="rank" class="gm-col ranking-col"></td>
              <td data-column="years" class="gm-col"></td>
              <td data-column="actions" class="gm-col"></td>
              {SALARY_YEARS.map((_, index) => (
                <td data-column={`dm${index + 1}`} id={`dmTotal${index + 1}`} class="gm-col">—</td>
              ))}
            </tr>
            <tr class="roster-totals gm-row">
              <td data-column="player" class="roster-totals__label">Total Salary</td>
              <td data-column="rank" class="gm-col ranking-col"></td>
              <td data-column="years" class="gm-col"></td>
              <td data-column="actions" class="gm-col"></td>
              {SALARY_YEARS.map((_, index) => (
                <td data-column={`year${index + 1}`} id={`yearTotal${index + 1}`} class="gm-col">—</td>
              ))}
            </tr>
            <tr class="roster-totals roster-totals--cap gm-row">
              <td data-column="player" class="roster-totals__label">Salary Cap</td>
              <td data-column="rank" class="gm-col ranking-col"></td>
              <td data-column="years" class="gm-col"></td>
              <td data-column="actions" class="gm-col"></td>
              {SALARY_YEARS.map((_, index) => (
                <td data-column={`cap${index + 1}`} id={`capLimit${index + 1}`} class="gm-col">—</td>
              ))}
            </tr>
            <tr class="roster-totals roster-totals--space gm-row">
              <td data-column="player" class="roster-totals__label">Cap Space</td>
              <td data-column="rank" class="gm-col ranking-col"></td>
              <td data-column="years" class="gm-col"></td>
              <td data-column="actions" class="gm-col"></td>
              {SALARY_YEARS.map((_, index) => (
                <td data-column={`space${index + 1}`} id={`capSpaceTotal${index + 1}`} class="gm-col">—</td>
              ))}
            </tr>
          </tfoot>
          <tbody id="rosterTableBody">
            {Array.from({ length: SKELETON_ROWS }).map(() => (
              <tr class="roster-row skeleton-row">
                <td data-column="player">
                  <div class="skeleton-player">
                    <div class="skeleton-avatar"></div>
                    <div class="skeleton-text-group">
                      <div class="skeleton-line skeleton-line--name"></div>
                      <div class="skeleton-line skeleton-line--meta"></div>
                    </div>
                  </div>
                </td>
                <td data-column="rank" class="gm-col ranking-col"><div class="skeleton-cell"></div></td>
                <td data-column="years" class="gm-col"><div class="skeleton-cell"></div></td>
                <td data-column="actions" class="gm-col"><div class="skeleton-cell"></div></td>
                {SALARY_YEARS.map((_, i) => (
                  <td data-column={`year${i + 1}`} class="gm-col"><div class="skeleton-cell"></div></td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      </div>

      <!-- Cap Subtotals (populated by deferred scripts) -->
      <div class="chart-card chart-card--sub">
        <div class="chart-card__header">
          <h3>Cap Subtotals (Current Season)</h3>
          <p class="chart-card__sub">Active, IR, Practice, and Dead Money</p>
        </div>
        <div class="cap-subtotals">
          <div class="cap-subtotals__row">
            <span><span class="legend-dot legend-active"></span>Active Roster <span id="countActive" class="cap-count"></span></span>
            <strong id="subtotalActive">—</strong>
          </div>
          <div class="cap-subtotals__row">
            <span><span class="legend-dot legend-practice"></span>Practice Squad <span id="countPractice" class="cap-count"></span></span>
            <strong id="subtotalPractice">—</strong>
          </div>
          <div class="cap-subtotals__row">
            <span><span class="legend-dot legend-injured"></span>Injured Reserve <span id="countInjured" class="cap-count"></span></span>
            <strong id="subtotalInjured">—</strong>
          </div>
          <div class="cap-subtotals__row">
            <span><span class="legend-dot legend-dead"></span>Dead Money</span>
            <strong id="subtotalDead">—</strong>
          </div>
          <div class="cap-subtotals__row">
            <span><span class="legend-dot legend-capspace"></span>Cap Space</span>
            <strong id="subtotalCapSpace">—</strong>
          </div>
        </div>
      </div>

      <!-- Dead Money Table (populated by deferred scripts) -->
      <div class="roster-table-card roster-table-card--sub">
        <div class="roster-table-card__header">
          <div>
            <h3>Cap Hits / Dead Money</h3>
            <p>Includes drops/buyouts for the selected franchise.</p>
          </div>
        </div>
        <div class="roster-table-wrapper">
          <table class="roster-table roster-table--compact">
            <thead>
              <tr>
                <th scope="col" data-column="player" class="deadmoney-player-heading">Player/Adjustment</th>
                {SALARY_YEARS.map((year, index) => (
                  <th scope="col" data-column={`dm-year${index + 1}`}>{year}</th>
                ))}
              </tr>
            </thead>
            <tbody id="deadMoneyTableBody">
              <tr>
                <td colspan={1 + SALARY_YEARS.length} class="roster-empty">
                  Loading...
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="roster-legend">
        <span><span class="legend-swatch legend-swatch--active"></span>Active Roster</span>
        <span><span class="legend-swatch legend-swatch--practice"></span>Practice Squad</span>
        <span><span class="legend-swatch legend-swatch--injured"></span>Injured Reserve</span>
        <span><span class="legend-swatch legend-swatch--trade-bait">🏷️</span>Trade Block</span>
      </div>
    </div>
    <!-- End Roster View -->

    <!-- Analytics View (populated by deferred scripts) -->
    <div class="view-container" data-view-content="analytics" style="display: none;">
      <div class="analytics-section">
        <h3 class="analytics-section__title">Cap Analysis</h3>
        <div class="chart-grid">
          <div class="chart-card"><div class="chart-card__header"><h3>Cap Allocation</h3></div><div id="capDonut"></div><div id="capDonut-legend"></div></div>
          <div class="chart-card"><div class="chart-card__header"><h3>Roster Composition</h3></div><div id="rosterDonut"></div><div id="rosterDonut-legend"></div></div>
          <div class="chart-card"><div class="chart-card__header"><h3>Position Allocation</h3></div><div id="posBar"></div></div>
          <div class="chart-card"><div class="chart-card__header"><h3>Cap Efficiency</h3></div><div id="efficiencyBar"></div></div>
        </div>
      </div>
      <div class="analytics-section">
        <h3 class="analytics-section__title">Age Analysis</h3>
        <div class="chart-grid">
          <div class="chart-card"><div class="chart-card__header"><h3>Age Distribution</h3></div><div id="ageChart"></div></div>
          <div class="chart-card"><div class="chart-card__header"><h3>Average Age by Position</h3></div><div id="posAgeBar"></div></div>
        </div>
      </div>
      <div class="analytics-section">
        <div class="section-header"><h3 class="section-header__title">NFL Analysis</h3></div>
      </div>
      <div id="playersbyTeamContainer" class="nfl-teams-grid"></div>
      <div class="analytics-section">
        <div class="section-header"><h3 class="section-header__title">College Analysis</h3></div>
      </div>
      <div id="playersByCollegeContainer" class="nfl-teams-grid"></div>
    </div>
    <!-- End Analytics View -->

    <!-- League Planner View (populated by deferred scripts) -->
    <div class="view-container" data-view-content="nextyear" style="display: none;">
      <div class="planner-layout">
        <div class="planner-section planner-section--metrics">
          <h3 class="chart-metrics__headline">{currentLeagueYear} at a glance</h3>
          <div class="chart-metrics">
            <div class="metric-card"><span class="metric-card__label">Cap Space</span><span class="metric-card__value" id="summaryCapNext">—</span></div>
            <div class="metric-card"><span class="metric-card__label">Avg per Player*</span><span class="metric-card__value" id="summaryAvg2026">—</span></div>
            <div class="metric-card"><span class="metric-card__label">Players Signed</span><span class="metric-card__value" id="summaryPlayersNext">—</span></div>
            <div class="metric-card"><span class="metric-card__label">Dead Money</span><span class="metric-card__value" id="summaryDeadMoney2026">—</span></div>
            <div class="metric-card"><span class="metric-card__label">Average Age</span><span class="metric-card__value" id="summaryAverageAge">—</span></div>
          </div>
        </div>
        <div class="planner-section planner-section--extensions">
          <h2 class="planner-section__title">Extensions</h2>
          <div class="chart-grid">
            <div class="chart-card"><div class="chart-card__header"><h3>Franchise Tag Options</h3></div><div class="skeleton-section">Loading...</div></div>
            <div class="chart-card"><div class="chart-card__header"><h3>Veteran Extension Candidates</h3></div><div class="skeleton-section">Loading...</div></div>
          </div>
        </div>
        <div class="planner-section planner-section--fa-needs">
          <div id="faNeedsPanels"></div>
        </div>
        <div class="planner-section planner-section--draft-2026">
          <div id="draftAssetsPanels"></div>
        </div>
      </div>
    </div>
    <!-- End Next Year View -->

    <p class="data-disclaimer">
      Live data &middot; refreshed every 2 minutes
    </p>
  </section>
</TheLeagueLayout>

<!-- Player Details Modal -->
<PlayerDetailsModal />

<!-- Player Injury Modal -->
<PlayerInjuryModal />

<ContractDeclarationModal />
<ContractDemoOverlay />

<!-- Deferred Data Island — streams in data + scripts after shell renders -->
<RosterDataIsland server:defer defaultTeamId={defaultTeamId} defaultSeason={defaultSeason} hideLeaguePrefix={hideLeaguePrefix}>
  <div slot="fallback"></div>
</RosterDataIsland>

<!-- Loading progress bar controller -->
<script>
  (() => {
    const bar = document.getElementById('rosterLoadingBar');
    const fill = document.getElementById('rosterLoadingFill');
    const label = document.getElementById('rosterLoadingLabel');
    if (!bar || !fill || !label) return;

    const ESTIMATED_MS = 8000; // estimated load time
    const TICK_MS = 100;
    const start = performance.now();
    let done = false;

    function updateLabel(elapsed) {
      const remaining = Math.max(0, Math.ceil((ESTIMATED_MS - elapsed) / 1000));
      if (remaining > 0) {
        label.textContent = `Loading roster data… ~${remaining}s`;
      } else {
        label.textContent = 'Almost there…';
      }
    }

    // Animate progress — fast at first, asymptotic near 95%
    const timer = setInterval(() => {
      if (done) return;
      const elapsed = performance.now() - start;
      // Ease-out: rushes to ~90% then crawls
      const raw = elapsed / ESTIMATED_MS;
      const pct = Math.min(95, raw < 1 ? raw * 90 : 90 + (1 - Math.exp(-(raw - 1) * 2)) * 5);
      fill.style.width = pct + '%';
      updateLabel(elapsed);
    }, TICK_MS);

    // Watch for the data island to inject the roster-config script tag
    const observer = new MutationObserver(() => {
      if (document.getElementById('roster-config')) {
        finish();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    // Also check immediately in case it already loaded
    if (document.getElementById('roster-config')) {
      finish();
    }

    function finish() {
      if (done) return;
      done = true;
      observer.disconnect();
      clearInterval(timer);
      fill.style.width = '100%';
      fill.style.transition = 'width 0.3s ease';
      label.textContent = 'Roster loaded';
      setTimeout(() => {
        bar.style.opacity = '0';
        bar.style.transition = 'opacity 0.4s ease';
        setTimeout(() => { bar.style.display = 'none'; }, 400);
      }, 600);
    }
  })();
</script>

<style>
  .roster-page {
    display: grid;
    gap: var(--padding-lg);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gray-400, #9ca3af);
    margin-bottom: 0.25rem;
  }

  .roster-page__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--padding-md);
    flex-wrap: wrap;
  }

  .roster-page__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md, 0.5rem);
    border: none;
    background: var(--btn-primary-bg, #1c497c);
    color: var(--btn-primary-text, #fff);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn:hover {
    background: var(--btn-primary-bg-hover, #164066);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-secondary {
    background: var(--color-gray-200, #dddedf);
    color: var(--color-gray-900, #111827);
    cursor: not-allowed;
  }

  .roster-controls {
    display: flex;
    justify-content: center;
    margin-bottom: .5rem;
  }


.team-icon-nav {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--padding-lg);
  justify-content: center;
  align-items: center;
  border-radius: 1rem;
  width: 100%;
  margin: 0 auto;
}

/* Tablet: 2x2 grid */
@media (min-width: 768px) {
  .team-icon-nav {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Desktop: all in one row */
@media (min-width: 1200px) {
  .team-icon-nav {
    grid-template-columns: repeat(4, 1fr);
  }
}

