            : '';

          const playerCellHtml = buildPlayerCellHTML({
            name: player.name,
            headshot: player.headshot,
            position: player.position,
            nflTeam: player.nflTeam,
            contractStatus: player.contractInfo || undefined,
            playerData: {
              id: player.id, espnId: player.espnId, name: player.name,
              position: player.position, nflTeam: player.nflTeam, status: player.status,
              salary: player.salary, contractYears: player.contractYears,
              totalRemaining: player.totalRemaining, contractType: player.contractType,
              points: player.points, byeWeek: player.byeWeek,
              draftYear: player.draftYear, draftTeam: player.draftTeam,
              draftRound: player.draftRound, draftPick: player.draftPick,
              birthdate: player.birthdate, franchiseId: player.franchiseId,
              rosterSlot: player.rosterSlot, college: player.college,
              collegeLogo: player.collegeLogo, height: player.height,
              weight: player.weight, number: player.number,
              experience: player.experience, depthChartPosition: player.depthChartPosition,
              depthChartOrder: player.depthChartOrder, depthChartAhead: player.depthChartAhead,
              injuryStatus: player.injuryStatus, injuryBodyPart: player.injuryBodyPart,
              sleeperId: player.sleeperId, sleeperFullName: player.sleeperFullName,
              sleeperPosition: player.sleeperPosition, fantasyPositions: player.fantasyPositions,
              gsisId: player.gsisId, sleeperAge: player.sleeperAge,
              sleeperStatus: player.sleeperStatus, sleeperActive: player.sleeperActive,
              offenseSnaps: player.offenseSnaps, defenseSnaps: player.defenseSnaps,
              stSnaps: player.stSnaps,
            },
            afterName: injuryBadge + tradeBaitBadge,
