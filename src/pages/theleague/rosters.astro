/* ========================================
   TEAM CARD NAVIGATION (INTEGRATED)
   ======================================== */

/* Navigation Container - spans full width at bottom of team-card */
.team-card__navigation {
  flex-basis: 100%; /* Force full width in flex layout */
  width: 100%;
  position: relative;
  order: 10; /* Ensure it appears last in flex layout */
  container-type: inline-size; /* Enable container queries */
  margin-top: var(--padding-xl);
}

/* Minimal Toggle Button - just a small arrow at bottom of card */
.team-nav-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--padding-sm);
  background: transparent;
  border: none;
  cursor: pointer;
  transition: opacity 0.2s ease;
  position: absolute; 
  top: -1.5rem;
}
@media (min-width: 480px) {
  .team-nav-toggle {
    top: -2rem;
  }
}

.team-nav-toggle:hover {
  opacity: 0.6;
}

.team-nav-toggle:focus {
  border-radius: 4px;
}

/* Chevron Icon - rotates to point down when collapsed */
.team-nav-toggle__chevron {
  transition: transform 0.3s ease;
  color: var(--muted-text-color, #9ca3af);
  display: flex;
  align-items: center;
  flex-shrink: 0;
  opacity: 0.5;
}

.team-nav-toggle:hover .team-nav-toggle__chevron {
  opacity: 1;
}

.team-nav-toggle[aria-expanded="true"] .team-nav-toggle__chevron {
  transform: rotate(180deg);
}

/* Accordion Content */
.team-nav-accordion__content {
  overflow: hidden;
  transition: max-height 0.3s ease, opacity 0.2s ease;
}

.team-nav-accordion__content.expanded {
  max-height: 600px;
  opacity: 1;
  margin-top: var(--padding-md);
}

.team-nav-accordion__content.collapsed {
  max-height: 0;
  opacity: 0;
}

/* Restore original team-icon-nav styling when expanded */
.team-card__navigation .team-icon-nav {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--padding-lg);
  justify-content: center;
  align-items: center;
  background-color: var(--card-bg-color);
  width: 100%;
  margin: 0 auto;
  box-sizing: border-box;
}
/* Tablet: 2x2 grid */
@container (min-width: 600px) {
  .team-card__navigation .team-icon-nav {
    grid-template-columns: repeat(2, 1fr);
  }
}
@container (min-width: 1024px) {
  .team-card__navigation .team-icon-nav {
    grid-template-columns: repeat(4, 1fr);
  }
}



/* Container query: 4 columns as default when possible */
@container (min-width: 400px) {
  .team-icon-nav {
    grid-template-columns: repeat(4, auto);
  }

  .team-nav-accordion__content.expanded {
    max-height: 400px; /* Single row */
  }
}

/* Container query: fall back to 2x2 only when very narrow */
@container (max-width: 399px) and (min-width: 280px) {
  .team-icon-nav {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Hide roster-controls (now empty except hidden inputs) */
.roster-controls {
  display: none;
}



