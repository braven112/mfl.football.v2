          document.body.style.overflow = '';
          return;
        }
        // Find the active exitDemo via the exit button's click handler
        document.getElementById('cdemo-exit')?.click();
      });
    }

    // If ?testEligibility=true is present, also show the trigger as hidden
    // (the SSR mock is already injected, no need for the demo button)
    if (new URLSearchParams(window.location.search).get('testEligibility') === 'true') {
      if (demoTrigger) demoTrigger.hidden = true;
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRosterPage);
  } else {
    initRosterPage();
  }

  // Re-initialize after View Transitions (Astro page navigation)
  document.addEventListener('astro:page-load', initRosterPage);
</script>

<!-- Free Agent Needs tab switching -->
<script>
  function initFaNeedsTabs() {
    document.querySelectorAll('.fa-needs').forEach((card) => {
      const tabs = card.querySelectorAll('[data-fa-tab]');
      const panels = card.querySelectorAll('[data-fa-panel]');
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          const pos = tab.getAttribute('data-fa-tab');
          tabs.forEach((t) => {
            t.classList.toggle('fa-needs__tab--active', t === tab);
            t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
          });
          panels.forEach((p) => {
            p.style.display = p.getAttribute('data-fa-panel') === pos ? '' : 'none';
          });
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFaNeedsTabs);
  } else {
    initFaNeedsTabs();
  }
  document.addEventListener('astro:page-load', initFaNeedsTabs);
</script>

