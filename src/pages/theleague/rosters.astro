                        style={`display: ${teamId === defaultTeamId ? 'block' : 'none'}`}
                      >
                        <DraftTeamAssetsView
                          predictions={assetsPredictions}
                          teams={teamsList}
                          hideTeamSelector={true}
                          franchiseId={teamId}
                        />
