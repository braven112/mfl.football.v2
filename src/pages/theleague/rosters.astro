    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-gray-800, #1f2937);
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    padding-bottom: var(--padding-xs);
  }

  .cap-subtotals__row strong {
    font-size: 0.875rem;
    font-variant-numeric: tabular-nums;
  }

  .cap-count {
    font-weight: 600;
