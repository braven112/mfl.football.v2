    const favored = favoredHome ? home : away;
    const spread = `${favored} -${spreadNum}`;
    const overUnder = String(Math.floor(Math.random() * 15) + 40 + 0.5);
    const weather = weatherOptions[i % weatherOptions.length];

    oddsData[home] = {
      id: `demo-${i}`,
      date: new Date().toISOString(),
      homeTeam: home,
      awayTeam: away,
      status: 'Scheduled',
      spread,
      overUnder,
      homeScore: null,
      awayScore: null,
      weather,
      isHome: true,
      opponent: away,
    };

    oddsData[away] = {
      id: `demo-${i}`,
      date: new Date().toISOString(),
      homeTeam: home,
      awayTeam: away,
      status: 'Scheduled',
      spread,
      overUnder,
      homeScore: null,
      awayScore: null,
      weather,
      isHome: false,
      opponent: home,
    };
  });

  return oddsData;
};

