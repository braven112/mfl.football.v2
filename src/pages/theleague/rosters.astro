                    ))}
                  </div>
                </ChartCard>
              ) : draftPredictions.length > 0 ? (
                <ChartCard title={`${draftNextYear} Draft Picks`} subtitle="Projected draft picks based on current standings">
                  <a href={r("/theleague/draft-predictor")} class="chart-card-link" title="View full draft predictor" slot="actions">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                      <path d="M8.5 1.5H2.5a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7.5M14.5 1.5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    </svg>
                  </a>
                  <DraftPicksCard
