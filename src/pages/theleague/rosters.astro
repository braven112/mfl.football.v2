      injuryBodyPart: null,
      sleeperId: null,
      sleeperFullName: null,
      sleeperPosition: null,
      fantasyPositions: null,
      gsisId: null,
      sleeperAge: null,
      sleeperStatus: null,
      sleeperActive: null,
      offenseSnaps: null,
      defenseSnaps: null,
      stSnaps: null,
      gamesPlayed: null,
      depthChartAhead: null,
      tradeBait: false,
    },
  ];

  // Inject mock players into the roster table
  if (teamData?.players) {
    teamData.players.unshift(...mockPlayers);
  }

  // --- Eligibility data for the 3 scenarios ---
  eligibilityByTeam[testTeamId] = {
    // Hopkins: free agent BBID pickup, 18h deadline, can declare 1-5 years
    '11232': {
      type: 'new-acquisition',
      yearOptions: [1, 2, 3, 4, 5],
      deadlineTimestamp: Math.floor((now + 18 * 60 * 60 * 1000) / 1000),
      isExpired: false,
      currentYears: 1,
      currentSalary: 500000,
      contractInfo: '',
      isRookieContract: false,
    },
    // Jackson (TO, 3yr remaining): 1st-round pick eligible for rookie extension
    '99901': {
      type: 'rookie-extension',
      currentYears: 3,
      currentSalary: 2000000,
      contractInfo: 'TO',
      isRookieContract: false,
      extensionSalary: 2000000 * Math.pow(1.10, 3),
      extensionYears: 5,
    },
    // Williams (TO, 1yr remaining): 1st-round pick eligible for team option
    '99902': {
      type: 'team-option',
      currentYears: 1,
      currentSalary: 2000000,
      contractInfo: 'TO',
      isRookieContract: false,
      teamOptionSalary: frozenSalaryAverages?.teamOptionSalaries?.['QB'] ?? 0,
      tagBasis: 'top 10 average',
    },
    // Mendoza: #1 overall pick, 4yr RC default, can reduce to 1-3, August cutdown deadline
    // 3rd Sunday in August @ 8:45 PM PT
    '17462': (() => {
      const y = new Date().getFullYear();
      const a = new Date(y, 7, 1);
      const d = (7 - a.getDay()) % 7 || 7;
      const ts = new Date(y, 7, 1 + d + 14, 20, 45, 0);
      const deadline = ts.getTime() > now ? ts : (() => { const a2 = new Date(y+1, 7, 1); const d2 = (7 - a2.getDay()) % 7 || 7; return new Date(y+1, 7, 1 + d2 + 14, 20, 45, 0); })();
      return {
        type: 'rookie-override' as const,
        yearOptions: [1, 2, 3],
        deadlineTimestamp: Math.floor(deadline.getTime() / 1000),
        isExpired: false,
        currentYears: 4,
        currentSalary: 3250000,
        contractInfo: 'RC',
        isRookieContract: true,
      };
    })(),
    // Hailmary, Hank: mock 2024 #1 overall (TO), 3 years remaining — team option or rookie extension
    '99902': {
      type: 'team-option' as const,
      teamOptionSalary: frozenSalaryAverages?.teamOptionSalaries?.['QB'] ?? 15000000,
      // Rookie extension uses same formula as 2-year vet extension
      extensionSalary: Math.round(((frozenSalaryAverages?.extensionSalaries?.['QB'] ?? 0) * 2 / (3 + 2)) + 2000000),
      extensionYears: 5,
      deadlineTimestamp: null,
      isExpired: false,
      currentYears: 3,
      currentSalary: 2000000,
      contractInfo: 'TO',
      isRookieContract: false,
    },
    // Misack, Buck: 2023 2nd round WR, 2 years remaining — eligible for rookie extension
    // Uses same formula as 2-year veteran extension: (top5avg * extYrs / (existing + ext)) + salary
    '99901': {
      type: 'rookie-extension' as const,
      extensionSalary: Math.round(((frozenSalaryAverages?.extensionSalaries?.['WR'] ?? 0) * 2 / (2 + 2)) + 1800000),
      extensionYears: 4,
      deadlineTimestamp: null,
      isExpired: false,
      currentYears: 2,
      currentSalary: 1800000,
      contractInfo: 'RC',
      isRookieContract: true,
    },
  };
}

// Load existing declarations for indicator display
const allDeclarations = await getDeclarations();
const declarationsByPlayer: Record<string, { status: string; type: string; requestedYears: number }> = {};
for (const decl of allDeclarations) {
  if (decl.status === 'pending' || decl.status === 'approved') {
    declarationsByPlayer[decl.playerId] = {
      status: decl.status,
      type: decl.type,
      requestedYears: decl.requestedYears,
    };
  }
}

const serializedConfig = JSON.stringify({
  seasons: rostersBySeason,
  seasonOptions,
  defaultSeason,
  defaultTeamId,
  initialSeasonData,
  initialTeamData,
  adjustmentsBySeason: feedSalaryAdjustmentsBySeason,
  salaryAverages: salaryAveragesBySeason,
  extensionSeason,
  teams: teamLookup,
  rosterLimit: ROSTER_LIMIT,
  positionOrder,
  columnOptions: rosterColumnOptions,
  salaryYears: SALARY_YEARS,
  byeWeeks: nflByeWeeks,
  capLimit: initialCapLimit,
  rosterLimitOverride: initialRosterLimit,
  capInclusion: CAP_INCLUSION,
  deadMoneySources: DEAD_MONEY_SOURCES,
  positionColors: POSITION_COLORS,
  targetActiveCount: TARGET_ACTIVE_COUNT,
  reserveForRookies: RESERVE_FOR_ROOKIES,
  collegeLogos: collegeLogosNormalized,
  authUser: authUser
    ? { franchiseId: authUser.franchiseId, leagueId: authUser.leagueId }
    : testEligibility
      ? { franchiseId: defaultTeamId, leagueId: '13522' }
      : null,
  trendWeeks,
  hideLeaguePrefix: Astro.locals.hideLeaguePrefix ?? false,
  eligibilityByTeam,
  declarationsByPlayer,
});

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

// Owner activity data for "last seen" indicators
let ownerActivityMap: Record<string, number> = {};
try {
  ownerActivityMap = await Promise.race([
    getAllActivity('13522'),
    new Promise<Record<string, number>>((_, reject) => setTimeout(() => reject(new Error('Redis timeout')), 3000)),
  ]);
} catch { /* Redis unavailable or timed out */ }
const defaultLastSeen = ownerActivityMap[defaultTeamId] ?? null;
const defaultActivityLevel = getActivityLevel(defaultLastSeen);
const defaultLastSeenText = formatLastSeen(defaultLastSeen);
