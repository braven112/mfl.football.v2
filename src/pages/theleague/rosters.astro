// Process salary averages for extension calculator
const salaryAveragesBySeason = {};
Object.entries(salaryAveragesModules).forEach(([path, mod]) => {
  const season = extractSeason(path);
  if (!season) return;
  const data = getModuleData(mod);
  if (data?.positions) {
    salaryAveragesBySeason[season] = {
      extensionSalaries: {
        QB: data.positions.QB?.top5Average ?? 0,
        RB: data.positions.RB?.top5Average ?? 0,
        WR: data.positions.WR?.top5Average ?? 0,
        TE: data.positions.TE?.top5Average ?? 0,
        PK: data.positions.PK?.top5Average ?? 0,
        DEF: data.positions.Def?.top5Average ?? 0,
      },
      franchiseSalaries: {
        QB: data.positions.QB?.top3Average ?? 0,
        RB: data.positions.RB?.top3Average ?? 0,
        WR: data.positions.WR?.top3Average ?? 0,
        TE: data.positions.TE?.top3Average ?? 0,
        PK: data.positions.PK?.top3Average ?? 0,
        DEF: data.positions.Def?.top3Average ?? 0,
      },
      teamOptionSalaries: {
        QB: data.positions.QB?.top10Average ?? 0,
        RB: data.positions.RB?.top10Average ?? 0,
        WR: data.positions.WR?.top10Average ?? 0,
        TE: data.positions.TE?.top10Average ?? 0,
        PK: data.positions.PK?.top10Average ?? 0,
        DEF: data.positions.Def?.top10Average ?? 0,
      },
    };
  }
});

// Use previous season's frozen (week 14) salary averages until current season reaches week 14
const extensionSeason = String(getFrozenSalaryAveragesYear(salaryAveragesModules, getModuleData));

const seasonOptions = Object.keys(rostersBySeason).sort(
  (a, b) => Number(b) - Number(a)
);
const currentLeagueYear = getCurrentLeagueYear();
const preferredSeason = seasonOptions.find(
  (season) => Number(season) === currentLeagueYear
);
const defaultSeason = preferredSeason ?? seasonOptions[0] ?? seasonOptions.at(-1) ?? String(currentLeagueYear);

// Normalize franchise ids so "8" and "0008" resolve to the same team
const normalizeFranchiseId = (id) => {
  if (!id) return null;
  const trimmed = `${id}`.trim();
  if (!trimmed) return null;
  return /^\d+$/.test(trimmed) ? trimmed.padStart(4, '0') : trimmed;
};

const rosterTeamIds = seasonOptions.flatMap(
  (season) => Object.keys(rostersBySeason[season]?.teams ?? {})
);
const knownTeamIds = new Set([
  ...teamsList.map((team) => team.id),
  ...rosterTeamIds,
]);

// Get authenticated user and set default team to their franchise if logged in
