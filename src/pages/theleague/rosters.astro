const generateDemoOddsData = () => {
  // 16 matchups covering all 32 teams
  const matchups: [string, string][] = [
    ['KC', 'BUF'], ['PHI', 'DAL'], ['SF', 'SEA'], ['DET', 'GB'],
    ['BAL', 'CIN'], ['MIA', 'NYJ'], ['MIN', 'CHI'], ['HOU', 'JAX'],
