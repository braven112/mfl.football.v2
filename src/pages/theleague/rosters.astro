        const sortKey = th.dataset.sortKey;

        if (sortKey === 'position') {
          // Player column always resets to default
          resetSort();
          applySort();
          return;
        }

        if (currentSortKey === sortKey) {
          // Toggle: desc <-> asc
          currentSortDir = currentSortDir === 'desc' ? 'asc' : 'desc';
        } else {
          currentSortKey = sortKey;
          // Rank defaults to ascending (1 = best at top), everything else descending
          currentSortDir = sortKey === 'topRanking' ? 'asc' : 'desc';
