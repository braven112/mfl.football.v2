  import { buildRankingLookup, onRankingsChanged } from '../../utils/rankings-lookup';

  let unsubscribe: (() => void) | null = null;

  function populateRankCells() {
    const lookup = buildRankingLookup();
    // Expose on window so the sort function can access it
    (window as any).__rosterRankingLookup = lookup;

    const topColumn = lookup.columns[0];
    const headerEl = document.getElementById('rankColHeader');

    // Update header text and tooltip with ranking source name
    if (headerEl && topColumn) {
      headerEl.title = topColumn.fullName;
      // Show source abbreviation as the column header
      const sortArrow = headerEl.querySelector('.sort-arrow');
      headerEl.textContent = '';
      headerEl.append(`${topColumn.header} `, sortArrow || document.createElement('span'));
      if (sortArrow) sortArrow.className = 'sort-arrow';
    }

    // If no rankings imported, hide the column
    const rankCols = document.querySelectorAll('.ranking-col');
    if (!topColumn) {
      rankCols.forEach(el => (el as HTMLElement).style.display = 'none');
      return;
    }

    const playerRanks = lookup.byImport.get(topColumn.importId);
    if (!playerRanks) return;

    // Populate rank cells in all visible rows
    document.querySelectorAll('#rosterTableBody tr[data-player-id]').forEach(row => {
      const playerId = (row as HTMLElement).dataset.playerId;
      const cell = row.querySelector('.ranking-cell');
      if (!cell || !playerId) return;

      const rank = playerRanks.get(playerId);
      cell.textContent = rank != null ? String(rank) : '—';
    });

    // Re-apply mode visibility so ranking-col cells respect GM/Coach toggle
    const currentMode = localStorage.getItem('rosterViewMode') || 'gm';
    rankCols.forEach(el => {
      (el as HTMLElement).style.display = currentMode === 'gm' ? 'table-cell' : 'none';
    });
  }

  function initRankings() {
    if (unsubscribe) {
      unsubscribe();
      unsubscribe = null;
    }

    populateRankCells();

    // Re-populate when rankings change (import/delete on another page or tab)
    unsubscribe = onRankingsChanged(() => populateRankCells());

    // Re-populate after the main script re-renders table rows
    const observer = new MutationObserver(() => populateRankCells());
    const tbody = document.getElementById('rosterTableBody');
    if (tbody) {
      observer.observe(tbody, { childList: true });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRankings);
  } else {
    // Small delay to ensure main script has rendered rows first
    setTimeout(initRankings, 50);
  }

  document.addEventListener('astro:page-load', () => setTimeout(initRankings, 50));
</script>

<!-- Rankings integration for Potential Targets (FA needs) card in planner view -->
<script>
  import { buildRankingLookup as buildFaRankingLookup, onRankingsChanged as onFaRankingsChanged } from '../../utils/rankings-lookup';

  let faRankUnsubscribe: (() => void) | null = null;

  function injectFaRankings() {
    const lookup = buildFaRankingLookup();
    const columns = lookup.columns;

    if (columns.length === 0) return;

    // Process each panel (each position tab)
    document.querySelectorAll('.fa-needs__panel').forEach(panel => {
      // Add ranking column headers to the existing thead row
      const headerRow = panel.querySelector('.fa-needs__thead tr');
      if (!headerRow) return;

      // Remove previously injected ranking headers (keep static ones)
      headerRow.querySelectorAll('.fa-needs__th--rank-col').forEach(th => th.remove());

      // Add ranking column headers after the PTS column
      for (const col of columns) {
        const th = document.createElement('th');
        th.className = 'fa-needs__th fa-needs__th--rank-col';
        th.textContent = col.header;
        th.title = col.fullName;
        headerRow.appendChild(th);
      }
    });

    // Inject ranking values into each player row
    document.querySelectorAll('.fa-needs__player[data-fa-player-id]').forEach(row => {
      const el = row as HTMLElement;
      const playerId = el.dataset.faPlayerId;
      if (!playerId) return;

      // Remove old injected ranking values
      el.querySelectorAll('.fa-needs__rank-value').forEach(v => v.remove());

      // Add ranking values as table cells
      for (const col of columns) {
        const rank = lookup.byImport.get(col.importId)?.get(playerId);
        const td = document.createElement('td');
        td.className = 'fa-needs__rank-value';
        td.textContent = rank != null ? String(rank) : '—';
        el.appendChild(td);
      }
    });
  }

  function initFaRankings() {
    if (faRankUnsubscribe) {
      faRankUnsubscribe();
      faRankUnsubscribe = null;
    }

    injectFaRankings();
    faRankUnsubscribe = onFaRankingsChanged(() => injectFaRankings());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => setTimeout(initFaRankings, 100));
  } else {
    setTimeout(initFaRankings, 100);
  }
  document.addEventListener('astro:page-load', () => setTimeout(initFaRankings, 100));
</script>
