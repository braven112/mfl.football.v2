                    draftPredictions={draftPredictions}
                    actualPicks={actualDraftPicks}
                    season={draftNextYear}
                  />
                </ChartCard>
              ) : null}
            </div>
          </Fragment>
        )}

      </div>
    </div>
    <!-- End Next Year View -->

    {lastFetched && (
      <p class="data-disclaimer">
        Data as of {lastFetched.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'short' })}
      </p>
    )}
  </section>
</TheLeagueLayout>

