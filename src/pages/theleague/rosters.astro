  }

  /* --- League Planner Layout --- */
  .planner-layout {
    display: grid;
    gap: 1.5rem;
    min-width: 0;
  }

  .planner-layout > * {
    min-width: 0;
  }

  .planner-section__title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-900, #111827);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  .draft-section {
    display: grid;
    gap: 1rem;
  }

  /* Default section order (extensions at bottom until Week 10) */
  .planner-section--metrics          { order: 1; }
  .planner-section--draft-2026       { order: 2; }
  .planner-section--drafts-combined  { order: 2; }
  .planner-section--fa-needs         { order: 3; }
  .planner-section--draft-2027       { order: 4; }
  .planner-section--extensions       { order: 5; }

  /* Extensions & Tags phase: extensions first */
  [data-planner-phase="extensions-and-tags"] .planner-section--extensions       { order: 1; }
  [data-planner-phase="extensions-and-tags"] .planner-section--metrics          { order: 2; }
  [data-planner-phase="extensions-and-tags"] .planner-section--draft-2026       { order: 3; }
  [data-planner-phase="extensions-and-tags"] .planner-section--drafts-combined  { order: 3; }
  [data-planner-phase="extensions-and-tags"] .planner-section--fa-needs         { order: 4; }

  /* Free Agency phase: FA needs + metrics prominent */
  [data-planner-phase="free-agency"] .planner-section--fa-needs         { order: 1; }
  [data-planner-phase="free-agency"] .planner-section--metrics          { order: 2; }
  [data-planner-phase="free-agency"] .planner-section--draft-2026       { order: 3; }
  [data-planner-phase="free-agency"] .planner-section--drafts-combined  { order: 3; }
  [data-planner-phase="free-agency"] .planner-section--draft-2027       { order: 4; }
  [data-planner-phase="free-agency"] .planner-section--extensions       { order: 5; }

  /* Draft phase: draft assets first */
  [data-planner-phase="draft"] .planner-section--draft-2026       { order: 1; }
  [data-planner-phase="draft"] .planner-section--drafts-combined  { order: 1; }
  [data-planner-phase="draft"] .planner-section--draft-2027       { order: 2; }
  [data-planner-phase="draft"] .planner-section--metrics          { order: 3; }
  [data-planner-phase="draft"] .planner-section--fa-needs         { order: 4; }
  [data-planner-phase="draft"] .planner-section--extensions       { order: 5; }

  /* Side-by-side draft cards */
  .draft-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--padding-md, 1rem);
  }

  @media (min-width: 1200px) {
    .draft-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

