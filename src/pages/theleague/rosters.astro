const initialRosterSlices: ChartSlice[] = [];
const initialPositionSlices: ChartSlice[] = [];
const initialCapEfficiencySlices: ChartSlice[] = [];
const initialAgeDistributionSlices: ChartSlice[] = [];
const initialPositionalAgeSlices: ChartSlice[] = [];
let initialAverageAge: number | null = null;
// Get all players from the default season (which contains all rosters)
const initialAllPlayers: any[] = initialSeasonData
  ? Object.values(initialSeasonData.teams ?? {}).flatMap((team: any) => [
      ...(team.players ?? []),
      ...(team.practiceSquad ?? []),
      ...(team.injuredReserve ?? []),
    ])
  : [];

// Between Feb 15 and Labor Day (season start), current season points are 0.
// Fall back to last season's points so extension/franchise tag filtering works.
const prevSeasonKey = String(Number(defaultSeason) - 1);
const prevSeasonData = rostersBySeason[prevSeasonKey];
if (prevSeasonData) {
  const allCurrentPointsZero = initialAllPlayers.every(p => (p.points ?? 0) === 0);
  if (allCurrentPointsZero) {
    const prevPointsMap = new Map<string, number>();
    Object.values(prevSeasonData.teams ?? {}).forEach((team: any) => {
      [...(team.players ?? []), ...(team.practiceSquad ?? []), ...(team.injuredReserve ?? [])].forEach((p: any) => {
        if (p.points && p.points > 0) prevPointsMap.set(p.id, p.points);
      });
    });
    initialAllPlayers.forEach(p => {
      if ((p.points ?? 0) === 0 && prevPointsMap.has(p.id)) {
        p.points = prevPointsMap.get(p.id);
      }
    });
  }
}

// Draft predictions use season year (standings come from the season played, not the new league year)
const draftSeasonYear = getCurrentSeasonYear();
const draftNextYear = draftSeasonYear + 1;

// Get last fetched timestamp from meta file
const fetchMeta = loadFeedJson(currentLeagueYear, 'fetch.meta.json');
const lastFetched = fetchMeta?.lastFetched ? new Date(fetchMeta.lastFetched) : null;
let draftPredictions = [];
let actualDraftPicks = [];
let assetsPredictions = [];
let toiletBowlWinners = [];
let assetTeamIds: string[] = [];

// Load standings and bracket data for draft predictions (from the season that was played)
const standingsKey = Object.keys(standingsFeeds).find(
  (path) => extractFeedSeason(path) === String(draftSeasonYear)
);
const standingsData = standingsKey ? getModuleData(standingsFeeds[standingsKey]) : null;

const bracketData = loadFeedJson(draftSeasonYear, 'playoff-brackets.json');

// Load draft results from next year to show actual picks with trades
const draftResultsData = loadFeedJson(draftNextYear, 'draftResults.json');

// Load transactions from season year to extract trade information
const transactionsData = loadFeedJson(draftSeasonYear, 'transactions.json');

if (standingsData?.leagueStandings?.franchise) {
  // Build team config map with icons and banners
  const teamConfigMap = new Map(
    teamsList.map((team) => [
      team.id,
      {
        id: team.id,
        name: team.name,
        icon: team.icon,
        banner: leagueAssets.teams?.find((t) => t.id === team.id)?.assets?.banners?.[0]?.relativePath ?? '',
      },
    ])
  );

  // Extract toilet bowl winners from bracket (optional - only needed for special picks)
  if (bracketData) {
    toiletBowlWinners = extractToiletBowlWinners(bracketData);
  }

  // Extract league champion from playoff bracket (same as draft-predictor)
  const leagueWinnerId = bracketData ? extractLeagueChampion(bracketData) : '';

  // Calculate draft order (with champion at pick 16)
  draftPredictions = calculateDraftOrder(
    standingsData.leagueStandings.franchise,
    teamConfigMap,
    leagueWinnerId,
    toiletBowlWinners
  );

  // Extract actual draft assets from draft results if available
  if (draftResultsData) {
    actualDraftPicks = buildActualDraftPicks(draftResultsData, teamConfigMap);
  }

  // Current-year draft assets: prefer actual MFL draft data (authoritative pick numbers)
  // over transaction-based computation which can miscalculate positions
  if (actualDraftPicks.length > 0) {
    assetsPredictions = convertActualPicksToPredictions(actualDraftPicks, teamConfigMap);
  } else if (transactionsData) {
    // Fallback: compute from transactions when draft results aren't available yet
    const assetsData = extractAssetsFromTransactions(transactionsData, standingsData, draftNextYear, draftPredictions);
    if (isValidAssetsData(assetsData)) {
      assetsPredictions = convertAssetsToPredictions(assetsData, teamConfigMap);
    }
  }
}

assetTeamIds = Array.from(new Set(assetsPredictions.map((p) => p.franchiseId))).filter(Boolean);
if (defaultTeamId && !assetTeamIds.includes(defaultTeamId)) {
