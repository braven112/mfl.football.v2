---
/**
 * Auction Tracker Page
 *
 * Real-time auction tracker for TheLeague's slow email auction.
 * Polls MFL transactions every 30s to show active bids, completed auctions,
 * available players ranked by custom rankings, and per-team cap tracking.
 *
 * SSR (prerender = false) — needs auth for "my team" context and bid placement.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import PlayerCell from '../../components/theleague/PlayerCell.astro';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getAuthUser } from '../../utils/auth';
import { SALARY_CAP } from '../../utils/salary-calculations';
import { normalizeTeamCode } from '../../utils/nfl-logo';
import { chooseTeamName } from '../../utils/team-names';
import leagueConfig from '../../data/theleague.config.json';
import '../../styles/player-cell.css';

export const prerender = false;

const currentYear = getCurrentLeagueYear();
const user = getAuthUser(Astro.request);
const myFranchiseId = user?.franchiseId || '';

// ---------------------------------------------------------------------------
// Build-time data: Players + Rosters (serialized to client)
// ---------------------------------------------------------------------------
// Direct dynamic imports for current year only — avoids loading all 20 years
// of historical data (~23MB) that import.meta.glob({ eager: true }) would pull in.
// Rosters are fetched LIVE from /api/auction (not build-time) to ensure data is never stale.
const getModuleData = (mod: any) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

let playersData: any = null;
let leagueData: any = null;
try {
  playersData = getModuleData(await import(`../../../data/theleague/mfl-feeds/${currentYear}/players.json`));
} catch { /* Player data unavailable for this year */ }
try {
  leagueData = getModuleData(await import(`../../../data/theleague/mfl-feeds/${currentYear}/league.json`));
} catch { /* League data unavailable for this year */ }

// MFL team code normalization
const MFL_TEAM_CODE_MAP: Record<string, string> = {
  GBP: 'GB', KCC: 'KC', NEP: 'NE', NOS: 'NO',
  SFO: 'SF', TBB: 'TB', LVR: 'LV', HST: 'HOU',
  BLT: 'BAL', CLV: 'CLE', ARZ: 'ARI', JAC: 'JAX',
};
function normalizeMflTeam(code: string): string {
  if (!code) return 'FA';
  return MFL_TEAM_CODE_MAP[code] || code;
}

// Build compact player lookup (only relevant fields)
interface PlayerInfo {
  id: string;
  name: string;
  position: string;
  team: string;
}

const playerLookup: Record<string, PlayerInfo> = {};
if (playersData?.players?.player) {
  const players = Array.isArray(playersData.players.player)
    ? playersData.players.player
    : [playersData.players.player];
  for (const p of players) {
    if (p?.id && p?.name) {
      const pos = (p.position || 'Unknown').split(',')[0];
      // Filter to fantasy-relevant positions only
      if (['QB', 'RB', 'WR', 'TE', 'PK', 'Def', 'DEF'].includes(pos)) {
        playerLookup[p.id] = {
          id: p.id,
          name: p.name.includes(',') ? `${p.name.split(', ')[1]} ${p.name.split(', ')[0]}` : p.name,
          position: pos === 'Def' ? 'DEF' : pos,
          team: normalizeMflTeam(p.team || ''),
        };
      }
    }
  }
}

// League auction config
const auctionBudget = parseInt(leagueData?.league?.auctionStartAmount || '45000000', 10);
const draftLimitHours = parseFloat(leagueData?.league?.draftLimitHours || '12');
const draftTimerSusp = leagueData?.league?.draftTimerSusp || '03 07';
const [suspStart, suspEnd] = draftTimerSusp.split(' ').map(Number);

// Team config for display
const teamLookup: Record<string, { name: string; nameMedium: string; nameShort: string; abbrev: string; icon: string }> = {};
for (const team of (leagueConfig as any).teams || []) {
  teamLookup[team.franchiseId] = {
    name: team.name,
    nameMedium: team.nameMedium || team.name,
    nameShort: team.nameShort || team.name,
    abbrev: team.abbrev || '',
    icon: team.icon || '',
  };
}

const pageTitle = 'Auction Tracker';
---

<TheLeagueLayout title={pageTitle}>
  <div class="auction-page">
    <!-- Notification banner area (populated by JS) -->
    <div id="auction-notifications" class="auction-notifications" role="alert" aria-live="polite"></div>

    <!-- Key Metrics Strip -->
    <div class="metrics-grid" id="metrics-grid">
      <div class="metric-card">
        <div class="metric-value" id="metric-budget">--</div>
        <div class="metric-label">Budget Remaining</div>
      </div>
      <div class="metric-card">
        <div class="metric-value" id="metric-won">--</div>
        <div class="metric-label">Players Won</div>
      </div>
      <div class="metric-card">
        <div class="metric-value" id="metric-active">--</div>
        <div class="metric-label">Active Bids</div>
      </div>
      <div class="metric-card">
        <div class="metric-value" id="metric-spent">--</div>
        <div class="metric-label">Total Spent</div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="auction-toolbar">
      <div class="toolbar-left">
        <h1 class="section-title">Auction Tracker</h1>
        <span class="count-display" id="auction-count" aria-live="polite"></span>
      </div>
      <div class="toolbar-center">
        <div class="view-toggle" role="tablist" aria-label="Auction views">
          <button role="tab" id="tab-btn-active" class="view-tab view-tab--active" data-tab="active" aria-selected="true" aria-controls="tab-active">Active</button>
          <button role="tab" id="tab-btn-completed" class="view-tab" data-tab="completed" aria-selected="false" aria-controls="tab-completed">Completed</button>
          {myFranchiseId && (
            <button role="tab" id="tab-btn-my-activity" class="view-tab" data-tab="my-activity" aria-selected="false" aria-controls="tab-my-activity">My Activity</button>
          )}
        </div>
      </div>
      <div class="toolbar-right">
        <label class="team-filter">
          <select id="team-filter-select" aria-label="Filter by team">
            <option value="">All Teams</option>
            {(leagueConfig as any).teams.map((t: any) => (
              <option value={t.franchiseId} selected={t.franchiseId === myFranchiseId}>
                {chooseTeamName({ fullName: t.name, nameMedium: t.nameMedium, nameShort: t.nameShort, abbrev: t.abbrev }, 'short')}
              </option>
            ))}
          </select>
        </label>
        <div class="refresh-indicator" id="refresh-indicator">
          <span class="refresh-dot"></span>
          <span class="refresh-text" id="refresh-text">Loading...</span>
        </div>
      </div>
    </div>

    <!-- Split View Container -->
    <div class="auction-split" id="auction-split">
      <!-- Left: Auction Data -->
      <div class="auction-panel auction-panel--main">
        <!-- Active Auctions Tab -->
        <div class="tab-content tab-content--active" id="tab-active" role="tabpanel" aria-labelledby="tab-btn-active">
          <div class="auction-table-wrap">
            <table class="auction-table" id="active-table">
              <thead>
                <tr>
                  <th scope="col" class="col-player">Player</th>
                  <th scope="col" class="col-bid">Current Bid</th>
                  <th scope="col" class="col-bidder">High Bidder</th>
                  <th scope="col" class="col-time">Time Left</th>
                  <th scope="col" class="col-bids">Bids</th>
                  <th scope="col" class="col-action">Action</th>
                </tr>
              </thead>
              <tbody id="active-tbody">
                <tr class="loading-row">
                  <td colspan="6">
                    <div class="loading-shimmer">Loading auction data...</div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Completed Auctions Tab -->
        <div class="tab-content" id="tab-completed" role="tabpanel" aria-labelledby="tab-btn-completed" style="display:none">
          <div class="auction-table-wrap">
            <table class="auction-table" id="completed-table">
              <thead>
                <tr>
                  <th scope="col" class="col-player">Player</th>
                  <th scope="col" class="col-bid">Winning Bid</th>
                  <th scope="col" class="col-bidder">Winner</th>
                  <th scope="col" class="col-time">Completed</th>
                  <th scope="col" class="col-bids">Bids</th>
                </tr>
              </thead>
              <tbody id="completed-tbody"></tbody>
            </table>
          </div>
        </div>

        <!-- My Activity Tab -->
        {myFranchiseId && (
          <div class="tab-content" id="tab-my-activity" role="tabpanel" aria-labelledby="tab-btn-my-activity" style="display:none">
            <div class="auction-table-wrap">
              <table class="auction-table" id="my-activity-table">
                <thead>
                  <tr>
                    <th scope="col" class="col-player">Player</th>
                    <th scope="col" class="col-bid">Bid</th>
                    <th scope="col" class="col-status">Status</th>
                    <th scope="col" class="col-time">Time</th>
                  </tr>
                </thead>
                <tbody id="my-activity-tbody"></tbody>
              </table>
            </div>
          </div>
        )}
      </div>

      <!-- Right: Available Players Board -->
      <div class="auction-panel auction-panel--board">
        <div class="board-header">
          <h2 class="section-title section-title--board">Available Players</h2>
          <div class="board-controls">
            <select id="position-filter" class="board-select" aria-label="Filter by position">
              <option value="ALL">All Pos</option>
              <option value="QB">QB</option>
              <option value="RB">RB</option>
              <option value="WR">WR</option>
              <option value="TE">TE</option>
              <option value="DEF">DEF</option>
            </select>
            <select id="ranking-source" class="board-select" aria-label="Ranking source">
              <option value="custom">My Rankings</option>
              <option value="average">Avg Rankings</option>
            </select>
          </div>
        </div>
        <div class="board-list" id="board-list">
          <div class="loading-shimmer">Loading rankings...</div>
        </div>
      </div>
    </div>

    <!-- Empty State -->
    <div class="auction-empty" id="auction-empty" style="display:none">
      <div class="empty-icon">&#9878;</div>
      <h2 class="empty-title">No Auction Activity</h2>
      <p class="empty-text">The auction has not started yet, or all auctions are complete.</p>
    </div>

    <!-- Bid Modal -->
    <div class="bid-modal-overlay" id="bid-modal" style="display:none" role="dialog" aria-modal="true" aria-label="Place Bid">
      <div class="bid-modal">
        <button class="bid-modal__close" id="bid-modal-close" aria-label="Close bid dialog" type="button">&times;</button>
        <h3 class="section-title">Place Bid</h3>
        <div class="bid-modal__player" id="bid-modal-player"></div>
        <div class="bid-modal__current" id="bid-modal-current"></div>
        <label class="bid-modal__label">
          Your Bid ($)
          <input type="number" id="bid-amount-input" class="bid-modal__input" min="0" step="25000" />
        </label>
        <div class="bid-modal__actions">
          <button class="btn btn--ghost" id="bid-cancel" type="button">Cancel</button>
          <button class="btn btn--secondary" id="bid-submit" type="button">Submit Bid</button>
        </div>
        <div class="bid-modal__status" id="bid-status" role="status"></div>
      </div>
    </div>

    <!-- Screen reader live region for auction updates -->
    <div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" id="auction-announcer"></div>
  </div>

  <!-- Serialized data for client-side use -->
  <script type="application/json" id="player-data">{JSON.stringify(playerLookup)}</script>
  <script type="application/json" id="team-data">{JSON.stringify(teamLookup)}</script>
  <script type="application/json" id="auction-config">{JSON.stringify({
    myFranchiseId,
    auctionBudget,
    draftLimitHours,
    suspStart,
    suspEnd,
    isAuthenticated: !!user,
    currentYear,
  })}</script>

  <script>
    /**
     * Auction Tracker Client Script
     *
     * Handles: polling, DOM updates, tab switching, notifications, bid placement.
     * Uses vanilla JS — no React hydration needed.
     */
    function initAuctionTracker() {
      // ---------------------------------------------------------------------------
      // Parse serialized data
      // ---------------------------------------------------------------------------
      const playerLookup = JSON.parse(document.getElementById('player-data')?.textContent || '{}');
      const teamLookup = JSON.parse(document.getElementById('team-data')?.textContent || '{}');
      const config = JSON.parse(document.getElementById('auction-config')?.textContent || '{}');

      // ---------------------------------------------------------------------------
      // State
      // ---------------------------------------------------------------------------
      let currentTab = 'active';
      let previousActive: any[] = [];
      let currentState: any = { active: [], completed: [], teamSummaries: {} };
      let rosteredIds = new Set();
      let pollInterval: ReturnType<typeof setInterval> | null = null;
      let customRankings: string[] | null = null;
      let rankMap: Map<string, number> | null = null;
      let isPageVisible = true;
      let lastFetchTime = 0;
      let notificationSound = localStorage.getItem('auction-notification-sound') !== 'off';
      let selectedTeamFilter = config.myFranchiseId || '';
      let selectedPosition = 'ALL';
      let rankingSource = 'custom';

      // DOM references
      const activeTbody = document.getElementById('active-tbody');
      const completedTbody = document.getElementById('completed-tbody');
      const myActivityTbody = document.getElementById('my-activity-tbody');
      const metricsGrid = document.getElementById('metrics-grid');
      const boardList = document.getElementById('board-list');
      const notificationsEl = document.getElementById('auction-notifications');
      const announcer = document.getElementById('auction-announcer');
      const refreshText = document.getElementById('refresh-text');
      const auctionCount = document.getElementById('auction-count');
      const emptyState = document.getElementById('auction-empty');
      const splitView = document.getElementById('auction-split');

      // ---------------------------------------------------------------------------
      // Formatting helpers (duplicated from server utils for client use)
      // ---------------------------------------------------------------------------
      function formatBid(amount) {
        if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(2)}M`;
        if (amount >= 1_000) {
          const k = amount / 1_000;
          return k === Math.floor(k) ? `$${k}k` : `$${Math.round(k)}k`;
        }
        return `$${amount.toLocaleString()}`;
      }

      function formatRelative(unixSec) {
        const diff = Math.floor(Date.now() / 1000) - unixSec;
        if (diff < 60) return 'just now';
        if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
        if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
        if (diff < 604800) return `${Math.floor(diff / 86400)}d ago`;
        return new Date(unixSec * 1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      function formatFull(unixSec) {
        return new Date(unixSec * 1000).toLocaleString('en-US', {
          month: 'short', day: 'numeric', year: 'numeric',
          hour: 'numeric', minute: '2-digit', hour12: true,
        });
      }

      function estimateExpiration(lastBidTime) {
        const suspDuration = (config.suspEnd - config.suspStart) * 3600;
        const limit = config.draftLimitHours * 3600;
        let remaining = limit;
        let cursor = lastBidTime;
        let iterations = 0;
        while (remaining > 0 && iterations < 100) {
          iterations++;
          const d = new Date(cursor * 1000);
          const hour = d.getHours();
          if (hour >= config.suspStart && hour < config.suspEnd) {
            const end = new Date(d);
            end.setHours(config.suspEnd, 0, 0, 0);
            cursor = Math.floor(end.getTime() / 1000);
          } else {
            const next = new Date(d);
            if (hour >= config.suspEnd) next.setDate(next.getDate() + 1);
            next.setHours(config.suspStart, 0, 0, 0);
            const secUntil = Math.floor(next.getTime() / 1000) - cursor;
            if (remaining <= secUntil) {
              cursor += remaining;
              remaining = 0;
            } else {
              remaining -= secUntil;
              cursor += secUntil + suspDuration;
            }
          }
        }
        return cursor;
      }

      function formatTimeRemaining(expTs) {
        const diff = expTs - Math.floor(Date.now() / 1000);
        if (diff <= 0) return '<span class="time-expired">Expired</span>';
        if (diff < 3600) return `${Math.floor(diff / 60)}m left`;
        if (diff < 86400) {
          const h = Math.floor(diff / 3600);
          const m = Math.floor((diff % 3600) / 60);
          return m > 0 ? `${h}h ${m}m` : `${h}h left`;
        }
        const d = Math.floor(diff / 86400);
        const h = Math.floor((diff % 86400) / 3600);
        return h > 0 ? `${d}d ${h}h` : `${d}d left`;
      }

      // HTML-escape to prevent XSS in innerHTML templates
      function esc(str) {
        if (!str) return '';
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function teamName(franchiseId) {
        const t = teamLookup[franchiseId];
        if (!t) return esc(franchiseId);
        return esc(t.nameShort || t.nameMedium || t.name || franchiseId);
      }

      function teamIcon(franchiseId) {
        const t = teamLookup[franchiseId];
        return t?.icon || '';
      }

      function playerInfo(playerId) {
        return playerLookup[playerId] || { id: playerId, name: `Player ${playerId}`, position: '??', team: 'FA' };
      }

      // ---------------------------------------------------------------------------
      // Rendering: Player cell HTML (client-side equivalent of PlayerCell.astro)
      // ---------------------------------------------------------------------------
      function buildPlayerHTML(p) {
        const isDef = p.position === 'DEF';
        const headshot = isDef
          ? `https://a.espncdn.com/combiner/i?img=/i/teamlogos/nfl/500/${p.team}.png&h=80&w=80`
          : `https://a.espncdn.com/i/headshots/nfl/players/full/${p.id}.png`;
        const nflLogo = `https://a.espncdn.com/combiner/i?img=/i/teamlogos/nfl/500/${p.team}.png&h=28&w=28`;
        return `
          <div class="player-lockup">
            <img class="player-lockup__avatar" src="${headshot}" alt="" width="36" height="36"
              onerror="this.onerror=null;this.src='/assets/default-headshot.png'" loading="lazy" />
            <div class="player-lockup__info">
              <span class="player-lockup__name">${esc(p.name)}</span>
              <span class="player-lockup__meta">
                <span class="player-lockup__pos">${p.position}</span>
                ${!isDef ? `<img class="player-lockup__nfl-logo" src="${nflLogo}" alt="${p.team}" width="14" height="14" />` : ''}
              </span>
            </div>
          </div>`;
      }

      // ---------------------------------------------------------------------------
      // Rendering: Active Auctions
      // ---------------------------------------------------------------------------
      function renderActive(auctions) {
        if (!activeTbody) return;
        const filtered = selectedTeamFilter
          ? auctions.filter(a => a.highBidder === selectedTeamFilter || a.nominatedBy === selectedTeamFilter ||
              a.bidHistory?.some(b => b.franchise === selectedTeamFilter))
          : auctions;

        if (filtered.length === 0) {
          activeTbody.innerHTML = `<tr><td colspan="6" class="empty-cell">No active auctions</td></tr>`;
          return;
        }

        activeTbody.innerHTML = filtered.map(a => {
          const p = playerInfo(a.playerId);
          const exp = estimateExpiration(a.lastBidTime);
          const isMyBid = a.highBidder === config.myFranchiseId;
          const iOutbid = !isMyBid && a.bidHistory?.some(b => b.franchise === config.myFranchiseId);
          const icon = teamIcon(a.highBidder);
          const rowClass = isMyBid ? 'auction-row auction-row--my-bid' : iOutbid ? 'auction-row auction-row--outbid' : 'auction-row';

          return `<tr class="${rowClass}" data-player="${a.playerId}">
            <td class="col-player">${buildPlayerHTML(p)}</td>
            <td class="col-bid"><span class="bid-amount">${formatBid(a.currentBid)}</span></td>
            <td class="col-bidder">
              <span class="bidder-cell">
                ${icon ? `<img class="bidder-icon" src="${icon}" alt="" width="20" height="20" />` : ''}
                <span>${teamName(a.highBidder)}</span>
                ${isMyBid ? '<span class="badge badge--high-bidder">You</span>' : ''}
                ${iOutbid ? '<span class="badge badge--outbid">Outbid</span>' : ''}
              </span>
            </td>
            <td class="col-time" title="${formatFull(a.lastBidTime)}">${formatTimeRemaining(exp)}</td>
            <td class="col-bids">${a.bidCount}</td>
            <td class="col-action">
              ${config.isAuthenticated ? `<button class="btn-bid" data-player="${a.playerId}" data-current="${a.currentBid}" type="button" aria-label="Bid on ${esc(p.name)}">Bid</button>` : ''}
            </td>
          </tr>`;
        }).join('');

        // Attach bid button listeners
        activeTbody.querySelectorAll('.btn-bid').forEach(btn => {
          btn.addEventListener('click', () => openBidModal(btn.dataset.player, parseInt(btn.dataset.current, 10)));
        });
      }

      // ---------------------------------------------------------------------------
      // Rendering: Completed Auctions
      // ---------------------------------------------------------------------------
      function renderCompleted(auctions) {
        if (!completedTbody) return;
        const filtered = selectedTeamFilter
          ? auctions.filter(a => a.winner === selectedTeamFilter)
          : auctions;

        if (filtered.length === 0) {
          completedTbody.innerHTML = `<tr><td colspan="5" class="empty-cell">No completed auctions</td></tr>`;
          return;
        }

        completedTbody.innerHTML = filtered.map(a => {
          const p = playerInfo(a.playerId);
          const icon = teamIcon(a.winner);
          const isMyWin = a.winner === config.myFranchiseId;
          return `<tr class="${isMyWin ? 'auction-row auction-row--my-bid' : 'auction-row'}">
            <td class="col-player">${buildPlayerHTML(p)}</td>
            <td class="col-bid"><span class="bid-amount">${formatBid(a.winningBid)}</span></td>
            <td class="col-bidder">
              <span class="bidder-cell">
                ${icon ? `<img class="bidder-icon" src="${icon}" alt="" width="20" height="20" />` : ''}
                <span>${teamName(a.winner)}</span>
                ${isMyWin ? '<span class="badge badge--won">Won</span>' : ''}
              </span>
            </td>
            <td class="col-time" title="${formatFull(a.lastBidTime)}">${formatRelative(a.lastBidTime)}</td>
            <td class="col-bids">${a.bidCount}</td>
          </tr>`;
        }).join('');
      }

      // ---------------------------------------------------------------------------
      // Rendering: My Activity
      // ---------------------------------------------------------------------------
      function renderMyActivity(state) {
        if (!myActivityTbody || !config.myFranchiseId) return;

        const rows = [];

        // Active where I'm high bidder
        for (const a of state.active) {
          if (a.highBidder === config.myFranchiseId) {
            const p = playerInfo(a.playerId);
            const exp = estimateExpiration(a.lastBidTime);
            rows.push(`<tr class="auction-row auction-row--my-bid">
              <td class="col-player">${buildPlayerHTML(p)}</td>
              <td class="col-bid">${formatBid(a.currentBid)}</td>
              <td class="col-status"><span class="badge badge--high-bidder">High Bidder</span></td>
              <td class="col-time">${formatTimeRemaining(exp)}</td>
            </tr>`);
          }
        }

        // Active where I've been outbid
        for (const a of state.active) {
          if (a.highBidder !== config.myFranchiseId && a.bidHistory?.some(b => b.franchise === config.myFranchiseId)) {
            const p = playerInfo(a.playerId);
            rows.push(`<tr class="auction-row auction-row--outbid">
              <td class="col-player">${buildPlayerHTML(p)}</td>
              <td class="col-bid">${formatBid(a.currentBid)}</td>
              <td class="col-status"><span class="badge badge--outbid">Outbid</span></td>
              <td class="col-time">${formatRelative(a.lastBidTime)}</td>
            </tr>`);
          }
        }

        // Won
        for (const a of state.completed) {
          if (a.winner === config.myFranchiseId) {
            const p = playerInfo(a.playerId);
            rows.push(`<tr class="auction-row">
              <td class="col-player">${buildPlayerHTML(p)}</td>
              <td class="col-bid">${formatBid(a.winningBid)}</td>
              <td class="col-status"><span class="badge badge--won">Won</span></td>
              <td class="col-time">${formatRelative(a.lastBidTime)}</td>
            </tr>`);
          }
        }

        myActivityTbody.innerHTML = rows.length > 0 ? rows.join('')
          : `<tr><td colspan="4" class="empty-cell">No auction activity for your team yet</td></tr>`;
      }

      // ---------------------------------------------------------------------------
      // Rendering: Metrics
      // ---------------------------------------------------------------------------
      function renderMetrics(state) {
        const fid = selectedTeamFilter || config.myFranchiseId;
        const summary = fid ? state.teamSummaries[fid] : null;

        document.getElementById('metric-spent').textContent = summary
          ? formatBid(summary.totalSpent)
          : formatBid(Object.values(state.teamSummaries).reduce((s, t) => s + (t.totalSpent || 0), 0));

        document.getElementById('metric-won').textContent = summary
          ? String(summary.playersWon)
          : String(state.completed.length);

        document.getElementById('metric-active').textContent = summary
          ? String(summary.activeBidsAsHighBidder)
          : String(state.active.length);

        const spent = summary ? summary.totalSpent : 0;
        document.getElementById('metric-budget').textContent = fid
          ? formatBid(config.auctionBudget - spent)
          : '--';
      }

      // ---------------------------------------------------------------------------
      // Rendering: Available Players Board
      // ---------------------------------------------------------------------------
      function renderBoard(state) {
        if (!boardList) return;

        const activePlayerIds = new Set(state.active.map(a => a.playerId));
        const completedPlayerIds = new Set(state.completed.map(a => a.playerId));

        // Find available players
        const available = [];
        for (const [id, p] of Object.entries(playerLookup)) {
          if (rosteredIds.has(id) || activePlayerIds.has(id) || completedPlayerIds.has(id)) continue;
          if (selectedPosition !== 'ALL' && p.position !== selectedPosition) continue;
          available.push(p);
        }

        // Rank: by custom rankings if available, otherwise alphabetical
        if (rankingSource === 'custom' && rankMap && rankMap.size > 0) {
          available.sort((a, b) => {
            const ra = rankMap.get(a.id) ?? 999999;
            const rb = rankMap.get(b.id) ?? 999999;
            return ra - rb;
          });
        } else {
          // Alphabetical fallback
          available.sort((a, b) => a.name.localeCompare(b.name));
        }

        // Determine highest-ranked active auction player
        let highestActiveRank = 999999;
        if (rankMap) {
          for (const a of state.active) {
            const rank = rankMap.get(a.playerId);
            if (rank !== undefined && rank < highestActiveRank) highestActiveRank = rank;
          }
        }

        const top50 = available.slice(0, 50);

        if (top50.length === 0) {
          boardList.innerHTML = '<div class="empty-cell">No available players matching filters</div>';
          return;
        }

        boardList.innerHTML = top50.map((p, i) => {
          const rank = rankMap ? (rankMap.get(p.id) ?? -1) : -1;
          const isHigher = rank !== -1 && rank < highestActiveRank;
          return `<div class="board-player ${isHigher ? 'board-player--higher' : ''}">
            <span class="board-rank">${rank !== -1 ? rank + 1 : '--'}</span>
            ${buildPlayerHTML(p)}
            ${isHigher ? '<span class="badge badge--higher">Higher on Board</span>' : ''}
          </div>`;
        }).join('');
      }

      // ---------------------------------------------------------------------------
      // Notifications
      // ---------------------------------------------------------------------------
      function playNotificationSound() {
        if (!notificationSound) return;
        try {
          const ctx = new (window.AudioContext || window.webkitAudioContext)();
          // Two-tone alert: ascending notes (C5 → E5)
          [523.25, 659.25].forEach((freq, i) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0.15, ctx.currentTime + i * 0.15);
            gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.15 + 0.25);
            osc.connect(gain).connect(ctx.destination);
            osc.start(ctx.currentTime + i * 0.15);
            osc.stop(ctx.currentTime + i * 0.15 + 0.25);
          });
        } catch { /* AudioContext unavailable */ }
      }

      function checkOutbids(newActive) {
        if (!config.myFranchiseId || previousActive.length === 0) return;

        const prevByPlayer = new Map(previousActive.map(a => [a.playerId, a]));
        const alerts = [];

        for (const curr of newActive) {
          const prev = prevByPlayer.get(curr.playerId);
          if (!prev) continue;
          if (prev.highBidder === config.myFranchiseId && curr.highBidder !== config.myFranchiseId) {
            const p = playerInfo(curr.playerId);
            alerts.push({ player: p.name, team: teamName(curr.highBidder), amount: curr.currentBid });
          }
        }

        if (alerts.length > 0 && notificationsEl) {
          const html = alerts.map(a =>
            `<div class="notification notification--outbid">
              <span class="notification__text">You've been outbid on <strong>${esc(a.player)}</strong> — ${esc(a.team)} bid ${formatBid(a.amount)}</span>
              <button class="notification__close" aria-label="Dismiss" type="button">&times;</button>
            </div>`
          ).join('');
          notificationsEl.insertAdjacentHTML('beforeend', html);
          // Only bind listeners to newly added notifications (avoid orphaning existing ones)
          notificationsEl.querySelectorAll('.notification:not([data-bound]) .notification__close').forEach(btn => {
            btn.closest('.notification').dataset.bound = '1';
            btn.addEventListener('click', () => btn.closest('.notification').remove());
          });

          // Play notification sound
          playNotificationSound();

          // Announce to screen readers
          announce(alerts.map(a => `Outbid on ${a.player} by ${a.team} at ${formatBid(a.amount)}`).join('. '));
        }
      }

      function announce(msg) {
        if (announcer) {
          announcer.textContent = msg;
          setTimeout(() => { announcer.textContent = ''; }, 1500);
        }
      }

      // ---------------------------------------------------------------------------
      // Bid Modal
      // ---------------------------------------------------------------------------
      const bidModal = document.getElementById('bid-modal');
      const bidInput = document.getElementById('bid-amount-input');
      const bidStatus = document.getElementById('bid-status');
      let bidPlayerId = '';

      let previousActiveElement = null;

      function openBidModal(playerId, currentBid) {
        bidPlayerId = playerId;
        previousActiveElement = document.activeElement;
        const p = playerInfo(playerId);
        const minBid = currentBid + 25000; // Minimum increment assumption
        document.getElementById('bid-modal-player').innerHTML = buildPlayerHTML(p);
        document.getElementById('bid-modal-current').innerHTML = `Current bid: <strong>${formatBid(currentBid)}</strong>`;
        bidInput.value = minBid;
        bidInput.min = minBid;
        bidStatus.textContent = '';
        bidModal.style.display = 'flex';
        bidInput.focus();
      }

      function closeBidModal() {
        bidModal.style.display = 'none';
        bidPlayerId = '';
        if (previousActiveElement && typeof previousActiveElement.focus === 'function') {
          previousActiveElement.focus();
          previousActiveElement = null;
        }
      }

      // Focus trap within the modal
      function trapFocus(e) {
        if (bidModal.style.display === 'none') return;
        const focusable = bidModal.querySelectorAll('button, input, select, textarea, [tabindex]:not([tabindex="-1"])');
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }

      function handleKeyDown(e) {
        if (e.key === 'Escape' && bidModal.style.display !== 'none') closeBidModal();
        if (e.key === 'Tab' && bidModal.style.display !== 'none') trapFocus(e);
      }
      document.addEventListener('keydown', handleKeyDown);

      document.getElementById('bid-modal-close')?.addEventListener('click', closeBidModal);
      document.getElementById('bid-cancel')?.addEventListener('click', closeBidModal);
      bidModal?.addEventListener('click', (e) => { if (e.target === bidModal) closeBidModal(); });

      document.getElementById('bid-submit')?.addEventListener('click', async () => {
        const amount = parseInt(bidInput.value, 10);
        if (!amount || amount <= 0 || !bidPlayerId) return;

        const submitBtn = document.getElementById('bid-submit');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
        bidStatus.textContent = '';

        try {
          const res = await fetch('/api/auction-bid', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ playerId: bidPlayerId, amount }),
          });
          const data = await res.json();
          if (data.success) {
            bidStatus.innerHTML = '<span class="bid-success">Bid placed! Refreshing...</span>';
            setTimeout(() => { closeBidModal(); fetchAuctionData(); }, 1500);
          } else {
            bidStatus.innerHTML = `<span class="bid-error">${data.message || 'Bid failed'}</span>`;
          }
        } catch {
          bidStatus.innerHTML = '<span class="bid-error">Network error. Please try again.</span>';
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Bid';
        }
      });

      // ---------------------------------------------------------------------------
      // Tab Switching
      // ---------------------------------------------------------------------------
      document.querySelectorAll('.view-tab').forEach(tab => {
        tab.addEventListener('click', () => {
          const tabId = tab.dataset.tab;
          currentTab = tabId;
          document.querySelectorAll('.view-tab').forEach(t => {
            t.classList.toggle('view-tab--active', t.dataset.tab === tabId);
            t.setAttribute('aria-selected', t.dataset.tab === tabId ? 'true' : 'false');
          });
          document.querySelectorAll('.tab-content').forEach(c => {
            c.style.display = c.id === `tab-${tabId}` ? '' : 'none';
          });
        });
      });

      // ---------------------------------------------------------------------------
      // Team Filter
      // ---------------------------------------------------------------------------
      document.getElementById('team-filter-select')?.addEventListener('change', (e) => {
        selectedTeamFilter = e.target.value;
        renderAll();
      });

      // ---------------------------------------------------------------------------
      // Position Filter & Ranking Source
      // ---------------------------------------------------------------------------
      document.getElementById('position-filter')?.addEventListener('change', (e) => {
        selectedPosition = e.target.value;
        renderBoard(currentState);
      });

      document.getElementById('ranking-source')?.addEventListener('change', (e) => {
        rankingSource = e.target.value;
        renderBoard(currentState);
      });

      // ---------------------------------------------------------------------------
      // Render All
      // ---------------------------------------------------------------------------
      function renderAll() {
        renderActive(currentState.active);
        renderCompleted(currentState.completed);
        renderMyActivity(currentState);
        renderMetrics(currentState);
        renderBoard(currentState);

        // Count display
        if (auctionCount) {
          auctionCount.innerHTML = `<strong>${currentState.active.length}</strong> active · <strong>${currentState.completed.length}</strong> completed`;
        }

        // Empty state
        const hasData = currentState.active.length > 0 || currentState.completed.length > 0;
        if (emptyState) emptyState.style.display = hasData ? 'none' : '';
        if (splitView) splitView.style.display = hasData ? '' : 'none';
      }

      // ---------------------------------------------------------------------------
      // Polling
      // ---------------------------------------------------------------------------
      async function fetchAuctionData() {
        lastFetchTime = Date.now();
        try {
          const res = await fetch('/api/auction');
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const data = await res.json();

          previousActive = currentState.active;
          currentState = data;

          // Update live roster data from API
          if (data.rosteredPlayerIds) {
            rosteredIds = new Set(data.rosteredPlayerIds);
          }

          // Check for outbids
          checkOutbids(data.active);

          renderAll();

          if (refreshText) {
            refreshText.textContent = `Updated ${new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })}`;
          }
        } catch (err) {
          console.error('[auction-tracker] Fetch error:', err);
          if (refreshText) refreshText.textContent = 'Update failed — retrying...';
          // Clear all loading shimmers so the page doesn't appear stuck
          const loadingRow = activeTbody?.querySelector('.loading-row');
          if (loadingRow) {
            activeTbody.innerHTML = '<tr><td colspan="6" class="empty-cell">Failed to load auction data — retrying...</td></tr>';
          }
          if (boardList?.querySelector('.loading-shimmer')) {
            renderBoard(currentState);
          }
        }
      }

      function startPolling() {
        fetchAuctionData();
        pollInterval = setInterval(() => {
          if (isPageVisible) fetchAuctionData();
        }, 30000);
      }

      function stopPolling() {
        if (pollInterval) {
          clearInterval(pollInterval);
          pollInterval = null;
        }
        document.removeEventListener('keydown', handleKeyDown);
        document.removeEventListener('visibilitychange', handleVisibilityChange);
      }

      // Page Visibility API — pause polling when tab is hidden
      function handleVisibilityChange() {
        isPageVisible = !document.hidden;
        if (isPageVisible) {
          // Only refetch if stale (>20s since last fetch) to avoid redundant calls
          const staleness = Date.now() - lastFetchTime;
          if (staleness > 20_000) fetchAuctionData();
        }
      }
      document.addEventListener('visibilitychange', handleVisibilityChange);

      // ---------------------------------------------------------------------------
      // Load Custom Rankings
      // ---------------------------------------------------------------------------
      async function loadRankings() {
        try {
          const res = await fetch('/api/cr');
          if (res.ok) {
            const { data } = await res.json();
            if (data?.rankings) {
              customRankings = data.rankings;
              rankMap = new Map(customRankings.map((id, i) => [id, i]));
              renderBoard(currentState);
            }
          }
        } catch {
          // Rankings unavailable — clear shimmer and fall back to alphabetical
          if (boardList?.querySelector('.loading-shimmer')) {
            renderBoard(currentState);
          }
        }
      }

      // ---------------------------------------------------------------------------
      // Init
      // ---------------------------------------------------------------------------
      startPolling();
      loadRankings();

      // Cleanup on View Transitions navigation
      document.addEventListener('astro:before-swap', stopPolling, { once: true });
    }

    // Initialize on page load and on View Transitions
    document.addEventListener('astro:page-load', initAuctionTracker);
  </script>
</TheLeagueLayout>

