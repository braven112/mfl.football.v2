    summary:
      '“Same guy, leveled up” — an enhancement casts a rostered player in his first five NFL seasons. Strictly someone an owner invested in; the caption reads his year.',
    name: 'Jahmyr Gibbs',
    descriptor: '4th Year',
    pos: 'RB',
    code: 'DET',
    espnId: '4429795',
    primary: '#0076b6',
  },
  {
    key: 'auction',
    accent: 'amber',
    component: 'AuctionCompositeHero',
    wordmark: 'AUCTION',
    pill: 'Bidding open',
    title: 'The auction is live',
    summary:
      'Best available by dynasty ADP models the money window — the pick rotates daily so one face doesn’t own the whole auction. Amber money accent.',
    name: "Ja'Marr Chase",
    descriptor: 'Best Available',
    pos: 'WR',
    code: 'CIN',
    espnId: '4362628',
    primary: '#fb4f14',
  },
  {
    key: 'cut',
    accent: 'red',
    component: 'CutWatchCompositeHero',
    wordmark: 'CUT WATCH',
    pill: 'Final 30 days',
    title: 'Two teams are over the roster limit',
    summary:
      'Signed in, the hero casts a suggested cut candidate from YOUR team, chip reads “You +2.” The blue planning tier flips to this urgent red inside the final 30 days.',
    name: 'Bijan Robinson',
    descriptor: 'Your bubble player',
    pos: 'RB',
    code: 'ATL',
    espnId: '4430807',
    primary: '#a71930',
  },
  {
    key: 'kickoff',
    accent: 'green',
    component: 'PreseasonCompositeHero',
    wordmark: 'KICKOFF',
    pill: 'Season opener',
    title: 'Football is back Thursday night',
    summary:
      'The best projected starter in the week’s earliest game — and if you roster a player in that opener, you see your own best one. “Your Kickoff Starter.”',
    name: 'Lamar Jackson',
    descriptor: 'Your Kickoff Starter',
    pos: 'QB',
    code: 'BAL',
    espnId: '3916387',
    primary: '#241773',
  },
];
const galleryVars = (primary: string) =>
  // Match the shipped FeatureCompositeHero glow alphas exactly: 0.38 dark, 0.2 light.
  `--hc-glow-dark: ${hexToRgba(primary, 0.38)}; --hc-glow-light: ${hexToRgba(primary, 0.2)};`;

// The 14 season phases — verbatim windows from src/types/hero-state.ts.
const phases = [
  ['championship', 'Week 17 Thu → Mon night final'],
  ['champion-crowned', 'Championship decided → +7 days'],
  ['tag-window', 'After champion crowned → Feb 14'],
  ['tagged-showcase', 'Feb 15 → auction hero start'],
  ['auction-preview', 'Mon before 3rd Thu Mar → Thu 7am PT'],
  ['auction-live', '3rd Thu Mar 7am PT → +10 days'],
  ['draft-countdown', 'Auction end → Draft hero (scouting lull)'],
  ['draft-announced', 'Mon after NFL Draft → rookie draft'],
  ['draft-live', 'Rookie draft start → draft completes'],
  ['udfa-window', 'Draft completes → +7 days'],
  ['cut-watch', 'Jun 1 → 3rd Sun of Aug'],
  ['preseason-countdown', 'FA close → NFL kickoff'],
  ['regular-season', 'NFL kickoff → end of Week 14'],
  ['trade-deadline', 'Nov 13 (24h override)'],
  ['playoffs', 'Week 15 → Week 16'],
  ['offseason-fallback', 'Any gap not covered above'],
];
const slots = [
  ['live-scoring', 'TNF, Sunday, MNF game windows'],
  ['standings', 'Monday pre-game'],
  ['recap', 'Tuesday AM'],
  ['waiver-wire', 'Tuesday PM → Wednesday 8pm'],
  ['article', 'Schefter articles (pickups, preview)'],
  ['game-day-preview', 'Saturday, Sunday pre-game'],
];

// The real casting functions (src/utils/hero-casting.ts).
const castFns = [
  ['castFeaturedModel', 'What’s New (entry names a player)', 'Exactly the player the entry features — otherwise the hero shows the feature’s own screenshot.'],
  ['castRookieModel', 'Season reset (AFL new-season)', 'Newest draft class in the pool, rostered-first, daily rotation.'],
  ['castTopFreeAgentModel', 'Auction preview / live', 'Top-5 unrostered free agents by dynasty ADP, rotated daily.'],
  ['castClosingAuctionModel', 'Auction, live bids', 'The player whose bid clock runs out first (oldest anchor + MFL’s 36h rule).'],
  ['castRookiesOnBoard', 'UDFA window', 'Best current-class rookies still unrostered — the board is the board (no rotation).'],
  ['castBestScoredModel', 'Preseason / kickoff', 'Highest-projected starter in the earliest game — your player if you roster one.'],
  ['castRandomStarterModel', 'Preseason / kickoff', 'Rotates among likely starters (top-8/team by projection) in that game.'],
  ['castRosterModel', 'Roster actions (cuts, tags)', 'A candidate from YOUR franchise; guests get a league-wide daily pick.'],
];
---

<TheLeagueLayout title="Composite Hero System | The League">
  <div class="hc-page">

    <!-- ===== HERO ===== -->
    <header class="hc-hero">
      <div class="hc-hero__eyebrow">
        <span class="hc-tag">Feature Deep-Dive</span>
        <span class="hc-dot">·</span>
        <span class="hc-hero__date">Homepage Hero System</span>
      </div>

      <h1 class="hc-hero__title">Every hero puts a real player on screen.<br>The face always means something.</h1>

      <p class="hc-hero__deck">
        The homepage hero isn't decoration. A rules engine decides <em>which</em> player's
        face appears on any given day, and a small image pipeline decides <em>how</em> it's
        rendered — a free ESPN cutout composited over his NFL team's colors, personalized to
        the signed-in owner, and stable for a full Pacific-Time day. This is how it works.
      </p>

      <div class="hc-hero__stack">
        <span class="hc-stack-item">Astro SSR</span>
        <span class="hc-stack-dot">·</span>
        <span class="hc-stack-item">Deterministic casting</span>
        <span class="hc-stack-dot">·</span>
        <span class="hc-stack-item">CSS composites over ESPN CDN</span>
        <span class="hc-stack-dot">·</span>
        <span class="hc-stack-item">14-phase state machine</span>
        <span class="hc-stack-dot">·</span>
        <span class="hc-stack-item">Light + dark</span>
      </div>
    </header>

    <!-- ===== GALLERY (show, don't tell) ===== -->
    <section class="hc-gallery" aria-label="Composite hero gallery">
      {gallery.map((g) => (
        <article
          class={`hcx hcx--${g.accent}`}
          style={galleryVars(g.primary ?? '#1c497c')}
          aria-label={`${g.title} — featuring ${g.name}, ${g.descriptor}, ${g.pos}, ${g.code}`}
        >
          <span class="hcx__ghost" aria-hidden="true">{g.wordmark}</span>
          <div class="hcx__glow" aria-hidden="true"></div>
          <img
            class="hcx__model"
            src={headshot(g.espnId)}
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
            onerror="this.closest('.hcx').classList.add('hcx--no-model')"
          />
          <span class="hcx__caption">
            <strong>{g.name}</strong>
            <span class="hcx__caption-meta">{g.descriptor} · {g.pos} · {g.code}</span>
          </span>
          <!-- On a headshot 404 the card reveals the league-logo silhouette
               instead of an empty flank — mirrors the shipped .fch behavior. -->
          <img class="hcx__logo-art hcx__logo-art--light" src="/assets/logos/theleague-logo.svg" alt="" aria-hidden="true" loading="lazy" />
          <img class="hcx__logo-art hcx__logo-art--dark" src="/assets/logos/theleague-logo-dark.svg" alt="" aria-hidden="true" loading="lazy" />
          <div class="hcx__content">
            <p class="hcx__eyebrow">
              <span class="hcx__pill">{g.pill}</span>
              <span class="hcx__component">{g.component}</span>
            </p>
            <h3 class="hcx__title">{g.title}</h3>
            <p class="hcx__summary">{g.summary}</p>
            <span class="hcx__cta">Check it out <span aria-hidden="true">→</span></span>
          </div>
        </article>
      ))}
    </section>
    <p class="hc-gallery__note">
      Reproductions of the shipped hero treatment — real players, real NFL team colors, and the
      exact gradient / radial glow / ghost-wordmark / frosted-caption CSS from the live components.
      Toggle your theme: the gradient, glow, and tokens re-resolve for dark mode.
    </p>

    <div class="hc-body">

      <!-- ===== 01: THE PREMISE ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">01</span>
          <div>
            <h2 class="hc-section-title">The Premise</h2>
            <p class="hc-section-sub">Why there's a real player on the hero at all — and the one rule that governs it</p>
          </div>
        </div>

        <div class="hc-two-col">
          <div class="hc-prose">
            <p>
              Identifiable NFL action photography is rights-managed — Getty, AP, Imagn. A fantasy
              site can't ship it. The easy fallback is a gradient with a headline slapped on top,
              which is exactly how most fantasy homepages look: fine, forgettable, decorative.
            </p>
            <p>
              The approach here is different. Every NFL player has a <strong>free, transparent
              headshot on ESPN's CDN</strong>. Layer that cutout over his team's colors with a
              little typography and glow, and you get a branded, on-topic hero — automatically, for
              any player, with zero licensing. The constraint became the design language.
            </p>
            <p>
              That unlocks the actual rule, which is the whole point of the system:
            </p>
          </div>
          <blockquote class="hc-quote hc-quote--binding">
            <div class="hc-quote__label">Casting Rule — Brandon, binding</div>
            “Every hero casts a <strong>semantically relevant</strong> player — the actual player
            in a breaking story, the rookie behind a new feature, a bubble player from
            <em>your</em> roster on cut watch. Never a random star for decoration.”
          </blockquote>
        </div>
      </section>

      <!-- ===== 02: THE IMAGE PIPELINE ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">02</span>
          <div>
            <h2 class="hc-section-title">The Image Pipeline</h2>
            <p class="hc-section-sub">How a name becomes a composite — and the gate that keeps it from breaking</p>
          </div>
        </div>

        <div class="hc-layers">
          <div class="hc-layer">
            <div class="hc-layer__z">z-0</div>
            <div class="hc-layer__body">
              <div class="hc-layer__name">Team-color gradient + ghost wordmark</div>
              <div class="hc-layer__desc">A diagonal gradient (league-blue base) with an oversized, barely-there wordmark — <code>WHAT'S&nbsp;NEW</code>, <code>AUCTION</code>, <code>CUT&nbsp;WATCH</code> — bled off the top edge.</div>
            </div>
          </div>
          <div class="hc-layer">
            <div class="hc-layer__z">z-1</div>
            <div class="hc-layer__body">
              <div class="hc-layer__name">Radial glow, tinted by NFL team color</div>
              <div class="hc-layer__desc"><code>hexToRgba(primary, 0.38)</code> in dark, <code>0.2</code> in light — the player's team hue bleeds in from the corner behind him.</div>
            </div>
          </div>
          <div class="hc-layer">
            <div class="hc-layer__z">z-2</div>
            <div class="hc-layer__body">
              <div class="hc-layer__name">Transparent ESPN headshot cutout</div>
              <div class="hc-layer__desc">Anchored bottom-right with a soft drop-shadow. On the real homepage hero it's <code>loading="eager"</code> (above the fold); the reproductions below lazy-load. Always <code>decoding="async"</code>, decorative <code>alt=""</code>.</div>
            </div>
          </div>
          <div class="hc-layer">
            <div class="hc-layer__z">z-3</div>
            <div class="hc-layer__body">
              <div class="hc-layer__name">Frosted caption + editorial copy</div>
              <div class="hc-layer__desc">Player name on a <code>backdrop-filter: blur(2px)</code> pill bottom-right; kicker, title, summary, CTA bottom-left with an <strong>explicit</strong> text color so global heading rules can't restyle it.</div>
            </div>
          </div>
        </div>

        <div class="hc-two-col hc-two-col--code-left">
          <figure class="hc-code">
            <figcaption class="hc-code__cap">src/utils/hero-casting.ts</figcaption>
            <pre class="hc-code__pre"><code>{`/** Composites need a transparent ESPN cutout —
    MFL JPGs have baked backgrounds. */
function isCompositable(player: PlayerIdentity): boolean {
  return player.position !== 'DEF'
    && player.headshot.includes('espncdn.com');
}`}</code></pre>
          </figure>
          <div class="hc-prose">
            <p>
              Two failure modes get gated out before anything renders. <strong>Transparency is
              load-bearing:</strong> the ESPN headshot has an alpha channel; MFL's fallback JPG
              (<code>player_photos_big_2014/…_thumb.jpg</code>) has a baked-in background that ruins
              the composite. So the gate requires an <code>espncdn.com</code> URL. And a
              <strong>team defense isn't a person</strong> — <code>position === 'DEF'</code> is
              excluded, since a "DEF player" is a logo, not a face.
            </p>
            <p>
              Even a valid ESPN id can 404 (deep free agents sometimes have no photo). The cutout
              carries an inline <code>onerror</code> that hides itself and its caption, and the
              hero swaps to the <strong>league-logo silhouette</strong> — a gradient with an empty
              flank reads as broken, so it never ships one.
            </p>
          </div>
        </div>

        <div class="hc-chips">
          <span class="hc-chip">DEF → excluded</span>
          <span class="hc-chip">MFL JPG → excluded</span>
          <span class="hc-chip">404 → league-logo silhouette</span>
          <span class="hc-chip">tabular-nums on every metric</span>
          <span class="hc-chip">prefers-reduced-motion guarded</span>
        </div>
      </section>

      <!-- ===== 03: BRANDING & COLOR ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">03</span>
          <div>
            <h2 class="hc-section-title">Branding &amp; Color</h2>
            <p class="hc-section-sub">The player's NFL team paints the hero; his fantasy team rides alongside</p>
          </div>
        </div>

        <div class="hc-prose">
          <p>
            Color comes from one source of truth: a <strong>32-team NFL brand-color map</strong>
            (<code>NFL_TEAM_COLORS</code>, keyed by ESPN codes) with a hand-picked primary and
            secondary per team — secondary deliberately skips near-white "official" colors that
            would be useless on a dark composite. The player's NFL team drives the gradient anchor
            and the glow tint. Unknown or free-agent codes fall back to <strong>TheLeague
            blue, <code>#1c497c</code></strong>.
          </p>
        </div>

        <div class="hc-brand-grid">
          <div class="hc-brand-card">
            <div class="hc-brand-card__head">Rostered player</div>
            <p class="hc-brand-card__body">
              The hero is about a fantasy team, so franchise identity rides alongside the NFL
              color — the owner's <strong>crest and short name</strong> as a chip, a
              <strong>“You&nbsp;+N”</strong> marker when it's your own player. Cut watch and the
              tagged-player showcase are the roster-branded surfaces.
            </p>
            <div class="hc-brand-card__tag">franchise crest · chooseTeamName(…, 'short')</div>
          </div>
          <div class="hc-brand-card">
            <div class="hc-brand-card__head">Free agent / unrostered</div>
            <p class="hc-brand-card__body">
              No fantasy team to brand to, so the hero leans on <strong>NFL identity</strong> — the
              team-color gradient and glow, the league logo as backdrop art on the live auction.
              Auction and UDFA are the free-agent surfaces; deep FAs fall back to league blue.
            </p>
            <div class="hc-brand-card__tag">NFL_TEAM_COLORS · #1c497c fallback</div>
          </div>
        </div>

        <div class="hc-swatches" role="list" aria-label="Sample NFL team colors">
          <div class="hc-swatch" role="listitem" style="--sw: #241773"><span class="hc-swatch__dot"></span>BAL <code>#241773</code></div>
          <div class="hc-swatch" role="listitem" style="--sw: #fb4f14"><span class="hc-swatch__dot"></span>CIN <code>#fb4f14</code></div>
          <div class="hc-swatch" role="listitem" style="--sw: #0b162a"><span class="hc-swatch__dot"></span>CHI <code>#0b162a</code></div>
          <div class="hc-swatch" role="listitem" style="--sw: #a71930"><span class="hc-swatch__dot"></span>ATL <code>#a71930</code></div>
          <div class="hc-swatch" role="listitem" style="--sw: #e31837"><span class="hc-swatch__dot"></span>KC <code>#e31837</code></div>
          <div class="hc-swatch" role="listitem" style="--sw: #1c497c"><span class="hc-swatch__dot"></span>FA <code>#1c497c</code></div>
        </div>
      </section>

      <!-- ===== 04: PERSONALIZATION ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">04</span>
          <div>
            <h2 class="hc-section-title">Personalization Without Randomness</h2>
            <p class="hc-section-sub">Signed-in owners see their own player; guests see a deterministic public pick</p>
          </div>
        </div>

        <div class="hc-two-col hc-two-col--wide-text">
          <div class="hc-prose">
            <p>
              Same layout, different casting. The roster-action and kickoff heroes take an optional
              <code>userFranchiseId</code>. When it's set and the owner has a relevant candidate,
              the pool <strong>narrows to their own players</strong> — your bubble cut, your
              kickoff starter, your suggested tag. When it's empty (a guest, or an owner with no
              candidate), the hero falls back to a <strong>league-wide pick</strong>.
            </p>
            <p>
              The catch: this is server-rendered, and SSR can't call <code>Math.random()</code> at
              request time — two loads of the same page would disagree, and the cache would be
              useless. So the pick is <strong>deterministic per Pacific-Time calendar day</strong>:
              an FNV-1a hash of the PT day-key plus a per-hero seed indexes into the sorted
              candidate pool. Stable across every request that day, then it rotates at midnight PT
              so one face doesn't own the window.
            </p>
            <p>
              It's testable, too — <code>?testDate=YYYY-MM-DD</code> drives both the phase and the
              rotation seed, so any day's hero can be previewed on demand.
            </p>
          </div>
          <figure class="hc-code">
            <figcaption class="hc-code__cap">The deterministic daily pick</figcaption>
            <pre class="hc-code__pre"><code>{`// PT calendar day (YYYY-MM-DD) — the rotation seed
function ptDayKey(date) {
  return new Intl.DateTimeFormat('en-CA', {
    timeZone: 'America/Los_Angeles', …
  }).format(date);
}

function dailyPick(pool, date, seedKey, keyOf) {
  if (pool.length === 0) return null;
  const sorted = [...pool].sort(
    (a, b) => keyOf(a).localeCompare(keyOf(b)));
  const i = hashSeed(\`\${ptDayKey(date)}:\${seedKey}\`)
            % sorted.length;
  return sorted[i];        // same all day, rotates at PT midnight
}`}</code></pre>
          </figure>
        </div>

        <div class="hc-persona">
          <div class="hc-persona__col">
            <div class="hc-persona__who hc-persona__who--owner">Signed-in owner</div>
            <div class="hc-persona__line">Cut watch → <strong>your</strong> suggested cut, chip reads “You&nbsp;+2”</div>
            <div class="hc-persona__line">Kickoff → <strong>your</strong> best starter in the opener</div>
            <div class="hc-persona__line">Pool narrows to <code>franchiseId === userFranchiseId</code></div>
          </div>
          <div class="hc-persona__col">
            <div class="hc-persona__who hc-persona__who--guest">Guest</div>
            <div class="hc-persona__line">Cut watch → a league-wide bubble candidate</div>
            <div class="hc-persona__line">Kickoff → the opener's highest projection</div>
            <div class="hc-persona__line">Deterministic daily pick from the full pool</div>
          </div>
        </div>
      </section>

      <!-- ===== 05: THE CASTING RULES ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">05</span>
          <div>
            <h2 class="hc-section-title">The Casting Rules, by Category</h2>
            <p class="hc-section-sub">What's New heroes show the feature itself — a player appears only when the entry names one</p>
          </div>
        </div>

        <div class="hc-cat-grid">
          <div class="hc-cat">
            <div class="hc-cat__type">entry with screenshot</div>
            <div class="hc-cat__cast">The feature itself</div>
            <div class="hc-cat__desc">The entry's screenshot in a browser frame — light/dark capture pair, hidden on mobile where the logo silhouette stands in.</div>
          </div>
          <div class="hc-cat">
            <div class="hc-cat__type">entry naming a player</div>
            <div class="hc-cat__cast">That exact player</div>
            <div class="hc-cat__desc">heroPlayerId on the entry casts him over the gradient — players show up when they're being talked about, never as stand-ins.</div>
          </div>
          <div class="hc-cat">
            <div class="hc-cat__type">bug-fix</div>
            <div class="hc-cat__cast">No player</div>
            <div class="hc-cat__desc">League-logo silhouette (light/dark asset pair). A bug fix doesn't get a face.</div>
          </div>
          <div class="hc-cat">
            <div class="hc-cat__type">league-event</div>
            <div class="hc-cat__cast">Relevant player</div>
            <div class="hc-cat__desc">The player who's actually in the story. (Event-hero conversions in progress.)</div>
          </div>
        </div>
      </section>

      <!-- ===== 06: THE CAST FUNCTIONS ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">06</span>
          <div>
            <h2 class="hc-section-title">Eight Casting Functions</h2>
            <p class="hc-section-sub">Each surface has a purpose-built picker in <code>hero-casting.ts</code> — all deterministic, all reusable</p>
          </div>
        </div>

        <div class="hc-table-wrap">
          <table class="hc-table">
            <thead>
              <tr><th>Function</th><th>Surface</th><th>Who it picks</th></tr>
            </thead>
            <tbody>
              {castFns.map(([fn, surface, who]) => (
                <tr>
                  <td><code>{fn}</code></td>
                  <td>{surface}</td>
                  <td>{who}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- ===== 07: THE STATE MACHINE ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">07</span>
          <div>
            <h2 class="hc-section-title">The Calendar Decides</h2>
            <p class="hc-section-sub">14 core season phases resolve by date — plus a trade-deadline override and an offseason fallback; the two live phases subdivide into 6 daily slots</p>
          </div>
        </div>

        <div class="hc-prose">
          <p>
            Which hero shows isn't a toggle — it's resolved from the calendar. The
            <code>hero-resolver</code> maps the current Pacific-Time date to a season phase.
            <strong>Fourteen are real windows</strong> on the league year; the
            <code>SeasonPhase</code> union below adds two more — a 24-hour
            <code>trade-deadline</code> override and an <code>offseason-fallback</code> catch-all
            for any gap (16 states in all). During the two live phases the resolver drops into a
            second axis — six <strong>daily slots</strong> keyed on day-of-week and game windows —
            so a Monday standings hero gives way to a Tuesday recap gives way to a waiver-wire
            push. A priority ladder (P0++ → P5) breaks ties.
          </p>
        </div>

        <div class="hc-phase-grid" aria-label="Season phases">
          {phases.map(([name, window], i) => (
            <div class={`hc-phase${['auction-live','cut-watch','preseason-countdown','udfa-window','offseason-fallback'].includes(name) ? ' hc-phase--shipped' : ''}`}>
              <span class="hc-phase__i">{String(i + 1).padStart(2, '0')}</span>
              <div>
                <div class="hc-phase__name">{name}</div>
                <div class="hc-phase__window">{window}</div>
              </div>
            </div>
          ))}
        </div>

        <div class="hc-slots">
          <div class="hc-slots__label">Daily slots · regular-season + playoffs</div>
          <div class="hc-slots__row">
            {slots.map(([name, when]) => (
              <div class="hc-slot"><span class="hc-slot__name">{name}</span><span class="hc-slot__when">{when}</span></div>
            ))}
          </div>
        </div>
        <p class="hc-phase-legend"><span class="hc-legend-swatch"></span> Phases with a shipped composite hero today</p>
      </section>

      <!-- ===== 08: SHIPPED HEROES ===== -->
      <section class="hc-section">
        <div class="hc-section-header">
          <span class="hc-section-num">08</span>
          <div>
            <h2 class="hc-section-title">What's Shipped</h2>
            <p class="hc-section-sub">Five composite heroes live today; each owns its gradient, wordmark, glow, and casting</p>
          </div>
        </div>

        <div class="hc-ship-grid">
          <div class="hc-ship">
            <div class="hc-ship__name">FeatureCompositeHero</div>
            <div class="hc-ship__cast">screenshot / castFeatured</div>
            <p class="hc-ship__desc">The What's New hero. The feature's own screenshot in a browser frame; the entry's featured player composites over the gradient when one is named. Can force the dark treatment when the dark card <em>is</em> the story.</p>
          </div>
          <div class="hc-ship">
            <div class="hc-ship__name">AuctionCompositeHero</div>
            <div class="hc-ship__cast">castTopFreeAgent / castClosingAuction</div>
            <p class="hc-ship__desc">Amber money accent. Best-available-by-ADP in preview; once bids are live, it flips to the player whose clock runs out first and adds a high-bid line.</p>
          </div>
          <div class="hc-ship">
            <div class="hc-ship__name">CutWatchCompositeHero</div>
            <div class="hc-ship__cast">castRosterModel</div>
            <p class="hc-ship__desc">The first personalized hero — your own bubble player, “You&nbsp;+N” chip. Blue planning tier flips red inside the final 30 days.</p>
          </div>
          <div class="hc-ship">
            <div class="hc-ship__name">PreseasonCompositeHero</div>
            <div class="hc-ship__cast">castBestScored / castRandomStarter</div>
            <p class="hc-ship__desc">The best (or a rotating) likely starter in the week's earliest game — your player if you roster one in the opener.</p>
          </div>
          <div class="hc-ship">
            <div class="hc-ship__name">UdfaCompositeHero</div>
            <div class="hc-ship__cast">castRookiesOnBoard</div>
            <p class="hc-ship__desc">Four team-gradient panels of the best rookies still on the board. Casts eight, renders the four whose photos actually load — a 404 never costs a slot.</p>
          </div>
          <div class="hc-ship hc-ship--muted">
            <div class="hc-ship__name">Honest scope</div>
            <div class="hc-ship__cast">not composites (yet)</div>
            <p class="hc-ship__desc">The playoff hero is a bracket-summary table, not a player composite. Feed-card composites were built and deliberately reverted. Breaking-story and tagged-showcase panels are mocked, not shipped.</p>
          </div>
        </div>
      </section>

      <!-- ===== CLOSING ===== -->
      <section class="hc-closing">
        <div class="hc-closing__inner">
          <div class="hc-closing__text">
            <h2 class="hc-closing__title">The Bottom Line</h2>
            <p>
              The interesting part isn't the gradient — it's that a licensing constraint turned into
              a rule (“every hero means something”), the rule turned into eight small deterministic
              pickers, and those plug into a calendar-driven state machine that already knew what day
              it was. Personalization fell out for free, because the casting functions already took a
              franchise id.
            </p>
            <p>
              It renders on the server, stays stable for a Pacific-Time day, degrades gracefully when
              a photo 404s, and looks right in light and dark. No stock photos. No licensed action
              shots. Just the right player, rendered the right way, every day.
            </p>
          </div>
          <div class="hc-closing__meta">
            <div class="hc-closing__meta-label">Key files</div>
            <ul class="hc-closing__files">
              <li>src/utils/hero-casting.ts</li>
              <li>src/utils/nfl-team-colors.ts</li>
              <li>src/utils/hero-resolver.ts · src/types/hero-state.ts</li>
              <li>src/components/theleague/*CompositeHero.astro</li>
              <li>docs/…/features/player-composites.md</li>
            </ul>
          </div>
          <div class="hc-closing__ctas">
            <a href="/theleague/about" class="hc-btn hc-btn--primary">The full case study <span class="hc-btn__arrow">→</span></a>
            <a href="/theleague/whats-new" class="hc-btn hc-btn--ghost">See heroes in the wild <span class="hc-btn__arrow">→</span></a>
          </div>
        </div>
      </section>

    </div><!-- /.hc-body -->
  </div>
</TheLeagueLayout>

