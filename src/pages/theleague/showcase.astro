---
/**
 * Composite Player-Image Hero System — engineering showcase.
 *
 * A self-contained, guest-visible deep-dive on the homepage composite hero
 * system: the casting rules, the personalization, the image pipeline, and the
 * calendar-driven state machine that decides which player's face shows and how
 * it's rendered. Built as a portfolio/interview surface in the editorial voice
 * of /theleague/about.
 *
 * The composite hero components + utils are live on main (PR #346). This page
 * deliberately reproduces the shipped `.fch` hero treatment inline — real
 * players, real NFL team colors, the exact gradient/glow/ghost-wordmark/
 * frosted-caption CSS — rather than importing those components, so the whole
 * showcase stays a single self-contained file.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';

// SSR (not prerendered) — mirrors about.astro. The apex-host clean-URL rewrite
// in src/middleware.ts (/showcase → /theleague/showcase) only runs for SSR
// routes; a prerendered route can 404 on theleague.us. Content is fully static
// so SSR is effectively free.

/** Local copy of the shipped hexToRgba (src/utils/nfl-team-colors.ts). */
function hexToRgba(hex: string, alpha: number): string {
  const m = /^#?([0-9a-f]{6})$/i.exec(hex.trim());
  if (!m) return `rgba(22, 32, 44, ${alpha})`;
  const v = parseInt(m[1], 16);
  return `rgba(${(v >> 16) & 255}, ${(v >> 8) & 255}, ${v & 255}, ${alpha})`;
}

const headshot = (espnId: string) =>
  `https://a.espncdn.com/i/headshots/nfl/players/full/${espnId}.png`;

// Real players, real ESPN ids, real NFL team primary colors (from the shipped
// 32-team NFL_TEAM_COLORS map). Each card reproduces one shipped treatment.
const gallery = [
  {
    key: 'feature',
    accent: 'blue',
    component: 'FeatureCompositeHero',
    wordmark: "WHAT'S NEW",
    pill: 'New this week',
    title: 'Dynamic top-player spotlight on Free Agents',
    summary:
