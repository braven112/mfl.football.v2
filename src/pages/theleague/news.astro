---
/**
 * The Scheftner Report — TheLeague News Feed
 *
 * Bluesky-style social feed of league transactions, articles,
 * and hot takes from Claude Schefter.
 */
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import ScheftnerFeed from '../../components/shared/ScheftnerFeed.astro';
import { getAuthUser } from '../../utils/auth';
import feedData from '../../data/theleague/scheftner-feed.json';
import type { ScheftnerFeed as FeedType } from '../../types/scheftner';
import '../../styles/scheftner-feed.css';

const authUser = getAuthUser(Astro.request);
const isAuthenticated = !!authUser;
const feed = feedData as FeedType;
---

<TheLeagueLayout title="The Scheftner Report">
  <main class="sf-news-page">
    <div class="sf-news-card">
      <div class="sf-page-header">
        <div class="sf-page-header__persona">
          <img class="sf-page-header__avatar" src="/assets/claude-schefter-avatar.webp" alt="" aria-hidden="true" width="48" height="48" />
          <div>
            <h1 class="sf-page-header__name">Claude Schefter</h1>
            <div class="sf-page-header__handle">@schefter</div>
          </div>
        </div>
        <p class="sf-page-header__bio">
          League insider. Beat reporter. I'm told I have the best sources in the building.
          Breaking trades, grading picks, and calling out overpays since 2026.
        </p>
      </div>

      <div data-feed-container>
        <ScheftnerFeed
          posts={feed.posts}
          isAuthenticated={isAuthenticated}
          initialLimit={25}
        />
      </div>
    </div>
  </main>
</TheLeagueLayout>
