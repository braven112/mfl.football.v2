---
/**
 * League News — Multi-source feed
 *
 * Bluesky-style social feed combining league transactions from Claude Schefter
 * with real NFL news from ESPN's Adam Schefter.
 *
 * Filters:
 *   ?source=theleague — League news + events (Claude Schefter + Ask Roger)
 *   ?source=nfl       — NFL news + wire (ESPN authors + wire posts)
 *   ?source=draft     — NFL Draft coverage
 *   ?source=insider   — Injuries + odds (Doc Rivers + Vegas Vic)
 *   ?source=groupme   — GroupMe group chat (auth-gated)
 *   (default)         — All sources, mixed timeline
 */
export const prerender = false;

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import SchefterFeed from '../../components/shared/SchefterFeed.astro';
import GroupMeChatPanel from '../../components/shared/GroupMeChatPanel.tsx';
import { getAuthUser } from '../../utils/auth';
import { getAuthor, getAuthorAvatar, SCHEFTER_AUTHORS } from '../../types/schefter';
import type { SchefterPost } from '../../types/schefter';
import feedData from '../../data/theleague/schefter-feed.json';
import type { SchefterFeed as FeedType } from '../../types/schefter';
import { getRecentMessages, toSchefterPosts, loadTeamConfig, enrichPostsWithOgPreviews } from '../../utils/groupme-storage';
import '../../styles/schefter-feed.css';
import '../../styles/schefter-feed-compact.css';

const authUser = getAuthUser(Astro.request);
const isAuthenticated = !!authUser;
const userFranchiseId = authUser?.franchiseId;
const feed = feedData as FeedType;

// Resolve team info for reply composer avatar
let userTeamName: string | undefined;
let userTeamIcon: string | undefined;

if (userFranchiseId) {
  try {
    const config = await import('../../data/theleague.config.json');
    const teams = config.default?.teams ?? config.teams ?? [];
    const team = teams.find((t: { franchiseId: string }) => t.franchiseId === userFranchiseId);
    if (team) {
      userTeamName = team.name;
      userTeamIcon = team.icon;
    }
  } catch { /* fallback gracefully */ }
}

// Source filter via ?source=theleague|nfl|draft|insider|groupme
// Legacy aliases: claude/events → theleague, wire → nfl, injuries/odds → insider
const sourceParam = Astro.url.searchParams.get('source');
const legacyAliases: Record<string, string> = {
  claude: 'theleague', events: 'theleague',
  wire: 'nfl',
  injuries: 'insider', odds: 'insider',
};
const resolvedSource = legacyAliases[sourceParam ?? ''] ?? sourceParam;
const validSources = ['theleague', 'nfl', 'draft', 'insider', 'groupme'] as const;
type SourceFilter = typeof validSources[number];
const activeSource: SourceFilter | null = validSources.includes(resolvedSource as SourceFilter)
  ? (resolvedSource as SourceFilter)
  : null;

// ESPN external authors (excluding draft + insider personas which have their own tabs)
const draftAuthorIds = new Set(['nfl-draft']);
const insiderAuthorIds = new Set(['doc-rivers', 'vegas-vic']);
const nflExcludeIds = new Set([...draftAuthorIds, ...insiderAuthorIds]);
const espnAuthorIds = new Set(
  Object.values(SCHEFTER_AUTHORS).filter(a => a.external && !nflExcludeIds.has(a.id)).map(a => a.id)
);

// Fetch GroupMe messages from Redis (auth-gated)
let groupMePosts: SchefterPost[] = [];
if (isAuthenticated) {
  try {
    const gmMessages = await getRecentMessages(100);
    const teamConfig = await loadTeamConfig();
    groupMePosts = toSchefterPosts(gmMessages, teamConfig);
  } catch (err) {
    console.warn('[news] Failed to load GroupMe messages:', err);
  }
}

// Filter posts by source
const filteredPosts = (() => {
  if (activeSource === 'groupme') return groupMePosts;
  if (!activeSource) {
    // "All" tab: merge Schefter + GroupMe (if authenticated), sorted by timestamp
    if (isAuthenticated && groupMePosts.length > 0) {
      const merged = [...feed.posts, ...groupMePosts];
      merged.sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
      return merged;
    }
    return feed.posts;
  }
  if (activeSource === 'theleague') return feed.posts.filter(p => {
    const authorId = p.authorId ?? 'claude';
    return authorId === 'claude' || authorId === 'roger';
  });
  if (activeSource === 'nfl') return feed.posts.filter(p => {
    const authorId = p.authorId ?? '';
    return (espnAuthorIds.has(authorId) || p.id.startsWith('wire_')) && !draftAuthorIds.has(authorId);
  });
  if (activeSource === 'draft') return feed.posts.filter(p => p.authorId === 'nfl-draft');
  if (activeSource === 'insider') return feed.posts.filter(p => insiderAuthorIds.has(p.authorId ?? ''));
  return feed.posts;
})();

// Enrich GroupMe posts with Open Graph previews (server-side, Redis-cached).
// Failures are silent — posts without previews fall back to simple link cards.
try {
  await enrichPostsWithOgPreviews(filteredPosts);
} catch (err) {
  console.warn('[news] OG enrichment failed:', err);
}

// Show profile header for each tab's persona
const sourceAuthorMap: Record<string, string> = {
  theleague: 'roger',
  nfl: 'nfl-wire',
  draft: 'nfl-draft',
  insider: 'nfl-insider',
};
// Default to Claude Schefter for the "All" tab, otherwise use the source's persona
const profileAuthorId = activeSource && activeSource !== 'groupme' ? sourceAuthorMap[activeSource] : 'claude';
const profileAuthor = profileAuthorId ? getAuthor(profileAuthorId) : null;
const profileAvatar = profileAuthor ? getAuthorAvatar(profileAuthor) : null;

const isGroupMeTab = activeSource === 'groupme';

// Build filter tab URLs
const basePath = '/theleague/news';
const tabs = [
  { label: 'All', href: basePath, active: !activeSource },
  { label: 'The League', href: `${basePath}?source=theleague`, active: activeSource === 'theleague' },
  ...(isAuthenticated ? [{ label: 'Group Chat', href: `${basePath}?source=groupme`, active: activeSource === 'groupme' }] : []),
  { label: 'NFL', href: `${basePath}?source=nfl`, active: activeSource === 'nfl' },
  { label: 'NFL Draft', href: `${basePath}?source=draft`, active: activeSource === 'draft' },
  { label: 'NFL Insider', href: `${basePath}?source=insider`, active: activeSource === 'insider' },
];
---

<TheLeagueLayout title="League News">
  <main class="sf-news-page">
    <div class="sf-news-card">
      {/* Profile header — every tab has a persona */}
      {isGroupMeTab ? (
        <div class="sf-page-header sf-page-header--feed">
          <h1 class="sf-page-header__name">Group Chat</h1>
          <p class="sf-page-header__bio">
            The latest from TheLeague's GroupMe — trash talk, trade talk, and everything in between.
          </p>
        </div>
      ) : (
        <div class="sf-page-header">
          <div class="sf-page-header__persona">
            <img class="sf-page-header__avatar" src={profileAvatar} alt="" aria-hidden="true" width="48" height="48" />
            <div>
              <h1 class="sf-page-header__name">{profileAuthor!.name}</h1>
              <div class="sf-page-header__handle">{profileAuthor!.handle}</div>
            </div>
          </div>
          <p class="sf-page-header__bio">{profileAuthor!.bio}</p>
        </div>
      )}

      {/* Source filter tabs */}
      <nav class="sf-source-tabs" aria-label="Filter news by source">
        {tabs.map(tab => (
          <a
            href={tab.href}
            class={`sf-source-tab${tab.active ? ' sf-source-tab--active' : ''}`}
            {...(tab.active ? { 'aria-current': 'page' } : {})}
          >
            {tab.label}
          </a>
        ))}
      </nav>

      {/* GroupMe compose bar — shown on the Group Chat tab for authenticated users */}
      {activeSource === 'groupme' && isAuthenticated && userFranchiseId && (
        <GroupMeChatPanel
          client:visible
          teamName={userTeamName ?? 'My Team'}
          teamIcon={userTeamIcon ?? ''}
        />
      )}

      <div
        data-feed-container
        data-groupme-poll={isGroupMeTab && isAuthenticated ? 'true' : undefined}
        data-groupme-since={isGroupMeTab && isAuthenticated && groupMePosts.length > 0
          ? String(new Date(groupMePosts[0].timestamp).getTime())
          : undefined}
      >
        <SchefterFeed
          posts={filteredPosts}
          isAuthenticated={isAuthenticated}
          userFranchiseId={userFranchiseId}
          userTeamName={userTeamName}
          userTeamIcon={userTeamIcon}
          initialLimit={25}
        />
      </div>
    </div>
  </main>
</TheLeagueLayout>

<script>
  // Live polling for the GroupMe tab — surfaces new messages without reload.
  // Polls /api/groupme/messages?since={ms}&format=posts every POLL_MS.
  // Renders new posts as plain markup (no reaction/reply islands until next reload).
  const POLL_MS = 20_000;

  function relTime(iso: string, now = new Date()): string {
    const then = new Date(iso).getTime();
    const diff = Math.max(0, now.getTime() - then);
    const m = Math.floor(diff / 60_000);
    if (m < 1) return 'just now';
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    if (d < 7) return `${d}d ago`;
    return new Date(iso).toLocaleDateString();
  }

  type GroupMePost = {
    id: string;
    timestamp: string;
    body: string;
    authorId?: string;
    _groupMe?: { name: string; avatar: string; likeCount: number; senderName: string };
  };

  function buildPostElement(post: GroupMePost): HTMLElement {
    const meta = post._groupMe ?? { name: 'GroupMe', avatar: '', likeCount: 0, senderName: '' };
    const body = post.body ?? '';

    const wrapper = document.createElement('div');
    wrapper.className = 'sf-feed__item';
    wrapper.setAttribute('data-feed-index', '0');

    const article = document.createElement('article');
    article.className = 'sf-post sf-post--groupme';
    article.dataset.postId = post.id;
    article.dataset.tier = 'standard';
    article.dataset.postType = 'groupme';
    article.dataset.author = post.authorId ?? 'groupme';
    article.setAttribute('aria-label', `${meta.name}: ${body.slice(0, 80)}`);

    if (meta.avatar) {
      const img = document.createElement('img');
      img.className = 'sf-avatar sf-avatar--groupme';
      img.src = meta.avatar;
      img.alt = '';
      img.setAttribute('aria-hidden', 'true');
      img.width = 40;
      img.height = 40;
      img.loading = 'lazy';
      article.appendChild(img);
    } else {
      const placeholder = document.createElement('div');
      placeholder.className = 'sf-avatar sf-avatar--groupme';
      placeholder.setAttribute('aria-hidden', 'true');
      article.appendChild(placeholder);
    }

    const content = document.createElement('div');
    content.className = 'sf-post__content';

    const header = document.createElement('div');
    header.className = 'sf-post__header';

    const nameSpan = document.createElement('span');
    nameSpan.className = 'sf-post__name';
    nameSpan.textContent = meta.name;
    header.appendChild(nameSpan);

    const handleSpan = document.createElement('span');
    handleSpan.className = 'sf-post__handle sf-post__handle--groupme';
    handleSpan.textContent = 'via GroupMe';
    header.appendChild(handleSpan);

    const time = document.createElement('time');
    time.className = 'sf-post__time';
    time.dateTime = post.timestamp;
    time.textContent = relTime(post.timestamp);
    header.appendChild(time);

    content.appendChild(header);

    const bodyDiv = document.createElement('div');
    bodyDiv.className = 'sf-post__body sf-post__body--groupme';
    bodyDiv.textContent = body;
    content.appendChild(bodyDiv);

    const actions = document.createElement('div');
    actions.className = 'sfc-post__actions';
    content.appendChild(actions);

    article.appendChild(content);
    wrapper.appendChild(article);
    return wrapper;
  }

  function initGroupMePolling() {
    const container = document.querySelector('[data-groupme-poll="true"]') as HTMLElement | null;
    if (!container) return;

    const feed = container.querySelector('.sf-feed--page') as HTMLElement | null;
    if (!feed) return;

    let since = Number(container.dataset.groupmeSince ?? '0') || 0;
    let stopped = false;

    async function tick() {
      if (stopped) return;
      try {
        const url = since > 0
          ? `/api/groupme/messages?since=${since}&format=posts&limit=50`
          : `/api/groupme/messages?format=posts&limit=50`;
        const res = await fetch(url, { credentials: 'same-origin' });
        if (!res.ok) return;
        const data = await res.json() as { posts?: GroupMePost[] };
        const posts = (data.posts ?? []).filter(p => p && p.id);
        if (posts.length === 0) return;

        const empty = feed.querySelector('.sf-empty');
        if (empty) empty.remove();

        const ordered = [...posts].sort(
          (a, b) => new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(),
        );

        const loadMoreEl = feed.querySelector('.sf-load-more');

        for (const post of ordered) {
          if (feed.querySelector(`[data-post-id="${CSS.escape(post.id)}"]`)) continue;
          const node = buildPostElement(post);
          feed.insertBefore(node, feed.firstChild);

          const ts = new Date(post.timestamp).getTime();
          if (ts > since) since = ts;
        }

        if (loadMoreEl) feed.appendChild(loadMoreEl);
        container.dataset.groupmeSince = String(since);
      } catch {
        /* swallow — try again next tick */
      }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') tick();
    });

    const interval = window.setInterval(tick, POLL_MS);
    window.addEventListener('beforeunload', () => {
      stopped = true;
      window.clearInterval(interval);
    });

    void tick();
  }

  document.addEventListener('astro:page-load', initGroupMePolling);
</script>
