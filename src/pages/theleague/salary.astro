---
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import { resolveLeaguePath } from '../../utils/nav-utils';
import leagueAssets from '../../data/theleague.assets.json';
import archiveUrls from '../../data/theleague/salary-archive-urls.json';

const summaryModules = import.meta.glob(
  '../../data/mfl-salary-averages-*.json',
  { eager: true }
);

const weeklyModules = import.meta.glob(
  '../../data/salary-history/theleague/*/summary-week-*.json',
  { eager: true }
);

const STARTER_COUNTS: Record<string, number> = { QB: 16, RB: 30, WR: 48, TE: 18, PK: 16, Def: 16 };

const positionLabels = [
  { key: 'QB', label: 'Quarterback' },
  { key: 'RB', label: 'Running Back' },
  { key: 'WR', label: 'Wide Receiver' },
  { key: 'TE', label: 'Tight End' },
  { key: 'PK', label: 'Kicker' },
  { key: 'Def', label: 'Defense/ST' },
];

const currencyFormatter = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});

const formatValue = (value: number | undefined) =>
  typeof value === 'number' && Number.isFinite(value)
    ? currencyFormatter.format(value)
    : 'N/A';

const getModuleData = (mod) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const extractSeason = (filepath: string) => {
  const match = filepath.match(/(\d{4})\.json$/);
  return match ? match[1] : null;
};

const extractSeasonAndWeek = (filepath: string) => {
  const seasonMatch = filepath.match(/\/(\d{4})\//);
  const weekMatch = filepath.match(/week-([\w-]+)\.json$/);
  return {
    season: seasonMatch ? seasonMatch[1] : null,
    week: weekMatch ? weekMatch[1] : null,
  };
};

// Load season-level summaries
const summariesBySeason: Record<string, any> = {};
Object.entries(summaryModules).forEach(([path, mod]) => {
  const season = extractSeason(path);
  if (season) {
    const data = getModuleData(mod);
    summariesBySeason[season] = {
      ...data,
      week: data?.metadata?.week ?? null,
      type: 'season',
    };
  }
});

// Load weekly snapshots and organize by season
const weeklyDataBySeasonAndWeek: Record<string, Record<string, any>> = {};
Object.entries(weeklyModules).forEach(([path, mod]) => {
  const { season, week } = extractSeasonAndWeek(path);
  if (season && week) {
    if (!weeklyDataBySeasonAndWeek[season]) {
      weeklyDataBySeasonAndWeek[season] = {};
    }
    const data = getModuleData(mod);
    weeklyDataBySeasonAndWeek[season][week] = {
      ...data,
      type: 'weekly',
    };
  }
});

const seasonOptions = Object.keys(summariesBySeason).sort(
  (a, b) => Number(b) - Number(a)
);
const defaultSeason = seasonOptions[0] ?? seasonOptions.at(-1) ?? '2024';
const currentSummary =
  summariesBySeason[defaultSeason] ??
  (seasonOptions.length ? summariesBySeason[seasonOptions[0]] : {});

const summary = currentSummary?.positions ?? {};
const generatedAt = currentSummary?.metadata?.generatedAt
  ? new Date(currentSummary.metadata.generatedAt)
  : null;
const generatedLabel =
  generatedAt && !Number.isNaN(generatedAt.getTime())
    ? generatedAt.toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
      })
    : 'Unknown';

const franchiseMeta = new Map(
  (leagueAssets.teams ?? []).map((team) => [
    team.id,
    {
      name: team.name,
      icon: team.assets?.icons?.[0]?.relativePath,
    },
  ])
);

const franchiseLookup = Object.fromEntries(
  Array.from(franchiseMeta.entries()).map(([id, data]) => [id, data ?? {}])
);

// Get available weeks for each season
// Sort order (desc): off-N (highest first), then regular weeks (highest first)
const weekOptionsBySeason: Record<string, string[]> = {};
Object.entries(weeklyDataBySeasonAndWeek).forEach(([season, weeks]) => {
  weekOptionsBySeason[season] = Object.keys(weeks).sort((a, b) => {
    const aIsOff = a.startsWith('off-');
    const bIsOff = b.startsWith('off-');
    if (aIsOff && bIsOff) return Number(b.slice(4)) - Number(a.slice(4));
    if (aIsOff) return -1; // offseason weeks sort first (most recent at top)
    if (bIsOff) return 1;
    return Number(b) - Number(a);
  });
});

const serializedConfig = JSON.stringify({
  seasons: summariesBySeason,
  weeklyData: weeklyDataBySeasonAndWeek,
  weekOptions: weekOptionsBySeason,
  seasonOptions,
  defaultSeason,
  franchiseMeta: franchiseLookup,
  archiveUrls: archiveUrls ?? {},
});

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
---

<TheLeagueLayout title="Salary Analytics">
  <section class="salary-report">
    <header class="salary-report__intro">
      <h1>Salary Analytics</h1>
      <div class="salary-report__filters">
        {seasonOptions.length > 1 && (
          <label class="season-toggle">
            <span>Season:</span>
            <select id="salarySeasonSelect">
              {seasonOptions.map((season) => (
                <option value={season} selected={season === defaultSeason}>
                  {season}
                </option>
              ))}
            </select>
          </label>
        )}
        <label class="week-toggle" id="weekToggleContainer" style="display: none;">
          <span>Week:</span>
          <select id="salaryWeekSelect">
            <option value="season">Season Total</option>
          </select>
        </label>
        <button type="button" id="exportXlsxBtn" class="salary-export-btn">
          Export to Excel
        </button>
        <a id="archiveSheetLink" class="salary-archive-link" href="#" target="_blank" rel="noopener" style="display: none;">
          View Original Spreadsheet
        </a>
      </div>
      <p>
        League {currentSummary?.metadata?.leagueId ?? 'Unknown'} &middot; Season{' '}
        <span id="salarySeasonLabel">
          {currentSummary?.metadata?.season ?? defaultSeason}
        </span>
        <span id="salaryWeekLabel">
          {currentSummary?.metadata?.week
            ? ` · Week ${currentSummary.metadata.week}`
            : ''}
        </span>
      </p>
      <p class="salary-report__timestamp" id="salarySnapshotLabel">
        Last Snapshot: {generatedLabel}
      </p>
      <p>
        Franchise tag figures use the average of the top three salaries at a
        position, while contract extensions use the average of the top five.
      </p>
      <p class="salary-report__archive-link">
        <a href={r("/theleague/salary-archive")}>View Historical Spreadsheets (2009&ndash;2025) &rarr;</a>
      </p>
    </header>

    <div class="salary-report__grid">
      {positionLabels.map(({ key, label }) => {
        const data = summary[key];
        return (
          <article class="salary-card" data-position={key}>
            <h2>{label}</h2>
            {data ? (
              <>
                <dl class="salary-card__figures">
                  <div>
                    <dt>Franchise Tag (Top 3)</dt>
                    <dd data-franchise-average={key}>{formatValue(data.top3Average)}</dd>
                  </div>
                  <div>
                    <dt>Extension (Top 5)</dt>
                    <dd data-extension-average={key}>{formatValue(data.top5Average)}</dd>
                  </div>
                  <div>
                    <dt data-starter-label={key}>Starter Avg (Top {data.starterCount ?? STARTER_COUNTS[key] ?? '?'})</dt>
                    <dd data-starter-average={key}>{formatValue(data.starterAverage)}</dd>
                  </div>
                  <div>
                    <dt>Starter Median (Top {data.starterCount ?? STARTER_COUNTS[key] ?? '?'})</dt>
                    <dd data-starter-median={key}>{formatValue(data.starterMedian)}</dd>
                  </div>
                  <div>
                    <dt>Average Salary</dt>
                    <dd data-average-salary={key}>{formatValue(data.averageSalary)}</dd>
                  </div>
                  <div>
                    <dt>Median Salary</dt>
                    <dd data-median-salary={key}>{formatValue(data.medianSalary)}</dd>
                  </div>
                </dl>
                <p class="salary-card__total" data-total={key}>
                  Tracked Players: {data.totalPlayers ?? 0}
                </p>

                <table class="salary-card__table">
                  <caption>Top Earners</caption>
                  <thead>
                    <tr>
                      <th scope="col">Player</th>
                      <th scope="col">Salary</th>
                    </tr>
                  </thead>
                  <tbody data-top-players={key}>
                    {(data.topPlayers ?? []).slice(0, 5).map((player) => {
                      const franchise = player?.franchiseId
                        ? franchiseMeta.get(player.franchiseId)
                        : null;
                      return (
                        <tr>
                          <td class="player-cell">
                            {franchise?.icon && (
                              <img
                                src={franchise.icon}
                                alt={`${franchise.name ?? 'Franchise'} icon`}
                                loading="lazy"
                              />
                            )}
                            <span>{player.name}</span>
                          </td>
                          <td>{formatValue(player.salary)}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
                {(data.topPlayers ?? []).length > 5 && (
                  <button class="salary-card__show-more" data-show-more={key} type="button">
                    Show More
                  </button>
                )}
              </>
            ) : (
              <p class="salary-card__empty">
                No salary data found for this position.
              </p>
            )}
          </article>
        );
      })}
    </div>
  </section>
</TheLeagueLayout>

<style>
  .salary-report {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .salary-report__intro h1 {
    margin-bottom: 0.25rem;
  }

  .salary-report__intro p {
    margin: 0.25rem 0;
  }

  .salary-report__timestamp {
    font-size: 0.95rem;
    color: #555;
  }

  .salary-report__archive-link {
    margin-top: 0.5rem;
  }

  .salary-report__archive-link a {
    color: var(--primary-color);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .salary-report__archive-link a:hover {
    text-decoration: underline;
  }

  .salary-report__filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .season-toggle,
  .week-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .season-toggle select,
  .week-toggle select {
    padding: 0.3rem 0.75rem;
    border: 1px solid #ccd3df;
    border-radius: 0.5rem;
    font-size: 1rem;
  }

  .salary-export-btn {
    padding: 0.3rem 0.75rem;
    border: 1px solid #ccd3df;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--primary-color, #1c497c);
    color: #fff;
    cursor: pointer;
    white-space: nowrap;
  }

  .salary-export-btn:hover {
    opacity: 0.85;
  }

  .salary-archive-link {
    padding: 0.3rem 0.75rem;
    border: 1px solid #ccd3df;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary-color, #1c497c);
    text-decoration: none;
    white-space: nowrap;
  }

  .salary-archive-link:hover {
    background: #f0f4f8;
  }

  .salary-report__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
    gap: 1.5rem;
  }

  .salary-card {
    background: var(--primary-content-bg-color);
    border: 1px solid var(--primary-content-border-color);
    box-shadow: var(--primary-content-boxshadow-size)
      var(--primary-content-boxshadow-color);
    border-radius: 0.75rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .salary-card h2 {
    margin: 0;
    font-size: 1.2rem;
  }

  .salary-card__figures {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
  }

  .salary-card__figures div {
    display: flex;
    flex-direction: column;
  }

  .salary-card__figures dt {
    font-size: 0.9rem;
    color: #555;
    margin-bottom: 0.2rem;
  }

  .salary-card__figures dd {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--primary-color);
  }

  .salary-card__total {
    font-size: 0.85rem;
    color: #666;
    margin: 0;
  }

  .salary-card__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .salary-card__table caption {
    text-align: left;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .salary-card__table th,
  .salary-card__table td {
    padding: 0.35rem 0;
    border-bottom: 1px solid #eee;
  }

  .salary-card__table th {
    text-align: left;
    font-size: 0.85rem;
    color: #555;
  }

  .salary-card__table td:last-child {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .salary-card__table tr:last-child td {
    border-bottom: none;
  }

  :global(.player-cell) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.player-cell img) {
    width: 32px;
    height: 32px;
    object-fit: cover;
  }

  :global(.salary-card__show-more) {
    width: 100%;
    border: 1px solid #ccc;
    padding: 0.5rem;
    border-radius: 1rem;
    background: transparent;
    cursor: pointer;
  }

  .salary-card__empty {
    margin: 0;
    font-size: 0.95rem;
    color: #777;
  }

  @media (max-width: 767px) {
    .salary-card__figures {
      flex-direction: column;
    }
  }
</style>

<script
  type="application/json"
  id="salary-config"
  set:html={serializedConfig}
></script>

<script type="module">
  const summaryConfigEl = document.getElementById('salary-config');
  if (summaryConfigEl) {
    const {
      seasons = {},
      weeklyData = {},
      weekOptions = {},
      defaultSeason,
      archiveUrls = {},
      franchiseMeta = {}
    } = JSON.parse(summaryConfigEl.textContent);

    const seasonSelectEl = document.getElementById('salarySeasonSelect');
    const weekSelectEl = document.getElementById('salaryWeekSelect');
    const weekToggleContainer = document.getElementById('weekToggleContainer');
    const seasonLabel = document.getElementById('salarySeasonLabel');
    const weekLabel = document.getElementById('salaryWeekLabel');
    const snapshotLabel = document.getElementById('salarySnapshotLabel');
    const archiveLink = document.getElementById('archiveSheetLink');

    const STARTER_COUNTS = { QB: 16, RB: 30, WR: 48, TE: 18, PK: 16, Def: 16 };

    let currentSeason = defaultSeason;
    let currentWeek = 'season';
    const INITIAL_COUNT = 5;
    const PAGE_SIZE = 10;
    const visibleCounts = {};

    const currencyFormatter = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 0,
    });

    const formatCurrency = (value) => {
      if (!Number.isFinite(value)) return 'N/A';
      return currencyFormatter.format(Math.round(value));
    };

    const buildPlayerRows = (players, franchiseMeta) =>
      players
        .map((player) => {
          const franchise = player?.franchiseId
            ? franchiseMeta[player.franchiseId]
            : null;
          const iconMarkup = franchise?.icon
            ? `<img src="${franchise.icon}" alt="${franchise.name ?? 'Franchise'} icon" loading="lazy" />`
            : '';
          return `
            <tr>
              <td class="player-cell">
                ${iconMarkup}
                <span>${player.name ?? ''}</span>
              </td>
              <td>${formatCurrency(player.salary)}</td>
            </tr>`;
        })
        .join('');

    const renderPlayersForPosition = (position, allPlayers, count) => {
      const playersBody = document.querySelector(
        `[data-top-players="${position}"]`
      );
      const showMoreBtn = document.querySelector(
        `[data-show-more="${position}"]`
      );
      if (!playersBody) return;

      const visible = allPlayers.slice(0, count);
      const rows = buildPlayerRows(visible, franchiseMeta);
      playersBody.innerHTML =
        rows || '<tr><td colspan="2" class="player-cell">No players tracked.</td></tr>';

      if (showMoreBtn) {
        if (count >= allPlayers.length) {
          showMoreBtn.style.display = 'none';
        } else {
          showMoreBtn.style.display = '';
          showMoreBtn.textContent = `Show More (${Math.min(allPlayers.length - count, PAGE_SIZE)} more)`;
        }
      } else if (count < allPlayers.length) {
        // Create the button if it doesn't exist yet (e.g. switching to a dataset with more players)
        const card = document.querySelector(`[data-position="${position}"]`);
        if (card) {
          const btn = document.createElement('button');
          btn.className = 'salary-card__show-more';
          btn.dataset.showMore = position;
          btn.type = 'button';
          btn.textContent = `Show More (${Math.min(allPlayers.length - count, PAGE_SIZE)} more)`;
          card.appendChild(btn);
        }
      }
    };

    const formatWeekLabel = (week) => {
      if (typeof week === 'string' && week.startsWith('off-')) {
        const num = week.slice(4);
        return `Off Season Week ${num}`;
      }
      return `Week ${week}`;
    };

    const updateArchiveLink = (seasonKey) => {
      if (!archiveLink) return;
      const url = archiveUrls[seasonKey];
      if (url) {
        archiveLink.href = url;
        archiveLink.style.display = 'inline-flex';
      } else {
        archiveLink.style.display = 'none';
      }
    };

    const populateWeekDropdown = (seasonKey) => {
      const weeks = weekOptions[seasonKey] || [];
      weekSelectEl.innerHTML = '<option value="season">Season Total</option>';

      if (weeks.length > 0) {
        weeks.forEach((week) => {
          const option = document.createElement('option');
          option.value = week;
          option.textContent = formatWeekLabel(week);
          weekSelectEl.appendChild(option);
        });
        weekToggleContainer.style.display = 'inline-flex';
      } else {
        weekToggleContainer.style.display = 'none';
      }

      // Reset to season total when changing seasons
      weekSelectEl.value = 'season';
      currentWeek = 'season';
    };

    const renderData = (seasonKey, weekKey) => {
      let summary;

      if (weekKey === 'season') {
        summary = seasons?.[seasonKey];
      } else {
        summary = weeklyData?.[seasonKey]?.[weekKey];
      }

      if (!summary) return;

      seasonLabel.textContent = summary?.metadata?.season ?? seasonKey;

      if (weekKey === 'season') {
        weekLabel.textContent = summary?.metadata?.week
          ? ` · Week ${summary.metadata.week}`
          : '';
      } else {
        weekLabel.textContent = ` · ${formatWeekLabel(weekKey)}`;
      }

      const generatedAt = summary?.metadata?.generatedAt
        ? new Date(summary.metadata.generatedAt)
        : null;
      snapshotLabel.textContent = `Last Snapshot: ${
        generatedAt && !Number.isNaN(generatedAt.getTime())
          ? generatedAt.toLocaleString('en-US', {
              dateStyle: 'medium',
              timeStyle: 'short',
            })
          : 'Unknown'
      }`;

      (summary?.positions
        ? Object.entries(summary.positions)
        : []
      ).forEach(([position, data]) => {
        const franCell = document.querySelector(
          `[data-franchise-average="${position}"]`
        );
        const extCell = document.querySelector(
          `[data-extension-average="${position}"]`
        );
        const starterCell = document.querySelector(
          `[data-starter-average="${position}"]`
        );
        const starterLabel = document.querySelector(
          `[data-starter-label="${position}"]`
        );
        const avgCell = document.querySelector(
          `[data-average-salary="${position}"]`
        );
        const medCell = document.querySelector(
          `[data-median-salary="${position}"]`
        );
        const totalEl = document.querySelector(`[data-total="${position}"]`);

        if (franCell) franCell.textContent = formatCurrency(data?.top3Average ?? 0);
        if (extCell) extCell.textContent = formatCurrency(data?.top5Average ?? 0);
        if (starterLabel) {
          const count = data?.starterCount ?? STARTER_COUNTS[position] ?? '?';
          starterLabel.textContent = `Starter Avg (Top ${count})`;
        }
        if (starterCell) starterCell.textContent = data?.starterAverage != null ? formatCurrency(data.starterAverage) : 'N/A';
        const starterMedCell = document.querySelector(
          `[data-starter-median="${position}"]`
        );
        if (starterMedCell) starterMedCell.textContent = data?.starterMedian != null ? formatCurrency(data.starterMedian) : 'N/A';
        if (avgCell) avgCell.textContent = data?.averageSalary != null ? formatCurrency(data.averageSalary) : 'N/A';
        if (medCell) medCell.textContent = data?.medianSalary != null ? formatCurrency(data.medianSalary) : 'N/A';
        if (totalEl) totalEl.textContent = `Tracked Players: ${data?.totalPlayers ?? 0}`;

        // Reset pagination on data change
        visibleCounts[position] = INITIAL_COUNT;
        renderPlayersForPosition(position, data?.topPlayers ?? [], INITIAL_COUNT);
      });
    };

    // Initialize
    populateWeekDropdown(defaultSeason);
    updateArchiveLink(defaultSeason);
    renderData(defaultSeason, 'season');

    // Event listeners
    seasonSelectEl?.addEventListener('change', (event) => {
      currentSeason = event.target.value;
      populateWeekDropdown(currentSeason);
      updateArchiveLink(currentSeason);
      renderData(currentSeason, currentWeek);
    });

    weekSelectEl?.addEventListener('change', (event) => {
      currentWeek = event.target.value;
      renderData(currentSeason, currentWeek);
    });

    // Show More click handler (delegated)
    document.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-show-more]');
      if (!btn) return;
      const position = btn.dataset.showMore;
      const summary = currentWeek === 'season'
        ? seasons?.[currentSeason]
        : weeklyData?.[currentSeason]?.[currentWeek];
      const allPlayers = summary?.positions?.[position]?.topPlayers ?? [];
      visibleCounts[position] = (visibleCounts[position] ?? INITIAL_COUNT) + PAGE_SIZE;
      renderPlayersForPosition(position, allPlayers, visibleCounts[position]);
    });
  }
</script>

<script src="../../scripts/salary-export-handler.ts"></script>
