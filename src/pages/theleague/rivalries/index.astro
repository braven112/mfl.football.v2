---
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import franchiseHistory from '../../../../data/theleague/derived/franchise-history.json';
import leagueConfig from '../../../data/theleague.config.json';

export const prerender = false;

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;

interface FranchiseRow {
  franchiseId: string;
  currentName: string;
  currentNameMedium: string;
  currentNameShort?: string;
  currentAbbrev?: string | null;
  currentIcon: string | null;
  currentBanner: string | null;
  currentColor: string | null;
  matchupHistory: Record<string, Array<{
    year: number;
    week: number;
    score: number;
    opponentScore: number;
    isPlayoff: boolean;
    bothAttributed: boolean;
  }>>;
}

const allFranchises: FranchiseRow[] = Object.values(
  franchiseHistory.franchises as Record<string, FranchiseRow>
);

// Sort the matrix by current franchise display name so rows are stable +
// alphabetic. Cards link via franchiseId → canonical pair URL.
allFranchises.sort((a, b) =>
  (a.currentNameMedium || a.currentName).localeCompare(b.currentNameMedium || b.currentName)
);

// Pair record from row's perspective vs col, restricted to games where both
// franchises had their CURRENT owners that year. Without that filter we'd
// be conflating ownership eras and the rivalry framing breaks.
type PairRecord = { wins: number; losses: number; ties: number; games: number; playoffGames: number };

function computePairRecord(row: FranchiseRow, colId: string): PairRecord {
  const meetings = (row.matchupHistory[colId] || []).filter((m) => m.bothAttributed);
  let wins = 0, losses = 0, ties = 0, playoffGames = 0;
  for (const m of meetings) {
    if (m.score > m.opponentScore) wins++;
    else if (m.score < m.opponentScore) losses++;
    else ties++;
    if (m.isPlayoff) playoffGames++;
  }
  return { wins, losses, ties, games: meetings.length, playoffGames };
}

function canonicalPair(a: string, b: string): string {
  return [a, b].sort().join('-vs-');
}

function recordLabel(r: PairRecord): string {
  if (!r.games) return '—';
  return r.ties > 0 ? `${r.wins}-${r.losses}-${r.ties}` : `${r.wins}-${r.losses}`;
}

// Intensity score: high when teams have played a lot and the record is close.
// Used for cell shading + the "Hot rivalries" highlight strip.
function intensity(r: PairRecord): number {
  if (r.games === 0) return 0;
  const total = r.wins + r.losses + r.ties;
  const closeness = total > 0 ? 1 - Math.abs(r.wins - r.losses) / total : 0;
  // Bonus for playoff meetings (each ~ 3 regular games of intensity).
  const weighted = total + r.playoffGames * 3;
  return closeness * Math.log2(1 + weighted);
}

// Top rivalries strip — highest intensity unique pairs.
type RivalryEntry = {
  a: FranchiseRow;
  b: FranchiseRow;
  record: PairRecord;
  intensity: number;
};
const seen = new Set<string>();
const topRivalries: RivalryEntry[] = [];
for (const a of allFranchises) {
  for (const b of allFranchises) {
    if (a.franchiseId === b.franchiseId) continue;
    const key = canonicalPair(a.franchiseId, b.franchiseId);
    if (seen.has(key)) continue;
    seen.add(key);
    const rec = computePairRecord(a, b.franchiseId);
    if (rec.games < 4) continue; // need a baseline of meetings
    topRivalries.push({ a, b, record: rec, intensity: intensity(rec) });
  }
}
topRivalries.sort((x, y) => y.intensity - x.intensity);
const top = topRivalries.slice(0, 6);

// Year coverage for header
const yearsCovered = (franchiseHistory.yearsCovered as number[]).slice().sort((a, b) => a - b);
const firstYear = yearsCovered[0];
const lastYear = yearsCovered[yearsCovered.length - 1];
---

<TheLeagueLayout title="Rivalries">
  <section class="rivalries-index">
    <header>
      <Breadcrumbs items={[
        { label: 'The League', href: '/theleague' },
        { label: 'Stats & Reports', href: '/theleague/stats' },
        { label: 'Rivalries' },
      ]} />
      <h1>Rivalries</h1>
      <p class="lede">
        All-time head-to-head record between every pair of franchises, restricted to seasons each franchise had its current owner. {firstYear}–{lastYear}.
      </p>
    </header>

    {top.length > 0 && (
      <section class="hot-rivalries">
        <h2>Hottest Rivalries</h2>
        <p class="dim small">Most intense pairings — a mix of total meetings, closeness, and playoff weight.</p>
        <ul class="hot-list">
          {top.map(({ a, b, record }) => (
            <li>
              <a class="hot-card" href={resolveLeaguePath(`/theleague/rivalries/${canonicalPair(a.franchiseId, b.franchiseId)}`, hideLeaguePrefix)}>
                <div class="hot-teams">
                  {a.currentIcon && <img src={a.currentIcon} alt="" loading="lazy" />}
                  <span class="hot-vs">vs</span>
                  {b.currentIcon && <img src={b.currentIcon} alt="" loading="lazy" />}
                </div>
                <div class="hot-text">
                  <strong>{a.currentNameShort || a.currentNameMedium}</strong>
                  <span class="dim">vs</span>
                  <strong>{b.currentNameShort || b.currentNameMedium}</strong>
                </div>
                <div class="hot-record">
                  {recordLabel(record)} · {record.games} game{record.games === 1 ? '' : 's'}
                  {record.playoffGames > 0 && <span class="playoff-tag">{record.playoffGames} playoff</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="matrix-section">
      <h2>Head-to-Head Matrix</h2>
      <p class="dim small">Each cell shows the row team's record vs the column team. Click any cell for the full rivalry page.</p>

      <div class="matrix-scroll">
        <table class="matrix" role="table">
          <thead>
            <tr>
              <th class="corner" scope="col" aria-label="Franchise"></th>
              {allFranchises.map((f) => (
                <th class="col-header" scope="col" title={f.currentName}>
                  <a href={resolveLeaguePath(`/theleague/franchises/${f.franchiseId}`, hideLeaguePrefix)}>
                    {f.currentIcon
                      ? <img src={f.currentIcon} alt={f.currentName} loading="lazy" />
                      : <span class="initials">{(f.currentAbbrev || f.currentNameShort || f.currentName).slice(0, 3)}</span>}
                  </a>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {allFranchises.map((row) => (
              <tr>
                <th class="row-header" scope="row" title={row.currentName}>
                  <a href={resolveLeaguePath(`/theleague/franchises/${row.franchiseId}`, hideLeaguePrefix)}>
                    {row.currentIcon && <img src={row.currentIcon} alt="" loading="lazy" />}
                    <span class="row-name">{row.currentNameShort || row.currentNameMedium}</span>
                  </a>
                </th>
                {allFranchises.map((col) => {
                  if (col.franchiseId === row.franchiseId) {
                    return <td class="self" aria-hidden="true">—</td>;
                  }
                  const rec = computePairRecord(row, col.franchiseId);
                  const ints = intensity(rec);
                  const intsPct = Math.min(1, ints / 4); // 0..4 → 0..1
                  if (rec.games === 0) {
                    return (
                      <td class="cell empty" aria-label={`${row.currentName} have not faced ${col.currentName}`}>
                        <span class="dim">—</span>
                      </td>
                    );
                  }
                  const winning = rec.wins > rec.losses;
                  const losing = rec.wins < rec.losses;
                  return (
                    <td
                      class:list={['cell', { 'cell--win': winning, 'cell--loss': losing }]}
                      style={`--intensity: ${intsPct.toFixed(2)};`}
                    >
                      <a
                        href={resolveLeaguePath(`/theleague/rivalries/${canonicalPair(row.franchiseId, col.franchiseId)}`, hideLeaguePrefix)}
                        title={`${row.currentName} vs ${col.currentName}: ${recordLabel(rec)} (${rec.games} game${rec.games === 1 ? '' : 's'}${rec.playoffGames > 0 ? `, ${rec.playoffGames} playoff` : ''})`}
                      >
                        {recordLabel(rec)}
                        {rec.playoffGames > 0 && <span class="playoff-dot" aria-hidden="true" /> }
                      </a>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="legend dim small">
        <span class="legend-key cell--win"><span class="legend-swatch"></span> winning record</span>
        <span class="legend-key cell--loss"><span class="legend-swatch"></span> losing record</span>
        <span class="legend-key"><span class="playoff-dot legend-dot"></span> includes playoff meetings</span>
      </p>
    </section>
  </section>
</TheLeagueLayout>

<style>
  .rivalries-index {
    padding: 1.5rem 1rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  header { margin-bottom: 2rem; }
  h1 {
    margin: 0.25rem 0 0.5rem;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }
  .lede {
    margin: 0;
    color: var(--text-secondary, #666);
    max-width: 70ch;
  }
  .dim { color: var(--text-tertiary, #888); }
  .small { font-size: 0.8125rem; }

  /* ============================================
   * HOT RIVALRIES STRIP
   * ============================================ */
  .hot-rivalries {
    margin-bottom: 2.5rem;
  }
  .hot-rivalries h2 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }
  .hot-rivalries p { margin: 0 0 0.875rem; }
  .hot-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.625rem;
  }
  .hot-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 0.875rem;
    background: var(--surface, #fff);
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 0.625rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .hot-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0,0,0,0.06);
    border-color: var(--color-primary, #1c497c);
  }
  .hot-teams {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
  }
  .hot-teams img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .hot-vs {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--text-tertiary, #888);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .hot-text {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    text-align: center;
    flex-wrap: wrap;
  }
  .hot-record {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--text-secondary, #555);
    font-variant-numeric: tabular-nums;
  }
  .playoff-tag {
    display: inline-block;
    margin-left: 0.375rem;
    padding: 0.0625rem 0.375rem;
    border-radius: 999px;
    background: #fff3c4;
    color: #7a5b00;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  /* ============================================
   * MATRIX
   * ============================================ */
  .matrix-section h2 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }
  .matrix-section p.dim { margin: 0 0 0.875rem; }

  .matrix-scroll {
    overflow-x: auto;
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 0.5rem;
    background: var(--surface, #fff);
  }
  .matrix {
    border-collapse: separate;
    border-spacing: 0;
    width: 100%;
    font-variant-numeric: tabular-nums;
  }
  .matrix th, .matrix td {
    padding: 0;
    border-bottom: 1px solid var(--border, #f0f0f0);
    border-right: 1px solid var(--border, #f0f0f0);
    text-align: center;
    vertical-align: middle;
    font-size: 0.8125rem;
  }
  .matrix tr:last-child th, .matrix tr:last-child td {
    border-bottom: none;
  }
  .matrix tr th:last-child, .matrix tr td:last-child {
    border-right: none;
  }

  .corner {
    background: var(--surface-2, #f7f7f7);
    width: 9rem;
    min-width: 9rem;
    position: sticky;
    left: 0;
    z-index: 3;
  }

  .col-header {
    background: var(--surface-2, #f7f7f7);
    padding: 0.375rem 0.25rem;
    width: 3.25rem;
    min-width: 3.25rem;
    position: sticky;
    top: 0;
    z-index: 1;
  }
  .col-header a { display: inline-block; line-height: 0; }
  .col-header img {
    width: 28px; height: 28px;
    object-fit: contain;
  }
  .col-header .initials {
    display: inline-block;
    padding: 0.25rem 0.375rem;
    background: var(--surface-3, #ebebeb);
    border-radius: 0.25rem;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .row-header {
    background: var(--surface-2, #f7f7f7);
    padding: 0.375rem 0.5rem;
    text-align: left;
    width: 9rem;
    min-width: 9rem;
    position: sticky;
    left: 0;
    z-index: 2;
  }
  .row-header a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
  }
  .row-header img {
    width: 24px; height: 24px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .row-name {
    font-weight: 600;
    font-size: 0.8125rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .self {
    background: repeating-linear-gradient(
      45deg,
      var(--surface-2, #f0f0f0) 0,
      var(--surface-2, #f0f0f0) 4px,
      var(--surface-3, #e6e6e6) 4px,
      var(--surface-3, #e6e6e6) 8px
    );
    color: var(--text-tertiary, #aaa);
  }

  .cell {
    --intensity: 0;
    height: 2.75rem;
    position: relative;
  }
  .cell a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.25rem;
    transition: background-color 0.12s ease;
  }
  .cell a:hover { background-color: rgba(28, 73, 124, 0.12); }
  .cell.empty a, .cell.empty {
    color: var(--text-tertiary, #ccc);
    font-weight: 400;
  }

  /* Subtle background tint by intensity. We layer two backgrounds: one
   * solid surface, one gradient driven by --intensity. */
  .cell--win a {
    background: linear-gradient(
      0deg,
      color-mix(in srgb, #1f5d2d calc(var(--intensity) * 28%), transparent),
      color-mix(in srgb, #1f5d2d calc(var(--intensity) * 28%), transparent)
    );
    color: #1f5d2d;
  }
  .cell--loss a {
    background: linear-gradient(
      0deg,
      color-mix(in srgb, #8b2a1f calc(var(--intensity) * 28%), transparent),
      color-mix(in srgb, #8b2a1f calc(var(--intensity) * 28%), transparent)
    );
    color: #8b2a1f;
  }

  .playoff-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 999px;
    margin-left: 0.25rem;
    background: #cc7800;
    vertical-align: 1px;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 0.875rem 0 0;
    align-items: center;
  }
  .legend-key {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .legend-swatch {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 0.25rem;
  }
  .legend-key.cell--win .legend-swatch {
    background: color-mix(in srgb, #1f5d2d 30%, transparent);
  }
  .legend-key.cell--loss .legend-swatch {
    background: color-mix(in srgb, #8b2a1f 30%, transparent);
  }
  .legend-dot { background: #cc7800; }

  @media (max-width: 600px) {
    .corner, .row-header { width: 7rem; min-width: 7rem; }
    .row-name { font-size: 0.75rem; }
    .col-header { width: 2.75rem; min-width: 2.75rem; }
    .col-header img { width: 24px; height: 24px; }
  }
</style>
