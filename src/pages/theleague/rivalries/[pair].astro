---
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import franchiseHistory from '../../../../data/theleague/derived/franchise-history.json';
import leagueConfig from '../../../data/theleague.config.json';

export const prerender = false;

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;

const { pair } = Astro.params;

// Parse the URL slug: "0001-vs-0007". Strict format check — anything else
// → redirect to the rivalries index. Canonical URL has the smaller ID
// first; reversed order issues a 301 to the canonical.
const slugMatch = pair?.match(/^(\d{4})-vs-(\d{4})$/);
if (!slugMatch) {
  return Astro.redirect(resolveLeaguePath('/theleague/rivalries', hideLeaguePrefix));
}
const [, idA, idB] = slugMatch;
if (idA === idB) {
  return Astro.redirect(resolveLeaguePath('/theleague/rivalries', hideLeaguePrefix));
}
const [smaller, bigger] = [idA, idB].sort();
if (`${smaller}-vs-${bigger}` !== pair) {
  return Astro.redirect(resolveLeaguePath(`/theleague/rivalries/${smaller}-vs-${bigger}`, hideLeaguePrefix), 301);
}

const frA: any = (franchiseHistory.franchises as any)[smaller];
const frB: any = (franchiseHistory.franchises as any)[bigger];
if (!frA || !frB) {
  return Astro.redirect(resolveLeaguePath('/theleague/rivalries', hideLeaguePrefix));
}

const playerNames = (franchiseHistory as any).playerNames as Record<string, { name: string; position: string; team: string }>;

// Franchise display lookups
const teamLookup: Record<string, any> = Object.fromEntries(
  (leagueConfig.teams as any[]).map((t) => [t.franchiseId, t])
);

// Pull every meeting between this pair where BOTH sides had their current
// owner at the time. We use frA's record (smaller id's perspective) as the
// source of truth — the loop is symmetric so frB's records mirror.
type Meeting = {
  year: number;
  week: number;
  scoreA: number;
  scoreB: number;
  isPlayoff: boolean;
  playoffRound: string | null;
  playoffBracket: string | null;
  margin: number; // |scoreA - scoreB|
};

const meetings: Meeting[] = ((frA.matchupHistory[bigger] as any[]) || [])
  .filter((m) => m.bothAttributed)
  .map((m) => ({
    year: m.year,
    week: m.week,
    scoreA: m.score, // frA's score
    scoreB: m.opponentScore,
    isPlayoff: m.isPlayoff,
    playoffRound: m.playoffRound,
    playoffBracket: m.playoffBracket,
    margin: Math.abs(m.score - m.opponentScore),
  }))
  .sort((x, y) => x.year - y.year || x.week - y.week);

// Aggregate record from A's perspective
let aWins = 0, bWins = 0, ties = 0;
for (const m of meetings) {
  if (m.scoreA > m.scoreB) aWins++;
  else if (m.scoreA < m.scoreB) bWins++;
  else ties++;
}
const totalGames = meetings.length;
const formatRecord = (a: number, b: number, t: number): string =>
  t > 0 ? `${a}-${b}-${t}` : `${a}-${b}`;
const overallLeader = aWins > bWins ? frA : aWins < bWins ? frB : null;

// Highlights
const playoffMeetings = meetings.filter((m) => m.isPlayoff);
const biggestBlowout = meetings.length
  ? meetings.reduce((acc, m) => (m.margin > acc.margin ? m : acc))
  : null;
const closestGame = meetings.length
  ? meetings.reduce((acc, m) => (m.margin < acc.margin ? m : acc))
  : null;
const highestScoringMatchup = meetings.length
  ? meetings.reduce((acc, m) => (m.scoreA + m.scoreB > acc.scoreA + acc.scoreB ? m : acc))
  : null;

// Longest winning streak by either side. Walk meetings chronologically.
function longestStreaks(games: Meeting[]): { aMax: number; bMax: number; current: { side: 'A' | 'B' | 'tie' | null; len: number } } {
  let aMax = 0, bMax = 0;
  let curSide: 'A' | 'B' | 'tie' | null = null;
  let curLen = 0;
  for (const g of games) {
    const side: 'A' | 'B' | 'tie' = g.scoreA > g.scoreB ? 'A' : g.scoreA < g.scoreB ? 'B' : 'tie';
    if (side === curSide) curLen++;
    else { curSide = side; curLen = 1; }
    if (side === 'A') aMax = Math.max(aMax, curLen);
    if (side === 'B') bMax = Math.max(bMax, curLen);
  }
  return { aMax, bMax, current: { side: curSide, len: curLen } };
}
const streaks = longestStreaks(meetings);

const mostRecent = meetings.length ? meetings[meetings.length - 1] : null;

// Trades between the two franchises (use frA's trade list; symmetry means
// frB has the same trade with sides flipped).
type Trade = {
  year: number;
  timestamp: number;
  partnerId: string;
  gaveUp: string[];
  received: string[];
  byCommish: boolean;
  comments: string;
  bothAttributed: boolean;
};

const tradesBetween: Trade[] = ((frA.trades as Trade[]) || [])
  .filter((t) => t.partnerId === bigger && t.bothAttributed)
  .sort((x, y) => x.timestamp - y.timestamp);

// Asset code → human label. Picks come in two flavors:
// - DP_<round>_<pick>      = current draft pick (round 0-indexed)
// - FP_<franchiseId>_<year>_<round> = future pick from another franchise's draft
function franchiseShortName(id: string): string {
  const t = teamLookup[id];
  return t?.nameShort ?? t?.nameMedium ?? t?.name ?? id;
}

function formatAsset(code: string): string {
  if (/^FP_(\d{4})_(\d{4})_(\d+)$/.test(code)) {
    const [, fid, yr, rnd] = code.match(/^FP_(\d{4})_(\d{4})_(\d+)$/)!;
    return `${yr} R${rnd} pick (via ${franchiseShortName(fid)})`;
  }
  if (/^DP_(\d+)_(\d+)$/.test(code)) {
    const [, rnd, pick] = code.match(/^DP_(\d+)_(\d+)$/)!;
    return `Draft pick R${Number(rnd) + 1}.${Number(pick) + 1}`;
  }
  if (code === 'CASH') return 'Salary cap cash';
  if (code.startsWith('BBID')) return `BBID balance`;
  if (/^\d+$/.test(code)) {
    const meta = playerNames[code];
    if (meta) return `${meta.name}${meta.position ? ` (${meta.position})` : ''}`;
    return `Player #${code}`;
  }
  return code;
}

function tradeDateLabel(t: Trade): string {
  if (!t.timestamp) return String(t.year);
  const d = new Date(t.timestamp * 1000);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const playoffResultLabel: Record<string, string> = {
  'champion': '🏆 Champion',
  'runner-up': '🥈 Runner-up',
  'third-place': '🥉 3rd place',
  'playoffs': 'Playoffs',
  'missed': '—',
};

function formatScore(s: number): string {
  return s.toFixed(1);
}

const titleA = frA.currentNameMedium || frA.currentName;
const titleB = frB.currentNameMedium || frB.currentName;
---

<TheLeagueLayout title={`${titleA} vs ${titleB} — Rivalry`}>
  <article class="rivalry-detail">
    <Breadcrumbs items={[
      { label: 'The League', href: '/theleague' },
      { label: 'Rivalries', href: '/theleague/rivalries' },
      { label: `${titleA} vs ${titleB}` },
    ]} />

    <header class="hero">
      <div class="side side--a" style={frA.currentColor ? `--accent: ${frA.currentColor};` : ''}>
        <a href={resolveLeaguePath(`/theleague/franchises/${frA.franchiseId}`, hideLeaguePrefix)} class="side-link">
          {frA.currentBanner && <img src={frA.currentBanner} alt="" class="banner" />}
          <div class="side-name">
            {frA.currentIcon && <img src={frA.currentIcon} alt="" class="logo" />}
            <h1>{frA.currentName}</h1>
          </div>
        </a>
      </div>
      <div class="versus">
        <span class="vs-text">vs</span>
        <div class="overall-record">
          {totalGames > 0 ? (
            <>
              <strong>{formatRecord(aWins, bWins, ties)}</strong>
              <span class="dim small">all-time</span>
            </>
          ) : (
            <span class="dim">No meetings yet</span>
          )}
        </div>
        {overallLeader && (
          <p class="leader dim small">
            {overallLeader.currentNameShort || overallLeader.currentNameMedium || overallLeader.currentName} lead{(overallLeader === frA ? aWins : bWins) - (overallLeader === frA ? bWins : aWins) > 1 ? '' : ''} {Math.max(aWins, bWins)}–{Math.min(aWins, bWins)}{ties > 0 ? `–${ties}` : ''}
          </p>
        )}
        {playoffMeetings.length > 0 && (
          <p class="intensity">
            <span aria-hidden="true">🔥</span>
            {playoffMeetings.length} playoff meeting{playoffMeetings.length === 1 ? '' : 's'}
          </p>
        )}
      </div>
      <div class="side side--b" style={frB.currentColor ? `--accent: ${frB.currentColor};` : ''}>
        <a href={resolveLeaguePath(`/theleague/franchises/${frB.franchiseId}`, hideLeaguePrefix)} class="side-link">
          {frB.currentBanner && <img src={frB.currentBanner} alt="" class="banner" />}
          <div class="side-name">
            {frB.currentIcon && <img src={frB.currentIcon} alt="" class="logo" />}
            <h1>{frB.currentName}</h1>
          </div>
        </a>
      </div>
    </header>

    {totalGames === 0 ? (
      <p class="empty-state">
        These franchises have not faced each other under their current owners. Cross-divisional matchups can take a while to surface in TheLeague's schedule rotation.
      </p>
    ) : (
      <>
        <section class="quick-stats">
          <div class="stat">
            <div class="stat-label">Meetings</div>
            <div class="stat-value">{totalGames}</div>
            <div class="stat-sub">
              {meetings[0].year}–{meetings[meetings.length - 1].year}
            </div>
          </div>
          <div class="stat">
            <div class="stat-label">Playoff Games</div>
            <div class="stat-value">{playoffMeetings.length}</div>
            <div class="stat-sub">
              {playoffMeetings.length > 0 ? 'High-stakes history' : 'No playoff history'}
            </div>
          </div>
          {mostRecent && (
            <div class="stat">
              <div class="stat-label">Most Recent</div>
              <div class="stat-value">{formatScore(mostRecent.scoreA)}–{formatScore(mostRecent.scoreB)}</div>
              <div class="stat-sub">Wk {mostRecent.week}, {mostRecent.year}</div>
            </div>
          )}
          <div class="stat">
            <div class="stat-label">Longest Streak</div>
            <div class="stat-value">
              {Math.max(streaks.aMax, streaks.bMax)}
            </div>
            <div class="stat-sub">
              {streaks.aMax >= streaks.bMax
                ? frA.currentNameShort || frA.currentNameMedium
                : frB.currentNameShort || frB.currentNameMedium}
            </div>
          </div>
        </section>

        <section class="highlights">
          <h2>Series Highlights</h2>
          <div class="highlight-grid">
            {biggestBlowout && (
              <div class="highlight">
                <div class="hl-label">Biggest Blowout</div>
                <div class="hl-value">+{biggestBlowout.margin.toFixed(2)}</div>
                <div class="hl-context">
                  {formatScore(biggestBlowout.scoreA)}–{formatScore(biggestBlowout.scoreB)}
                  · {biggestBlowout.scoreA > biggestBlowout.scoreB
                    ? frA.currentNameShort || frA.currentNameMedium
                    : frB.currentNameShort || frB.currentNameMedium} W
                  <br />Wk {biggestBlowout.week}, {biggestBlowout.year}
                  {biggestBlowout.isPlayoff && biggestBlowout.playoffRound && (
                    <span class="playoff-tag">{biggestBlowout.playoffRound}</span>
                  )}
                </div>
              </div>
            )}
            {closestGame && (
              <div class="highlight">
                <div class="hl-label">Closest Game</div>
                <div class="hl-value">{closestGame.margin === 0 ? 'TIE' : `${closestGame.margin.toFixed(2)}`}</div>
                <div class="hl-context">
                  {formatScore(closestGame.scoreA)}–{formatScore(closestGame.scoreB)}<br />
                  Wk {closestGame.week}, {closestGame.year}
                  {closestGame.isPlayoff && closestGame.playoffRound && (
                    <span class="playoff-tag">{closestGame.playoffRound}</span>
                  )}
                </div>
              </div>
            )}
            {highestScoringMatchup && (
              <div class="highlight">
                <div class="hl-label">Highest-Scoring</div>
                <div class="hl-value">{(highestScoringMatchup.scoreA + highestScoringMatchup.scoreB).toFixed(1)}</div>
                <div class="hl-context">
                  {formatScore(highestScoringMatchup.scoreA)}–{formatScore(highestScoringMatchup.scoreB)}<br />
                  Wk {highestScoringMatchup.week}, {highestScoringMatchup.year}
                  {highestScoringMatchup.isPlayoff && highestScoringMatchup.playoffRound && (
                    <span class="playoff-tag">{highestScoringMatchup.playoffRound}</span>
                  )}
                </div>
              </div>
            )}
            <div class="highlight">
              <div class="hl-label">Streaks</div>
              <div class="hl-value">{streaks.aMax} / {streaks.bMax}</div>
              <div class="hl-context">
                {frA.currentNameShort || frA.currentNameMedium} / {frB.currentNameShort || frB.currentNameMedium}
                <br />longest run by either
              </div>
            </div>
          </div>
        </section>

        {playoffMeetings.length > 0 && (
          <section class="playoff-meetings">
            <h2>Playoff Meetings</h2>
            <ul class="playoff-list">
              {playoffMeetings.slice().reverse().map((m) => {
                const winner = m.scoreA > m.scoreB ? frA : m.scoreA < m.scoreB ? frB : null;
                return (
                  <li>
                    <span class="po-year">{m.year}</span>
                    <span class="po-round">{m.playoffRound}</span>
                    <span class="po-score">
                      {formatScore(m.scoreA)}–{formatScore(m.scoreB)}
                    </span>
                    <span class="po-result">
                      {winner ? `${winner.currentNameShort || winner.currentNameMedium} W` : 'Tie'}
                    </span>
                  </li>
                );
              })}
            </ul>
          </section>
        )}

        <section class="meetings-section">
          <h2>Year-by-Year Meetings</h2>
          <div class="meetings-scroll">
            <table class="meetings">
              <thead>
                <tr>
                  <th>Year</th>
                  <th>Wk</th>
                  <th class="th-team">{frA.currentNameShort || frA.currentNameMedium || frA.currentName}</th>
                  <th class="th-team">{frB.currentNameShort || frB.currentNameMedium || frB.currentName}</th>
                  <th>Margin</th>
                  <th>Type</th>
                </tr>
              </thead>
              <tbody>
                {meetings.slice().reverse().map((m) => {
                  const winA = m.scoreA > m.scoreB;
                  const winB = m.scoreB > m.scoreA;
                  return (
                    <tr class:list={{ 'is-playoff': m.isPlayoff }}>
                      <td>{m.year}</td>
                      <td>{m.week}</td>
                      <td class:list={['score', { winner: winA }]}>{formatScore(m.scoreA)}</td>
                      <td class:list={['score', { winner: winB }]}>{formatScore(m.scoreB)}</td>
                      <td>{m.margin === 0 ? 'TIE' : m.margin.toFixed(2)}</td>
                      <td>
                        {m.isPlayoff
                          ? <span class="playoff-tag">{m.playoffRound ?? 'Playoff'}</span>
                          : 'Reg'}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
      </>
    )}

    {tradesBetween.length > 0 && (
      <section class="trades-section">
        <h2>Trades Between Them ({tradesBetween.length})</h2>
        <ul class="trade-list">
          {tradesBetween.slice().reverse().map((t) => (
            <li class="trade">
              <div class="trade-date">
                <span class="t-year">{t.year}</span>
                <span class="dim small">{tradeDateLabel(t)}</span>
                {t.byCommish && <span class="commish-tag" title="Trade was processed by the commissioner">commish</span>}
              </div>
              <div class="trade-cols">
                <div class="trade-col">
                  <div class="t-name">{frA.currentNameShort || frA.currentNameMedium} {t.partnerId === bigger ? 'sent' : 'received'}</div>
                  <ul>
                    {t.gaveUp.map((c) => <li>{formatAsset(c)}</li>)}
                  </ul>
                </div>
                <div class="trade-col">
                  <div class="t-name">{frB.currentNameShort || frB.currentNameMedium} {t.partnerId === bigger ? 'sent' : 'received'}</div>
                  <ul>
                    {t.received.map((c) => <li>{formatAsset(c)}</li>)}
                  </ul>
                </div>
              </div>
              {t.comments && <p class="trade-comments dim small">"{t.comments}"</p>}
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="badges-compare">
      <h2>Side-by-Side Trophy Case</h2>
      <div class="compare-grid">
        <div class="compare-side">
          <h3>{frA.currentNameMedium || frA.currentName}</h3>
          <ul class="badges-bar">
            {frA.championships.length > 0 && (
              <li class="badge badge--championship">
                <span aria-hidden="true">🏆</span>
                {frA.championships.length}x League Title{frA.championships.length > 1 ? 's' : ''}
              </li>
            )}
            {frA.runnerUps?.length > 0 && (
              <li class="badge badge--runnerup">
                <span aria-hidden="true">🥈</span>
                {frA.runnerUps.length}x Runner-up
              </li>
            )}
            {frA.divisionTitles?.length > 0 && (
              <li class="badge badge--division">
                <span aria-hidden="true">🛡</span>
                {frA.divisionTitles.length}x Division
              </li>
            )}
            {frA.mvpAwards?.length > 0 && (
              <li class="badge badge--mvp">
                <span aria-hidden="true">⭐</span>
                {frA.mvpAwards.length}x MVP
              </li>
            )}
            {frA.jerryJonesAwards?.length > 0 && (
              <li class="badge badge--jerry">
                <span aria-hidden="true">💸</span>
                {frA.jerryJonesAwards.length}x Jerry Jones
              </li>
            )}
            {frA.brockOsweilerAwards?.length > 0 && (
              <li class="badge badge--osweiler">
                <span aria-hidden="true">📉</span>
                {frA.brockOsweilerAwards.length}x Brock Osweiler
              </li>
            )}
          </ul>
        </div>
        <div class="compare-side">
          <h3>{frB.currentNameMedium || frB.currentName}</h3>
          <ul class="badges-bar">
            {frB.championships.length > 0 && (
              <li class="badge badge--championship">
                <span aria-hidden="true">🏆</span>
                {frB.championships.length}x League Title{frB.championships.length > 1 ? 's' : ''}
              </li>
            )}
            {frB.runnerUps?.length > 0 && (
              <li class="badge badge--runnerup">
                <span aria-hidden="true">🥈</span>
                {frB.runnerUps.length}x Runner-up
              </li>
            )}
            {frB.divisionTitles?.length > 0 && (
              <li class="badge badge--division">
                <span aria-hidden="true">🛡</span>
                {frB.divisionTitles.length}x Division
              </li>
            )}
            {frB.mvpAwards?.length > 0 && (
              <li class="badge badge--mvp">
                <span aria-hidden="true">⭐</span>
                {frB.mvpAwards.length}x MVP
              </li>
            )}
            {frB.jerryJonesAwards?.length > 0 && (
              <li class="badge badge--jerry">
                <span aria-hidden="true">💸</span>
                {frB.jerryJonesAwards.length}x Jerry Jones
              </li>
            )}
            {frB.brockOsweilerAwards?.length > 0 && (
              <li class="badge badge--osweiler">
                <span aria-hidden="true">📉</span>
                {frB.brockOsweilerAwards.length}x Brock Osweiler
              </li>
            )}
          </ul>
        </div>
      </div>
    </section>

    <p class="footnote">
      <a href={resolveLeaguePath('/theleague/rivalries', hideLeaguePrefix)}>← All rivalries</a>
    </p>
  </article>
</TheLeagueLayout>

<style>
  .rivalry-detail {
    padding: 1.5rem 1rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .dim { color: var(--text-tertiary, #888); }
  .small { font-size: 0.8125rem; }

  /* ============================================
   * HERO
   * ============================================ */
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr auto 1fr;
      gap: 1.5rem;
      align-items: stretch;
    }
  }

  .side {
    --accent: var(--color-primary, #cc2936);
    border-radius: 0.75rem;
    overflow: hidden;
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 60%, #000));
    color: #fff;
  }
  .side-link {
    color: inherit;
    text-decoration: none;
    display: block;
    height: 100%;
  }
  .side .banner {
    width: 100%;
    height: auto;
    display: block;
    line-height: 0;
    opacity: 0.9;
  }
  .side-name {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    background: rgba(0,0,0,0.25);
  }
  .side-name .logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    background: rgba(255,255,255,0.85);
    padding: 0.25rem;
    border-radius: 0.375rem;
  }
  .side-name h1 {
    margin: 0;
    font-size: clamp(1.125rem, 3vw, 1.625rem);
    line-height: 1.15;
  }
  .side--b .side-name {
    flex-direction: row-reverse;
  }
  @media (min-width: 768px) {
    .side--b .side-name { flex-direction: row-reverse; text-align: right; }
  }

  .versus {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 1rem 0;
  }
  .vs-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-tertiary, #888);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .overall-record {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .overall-record strong {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-variant-numeric: tabular-nums;
    color: var(--text, #222);
  }
  .leader { margin: 0; }
  .intensity {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin: 0.25rem 0 0;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: #fff3c4;
    color: #7a5b00;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .empty-state {
    margin: 1rem 0 2rem;
    padding: 1.5rem;
    border: 1px dashed var(--border, #e5e5e5);
    border-radius: 0.5rem;
    color: var(--text-secondary, #666);
    text-align: center;
  }

  /* ============================================
   * QUICK STATS
   * ============================================ */
  .quick-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
