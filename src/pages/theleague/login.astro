---
/**
 * Login Page
 * Slim wrapper around LoginForm for standalone page context.
 * The LoginForm component is also reusable inside modals on other pages.
 */

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import LoginForm from '../../components/theleague/LoginForm.astro';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getAuthUser } from '../../utils/auth';

// If user is already authenticated, redirect to theleague
const authUser = getAuthUser(Astro.request);
if (authUser) {
  return Astro.redirect('/theleague');
}

const envHost = (import.meta.env.PUBLIC_MFL_HOST as string | undefined) || 'https://api.myfantasyleague.com';
const envLeagueId = (import.meta.env.PUBLIC_MFL_LEAGUE_ID as string | undefined) || '';
const envYear = getCurrentLeagueYear().toString();
const envStaticHost = (import.meta.env.PUBLIC_STATIC_HOST as string | undefined) || envHost;
---

<TheLeagueLayout title="Sign In - The League" host={envHost} leagueId={envLeagueId} year={envYear} staticHost={envStaticHost}>
  <div class="login-page">
    <LoginForm />
  </div>
</TheLeagueLayout>

<style>
  .login-page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 4rem var(--spacing-lg, 1.5rem) var(--spacing-2xl, 3rem);
  }

  @media (max-width: 640px) {
    .login-page {
      padding: 2.5rem var(--spacing-md, 1rem) var(--spacing-xl, 2rem);
    }
  }
</style>
