---
/**
 * Login Page
 * Slim wrapper around LoginForm for standalone page context.
 * The LoginForm component is also reusable inside modals on other pages.
 */

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import LoginForm from '../../components/theleague/LoginForm.astro';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getAuthUser } from '../../utils/auth';
import { getLeagueBySlug } from '../../config/leagues';

const THELEAGUE_ID = getLeagueBySlug('theleague')!.id;

// Deep-link return path — honor ?redirect= (and ?next= for symmetry with the
// AFL login page). Validated server-side, mirroring AFL's safeNext: only
// same-league paths, so a crafted param can't send a fresh session off-site.
const requested =
  Astro.url.searchParams.get('redirect') || Astro.url.searchParams.get('next');
const safeRedirect =
  requested && requested.startsWith('/theleague') ? requested : null;

// Only short-circuit for a session already scoped to THIS league — dual-league
// owners are real, and an AFL-scoped session must fall through so the user can
// re-sign-in against TheLeague (mirrors afl-fantasy/login.astro). The
// franchiseId check keeps franchise-less JWTs on the form instead of bouncing
// them between here and pages that require a franchise.
const authUser = getAuthUser(Astro.request);
if (authUser?.leagueId === THELEAGUE_ID && authUser.franchiseId) {
  return Astro.redirect(safeRedirect ?? '/theleague');
}

const envHost = (import.meta.env.PUBLIC_MFL_HOST as string | undefined) || 'https://api.myfantasyleague.com';
const envLeagueId = (import.meta.env.PUBLIC_MFL_LEAGUE_ID as string | undefined) || '';
const envYear = getCurrentLeagueYear().toString();
const envStaticHost = (import.meta.env.PUBLIC_STATIC_HOST as string | undefined) || envHost;
---

<TheLeagueLayout title="Sign In - The League" host={envHost} leagueId={envLeagueId} year={envYear} staticHost={envStaticHost}>
  <div class="login-page">
    <LoginForm />
  </div>
</TheLeagueLayout>

<style>
  .login-page {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 4rem var(--spacing-lg, 1.5rem) var(--spacing-2xl, 3rem);
  }

  @media (max-width: 640px) {
    .login-page {
      padding: 2.5rem var(--spacing-md, 1rem) var(--spacing-xl, 2rem);
    }
  }
</style>
