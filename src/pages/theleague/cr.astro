---
/**
 * Custom Rankings
 *
 * Hidden, admin-only page for creating personalized player rankings.
 * Seeds from composite "My Rank" average, supports drag-and-drop reordering,
 * tier breaks, and position filtering. State persists via Vercel KV.
 */
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import CustomRankingsPage from '../../components/theleague/custom-rankings/CustomRankingsPage';
import { getCurrentLeagueYear } from '../../utils/league-year';
import { getPlayerMap } from '../../utils/player-map';
import '../../styles/player-cell.css';
import '../../styles/custom-rankings.css';
import { getAuthUser, isCommissionerOrAdmin } from '../../utils/auth';
import { parseNumber } from '../../utils/formatters';
import { calculatePointsPerDollar } from '../../utils/surplus-value';
import { calculateAllVORP } from '../../utils/vorp';
import espnCollegeIds from '../../../data/theleague/espn-college-ids.json';

export const prerender = false;

// Auth gate: admin only (same auth as nav sidebar)
const user = getAuthUser(Astro.request);
if (!user || !isCommissionerOrAdmin(user)) {
  return Astro.redirect('/theleague');
}

const leagueYear = getCurrentLeagueYear();
const leagueYearStr = String(leagueYear);

// ---------------------------------------------------------------------------
// Load MFL players for enrichment (headshot URLs, positions)
// ---------------------------------------------------------------------------
const playersFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/players.json',
  { eager: true },
);

const getModuleData = (mod: unknown) =>
  mod && typeof mod === 'object' && 'default' in mod ? (mod as { default: unknown }).default : mod;

const extractFeedSeason = (filepath: string) => {
  const match = filepath.match(/mfl-feeds\/(\d{4})\//);
  return match ? match[1] : null;
};

let playersData: any = null;
for (const [filepath, mod] of Object.entries(playersFeeds)) {
  if (extractFeedSeason(filepath) === leagueYearStr) {
    playersData = getModuleData(mod);
    break;
  }
}

// Build player array with headshot info for client-side enrichment
const crPlayerIdentityMap = getPlayerMap(leagueYear);
const rawPlayers = playersData?.players?.player ?? [];
const mflPlayers = rawPlayers
  .filter((p: any) => p.name && p.position)
  .map((p: any) => {
    const identity = crPlayerIdentityMap.get(p.id);
    return {
      id: p.id,
      name: identity?.name ?? p.name,
      position: identity?.position ?? (p.position === 'Def' ? 'DEF' : p.position),
      team: identity?.nflTeam ?? p.team ?? '',
      espnId: identity?.espnId ?? (p.espn_id || (espnCollegeIds as any).players?.[p.id]?.espnCollegeId || null),
    };
  });

// ---------------------------------------------------------------------------
// Load projected scores + rosters for VORP calculation
// ---------------------------------------------------------------------------
const projScoreFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/projectedScores.json',
  { eager: true },
);
const rostersFeeds = import.meta.glob(
  '../../../data/theleague/mfl-feeds/*/rosters.json',
  { eager: true },
);

let projScoreData: any = null;
let rostersData: any = null;
for (const [fp, mod] of Object.entries(projScoreFeeds)) {
  if (extractFeedSeason(fp) === leagueYearStr) { projScoreData = getModuleData(mod); break; }
}
for (const [fp, mod] of Object.entries(rostersFeeds)) {
  if (extractFeedSeason(fp) === leagueYearStr) { rostersData = getModuleData(mod); break; }
}

// Build maps for VORP
const projectedScores = new Map<string, number>();
for (const ps of (projScoreData?.projectedScores?.playerScore ?? [])) {
  const score = parseNumber(ps.score);
  if (score > 0) projectedScores.set(ps.id, score);
}

const playerPositionMap = new Map<string, { position: string }>();
for (const p of mflPlayers) {
  playerPositionMap.set(p.id, { position: p.position });
}

// Calculate points-per-dollar ratio from rostered players
const rosteredPlayers = new Map<string, { salary: number; position: string }>();
for (const franchise of (rostersData?.rosters?.franchise ?? [])) {
  for (const rp of (Array.isArray(franchise.player) ? franchise.player : [])) {
    const salary = parseNumber(rp.salary);
    const meta = playerPositionMap.get(rp.id);
    if (meta) {
      rosteredPlayers.set(rp.id, { salary, position: meta.position });
    }
  }
}
const pointsPerDollar = calculatePointsPerDollar(projectedScores, rosteredPlayers);

// Calculate VORP for all players
const vorpResults = calculateAllVORP(projectedScores, playerPositionMap, pointsPerDollar);
const vorpMap: Record<string, { vorpPoints: number; vorpDollar: number }> = {};
for (const [id, result] of vorpResults) {
  vorpMap[id] = result;
}
---

<TheLeagueLayout title="Custom Rankings | The League">
  <CustomRankingsPage
    client:load
    mflPlayersJson={JSON.stringify(mflPlayers)}
    franchiseId={user.franchiseId}
    vorpMapJson={JSON.stringify(vorpMap)}
  />
</TheLeagueLayout>
