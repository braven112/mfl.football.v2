---
/**
 * What's New detail (The League) — thin route wrapper.
 * Shared implementation lives in components/shared/whats-new/WhatsNewDetailPage.
 */
import WhatsNewDetailPage from '../../../components/shared/whats-new/WhatsNewDetailPage.astro';
import { resolveWhatsNewDetail } from '../../../utils/whats-new-detail';

export const prerender = false;

const result = resolveWhatsNewDetail(Astro, 'theleague');
if (result.redirectTo) return Astro.redirect(result.redirectTo);
---

<WhatsNewDetailPage
  leagueSlug="theleague"
  entry={result.entry!}
  prev={result.prev ?? null}
  next={result.next ?? null}
/>
