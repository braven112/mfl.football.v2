---
/**
 * What's New Detail Page
 *
 * Individual blog-post page for each What's New entry. Statically generated
 * via getStaticPaths(). Shows full description, optional hero image with
 * icon fallback, category badge, date, CTA link, and prev/next navigation.
 */
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import { spriteUrl } from '../../../utils/sprite-url';
import type { WhatsNewEntry } from '../../../types/whats-new';
import { WHATS_NEW_CATEGORY_LABELS } from '../../../types/whats-new';
import entries from '../../../data/whats-new.json';
import {
  sortEntriesNewestFirst,
  formatEntryDate,
  getAdjacentEntries,
} from '../../../utils/whats-new-helpers';
import { resolveLeaguePath } from '../../../utils/nav-utils';

export const prerender = false;

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

const sorted = sortEntriesNewestFirst(entries as WhatsNewEntry[]);
const id = Astro.params.id;
const entry = sorted.find((e) => e.id === id);
if (!entry) return Astro.redirect(r('/theleague/whats-new'));
const { prev, next } = getAdjacentEntries(sorted, entry.id);

const MULTICOLOR_ICONS = ['nfl'];
const iconId = entry.icon ? `icon-${entry.icon}` : null;
const isMulticolor = entry.icon ? MULTICOLOR_ICONS.includes(entry.icon) : false;
const imagePath = entry.image ? `/assets/whats-new/${entry.image}` : null;
---

<TheLeagueLayout title={`${entry.title} - What's New`}>
  <main class="wn-detail">
    <a href={r('/theleague/whats-new')} class="wn-detail__back">
      <span aria-hidden="true">&larr;</span> Back to What's New
    </a>

    <article class="wn-detail__article">
      <div class="wn-detail__meta">
        <span class={`wn-detail__badge wn-detail__badge--${entry.category}`}>
          {WHATS_NEW_CATEGORY_LABELS[entry.category]}
        </span>
        <time class="wn-detail__date" datetime={entry.date}>
          {formatEntryDate(entry.date)}
        </time>
        <button
          class="wn-detail__share"
          type="button"
          aria-label="Share this article"
          data-title={entry.title}
          data-summary={entry.summary}
        >
          <svg class="wn-detail__share-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
            <polyline points="16 6 12 2 8 6" />
            <line x1="12" y1="2" x2="12" y2="15" />
          </svg>
          <span class="wn-detail__share-label">Share</span>
        </button>
      </div>

      {imagePath ? (
        <div class={`wn-detail__hero wn-detail__hero--${entry.category}`}>
          <div class="browser-frame">
            <div class="browser-frame__bar">
              <span class="browser-frame__dot browser-frame__dot--red"></span>
              <span class="browser-frame__dot browser-frame__dot--yellow"></span>
              <span class="browser-frame__dot browser-frame__dot--green"></span>
              <span class="browser-frame__url">{entry.link ? `theleague.us${entry.link}` : 'theleague.us'}</span>
            </div>
            <img
              src={imagePath}
              alt={entry.imageAlt || entry.title}
              class="wn-detail__hero-img"
              loading="eager"
            />
          </div>
        </div>
      ) : iconId ? (
        <div class={`wn-detail__hero wn-detail__hero--fallback wn-detail__hero--${entry.category}`}>
          <svg
            class={`wn-detail__hero-icon${isMulticolor ? ' wn-detail__hero-icon--multicolor' : ''}`}
            aria-hidden="true"
          >
            <use href={`${spriteUrl}#${iconId}`} />
          </svg>
        </div>
      ) : null}

      <h1 class="wn-detail__title">{entry.title}</h1>

      <div class="wn-detail__body">
        {entry.description.map((para) => (
          <p set:html={para} />
        ))}
      </div>

      {entry.link && (
        <div class="wn-detail__cta">
          <a href={r(entry.link)} class="wn-detail__cta-link">
            {entry.linkLabel ?? 'Check it out'}
            <span class="wn-detail__cta-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      )}
    </article>

    <nav class="wn-detail__nav" aria-label="Previous and next entries">
      {prev ? (
        <a href={`${r('/theleague/whats-new')}/${prev.id}`} class="wn-detail__nav-link wn-detail__nav-link--prev">
          <span class="wn-detail__nav-dir">&larr; Newer</span>
          <span class="wn-detail__nav-title">{prev.title}</span>
        </a>
      ) : (
        <span />
      )}
      {next && (
        <a href={`${r('/theleague/whats-new')}/${next.id}`} class="wn-detail__nav-link wn-detail__nav-link--next">
          <span class="wn-detail__nav-dir">Older &rarr;</span>
          <span class="wn-detail__nav-title">{next.title}</span>
        </a>
      )}
    </nav>
  </main>
</TheLeagueLayout>

<style>
  /* ── Category color tokens ── */
  :root {
    --cat-new-page: #6d28d9;
    --cat-new-feature: #166534;
    --cat-enhancement: #1d4ed8;
    --cat-bug-fix: #b91c1c;
    --cat-league-event: #1c497c;
  }

  .wn-detail {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl, 2rem);
    padding: var(--spacing-xl, 2rem) var(--spacing-md, 1rem);
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── Back link ── */
  .wn-detail__back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .wn-detail__back:hover {
    color: var(--accent-link-hover-text-color, #3c9950);
  }

  /* ── Article ── */
  .wn-detail__article {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg, 1.5rem);
  }

  /* ── Meta (badge + date) ── */
  .wn-detail__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm, 0.5rem);
  }

  .wn-detail__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    color: #fff;
  }

  .wn-detail__badge--new-page { background: var(--cat-new-page); }
  .wn-detail__badge--new-feature { background: var(--cat-new-feature); }
  .wn-detail__badge--enhancement { background: var(--cat-enhancement); }
  .wn-detail__badge--bug-fix { background: var(--cat-bug-fix); }
  .wn-detail__badge--league-event { background: var(--cat-league-event); }

  .wn-detail__date {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--muted-text-color, #6b7280);
  }

  /* ── Share button ── */
  .wn-detail__share {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--muted-text-color, #6b7280);
    background: none;
    border: 1px solid var(--primary-content-border-color, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .wn-detail__share:hover {
    color: var(--color-primary, #1c497c);
    border-color: var(--color-primary, #1c497c);
    background: var(--primary-light-bg, #f0f4f8);
  }

  .wn-detail__share-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .wn-detail__share--copied {
    color: var(--cat-new-feature, #166534);
    border-color: var(--cat-new-feature, #166534);
  }

  /* ── Hero image / fallback ── */
  .wn-detail__hero {
    border-radius: 0.75rem;
    overflow: hidden;
    padding: var(--spacing-lg, 1.5rem);
    background: color-mix(in srgb, var(--entry-category-color, #1c497c) 10%, var(--content-bg, #fff));
    box-sizing: border-box;
  }

  .wn-detail__hero .browser-frame {
    background: #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: rotate(-1.5deg);
  }

  .wn-detail__hero-img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* ── Browser frame (macOS-style chrome) ── */
  .browser-frame__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: #e5e7eb;
  }

  .browser-frame__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .browser-frame__dot--red { background: #ff5f57; }
  .browser-frame__dot--yellow { background: #ffbd2e; }
  .browser-frame__dot--green { background: #28c840; }

  .browser-frame__url {
    flex: 1;
    margin-left: 6px;
    background: #fff;
    border-radius: 3px;
    padding: 2px 8px;
    font-size: 10px;
    color: #6b7280;
    font-family: ui-monospace, monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .wn-detail__hero--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--entry-category-color, #2e8743) 8%, var(--content-bg, #fff)) 0%,
      color-mix(in srgb, var(--entry-category-color, #2e8743) 15%, var(--content-bg, #fff)) 100%
    );
  }

  .wn-detail__hero--new-page { --entry-category-color: var(--cat-new-page); }
  .wn-detail__hero--new-feature { --entry-category-color: var(--cat-new-feature); }
  .wn-detail__hero--enhancement { --entry-category-color: var(--cat-enhancement); }
  .wn-detail__hero--bug-fix { --entry-category-color: var(--cat-bug-fix); }
  .wn-detail__hero--league-event { --entry-category-color: var(--cat-league-event); }

  .wn-detail__hero-icon {
    width: 4rem;
    height: 4rem;
    fill: currentColor;
    color: var(--entry-category-color, #2e8743);
    opacity: 0.6;
  }

  .wn-detail__hero-icon--multicolor {
    fill: none;
    color: unset;
  }

  /* ── Title ── */
  .wn-detail__title {
    font-size: var(--font-size-2xl, 2rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--primary-link-default-text-color, #1c497c);
    margin: 0;
    line-height: var(--line-height-tight, 1.25);
  }

  /* ── Body ── */
  .wn-detail__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1rem);
  }

  .wn-detail__body p {
    font-size: var(--font-size-base, 1rem);
    color: var(--text-color, #374151);
    margin: 0;
    line-height: 1.7;
  }

  /* ── CTA ── */
  .wn-detail__cta {
    margin-top: var(--spacing-sm, 0.5rem);
  }

  .wn-detail__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--btn-primary-text, #fff);
    background: var(--color-primary, #1c497c);
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .wn-detail__cta-link:hover {
    filter: brightness(0.9);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary, #1c497c) 35%, transparent);
    transform: translateY(-1px);
  }

  .wn-detail__cta-arrow {
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .wn-detail__cta-link:hover .wn-detail__cta-arrow {
    transform: translateX(2px);
  }

  /* ── Prev/Next Nav ── */
  .wn-detail__nav {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-md, 1rem);
    padding-top: var(--spacing-xl, 2rem);
  }

  .wn-detail__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    max-width: 45%;
    transition: color 0.15s ease;
  }

  .wn-detail__nav-link--next {
    text-align: right;
    margin-left: auto;
  }

  .wn-detail__nav-dir {
    font-size: 0.75rem;
    font-weight: var(--font-weight-semibold, 600);
    color: var(--muted-text-color, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .wn-detail__nav-title {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-primary, #1c497c);
    line-height: 1.3;
  }

  .wn-detail__nav-link:hover .wn-detail__nav-title {
    color: var(--accent-link-hover-text-color, #3c9950);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .wn-detail__title {
      font-size: var(--font-size-xl, 1.5rem);
    }

    .wn-detail__hero-icon {
      width: 3rem;
      height: 3rem;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.wn-detail__share');
  if (btn) {
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      const title = btn.dataset.title || document.title;
      const text = btn.dataset.summary || '';

      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          return;
        } catch (err) {
          if ((err as DOMException).name === 'AbortError') return;
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        const label = btn.querySelector('.wn-detail__share-label');
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied!';
          btn.classList.add('wn-detail__share--copied');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('wn-detail__share--copied');
          }, 2000);
        }
      } catch {
        window.prompt('Copy this link:', url);
      }
    });
  }
</script>
