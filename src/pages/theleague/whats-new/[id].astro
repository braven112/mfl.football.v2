---
/**
 * What's New Detail Page
 *
 * Individual article page for each What's New entry. Statically generated
 * via getStaticPaths(). Shows full description, optional hero image with
 * icon fallback, category badge, date, CTA link, and prev/next navigation.
 * Styled using the editorial design language from PlayerDetailsModal.
 */
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import { spriteUrl } from '../../../utils/sprite-url';
import type { WhatsNewEntry, DescriptionImageBlock } from '../../../types/whats-new';
import { WHATS_NEW_CATEGORY_LABELS } from '../../../types/whats-new';
import entries from '../../../data/whats-new.json';
import {
  sortEntriesNewestFirst,
  formatEntryDate,
  getAdjacentEntries,
} from '../../../utils/whats-new-helpers';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import { getAuthUser, isCommissionerOrAdmin } from '../../../utils/auth';
import SchefterWidget from '../../../components/shared/SchefterWidget.astro';
import type { SchefterFeed as FeedType } from '../../../types/schefter';
import schefterFeedData from '../../../data/theleague/schefter-feed.json';

export const prerender = false;

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

const user = getAuthUser(Astro.request);
const isAdmin = !!user && isCommissionerOrAdmin(user);

const visible = (entries as WhatsNewEntry[]).filter(
  (e) => e.visibility !== 'admin' || isAdmin,
);
const sorted = sortEntriesNewestFirst(visible);
const id = Astro.params.id;
const entry = sorted.find((e) => e.id === id);
if (!entry) return Astro.redirect(r('/theleague/whats-new'));
const { prev, next } = getAdjacentEntries(sorted, entry.id);

const MULTICOLOR_ICONS = ['nfl'];
const iconId = entry.icon ? `icon-${entry.icon}` : null;
const isMulticolor = entry.icon ? MULTICOLOR_ICONS.includes(entry.icon) : false;
const imagePath = entry.image ? `/assets/whats-new/${entry.image}` : null;
---

<TheLeagueLayout title={`${entry.title} - What's New`}>
  <main class="wn-detail">

    <!-- Back link -->
    <a href={r('/theleague/whats-new')} class="wn-detail__back">
      <svg class="wn-detail__back-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 3L5 8l5 5" />
      </svg>
      What's New
    </a>

    <!-- 2-Column Grid -->
    <div class="wn-detail__grid">

      <!-- ── Left: Main Column ── -->
      <div class="wn-detail__main">
        <article class={`wn-detail__article wn-detail__article--${entry.category}`}>

          <!-- Hero image / fallback icon — sits at top of card, edge-to-edge -->
          {imagePath ? (
            <div class="wn-detail__hero-wrap">
              <div class="browser-frame">
                <div class="browser-frame__bar">
                  <span class="browser-frame__dot browser-frame__dot--red"></span>
                  <span class="browser-frame__dot browser-frame__dot--yellow"></span>
                  <span class="browser-frame__dot browser-frame__dot--green"></span>
                  <span class="browser-frame__url">{entry.link ? `theleague.us${entry.link.replace('/theleague', '')}` : 'theleague.us'}</span>
                </div>
                <img
                  src={imagePath}
                  alt={entry.imageAlt || entry.title}
                  class="wn-detail__hero-img"
                  loading="eager"
                />
              </div>
            </div>
          ) : iconId ? (
            <div class={`wn-detail__hero-fallback wn-detail__hero-fallback--${entry.category}`}>
              <svg
                class={`wn-detail__hero-icon${isMulticolor ? ' wn-detail__hero-icon--multicolor' : ''}`}
                aria-hidden="true"
              >
                <use href={`${spriteUrl}#${iconId}`} />
              </svg>
            </div>
          ) : null}

          <!-- Article header inside card -->
          <div class="wn-detail__header">
            <!-- Category + date + share row -->
            <div class="wn-detail__meta">
              <span class={`wn-detail__badge wn-detail__badge--${entry.category}`}>
                {WHATS_NEW_CATEGORY_LABELS[entry.category]}
              </span>
              <span class="wn-detail__meta-dot" aria-hidden="true"></span>
              <time class="wn-detail__date" datetime={entry.date}>
                {formatEntryDate(entry.date)}
              </time>
              <button
                class="wn-detail__share"
                type="button"
                aria-label="Share this article"
                data-title={entry.title}
                data-summary={entry.summary}
              >
                <svg class="wn-detail__share-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
                  <polyline points="16 6 12 2 8 6" />
                  <line x1="12" y1="2" x2="12" y2="15" />
                </svg>
                <span class="wn-detail__share-label">Share</span>
              </button>
            </div>

            <!-- Title -->
            <h1 class="wn-detail__title">{entry.title}</h1>

            <!-- Summary lead -->
            <p class="wn-detail__summary">{entry.summary}</p>
          </div>

          <!-- Article body -->
          <div class="wn-detail__body-wrap">
            <h2 class="wn-detail__section-title">The Full Story</h2>
            <div class="wn-detail__body">
              {entry.description.map((block) => (
                typeof block === 'string' ? (
                  <p set:html={block} />
                ) : (block as DescriptionImageBlock).type === 'image' ? (
                  <figure class="wn-detail__inline-figure">
                    <div class="browser-frame browser-frame--inline">
                      <div class="browser-frame__bar">
                        <span class="browser-frame__dot browser-frame__dot--red"></span>
                        <span class="browser-frame__dot browser-frame__dot--yellow"></span>
                        <span class="browser-frame__dot browser-frame__dot--green"></span>
                      </div>
                      <img
                        src={`/assets/whats-new/${(block as DescriptionImageBlock).src}`}
                        alt={(block as DescriptionImageBlock).alt}
                        class="wn-detail__inline-img"
                        loading="lazy"
                      />
                    </div>
                    {(block as DescriptionImageBlock).caption && (
                      <figcaption class="wn-detail__caption">{(block as DescriptionImageBlock).caption}</figcaption>
                    )}
                  </figure>
                ) : null
              ))}
            </div>

            <!-- CTA -->
            {entry.link && (
              <div class="wn-detail__cta">
                <a href={r(entry.link)} class="wn-detail__cta-link">
                  {entry.linkLabel ?? 'Check it out'}
                  <svg class="wn-detail__cta-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="14" height="14">
                    <path d="M3 8h10M9 4l4 4-4 4" />
                  </svg>
                </a>
              </div>
            )}
          </div>

        </article>
      </div>

      <!-- ── Right: Sticky Sidebar ── -->
      <aside class="wn-detail__sidebar">
        <div class="wn-detail__sidebar-inner">

          <!-- Author card -->
          <div class="wn-detail__author-card">
            <img
              src="/assets/claude-schefter-avatar.webp"
              alt="Claude Schefter — Staff Writer"
              class="wn-detail__author-avatar"
              width="72"
              height="72"
              loading="eager"
            />
            <div class="wn-detail__author-name">Claude Schefter</div>
            <div class="wn-detail__author-role">Staff Writer</div>
            <p class="wn-detail__author-bio">Adam Schefter's lesser-known brother. Doesn't break NFL trades, but he does break down every new feature, bug fix, and enhancement with the same breathless urgency.</p>
          </div>

          <!-- Release Details card -->
          <div class="wn-detail__release-card">
            <h2 class="wn-detail__section-title">Release Details</h2>
            <div class="wn-detail__detail-list">
              <div class="wn-detail__detail-row">
                <span class="wn-detail__detail-label">Date</span>
                <time class="wn-detail__detail-value" datetime={entry.date}>{formatEntryDate(entry.date)}</time>
              </div>
              <div class="wn-detail__detail-row">
                <span class="wn-detail__detail-label">Type</span>
                <span class="wn-detail__detail-value">
                  <span class={`wn-detail__badge wn-detail__badge--${entry.category}`}>
                    {WHATS_NEW_CATEGORY_LABELS[entry.category]}
                  </span>
                </span>
              </div>
              {entry.link && (
                <div class="wn-detail__detail-row">
                  <span class="wn-detail__detail-label">Link</span>
                  <span class="wn-detail__detail-value">
                    <a href={r(entry.link)} class="wn-detail__inline-link">{entry.linkLabel ?? 'View feature'}</a>
                  </span>
                </div>
              )}
            </div>
          </div>

          <!-- League News widget -->
          {(schefterFeedData as FeedType).posts.length > 0 && (
            <div class="wn-detail__release-card">
              <SchefterWidget
                posts={(schefterFeedData as FeedType).posts.slice(0, 4)}
                league="theleague"
                allNewsLink={r('/theleague/news')}
              />
            </div>
          )}

          <!-- More Updates card (prev/next) -->
          {(prev || next) && (
            <nav class="wn-detail__nav-card" aria-label="Previous and next entries">
              <h2 class="wn-detail__section-title">More Updates</h2>
              <div class="wn-detail__nav-links">
                {prev && (
                  <a href={`${r('/theleague/whats-new')}/${prev.id}`} class="wn-detail__nav-link wn-detail__nav-link--prev">
                    <span class="wn-detail__nav-dir">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="12" height="12">
                        <path d="M10 3L5 8l5 5" />
                      </svg>
                      Newer
                    </span>
                    <span class="wn-detail__nav-entry">{prev.title}</span>
                  </a>
                )}
                {next && (
                  <a href={`${r('/theleague/whats-new')}/${next.id}`} class="wn-detail__nav-link wn-detail__nav-link--next">
                    <span class="wn-detail__nav-dir">
                      Older
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="12" height="12">
                        <path d="M6 3l5 5-5 5" />
                      </svg>
                    </span>
                    <span class="wn-detail__nav-entry">{next.title}</span>
                  </a>
                )}
              </div>
            </nav>
          )}

        </div>
      </aside>

    </div>

  </main>
</TheLeagueLayout>

<style>
  /* ── Category color tokens ── */
  :root {
    --cat-new-page: #6d28d9;
    --cat-new-feature: #166534;
    --cat-enhancement: #1d4ed8;
    --cat-bug-fix: #b91c1c;
    --cat-league-event: #1c497c;
  }

  /* ── Page shell ── */
  .wn-detail {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1rem);
    padding: var(--spacing-md, 1rem) var(--spacing-md, 1rem);
    margin: 0 auto;
  }

  /* ── 2-Column Grid ── */
  .wn-detail__grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 1.5rem;
    align-items: start;
  }

  .wn-detail__main {
    min-width: 0;
  }

  /* ── Sticky Sidebar ── */
  .wn-detail__sidebar {
    position: sticky;
    top: 1rem;
  }

  .wn-detail__sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Sidebar cards ── */
  .wn-detail__author-card,
  .wn-detail__release-card,
  .wn-detail__nav-card {
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    padding: 1rem 1.25rem;
  }

  /* ── Author card ── */
  .wn-detail__author-card {
    text-align: center;
    padding: 1.5rem 1.25rem;
  }

  .wn-detail__author-avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-full, 9999px);
    object-fit: cover;
    margin: 0 auto 0.75rem;
    border: 3px solid var(--color-gray-100, #f3f4f6);
  }

  .wn-detail__author-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    line-height: 1;
  }

  .wn-detail__author-role {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary, #1c497c);
    margin-top: 0.25rem;
  }

  .wn-detail__author-bio {
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-gray-400, #9ca3af);
    margin: 0.75rem 0 0 0;
  }

  /* ── Back link ── */
  .wn-detail__back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400, #9ca3af);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .wn-detail__back:hover {
    color: var(--color-primary, #1c497c);
  }

  .wn-detail__back-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* ── Article card ── */
  .wn-detail__article {
    background: var(--color-white, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-lg, 1rem);
    overflow: hidden;
  }

  .wn-detail__article--new-page      { --entry-cat-color: var(--cat-new-page); }
  .wn-detail__article--new-feature   { --entry-cat-color: var(--cat-new-feature); }
  .wn-detail__article--enhancement   { --entry-cat-color: var(--cat-enhancement); }
  .wn-detail__article--bug-fix       { --entry-cat-color: var(--cat-bug-fix); }
  .wn-detail__article--league-event  { --entry-cat-color: var(--cat-league-event); }

  /* ── Hero image (edge-to-edge at top of card) ── */
  .wn-detail__hero-wrap {
    padding: var(--spacing-lg, 1.5rem);
    background: color-mix(in srgb, var(--entry-cat-color, #1c497c) 8%, var(--color-gray-50, #f9fafb));
    /* Category-colored accent border between image and content */
    border-bottom: 3px solid var(--entry-cat-color, var(--color-primary, #1c497c));
  }

  .browser-frame {
    background: #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    transform: rotate(-1deg);
  }

  .wn-detail__hero-img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .browser-frame__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: #e5e7eb;
  }

  .browser-frame__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .browser-frame__dot--red    { background: #ff5f57; }
  .browser-frame__dot--yellow { background: #ffbd2e; }
  .browser-frame__dot--green  { background: #28c840; }

  .browser-frame__url {
    flex: 1;
    margin-left: 6px;
    background: #fff;
    border-radius: 3px;
    padding: 2px 8px;
    font-size: 10px;
    color: #6b7280;
    font-family: ui-monospace, monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Icon fallback hero ── */
  .wn-detail__hero-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 7;
    background: color-mix(in srgb, var(--entry-cat-color, #1c497c) 10%, var(--color-gray-50, #f9fafb));
    border-bottom: 3px solid var(--entry-cat-color, var(--color-primary, #1c497c));
  }

  .wn-detail__hero-fallback--new-page      { --entry-cat-color: var(--cat-new-page); }
  .wn-detail__hero-fallback--new-feature   { --entry-cat-color: var(--cat-new-feature); }
  .wn-detail__hero-fallback--enhancement   { --entry-cat-color: var(--cat-enhancement); }
  .wn-detail__hero-fallback--bug-fix       { --entry-cat-color: var(--cat-bug-fix); }
  .wn-detail__hero-fallback--league-event  { --entry-cat-color: var(--cat-league-event); }

  .wn-detail__hero-icon {
    width: 4rem;
    height: 4rem;
    fill: currentColor;
    color: var(--entry-cat-color, #1c497c);
    opacity: 0.5;
  }

  .wn-detail__hero-icon--multicolor {
    fill: none;
    color: unset;
    opacity: 1;
  }

  /* ── Article header (inside card) ── */
  .wn-detail__header {
    padding: var(--spacing-lg, 1.5rem) var(--spacing-lg, 1.5rem) 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    padding-bottom: var(--spacing-lg, 1.5rem);
  }

  /* ── Meta row ── */
  .wn-detail__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .wn-detail__meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-gray-300, #d1d5db);
    flex-shrink: 0;
  }

  .wn-detail__badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.175rem 0.5rem;
    border-radius: var(--radius-sm, 0.25rem);
    color: #fff;
    flex-shrink: 0;
  }

  .wn-detail__badge--new-page     { background: var(--cat-new-page); }
  .wn-detail__badge--new-feature  { background: var(--cat-new-feature); }
  .wn-detail__badge--enhancement  { background: var(--cat-enhancement); }
  .wn-detail__badge--bug-fix      { background: var(--cat-bug-fix); }
  .wn-detail__badge--league-event { background: var(--cat-league-event); }

  .wn-detail__date {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-gray-500, #6b7280);
  }

  /* ── Share button ── */
  .wn-detail__share {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gray-500, #6b7280);
    background: none;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .wn-detail__share:hover {
    color: var(--color-primary, #1c497c);
    border-color: var(--color-primary, #1c497c);
  }

  .wn-detail__share-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  .wn-detail__share--copied {
    color: var(--cat-new-feature, #166534);
    border-color: var(--cat-new-feature, #166534);
  }

  /* ── Title ── */
  .wn-detail__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    margin: 0;
    line-height: 1.2;
  }

  /* ── Summary lead ── */
  .wn-detail__summary {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-gray-600, #4b5563);
    margin: 0;
    line-height: 1.55;
  }

  /* ── Section title (left-border editorial accent) ── */
  .wn-detail__section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-900, #111827);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
    margin: 0 0 var(--spacing-md, 1rem);
  }

  /* ── Body wrap ── */
  .wn-detail__body-wrap {
    padding: var(--spacing-lg, 1.5rem);
  }

  .wn-detail__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wn-detail__body p {
    font-size: 0.9375rem;
    color: var(--color-gray-700, #374151);
    margin: 0;
    line-height: 1.7;
  }

  /* ── Inline images within article body ── */
  .wn-detail__inline-figure {
    margin: 0.5rem 0;
  }

  .browser-frame--inline {
    transform: none;
  }

  .wn-detail__inline-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .wn-detail__caption {
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
    margin-top: 0.5rem;
    font-style: italic;
    text-align: center;
  }

  /* ── CTA ── */
  .wn-detail__cta {
    margin-top: var(--spacing-lg, 1.5rem);
    padding-top: var(--spacing-lg, 1.5rem);
    border-top: 1px solid var(--color-gray-100, #f3f4f6);
  }

  .wn-detail__cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1;
    border-radius: 8px;
    padding: 0.625rem 1.25rem;
    border: none;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    background: var(--btn-primary-bg, #1c497c);
    color: var(--btn-primary-text, #fff);
    transition: background 0.15s ease, color 0.15s ease, opacity 0.15s ease;
  }

  .wn-detail__cta-link:hover {
    background: var(--btn-primary-bg-hover, #164066);
  }

  .wn-detail__cta-arrow {
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .wn-detail__cta-link:hover .wn-detail__cta-arrow {
    transform: translateX(2px);
  }

  .wn-detail__detail-list {
    display: flex;
    flex-direction: column;
  }

  .wn-detail__detail-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
  }

  .wn-detail__detail-row:last-child {
    border-bottom: none;
  }

  .wn-detail__detail-label {
    width: 3.5rem;
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
    text-align: right;
  }

  .wn-detail__detail-value {
    font-size: 0.875rem;
    color: var(--color-gray-700, #374151);
  }

