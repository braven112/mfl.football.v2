---
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import leagueConfig from '../../data/theleague.config.json';
import { getAuthUser, isCommissionerOrAdmin } from '../../utils/auth';
import { getLeagueContext } from '../../utils/league-context';
import { leagueHasFeature } from '../../config/leagues';
import { getCurrentSeasonYear } from '../../utils/league-year';
import { getCurrentNFLWeek } from '../../utils/current-week';
import { getDailySlot } from '../../utils/hero-resolver';
import { assembleLiveScoringData, buildTeamsMap, applyThrowbackOverrides, type ConfigTeam } from '../../utils/live-scoring-data';
import { isThrowbackWeek } from '../../data/theleague/throwback-config';
import { getEligibleThrowbackEras } from '../../utils/throwback-identity';
import { getAllThrowbackPreferences } from '../../utils/throwback-store';
import { getLiveScoringSample } from '../../data/live-scoring-sample';
import LiveScoreboard from '../../components/shared/LiveScoreboard';
import NflGamesStrip from '../../components/shared/NflGamesStrip';
import type { LiveScoringPageProps, NflGame } from '../../types/live-scoring';
import '../../styles/live-scoring.css';
import '../../styles/nfl-games-strip.css';

// Live-fetch on every request — scores must never be cached.
export const prerender = false;

const league = getLeagueContext(Astro.url);

// Gate on the registry feature flag.
if (!leagueHasFeature(league.slug, 'liveScoring')) {
  return Astro.redirect('/theleague');
}

const now = new Date();
const year = getCurrentSeasonYear();
const weekParam = Astro.url.searchParams.get('week');
const parsedWeek = weekParam ? parseInt(weekParam, 10) : NaN;
const week = Number.isFinite(parsedWeek) && parsedWeek > 0
  ? parsedWeek
  : (getCurrentNFLWeek(now) ?? 1);

// Reuse the homepage hero's game-day clock: Thu/Sun/Mon windows drive whether
// the island polls for live updates and which game-window label to show.
const daily = getDailySlot(now);
const isLive = daily.slot === 'live-scoring';

const authUser = getAuthUser(Astro.request);
const userFranchiseId = authUser?.franchiseId;
let configTeams = ((leagueConfig as { teams?: ConfigTeam[] }).teams ?? []) as ConfigTeam[];

// Throwback Week: swap every team's name/icon/banner to its resolved legacy
// identity before any downstream data assembly touches configTeams — both
// the live path (via assembleLiveScoringData -> buildTeamsMap) and the demo
// path below pick this up for free.
// Try-before-save preview state — set when ?previewEra applies below; drives
// the "Save this era" bar above the scoreboard. `ownSave` is false when a
// commissioner is previewing another franchise (view-only — no save button;
// the preference API is deliberately owner-scoped).
let throwbackPreview: { yearStart: number; eraName: string; teamName: string; ownSave: boolean } | null = null;

if (isThrowbackWeek(week)) {
  const ownerOverrides = await getAllThrowbackPreferences(configTeams.map((t) => t.franchiseId));

  // Try-before-save: ?previewEra={yearStart} lets a signed-in owner see an era
  // on THEIR OWN team without persisting it (the picker's per-card Preview
  // links use this), and only for an era the picker would actually offer.
  // Commissioners may add ?previewFranchise={id} to dress ANY team for
  // validation — still view-only; non-admins get the param ignored.
  const previewEraParam = Astro.url.searchParams.get('previewEra');
  const previewEra = previewEraParam ? parseInt(previewEraParam, 10) : NaN;
  if (Number.isFinite(previewEra) && userFranchiseId) {
    const previewFranchiseParam = Astro.url.searchParams.get('previewFranchise');
    const isAdmin = !!authUser && isCommissionerOrAdmin(authUser);
    const targetFranchiseId =
      previewFranchiseParam && isAdmin ? previewFranchiseParam : userFranchiseId;

    const targetTeam = configTeams.find((t) => t.franchiseId === targetFranchiseId);
    const chosen = targetTeam
      ? getEligibleThrowbackEras(targetTeam as Parameters<typeof getEligibleThrowbackEras>[0]).find(
          (e) => e.yearStart === previewEra,
        )
      : undefined;
    if (chosen && targetTeam) {
      ownerOverrides[targetFranchiseId] = previewEra;
      throwbackPreview = {
        yearStart: previewEra,
        eraName: chosen.name,
        teamName: targetTeam.name,
        ownSave: targetFranchiseId === userFranchiseId,
      };
    }
  }

  configTeams = applyThrowbackOverrides(configTeams, true, ownerOverrides);
}

// Demo/sample mode. During the offseason MFL turns off the liveScoring feed, so
// the real fetch comes back with no matchups — in that case the page auto-falls
// back to a bundled replay of last season's final week (see live-scoring-sample.ts,
// flagged with a "Sample data" badge). This is what the nav link shows out of
// season; once the season starts and the feed returns matchups, real data wins.
// Overrides: ?demo=1 forces the sample year-round (validation), ?demo=0 forces
// the live path even when the feed is empty (debugging the offseason empty state).
const demoParam = Astro.url.searchParams.get('demo');
const demoDoubleheader = Astro.url.searchParams.get('dh') === '1';

let useDemo = demoParam === '1';
let data: Awaited<ReturnType<typeof assembleLiveScoringData>> | undefined;

if (!useDemo) {
  data = await assembleLiveScoringData({
    siteUrl: Astro.url,
    week,
    year,
    leagueId: league.leagueId,
    host: league.host,
    dataPath: league.dataPath,
    configTeams,
    userFranchiseId,
  });
  // Empty feed (no matchups) = offseason / feed off → show the sample replay,
  // unless the caller explicitly forced the live path with ?demo=0. Require the
  // fetch to have SUCCEEDED (`ok`): a failed live request also yields no
  // matchups, and we must not paper over an in-season outage with last season's
  // sample — that case falls through to the island's empty/error state.
  if (demoParam !== '0' && data.ok && data.matchups.length === 0) {
    useDemo = true;
  }
}

let islandProps: LiveScoringPageProps;
let nflGames: NflGame[] | undefined;

if (useDemo) {
  const sample = getLiveScoringSample({ doubleheader: demoDoubleheader });
  nflGames = sample.nflGames;
  islandProps = {
    week: sample.week,
    year,
    leagueId: league.leagueId,
    host: league.host,
    slug: league.slug,
    isLive: false, // don't poll — the live feed would overwrite the sample
    gameWindow: daily.gameWindow,
    userFranchiseId: userFranchiseId ?? '0001',
    matchups: sample.matchups,
    teams: buildTeamsMap(configTeams),
    playerMeta: sample.playerMeta,
    initialScores: sample.scores,
    initialRemaining: sample.remaining,
    initialPlayers: sample.players,
    initialYetToPlay: sample.playersYetToPlay,
    demo: true,
    initialNflGames: sample.nflGames,
    initialMoments: sample.moments,
  };
} else {
  // data is always assigned in the non-demo branch above.
  const liveData = data!;
  islandProps = {
    week,
    year,
    leagueId: league.leagueId,
    host: league.host,
    slug: league.slug,
    isLive,
    gameWindow: daily.gameWindow,
    userFranchiseId,
    matchups: liveData.matchups,
    teams: liveData.teams,
    playerMeta: liveData.playerMeta,
    initialScores: liveData.scores,
    initialRemaining: liveData.remaining,
    initialPlayers: liveData.players,
    initialYetToPlay: liveData.playersYetToPlay,
  };
}
---

<TheLeagueLayout title="Live Scoring">
  <div class="ls-page">
    {throwbackPreview && (
      <div class="ls-tb-preview" id="tb-preview-bar" data-year-start={throwbackPreview.yearStart}>
        <span class="ls-tb-preview__text">
          {throwbackPreview.ownSave ? (
            <>
              Previewing <strong>{throwbackPreview.eraName} ({throwbackPreview.yearStart})</strong> —
              this is how your team looks on Throwback Week. Nothing is saved yet.
            </>
          ) : (
            <>
              Commissioner preview: <strong>{throwbackPreview.teamName}</strong> as{' '}
              <strong>{throwbackPreview.eraName} ({throwbackPreview.yearStart})</strong>.
              View-only — only that team's owner can save a pick.
            </>
          )}
        </span>
        <span class="ls-tb-preview__actions">
          {throwbackPreview.ownSave && (
            <button class="ls-tb-preview__save" id="tb-preview-save" type="button">Save this era</button>
          )}
          <a class="ls-tb-preview__back" href="/theleague/throwback-settings">Back to eras</a>
        </span>
        <span class="ls-tb-preview__status" id="tb-preview-status" role="status" aria-live="polite"></span>
      </div>
    )}
    <LiveScoreboard client:load {...islandProps} />
    <div class="ls-page-strip">
      <NflGamesStrip client:visible week={islandProps.week} year={year}
                     isLive={useDemo ? false : isLive} demo={useDemo} initialGames={nflGames} />
    </div>
  </div>
</TheLeagueLayout>

<script>
  // Bound on astro:page-load (not module top-level) so the button still works
  // when the page is reached via a ClientRouter view transition — same lesson
  // as the throwback-settings picker.
  function initTbPreviewSave() {
    const bar = document.getElementById('tb-preview-bar');
    const btn = document.getElementById('tb-preview-save') as HTMLButtonElement | null;
    const status = document.getElementById('tb-preview-status');
    if (!bar || !btn || bar.dataset.tbwBound === '1') return;
    bar.dataset.tbwBound = '1';

    btn.addEventListener('click', async () => {
      const yearStart = Number(bar.dataset.yearStart);
      btn.disabled = true;
      if (status) status.textContent = 'Saving…';
      try {
        const res = await fetch('/api/throwback-preference', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ yearStart }),
        });
        const data = await res.json();
        if (data.success) {
          if (status) status.textContent = 'Saved — this is your Throwback Week look.';
        } else {
          btn.disabled = false;
          if (status) status.textContent = data.error || 'Failed to save.';
        }
      } catch {
        btn.disabled = false;
        if (status) status.textContent = 'Failed to save — check your connection.';
      }
    });
  }
  document.addEventListener('astro:page-load', initTbPreviewSave);
</script>

<style>
  .ls-page {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: var(--spacing-lg) var(--spacing-md) var(--spacing-3xl);
  }
  .ls-page-strip {
    margin-top: var(--spacing-2xl);
  }
  .ls-tb-preview {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-sm) var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-md, 8px);
    background: var(--content-bg);
  }
  .ls-tb-preview__text {
    flex: 1 1 260px;
    font-size: var(--font-size-sm);
  }
  .ls-tb-preview__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }
  .ls-tb-preview__save {
    padding: var(--spacing-xs, 0.4rem) var(--spacing-sm, 0.9rem);
    border: none;
    border-radius: var(--radius-md, 8px);
    background: var(--color-accent);
    color: var(--color-accent-contrast, #fff);
    font-weight: 600;
    font-size: var(--font-size-sm);
    cursor: pointer;
  }
  .ls-tb-preview__save:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .ls-tb-preview__back {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .ls-tb-preview__back:hover,
  .ls-tb-preview__back:focus-visible {
    text-decoration: underline;
  }
  .ls-tb-preview__status {
    flex-basis: 100%;
    font-size: var(--font-size-sm);
    color: var(--text-secondary, inherit);
  }
  .ls-tb-preview__status:empty {
    display: none;
  }
</style>
