<script>
  function setupDeadMoneyFilters() {
    const viewFilter = document.getElementById('view-filter') as HTMLSelectElement;
    const yearFilter = document.getElementById('year-filter') as HTMLSelectElement;
    const startersView = document.getElementById('jerry-jones-starters-view');
    const rosterView = document.getElementById('jerry-jones-roster-view');
    const osweilerView = document.getElementById('brock-osweiler-view');
    const positionSection = document.querySelector('.position-worst');
    const positionGroups = document.querySelectorAll('.position-group');
    const announcer = document.getElementById('filter-announcer');

    const positionMap: Record<string, string> = {
      'QB': 'Quarterback',
      'RB': 'Running Back',
      'WR': 'Wide Receiver',
      'TE': 'Tight End',
      'PK': 'Kicker',
      'Def': 'Defense/ST'
    };

    function announce(message: string) {
      if (announcer) {
        announcer.textContent = message;
        setTimeout(() => { announcer.textContent = ''; }, 1000);
      }
    }

    function applyFilters() {
      if (!viewFilter || !yearFilter) return;

      const selectedView = viewFilter.value;
      const selectedYear = yearFilter.value;

      // Hide all views first
      if (startersView) startersView.style.display = 'none';
      if (rosterView) rosterView.style.display = 'none';
      if (osweilerView) osweilerView.style.display = 'none';
      if (positionSection) (positionSection as HTMLElement).style.display = 'none';

      if (selectedView === 'jerry_jones_starters') {
        if (startersView) startersView.style.display = '';
        yearFilter.disabled = false;
        startersView?.querySelectorAll('.season-rankings').forEach(el => {
          (el as HTMLElement).style.display = (el as HTMLElement).dataset.year === selectedYear ? '' : 'none';
        });
        announce(`Showing ${selectedYear} Jerry Jones Award, Starting Lineup`);

      } else if (selectedView === 'jerry_jones_roster') {
        if (rosterView) rosterView.style.display = '';
        yearFilter.disabled = false;
        rosterView?.querySelectorAll('.season-rankings').forEach(el => {
          (el as HTMLElement).style.display = (el as HTMLElement).dataset.year === selectedYear ? '' : 'none';
        });
        announce(`Showing ${selectedYear} Jerry Jones Award, Full Roster`);

      } else if (selectedView === 'brock_osweiler') {
        if (osweilerView) osweilerView.style.display = '';
        yearFilter.disabled = true;
        announce('Showing All-Time Brock Osweiler Awards');

      } else {
        // Position-specific view
        if (positionSection) (positionSection as HTMLElement).style.display = '';
        yearFilter.disabled = true;

        const selectedLabel = positionMap[selectedView];
        positionGroups.forEach(group => {
          const heading = group.querySelector('h3');
          const label = heading?.textContent?.trim();
          (group as HTMLElement).style.display = label === selectedLabel ? '' : 'none';
        });
        announce(`Showing Position Worst: ${selectedLabel}`);
      }
    }

    viewFilter?.addEventListener('change', applyFilters);
    yearFilter?.addEventListener('change', applyFilters);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupDeadMoneyFilters);
  } else {
    setupDeadMoneyFilters();
  }

  document.addEventListener('astro:after-swap', setupDeadMoneyFilters);
</script>
