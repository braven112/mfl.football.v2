---
import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../components/theleague/Breadcrumbs.astro';
import leagueConfig from '../../data/theleague.config.json';
import { DEFAULT_HEADSHOT_URL, getPlayerImageUrl } from '../../constants/roster-constants';
import { getCurrentSeasonYear } from '../../utils/league-year';
import { getTeamIdentityForYear, chooseTeamName } from '../../utils/team-names';
import { normalizeTeamCode } from '../../utils/nfl-logo';

// Minimum salary to qualify for individual Brock Osweiler / Position Worst awards.
// Filters out minimum-contract players — we want big-money busts, not dart throws.
const INDIVIDUAL_AWARD_MIN_SALARY = 1_500_000;

const playerModules = import.meta.glob(
  '../../data/mfl-player-salaries-*.json',
  { eager: true }
);

const getModuleData = (mod) =>
  mod && typeof mod === 'object' && 'default' in mod ? mod.default : mod;

const extractSeason = (filepath) => {
  const match = filepath.match(/(\d{4})\.json$/);
  return match ? match[1] : null;
};

const positionLabels = [
  { key: 'QB', label: 'Quarterback' },
  { key: 'RB', label: 'Running Back' },
  { key: 'WR', label: 'Wide Receiver' },
  { key: 'TE', label: 'Tight End' },
  { key: 'PK', label: 'Kicker' },
  { key: 'Def', label: 'Defense/ST' },
];
const positionLabelMap = new Map(
  positionLabels.map(({ key, label }) => [key, label])
);

// Year-aware franchise lookup — resolves historical names/icons per season
function getFranchiseForYear(franchiseId: string, season: string) {
  const team = leagueConfig.teams.find(t => t.franchiseId === franchiseId);
  if (!team) return null;
  const identity = getTeamIdentityForYear(team as any, Number(season));
  return {
    name: chooseTeamName({ fullName: identity.name, nameMedium: identity.nameMedium }),
    icon: identity.icon,
  };
}

// --- Brock Osweiler Award: worst individual player per season ---
const overallWorst = [];
const positionBuckets = new Map();
for (const { key } of positionLabels) {
  positionBuckets.set(key, []);
}

// --- Jerry Jones Award: worst team efficiency per season ---
const jerryJonesStartersBySeason = new Map();
const jerryJonesRosterBySeason = new Map();

// --- Zero-Point Hall of Shame ---
const zeroPointPlayersBySeason = new Map();

for (const [path, mod] of Object.entries(playerModules)) {
  const season = extractSeason(path);
  if (!season) continue;

  const data = getModuleData(mod);
  const players = data?.players ?? [];

  // All rostered players with salary
  const allRostered = players
    .filter(p => (Number(p.salary) || 0) > 0 && p.status === 'ROSTER')
    .map(p => ({
      season,
      id: p.id,
      name: p.name,
      position: p.position,
      salary: Number(p.salary) || 0,
      points: Number(p.points) || 0,
      efficiency: (Number(p.points) || 0) / (Number(p.salary) || 1),
      franchiseId: p.franchiseId,
      team: p.team ?? '',
      headshot: p.headshot ?? getPlayerImageUrl(p.id),
      contractYears: Number.parseInt(p.contractYear ?? p.contractYearRemaining ?? '0', 10) || 0,
      positionLabel: positionLabelMap.get(p.position) ?? p.position,
    }));

  // Zero-point players (salary > 0, points === 0)
  const zeroPts = allRostered.filter(p => p.points === 0);
  if (zeroPts.length) {
    zeroPts.sort((a, b) => b.salary - a.salary);
    zeroPointPlayersBySeason.set(season, zeroPts);
  }

  // Scored players with meaningful contracts for individual awards
  const scorers = allRostered.filter(p => p.points > 0 && p.salary >= INDIVIDUAL_AWARD_MIN_SALARY);
  if (!scorers.length) continue;

  // Sort ascending by efficiency (worst first)
  scorers.sort((a, b) => a.efficiency - b.efficiency);
  const worst = scorers[0];
  if (worst) {
    overallWorst.push({ ...worst });
  }

  // Worst per position
  const positionWorst = new Map();
  scorers.forEach((candidate) => {
    const existing = positionWorst.get(candidate.position);
    if (!existing || candidate.efficiency < existing.efficiency) {
      positionWorst.set(candidate.position, candidate);
    }
  });
  positionWorst.forEach((value, posKey) => {
    const bucket = positionBuckets.get(posKey);
    if (bucket) bucket.push({ ...value });
  });

  // --- Jerry Jones: build team lineups ---
  const byFranchise = new Map();
  allRostered.forEach(p => {
    if (!byFranchise.has(p.franchiseId)) byFranchise.set(p.franchiseId, []);
    byFranchise.get(p.franchiseId).push(p);
  });

  const starterRankings = [];
  const rosterRankings = [];

  for (const [franchiseId, roster] of byFranchise) {
    const franchise = getFranchiseForYear(franchiseId, season);
    const scoringRoster = roster.filter(p => p.points > 0);

    // Full roster stats
    const rosterSalary = scoringRoster.reduce((s, p) => s + p.salary, 0);
    const rosterPoints = scoringRoster.reduce((s, p) => s + p.points, 0);
    const zeroPlayers = roster.filter(p => p.points === 0);
    const deadMoney = zeroPlayers.reduce((s, p) => s + p.salary, 0);

    if (rosterPoints > 0) {
      rosterRankings.push({
        season,
        franchiseId,
        name: franchise?.name ?? franchiseId,
        icon: franchise?.icon,
        totalSalary: roster.reduce((s, p) => s + p.salary, 0),
        totalPoints: rosterPoints,
        costPerPoint: roster.reduce((s, p) => s + p.salary, 0) / rosterPoints,
        rosterSize: roster.length,
        zeroCount: zeroPlayers.length,
        deadMoney,
      });
    }

    // Build optimal starting lineup (best possible points)
    const qbs = roster.filter(p => p.position === 'QB').sort((a, b) => b.points - a.points);
    const pks = roster.filter(p => p.position === 'PK').sort((a, b) => b.points - a.points);
    const defs = roster.filter(p => ['Def', 'DEF'].includes(p.position)).sort((a, b) => b.points - a.points);
    const rbs = roster.filter(p => p.position === 'RB').sort((a, b) => b.points - a.points);
    const wrs = roster.filter(p => p.position === 'WR').sort((a, b) => b.points - a.points);
    const tes = roster.filter(p => p.position === 'TE').sort((a, b) => b.points - a.points);

    const lineup = [];
    if (qbs[0]) lineup.push({ ...qbs[0], slot: 'QB' });
    if (pks[0]) lineup.push({ ...pks[0], slot: 'PK' });
    if (defs[0]) lineup.push({ ...defs[0], slot: 'DEF' });

    const mandatoryRB = rbs[0];
    const mandatoryWR = wrs[0];
    const mandatoryTE = tes[0];
    if (mandatoryRB) lineup.push({ ...mandatoryRB, slot: 'RB' });
    if (mandatoryWR) lineup.push({ ...mandatoryWR, slot: 'WR' });
    if (mandatoryTE) lineup.push({ ...mandatoryTE, slot: 'TE' });

    const starterNames = new Set([mandatoryRB?.id, mandatoryWR?.id, mandatoryTE?.id].filter(Boolean));
    const flexPool = [...rbs.slice(1), ...wrs.slice(1), ...tes.slice(1)]
      .filter(p => !starterNames.has(p.id))
      .sort((a, b) => b.points - a.points);
    flexPool.slice(0, 3).forEach(p => lineup.push({ ...p, slot: 'FLEX' }));

    const lineupSalary = lineup.reduce((s, p) => s + p.salary, 0);
    const lineupPoints = lineup.reduce((s, p) => s + p.points, 0);

    if (lineupPoints > 0) {
      starterRankings.push({
        season,
        franchiseId,
        name: franchise?.name ?? franchiseId,
        icon: franchise?.icon,
        totalSalary: lineupSalary,
        totalPoints: lineupPoints,
        costPerPoint: lineupSalary / lineupPoints,
        lineup,
        zeroCount: zeroPlayers.length,
        deadMoney,
      });
    }
  }

  // Sort worst first (highest cost per point)
  starterRankings.sort((a, b) => b.costPerPoint - a.costPerPoint);
  rosterRankings.sort((a, b) => b.costPerPoint - a.costPerPoint);

  jerryJonesStartersBySeason.set(season, starterRankings);
  jerryJonesRosterBySeason.set(season, rosterRankings);
}

// Sort overall worst by season (newest first)
overallWorst.sort((a, b) => Number(b.season) - Number(a.season));

// Sort position buckets by season (newest first)
positionBuckets.forEach((bucket) => {
  bucket.sort((a, b) => Number(b.season) - Number(a.season));
});

// Create set of overall worst player IDs for badge display
const overallWorstIds = new Set(overallWorst.map(p => `${p.id}-${p.season}`));

// Available years
const availableYears = Array.from(jerryJonesStartersBySeason.keys())
  .map(Number)
  .sort((a, b) => b - a);
const mostRecentYear = availableYears[0]?.toString() ?? getCurrentSeasonYear().toString();

// Formatting helpers
const currencyFormatter = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
});
const formatCurrency = (value: number) => {
  if (!Number.isFinite(value)) return '$0';
  return currencyFormatter.format(Math.round(value));
};
const formatContract = (salary: number, years: number) => {
  const base = formatCurrency(salary);
  const normalizedYears = Number.isFinite(years) ? Number(years) : 0;
  return normalizedYears > 1 ? `${base} x ${normalizedYears}` : base;
};
const formatPoints = (value: number) =>
  Number.isFinite(value) ? value.toFixed(1) : '0.0';
const getNflLogo = (team: string) => {
  // Strip non-alpha chars (e.g., "FA*" → "FA") then normalize
  const cleaned = (team ?? '').replace(/[^A-Za-z]/g, '');
  const code = normalizeTeamCode(cleaned);
  if (!code || code === 'FA') return null;
  return `/assets/nfl-logos/${code}.svg`;
};
const formatCostPerPoint = (costPerPoint: number) => {
  if (!Number.isFinite(costPerPoint)) return '$∞';
  if (costPerPoint >= 1_000_000) return formatCurrency(costPerPoint / 1_000_000) + 'M / pt';
  if (costPerPoint >= 1_000) return formatCurrency(costPerPoint / 1_000) + 'K / pt';
  return formatCurrency(costPerPoint) + ' / pt';
};
---

<TheLeagueLayout title="Dead Money Awards">
  <div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" id="filter-announcer"></div>
  <section class="dead-money">
    <header class="page-header">
      <Breadcrumbs items={[
        { label: 'The League', href: '/theleague' },
        { label: 'Stats & Reports', href: '/theleague/stats' },
        { label: 'Dead Money Awards' },
      ]} />
      <h1>The Dead Money Awards</h1>
      <p class="page-subtitle">
        Celebrating the league's finest examples of financial mismanagement.
      </p>
      <div class="award-descriptions">
        <div class="award-desc">
          <img src="/assets/theleague/awards/jerry-jones.jpg" alt="Jerry Jones" class="award-avatar" />
          <span><strong>The Jerry Jones Award</strong> — Honors the GM who spent the most for the least.</span>
        </div>
        <div class="award-desc">
          <img src="/assets/theleague/awards/brock-osweiler.jpg" alt="Brock Osweiler" class="award-avatar" />
          <span><strong>The Brock Osweiler Award</strong> — Goes to the player (min $1.5M salary) who burned the most salary per point scored.</span>
        </div>
      </div>
      <a href="/theleague/mvp" class="cross-link">
        Looking for the winners? &rarr; GM MVP Awards
      </a>
    </header>

    <div class="filters">
      <div class="filter-group">
        <label for="view-filter" class="filter-label">View</label>
        <select id="view-filter" class="filter-select">
          <option value="jerry_jones_starters">Jerry Jones Award (Starting Lineup)</option>
          <option value="jerry_jones_roster">Jerry Jones Award (Full Roster)</option>
          <option value="brock_osweiler">All-Time Brock Osweiler Awards</option>
          {positionLabels.map(({ key, label }) => (
            <option value={key}>{label}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label for="year-filter" class="filter-label">Year</label>
        <select id="year-filter" class="filter-select">
          {availableYears.map(year => (
            <option value={year} selected={year.toString() === mostRecentYear}>
              {year}
            </option>
          ))}
        </select>
      </div>
    </div>

    <!-- Jerry Jones Award: Starting Lineup View -->
    <div id="jerry-jones-starters-view">
      {availableYears.map(year => {
        const rankings = jerryJonesStartersBySeason.get(year.toString()) ?? [];
        return (
          <div class="season-rankings" data-year={year} style={year.toString() === mostRecentYear ? '' : 'display: none;'}>
            <h2 class="section-title"><img src="/assets/theleague/awards/jerry-jones.jpg" alt="" class="section-avatar" /> {year} Jerry Jones Award <span class="title-sub">Starting Lineup</span></h2>
            <div class="team-rankings">
              {rankings.map((team, idx) => {
                const isWinner = idx === 0;
                return (
                  <article class={`team-rank-card ${isWinner ? 'team-rank-winner' : ''}`}>
                    <div class="rank-number">{idx + 1}</div>
                    <div class="team-rank-header">
                      <div class="team-rank-identity">
                        {team.icon && <img src={team.icon} alt={team.name} class="franchise-icon" loading="lazy" />}
                        <div>
                          <h3 class="team-rank-name">
                            {team.name}
                            {isWinner && <span class="dead-money-badge">Jerry Jones Award</span>}
                          </h3>
                          <div class="team-rank-stats">
                            <span class="stat">Salary: <strong>{formatCurrency(team.totalSalary)}</strong></span>
                            <span class="stat">Points: <strong>{formatPoints(team.totalPoints)}</strong></span>
                            <span class="stat cost-stat">Cost/Pt: <strong>{formatCostPerPoint(team.costPerPoint)}</strong></span>
                            {team.deadMoney > 0 && (
                              <span class="stat dead-stat">Dead Money: <strong>{formatCurrency(team.deadMoney)}</strong> ({team.zeroCount} player{team.zeroCount !== 1 ? 's' : ''})</span>
                            )}
                          </div>
                        </div>
                      </div>
                    {team.lineup && (() => {
                      const col1 = team.lineup.filter(p => ['QB', 'RB', 'WR'].includes(p.slot));
                      const col2 = team.lineup.filter(p => ['TE', 'PK', 'DEF'].includes(p.slot));
                      const col3 = team.lineup.filter(p => p.slot === 'FLEX');
                      const renderPlayer = (player) => {
                        const nflLogo = player.team ? getNflLogo(player.team) : null;
                        return (
                          <div class="lineup-player">
                            <span class="lineup-slot">{player.slot}</span>
                            <img
                              src={player.headshot ?? DEFAULT_HEADSHOT_URL}
                              alt={player.name}
                              class="lineup-headshot"
                              loading="lazy"
                              onerror={`this.onerror=null;this.src='${DEFAULT_HEADSHOT_URL}';`}
                            />
                            <div class="lineup-info">
                              <span class="lineup-name">{player.name}</span>
                              <span class="lineup-meta">
                                {nflLogo && <img src={nflLogo} alt={player.team} class="lineup-nfl-icon" loading="lazy" />}
                                {formatCurrency(player.salary)} &middot; {formatPoints(player.points)} pts
                              </span>
                            </div>
                          </div>
                        );
                      };
                      return (
                        <div class="lineup-columns">
                          <div class="lineup-col">{col1.map(renderPlayer)}</div>
                          <div class="lineup-col">{col2.map(renderPlayer)}</div>
                          <div class="lineup-col">{col3.map(renderPlayer)}</div>
                        </div>
                      );
                    })()}
                  </div>
                  </article>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Jerry Jones Award: Full Roster View -->
    <div id="jerry-jones-roster-view" style="display: none;">
      {availableYears.map(year => {
        const rankings = jerryJonesRosterBySeason.get(year.toString()) ?? [];
        return (
          <div class="season-rankings" data-year={year} style={year.toString() === mostRecentYear ? '' : 'display: none;'}>
            <h2 class="section-title"><img src="/assets/theleague/awards/jerry-jones.jpg" alt="" class="section-avatar" /> {year} Jerry Jones Award <span class="title-sub">Full Roster</span></h2>
            <div class="team-rankings">
              {rankings.map((team, idx) => {
                const isWinner = idx === 0;
                return (
                  <article class={`team-rank-card ${isWinner ? 'team-rank-winner' : ''}`}>
                    <div class="rank-number">{idx + 1}</div>
                    <div class="team-rank-header">
                      <div class="team-rank-identity">
                        {team.icon && <img src={team.icon} alt={team.name} class="franchise-icon" loading="lazy" />}
                        <div>
                          <h3 class="team-rank-name">
                            {team.name}
                            {isWinner && <span class="dead-money-badge">Jerry Jones Award</span>}
                          </h3>
                          <div class="team-rank-stats">
                            <span class="stat">Roster: <strong>{team.rosterSize} players</strong></span>
                            <span class="stat">Salary: <strong>{formatCurrency(team.totalSalary)}</strong></span>
                            <span class="stat">Points: <strong>{formatPoints(team.totalPoints)}</strong></span>
                            <span class="stat cost-stat">Cost/Pt: <strong>{formatCostPerPoint(team.costPerPoint)}</strong></span>
                            {team.deadMoney > 0 && (
                              <span class="stat dead-stat">Dead Money: <strong>{formatCurrency(team.deadMoney)}</strong> ({team.zeroCount} player{team.zeroCount !== 1 ? 's' : ''})</span>
                            )}
                          </div>
                        </div>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <!-- All-Time Brock Osweiler Awards -->
    <section id="brock-osweiler-view" style="display: none;" aria-labelledby="brock-osweiler-heading">
      <h2 id="brock-osweiler-heading" class="section-title"><img src="/assets/theleague/awards/brock-osweiler.jpg" alt="" class="section-avatar" /> All-Time Brock Osweiler Awards</h2>
      <div class="mvp-grid" id="brock-osweiler-grid">
        {overallWorst.length ? (
          overallWorst.map((player) => {
            const franchise = player.franchiseId
              ? getFranchiseForYear(player.franchiseId, player.season)
              : null;
            const nflLogo = player.team ? getNflLogo(player.team) : null;
            return (
              <article class="dm-card" data-year={player.season} data-position={player.position}>
                <header>
                  <div class="card-header-top">
                    <div class="season-badge-row">
                      <p class="dm-season">{player.season}</p>
                      <span class="dead-money-badge">Brock Osweiler Award</span>
                    </div>
                    {franchise?.icon && (
                      <img src={franchise.icon} alt={franchise?.name ?? 'Franchise'} class="franchise-icon" loading="lazy" />
                    )}
                  </div>
                  <div class="player-info">
                    <img
                      src={player.headshot ?? DEFAULT_HEADSHOT_URL}
                      alt={`${player.name} headshot`}
                      class="player-headshot"
                      loading="lazy"
                      onerror={`this.onerror=null;this.src='${DEFAULT_HEADSHOT_URL}';`}
                    />
                    <div>
                      <h3 class="dm-card-name">{player.name}</h3>
                      <p class="dm-meta">
                        {nflLogo && <img src={nflLogo} alt={`${player.team ?? 'FA'} logo`} class="nfl-icon" loading="lazy" />}
                        <span>{player.position}</span>
                      </p>
                    </div>
                  </div>
                </header>
                <dl>
                  <div><dt>Points</dt><dd>{formatPoints(player.points)}</dd></div>
                  <div><dt>Contract</dt><dd>{formatContract(player.salary, player.contractYears)}</dd></div>
                  <div><dt>Cost / Point</dt><dd class="cost-highlight">{formatCostPerPoint(1 / player.efficiency)}</dd></div>
                </dl>
              </article>
            );
          })
        ) : (
          <p>No data available yet.</p>
        )}
      </div>
    </section>

    <!-- Position Worst -->
    <section class="position-worst" style="display: none;" aria-labelledby="position-worst-heading">
      <h2 id="position-worst-heading">Position Worst</h2>
      {positionLabels.map(({ key, label }) => {
        const list = positionBuckets.get(key) ?? [];
        return (
          <div class="position-group">
            <h3>{label}</h3>
            <div class="mvp-grid">
              {list.length ? (
                list.map((player) => {
                  const franchise = player.franchiseId
                    ? getFranchiseForYear(player.franchiseId, player.season)
                    : null;
                  const nflLogo = player.team ? getNflLogo(player.team) : null;
                  const isOverallWorst = overallWorstIds.has(`${player.id}-${player.season}`);
                  return (
                    <article class="dm-card" data-year={player.season} data-position={player.position}>
                      <header>
                        <div class="card-header-top">
                          <div class="season-badge-row">
                            <p class="dm-season">{player.season}</p>
                            {isOverallWorst && <span class="dead-money-badge">Brock Osweiler Award</span>}
                          </div>
                          {franchise?.icon && (
                            <img src={franchise.icon} alt={franchise?.name ?? 'Franchise'} class="franchise-icon" loading="lazy" />
                          )}
                        </div>
                        <div class="player-info">
                          <img
                            src={player.headshot ?? DEFAULT_HEADSHOT_URL}
                            alt={`${player.name} headshot`}
                            class="player-headshot"
                            loading="lazy"
                            onerror={`this.onerror=null;this.src='${DEFAULT_HEADSHOT_URL}';`}
                          />
                          <div>
                            <h4 class="dm-card-name">{player.name}</h4>
                            <p class="dm-meta">
                              {nflLogo && <img src={nflLogo} alt={`${player.team ?? 'FA'} logo`} class="nfl-icon" loading="lazy" />}
                              <span>{player.position}</span>
                            </p>
                          </div>
                        </div>
                      </header>
                      <dl>
                        <div><dt>Points</dt><dd>{formatPoints(player.points)}</dd></div>
                        <div><dt>Contract</dt><dd>{formatContract(player.salary, player.contractYears)}</dd></div>
                        <div><dt>Cost / Point</dt><dd class="cost-highlight">{formatCostPerPoint(1 / player.efficiency)}</dd></div>
                      </dl>
                    </article>
                  );
                })
              ) : (
                <p class="empty-state">No data yet.</p>
              )}
            </div>
          </div>
        );
      })}
    </section>

    <!-- Zero-Point Hall of Shame -->
    <section class="hall-of-shame" aria-labelledby="hall-of-shame-heading">
      <h2 id="hall-of-shame-heading" class="section-title shame-title">Zero-Point Hall of Shame</h2>
      <p class="shame-subtitle">Rostered players who collected a paycheck and scored exactly zero points. Money well spent.</p>
      {availableYears.map(year => {
        const zeroes = zeroPointPlayersBySeason.get(year.toString());
        if (!zeroes?.length) return null;
        const totalWasted = zeroes.reduce((s, p) => s + p.salary, 0);
        return (
          <div class="shame-season">
            <h3 class="shame-season-title">
              {year}
              <span class="shame-season-summary">{zeroes.length} player{zeroes.length !== 1 ? 's' : ''} &middot; {formatCurrency(totalWasted)} wasted</span>
            </h3>
            <div class="shame-grid">
              {zeroes.map(player => {
                const franchise = getFranchiseForYear(player.franchiseId, player.season);
                const nflLogo = player.team ? getNflLogo(player.team) : null;
                return (
                  <div class="shame-card">
                    <div class="shame-player-info">
                      <img
                        src={player.headshot ?? DEFAULT_HEADSHOT_URL}
                        alt={player.name}
                        class="shame-headshot"
                        loading="lazy"
                        onerror={`this.onerror=null;this.src='${DEFAULT_HEADSHOT_URL}';`}
                      />
                      <div>
                        <span class="shame-name">{player.name}</span>
                        <span class="shame-meta">
                          {nflLogo && <img src={nflLogo} alt={player.team} class="shame-nfl-icon" loading="lazy" />}
                          {player.position}
                        </span>
                      </div>
                    </div>
                    <div class="shame-details">
                      <span class="shame-salary">{formatCurrency(player.salary)}</span>
                      <span class="shame-team">{franchise?.name ?? 'Unknown'}</span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>
  </section>
</TheLeagueLayout>

