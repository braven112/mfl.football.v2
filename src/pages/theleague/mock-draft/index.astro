---
/**
 * Mock Draft Lobby
 * Create or join a mock draft session. Lists active and recent sessions.
 * Auth-gated: only authenticated owners can create/join.
 */

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import { getAuthUser } from '../../../utils/auth';
import { getCurrentLeagueYear } from '../../../utils/league-year';
import leagueConfigData from '../../../data/theleague.config.json';

export const prerender = false;

const user = getAuthUser(Astro.request);
const leagueYear = getCurrentLeagueYear();
const partyHost = import.meta.env.PUBLIC_PARTYKIT_HOST || '';

// Build team lookup for display
const teamMap = new Map<string, { name: string; icon: string }>();
for (const team of leagueConfigData.teams ?? []) {
  teamMap.set(team.franchiseId, {
    name: (team as any).nameMedium || team.name,
    icon: (team as any).icon || '',
  });
}
const teamMapJson = JSON.stringify(Object.fromEntries(teamMap));

// Ordered franchise list for the Board Settings per-team overrides
const franchiseList = (leagueConfigData.teams ?? []).map((t: any) => ({
  franchiseId: t.franchiseId,
  name: t.nameMedium || t.name,
}));
const franchiseListJson = JSON.stringify(franchiseList);

// Source catalog — keep in sync with MockRankingSource in src/types/draft-room.ts
const rankingSources = [
  { value: 'mfl-rookie', label: 'MFL Rookie ADP' },
  { value: 'mfl-dynasty', label: 'MFL Dynasty ADP' },
  { value: 'sleeper', label: 'Sleeper' },
  { value: 'ktc', label: 'KeepTradeCut' },
  { value: 'fbg', label: 'FBG Rookies' },
  { value: 'random', label: 'Chaos (random)' },
];
const rankingSourcesJson = JSON.stringify(rankingSources);
---

<TheLeagueLayout title="Mock Draft | The League">
  <div class="mock-lobby">
    <!-- Header -->
    <header class="mock-lobby__header">
      <h1 class="mock-lobby__title">Mock Draft</h1>
      <p class="mock-lobby__subtitle">
        Practice your {leagueYear} rookie draft strategy before the real thing.
      </p>
    </header>

    {!user ? (
      <div class="mock-lobby__auth-wall">
        <p>Sign in to create or join a mock draft.</p>
        <a href="/theleague/login" class="mock-lobby__signin-btn">Sign In</a>
      </div>
    ) : (
      <>
        <!-- Create section -->
        <section class="mock-lobby__create">
          <div class="mock-lobby__section-header">
            <h2 class="mock-lobby__section-header-title">Start a Mock Draft</h2>
            <p class="mock-lobby__section-header-sub">Configure and launch a new session</p>
          </div>

          <div class="mock-lobby__create-form" id="create-form">
            <div class="mock-lobby__form-row">
              <label class="mock-lobby__label">Timer per pick</label>
              <div class="mock-lobby__timer-chips" id="timer-chips">
                <button class="mock-lobby__chip" data-value="60">1 min</button>
                <button class="mock-lobby__chip mock-lobby__chip--active" data-value="120">2 min</button>
                <button class="mock-lobby__chip" data-value="300">5 min</button>
              </div>
            </div>

            <div class="mock-lobby__form-row">
              <label class="mock-lobby__label">Rounds</label>
              <div class="mock-lobby__timer-chips" id="round-chips">
                <button class="mock-lobby__chip" data-value="1">1</button>
                <button class="mock-lobby__chip" data-value="2">2</button>
                <button class="mock-lobby__chip mock-lobby__chip--active" data-value="3">3</button>
              </div>
            </div>

            <div class="mock-lobby__form-row">
              <label class="mock-lobby__label">Draft order</label>
              <div class="mock-lobby__timer-chips" id="order-chips">
                <button class="mock-lobby__chip mock-lobby__chip--active" data-value="real">Real order</button>
                <button class="mock-lobby__chip" data-value="random">Randomized</button>
              </div>
            </div>

            <!-- Board Settings: which rankings AI teams draft from -->
            <div class="mock-lobby__board">
              <div class="mock-lobby__board-head">
                <h3 class="mock-lobby__board-title">Board Settings</h3>
                <p class="mock-lobby__board-hint">How AI opponents draft</p>
              </div>

              <div class="mock-lobby__form-row">
                <label class="mock-lobby__sub-label" for="default-source-select">Default board</label>
                <select class="mock-lobby__select" id="default-source-select"></select>
              </div>

              <div class="mock-lobby__form-row">
                <span class="mock-lobby__sub-label">Presets</span>
                <div class="mock-lobby__presets">
                  <button type="button" class="mock-lobby__chip" data-preset="uniform">All MFL</button>
                  <button type="button" class="mock-lobby__chip" data-preset="mixed">Mixed boards</button>
                  <button type="button" class="mock-lobby__chip" data-preset="chaos">Chaos mode</button>
                </div>
              </div>

              <button type="button" class="mock-lobby__disclosure" id="per-team-toggle" aria-expanded="false" aria-controls="per-team-panel">
                <span class="mock-lobby__disclosure-caret" aria-hidden="true">▸</span>
                Customize per team
              </button>
              <div class="mock-lobby__per-team" id="per-team-panel" hidden></div>
            </div>

            <button class="mock-lobby__start-btn" id="start-btn">
              Start Mock Draft
            </button>
            <p class="mock-lobby__error" id="create-error" aria-live="polite"></p>
          </div>
        </section>

        <!-- Active sessions -->
        <section class="mock-lobby__sessions">
          <div class="mock-lobby__section-header">
            <h2 class="mock-lobby__section-header-title">Active Sessions</h2>
            <p class="mock-lobby__section-header-sub">Join an in-progress mock draft</p>
          </div>

          <div id="sessions-list" class="mock-lobby__sessions-list">
            <p class="mock-lobby__loading">Loading sessions…</p>
          </div>
        </section>
      </>
    )}
  </div>
</TheLeagueLayout>

<script define:vars={{ userFranchiseId: user?.franchiseId, teamMapJson, franchiseListJson, rankingSourcesJson, partyHost }}>
  const teamMap = JSON.parse(teamMapJson);
  const franchiseList = JSON.parse(franchiseListJson);
  const rankingSources = JSON.parse(rankingSourcesJson);

  function getTeamName(franchiseId) {
    return teamMap[franchiseId]?.name || `Team ${franchiseId}`;
  }

  // ── Chip selection ──
  function initChipGroup(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.addEventListener('click', (e) => {
      const btn = e.target.closest('.mock-lobby__chip');
      if (!btn) return;
      container.querySelectorAll('.mock-lobby__chip').forEach((c) =>
        c.classList.remove('mock-lobby__chip--active'),
      );
      btn.classList.add('mock-lobby__chip--active');
    });
  }

  function getChipValue(containerId) {
    const container = document.getElementById(containerId);
    if (!container) return null;
    const active = container.querySelector('.mock-lobby__chip--active');
    return active?.dataset.value ?? null;
  }

  initChipGroup('timer-chips');
  initChipGroup('round-chips');
  initChipGroup('order-chips');

  // ── Board settings ──
  // Per-team assignments keyed by franchiseId. Empty = use default.
  const rankingAssignments = {};

  function fillSelect(sel, selected) {
    sel.replaceChildren();
    for (const s of rankingSources) {
      const opt = document.createElement('option');
      opt.value = s.value;
      opt.textContent = s.label;
      if (s.value === selected) opt.selected = true;
      sel.appendChild(opt);
    }
  }

  const defaultSourceSelect = document.getElementById('default-source-select');
  if (defaultSourceSelect) fillSelect(defaultSourceSelect, 'mfl-rookie');

  // Per-team override panel — one row per franchise
  function renderPerTeam() {
    const panel = document.getElementById('per-team-panel');
    if (!panel) return;
    panel.replaceChildren();
    for (const t of franchiseList) {
      const row = document.createElement('div');
      row.className = 'mock-lobby__per-team-row';

      const label = document.createElement('span');
      label.className = 'mock-lobby__per-team-name';
      label.textContent = t.name;

      const sel = document.createElement('select');
      sel.className = 'mock-lobby__select mock-lobby__select--compact';
      sel.dataset.franchise = t.franchiseId;
      const current = rankingAssignments[t.franchiseId];
      // "__default" means: inherit the default — no override recorded.
      const optDefault = document.createElement('option');
      optDefault.value = '__default';
      optDefault.textContent = 'Default';
      sel.appendChild(optDefault);
      for (const s of rankingSources) {
        const opt = document.createElement('option');
        opt.value = s.value;
        opt.textContent = s.label;
        sel.appendChild(opt);
      }
      sel.value = current ?? '__default';
      sel.addEventListener('change', () => {
        if (sel.value === '__default') {
          delete rankingAssignments[t.franchiseId];
        } else {
          rankingAssignments[t.franchiseId] = sel.value;
        }
      });

      row.append(label, sel);
      panel.appendChild(row);
    }
  }
  renderPerTeam();

  // Expand/collapse the per-team panel
  const perTeamToggle = document.getElementById('per-team-toggle');
  perTeamToggle?.addEventListener('click', () => {
    const panel = document.getElementById('per-team-panel');
    if (!panel) return;
    const expanded = perTeamToggle.getAttribute('aria-expanded') === 'true';
    const next = !expanded;
    perTeamToggle.setAttribute('aria-expanded', String(next));
    perTeamToggle.classList.toggle('mock-lobby__disclosure--open', next);
    panel.hidden = !next;
  });

  // Preset buttons — overwrite assignments
  document.querySelectorAll('[data-preset]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const preset = btn.dataset.preset;
      if (preset === 'uniform') {
        // Clear overrides; default handles everyone.
        for (const k of Object.keys(rankingAssignments)) delete rankingAssignments[k];
        if (defaultSourceSelect) defaultSourceSelect.value = 'mfl-rookie';
      } else if (preset === 'mixed') {
        // Cycle through non-random sources across teams so no two adjacent
        // picks come from the same board.
        const mix = rankingSources.filter((s) => s.value !== 'random').map((s) => s.value);
        franchiseList.forEach((t, i) => {
          rankingAssignments[t.franchiseId] = mix[i % mix.length];
        });
      } else if (preset === 'chaos') {
        // Random source per team (may include 'random' which is a shuffled pool)
        franchiseList.forEach((t) => {
          const pick = rankingSources[Math.floor(Math.random() * rankingSources.length)];
          rankingAssignments[t.franchiseId] = pick.value;
        });
      }
      renderPerTeam();
    });
  });

  // ── Create session ──
  const startBtn = document.getElementById('start-btn');
  const createError = document.getElementById('create-error');

  if (startBtn) {
    startBtn.addEventListener('click', async () => {
      startBtn.disabled = true;
      startBtn.textContent = 'Creating…';
      if (createError) createError.textContent = '';

      const timerSeconds = parseInt(getChipValue('timer-chips') || '120');
      const totalRounds = parseInt(getChipValue('round-chips') || '3');
      const useRealOrder = getChipValue('order-chips') === 'real';
      const defaultRankingSource = defaultSourceSelect?.value || 'mfl-rookie';

      try {
        const res = await fetch('/api/mock-draft/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            timerSeconds,
            totalRounds,
            useRealOrder,
            defaultRankingSource,
            rankingAssignments,
          }),
        });

        const data = await res.json();

        if (data.success && data.sessionId) {
          window.location.href = `/theleague/mock-draft/${data.sessionId}`;
          return;
        }

        if (createError) createError.textContent = data.message || 'Failed to create session.';
      } catch (err) {
        if (createError) createError.textContent = 'Network error. Please try again.';
      }

      startBtn.disabled = false;
      startBtn.textContent = 'Start Mock Draft';
    });
  }

  // ── Load sessions ──
  function formatRelativeTime(iso) {
    if (!iso) return '';
    const then = new Date(iso).getTime();
    if (!Number.isFinite(then)) return '';
    const now = Date.now();
    const seconds = Math.round((now - then) / 1000);
    if (seconds < 45) return 'just now';
    const minutes = Math.round(seconds / 60);
    if (minutes < 60) return `${minutes} min ago`;
    const hours = Math.round(minutes / 60);
    if (hours < 24) return `${hours} hr ago`;
    const days = Math.round(hours / 24);
    if (days === 1) return 'yesterday';
    if (days < 7) return `${days} days ago`;
    return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }

  function formatAbsoluteTime(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
  }

  function createSessionCard(s) {
    const statusLabels = {
      lobby: 'Waiting',
      active: 'In Progress',
      paused: 'Paused',
      completed: 'Completed',
    };

    const creator = teamMap[s.createdBy] || { name: `Team ${s.createdBy}`, icon: '' };
    const isYours = s.createdBy === userFranchiseId;

    const card = document.createElement('a');
    card.href = `/theleague/mock-draft/${encodeURIComponent(s.id)}`;
    card.className = 'mock-lobby__session-card' + (isYours ? ' mock-lobby__session-card--yours' : '');

    // Owner block — icon + name dominate the card
    const ownerRow = document.createElement('div');
    ownerRow.className = 'mock-lobby__session-owner';

    const avatar = document.createElement('div');
    avatar.className = 'mock-lobby__session-avatar';
    if (creator.icon) {
      const img = document.createElement('img');
      img.src = creator.icon;
      img.alt = '';
      img.loading = 'lazy';
      img.decoding = 'async';
      avatar.appendChild(img);
    } else {
      avatar.textContent = creator.name.slice(0, 2).toUpperCase();
      avatar.classList.add('mock-lobby__session-avatar--placeholder');
    }

    const ownerInfo = document.createElement('div');
    ownerInfo.className = 'mock-lobby__session-owner-info';

    const ownerName = document.createElement('div');
    ownerName.className = 'mock-lobby__session-owner-name';
    ownerName.textContent = isYours ? `${creator.name} (you)` : creator.name;

    const ownerSub = document.createElement('div');
    ownerSub.className = 'mock-lobby__session-owner-sub';
    ownerSub.textContent = formatRelativeTime(s.createdAt) || 'Started recently';

    ownerInfo.append(ownerName, ownerSub);

    const statusBadge = document.createElement('span');
    statusBadge.className = `mock-lobby__status mock-lobby__status--${s.status}`;
    statusBadge.textContent = statusLabels[s.status] || s.status;

    ownerRow.append(avatar, ownerInfo, statusBadge);

    // Detail row — compact progress + timer
    const detailRow = document.createElement('div');
    detailRow.className = 'mock-lobby__session-details';

    const progress = document.createElement('span');
    progress.className = 'mock-lobby__session-detail';
    progress.innerHTML = `<strong>R${s.currentRound}·P${s.currentPickInRound}</strong> of ${s.totalRounds} rd`;

    const joined = document.createElement('span');
    joined.className = 'mock-lobby__session-detail';
    joined.innerHTML = `<strong>${s.participantCount}</strong>/${s.totalTeams} joined`;

    const timer = document.createElement('span');
    timer.className = 'mock-lobby__session-detail';
    timer.innerHTML = `<strong>${s.timerSeconds}s</strong>/pick`;

    const absTime = document.createElement('span');
    absTime.className = 'mock-lobby__session-detail mock-lobby__session-detail--time';
    absTime.textContent = formatAbsoluteTime(s.createdAt);

    detailRow.append(progress, joined, timer, absTime);

    card.append(ownerRow, detailRow);
    return card;
  }

  async function loadSessions() {
    const container = document.getElementById('sessions-list');
    if (!container) return;

    try {
      const res = await fetch('/api/mock-draft/list', { cache: 'no-store' });
      const data = await res.json();
      const sessions = data.sessions || [];

      container.replaceChildren();

      if (sessions.length === 0) {
        const empty = document.createElement('p');
        empty.className = 'mock-lobby__empty';
        empty.textContent = 'No active sessions. Start one above!';
        container.appendChild(empty);
        return;
      }

      // Surface sessions you started first, then newest first
      sessions.sort((a, b) => {
        if ((a.createdBy === userFranchiseId) !== (b.createdBy === userFranchiseId)) {
          return a.createdBy === userFranchiseId ? -1 : 1;
        }
        return new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime();
      });

      for (const s of sessions) {
        container.appendChild(createSessionCard(s));
      }
    } catch {
      container.replaceChildren();
      const err = document.createElement('p');
      err.className = 'mock-lobby__empty';
      err.textContent = 'Could not load sessions.';
      container.appendChild(err);
    }
  }

  loadSessions();

  // iOS Safari and mobile Chrome restore pages from bfcache on back-nav, which
  // skips the script re-run above. Re-fetch sessions when the page becomes
  // visible again (back button, tab focus) so stale lists don't linger.
  window.addEventListener('pageshow', (e) => {
    if (e.persisted) loadSessions();
  });
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') loadSessions();
  });
</script>

<style is:global>
  .mock-lobby {
    max-width: 640px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .mock-lobby__header {
    margin-bottom: 2rem;
  }

  .mock-lobby__title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-gray-900, #111827);
    margin: 0 0 0.375rem;
  }

  .mock-lobby__subtitle {
    font-size: 0.875rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0;
  }

  /* ── Section headers (editorial pattern) ── */
  .mock-lobby__section-header {
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
    margin-bottom: 1rem;
  }

  .mock-lobby__section-header-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-900, #111827);
    margin: 0;
  }

  .mock-lobby__section-header-sub {
    font-size: 0.8125rem;
    color: var(--color-gray-400, #9ca3af);
    margin: 0.25rem 0 0;
  }

  /* ── Auth wall ── */
  .mock-lobby__auth-wall {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--color-gray-50, #f9fafb);
    border-radius: 0.5rem;
  }

  .mock-lobby__auth-wall p {
    color: var(--color-gray-500, #6b7280);
    margin: 0 0 1rem;
  }

  .mock-lobby__signin-btn {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: var(--color-primary, #1c497c);
    color: #fff;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
  }

  /* ── Create form ── */
  .mock-lobby__create {
    margin-bottom: 2.5rem;
  }

  .mock-lobby__create-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mock-lobby__form-row {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .mock-lobby__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
  }

  .mock-lobby__timer-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .mock-lobby__chip {
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--color-gray-200, #e5e7eb);
    border-radius: 999px;
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-600, #4b5563);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .mock-lobby__chip:hover {
    border-color: var(--color-primary, #1c497c);
    color: var(--color-primary, #1c497c);
  }

  .mock-lobby__chip--active {
    background: var(--color-primary, #1c497c);
    border-color: var(--color-primary, #1c497c);
    color: #fff;
  }

  .mock-lobby__chip--active:hover {
    color: #fff;
  }

  /* ── Board Settings ──
   * Inset card with the editorial section-header pattern (2px primary
   * left-border title) and a ds-detail-row-style per-team list.
   */
  .mock-lobby__board {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--color-gray-200, #e5e7eb);
    border-radius: var(--radius-md, 0.5rem);
  }

  .mock-lobby__board-head {
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  .mock-lobby__board-title {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-900, #111827);
  }

  .mock-lobby__board-hint {
    margin: 0.125rem 0 0;
    font-size: 0.75rem;
    color: var(--color-gray-400, #9ca3af);
    line-height: 1.35;
  }

  .mock-lobby__sub-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500, #6b7280);
  }

  .mock-lobby__select {
    padding: 0.4375rem 0.625rem;
    border: 1px solid var(--color-gray-200, #e5e7eb);
    border-radius: var(--radius-sm, 0.375rem);
    background: #fff;
    color: var(--color-gray-900, #111827);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
  }

  .mock-lobby__select:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 1px;
  }

  .mock-lobby__select--compact {
    padding: 0.3125rem 0.5rem;
    font-size: 0.75rem;
  }

  .mock-lobby__presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .mock-lobby__disclosure {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0;
    background: none;
    border: none;
    color: var(--color-primary, #1c497c);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    align-self: flex-start;
    transition: color 0.15s ease;
  }

  .mock-lobby__disclosure:hover {
    color: var(--btn-primary-bg-hover, #164066);
  }

  .mock-lobby__disclosure-caret {
    display: inline-block;
    transition: transform 0.15s ease;
    font-size: 0.6875rem;
    line-height: 1;
  }

  .mock-lobby__disclosure--open .mock-lobby__disclosure-caret {
    transform: rotate(90deg);
  }

  .mock-lobby__per-team {
    display: flex;
    flex-direction: column;
    padding-top: 0.25rem;
  }

  .mock-lobby__per-team-row {
    display: flex;
    align-items: center;
