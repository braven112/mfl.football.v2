---
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import PlayerCell from '../../../components/theleague/PlayerCell.astro';
import { getPendingDeclarations, getDeclarations } from '../../../utils/contract-storage';
import { getAuthUser, isCommissionerOrAdmin } from '../../../utils/auth';
import { getCurrentLeagueYear } from '../../../utils/league-year';
import { getPlayerMap } from '../../../utils/player-map';
import leagueConfig from '../../../data/theleague.config.json';

// Commissioner actions (Apply button) only show when commish-mode toggle is ON
const user = getAuthUser(Astro.request);
const isCommish = !!user && isCommissionerOrAdmin(user);
const isCommishMode = isCommish && Astro.cookies.get('commish-mode')?.value === 'true';

// Load declaration data at build/request time
const pending = await getPendingDeclarations();
const allDeclarations = await getDeclarations();
const appliedContracts = allDeclarations
  .filter(d => d.status === 'applied');

// Group applied contracts by league year (most recent year first)
const teamIconMap = new Map(leagueConfig.teams.map((t: any) => [t.franchiseId, t.icon]));
const teamNameMap = new Map(leagueConfig.teams.map((t: any) => [t.franchiseId, t.abbrev || t.nameShort || t.name]));
const contractsByYear = new Map<number, typeof appliedContracts>();
for (const d of appliedContracts) {
  const refDate = new Date(d.reviewedAt || d.submittedAt);
  const year = getCurrentLeagueYear(refDate);
  if (!contractsByYear.has(year)) contractsByYear.set(year, []);
  contractsByYear.get(year)!.push(d);
}
const sortedYears = [...contractsByYear.keys()].sort((a, b) => b - a);
const currentYear = getCurrentLeagueYear();

const declarationTypeLabels: Record<string, string> = {
  'new-acquisition': 'Contract Years',
  'rookie-override': 'Rookie Override',
  'franchise-tag': 'Franchise Tag',
  'veteran-extension': 'Veteran Extension',
  'rookie-extension': 'Rookie Extension',
  'team-option': 'Team Option',
};

const appliedCount = allDeclarations.filter(d => d.status === 'applied').length;

// Load player identity data for headshots/positions
const leagueYear = getCurrentLeagueYear();
const managePlayerMap = getPlayerMap(leagueYear);
const playerLookup: Record<string, { position: string; team: string; espnId?: string }> = {};
for (const [id, identity] of managePlayerMap) {
  playerLookup[id] = {
    position: identity.position,
    team: identity.nflTeam,
    espnId: identity.espnId ?? undefined,
  };
}

const getHeadshot = (playerId: string, espnId?: string) => {
  const identity = managePlayerMap.get(playerId);
  return identity?.headshot ?? (espnId
    ? `https://a.espncdn.com/i/headshots/nfl/players/full/${espnId}.png`
    : `https://www49.myfantasyleague.com/player_photos_big_2014/${playerId}_thumb.jpg`);
};
---

<TheLeagueLayout title="Manage Declarations">
  <main class="manage-page">
    <!-- Page header -->
    <header class="page-header">
      <Breadcrumbs items={[
        { label: 'The League', href: '/theleague' },
        { label: 'Manage Contracts' },
      ]} />
      <h1 class="page-title">Contract Declarations</h1>
      <p class="page-subtitle">Contract declaration status and history</p>
    </header>

    <div class="page-grid">
      <!-- Main content (left) -->
      <div class="manage-content">

      <!-- Pending declarations -->
      <section class="section" aria-labelledby="pending-review-heading">
        <h2 class="section__title" id="pending-review-heading">
          Pending Review
          <span class="section__count">{pending.length}</span>
        </h2>

        {isCommishMode && (
          <div class="batch-actions">
            {pending.length > 1 && (
              <button
                class="action-btn action-btn--approve action-btn--batch"
                id="applyAllBtn"
                aria-label="Apply all pending declarations"
              >
                Apply All ({pending.length})
              </button>
            )}
            {pending.length > 0 && (
              <button
                class="action-btn action-btn--verify"
                id="reconcileBtn"
                aria-label="Auto-fix stuck declarations by checking MFL"
              >
                Reconcile
              </button>
            )}
          </div>
        )}

        {pending.length === 0 ? (
          <div class="empty-state">
            <div class="empty-state__icon">
              <svg class="empty-state__svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 12l2 2 4-4" />
                <circle cx="12" cy="12" r="10" />
              </svg>
            </div>
            <p class="empty-state__text">No pending declarations to review</p>
            <p class="empty-state__hint">Declarations will appear here when owners submit contract changes</p>
          </div>
        ) : (
          <div class="card-list" id="pendingList">
            {pending.map(d => (
              <article class="decl-card" data-id={d.id}>
                <div class="decl-card__top">
                  <div class="decl-card__identity">
                    <h3 class="decl-card__player">{d.playerName}</h3>
                    <span class="decl-card__team">{d.franchiseName}</span>
                  </div>
                  <span class="decl-card__type">{declarationTypeLabels[d.type] || d.type}</span>
                </div>

                <div class="decl-card__grid">
                  <div class="decl-card__field">
                    <span class="field__label">Current</span>
                    <span class="field__value">{d.currentYears}yr</span>
                  </div>
                  <div class="decl-card__field">
                    <span class="field__label">Requested</span>
                    <span class="field__value field__value--accent">{d.requestedYears}yr
                    </span>
                  </div>
                  {d.currentContractInfo && (
                    <div class="decl-card__field">
                      <span class="field__label">Designation</span>
                      <span class="field__value">{d.currentContractInfo}</span>
                    </div>
                  )}
                  <div class="decl-card__field">
                    <span class="field__label">Submitted</span>
                    <span class="field__value">{new Date(d.submittedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
                  </div>
                  {d.deadlineAt && (
                    <div class="decl-card__field">
                      <span class="field__label">Deadline</span>
                      <span class="field__value deadline-value" data-deadline={d.deadlineAt}>
                        {new Date(d.deadlineAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}
                      </span>
                    </div>
                  )}
                </div>

                {isCommishMode && (
                  <div class="decl-card__actions">
                    <button
                      class="action-btn action-btn--approve"
                      data-action="approve"
                      data-id={d.id}
                      data-player={d.playerName}
                      aria-label={`Apply declaration for ${d.playerName}`}
                    >
                      Apply
                    </button>
                    <button
                      class="action-btn action-btn--dismiss"
                      data-action="dismiss"
                      data-id={d.id}
                      data-player={d.playerName}
                      aria-label={`Dismiss declaration for ${d.playerName}`}
                    >
                      Dismiss
                    </button>
                  </div>
                )}
              </article>
            ))}
          </div>
        )}
      </section>

      <!-- Applied contracts by year -->
      <section class="section" aria-labelledby="applied-contracts-heading">
        <div class="section__header-row">
          <h2 class="section__title" id="applied-contracts-heading">Applied Contracts</h2>
          {isCommishMode && appliedContracts.length > 0 && (
            <button class="action-btn action-btn--verify" id="verifyMflBtn">
              Verify MFL
            </button>
          )}
        </div>

        {appliedContracts.length === 0 ? (
          <div class="empty-state">
            <p class="empty-state__text">No applied contracts yet</p>
          </div>
        ) : (
          sortedYears.map(year => {
            const yearContracts = contractsByYear.get(year)!;
            return (
              <div class="year-group" data-year={year}>
                <h3 class="year-group__heading">
                  {year}
                  <span class="year-group__count">{yearContracts.length}</span>
                  {year === currentYear && <span class="year-group__current">Current</span>}
                </h3>
                <ul class="recent-list" id={year === currentYear ? 'appliedList' : undefined}>
                  {yearContracts.map(d => {
                    const pInfo = playerLookup[d.playerId];
                    const headshot = pInfo ? getHeadshot(d.playerId, pInfo.espnId) : undefined;
                    const teamIcon = teamIconMap.get(d.franchiseId);
                    const teamAbbrev = teamNameMap.get(d.franchiseId);
                    const typeLabel = declarationTypeLabels[d.type] || d.type;
                    return (
                      <li class="recent-item" data-id={d.id} data-player-id={d.playerId} data-requested-years={d.requestedYears}>
                        <div class="recent-item__player-cell">
                          <PlayerCell
                            name={d.playerName}
                            headshot={headshot}
                            position={pInfo?.position}
                            nflTeam={pInfo?.team}
                            size="compact"
                          />
                        </div>
                        <div class="recent-item__info">
                          <span class="recent-item__detail">
                            {teamIcon && (
                              <img
                                src={teamIcon}
                                alt={teamAbbrev || ''}
                                class="recent-item__team-icon"
                                loading="lazy"
                              />
                            )}
                            {d.currentYears}yr &rarr; {d.requestedYears}yr
                          </span>
                          <span class="recent-item__meta">
                            <span class="recent-item__type">{typeLabel}</span>
                            {d.reviewedAt && (
                              <span class="recent-item__date">
                                {new Date(d.reviewedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                              </span>
                            )}
                          </span>
                        </div>
                        <span class="recent-item__mfl-status" data-mfl-check={d.playerId}></span>
                        {isCommishMode && (
                          <div class="action-btn-group">
                            <button
                              class="action-btn action-btn--reapply"
                              data-action="reapply"
                              data-id={d.id}
                              data-player={d.playerName}
                              aria-label={`Reapply declaration for ${d.playerName}`}
                            >
                              Reapply
                            </button>
                            <button
                              class="action-btn action-btn--delete"
                              data-action="delete"
                              data-id={d.id}
                              data-player={d.playerName}
                              aria-label={`Delete declaration for ${d.playerName}`}
                            >
                              &times;
                            </button>
                          </div>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </div>
            );
          })
        )}
      </section>

      </div>

      <!-- Status sidebar (right) -->
      <aside class="status-sidebar">
        <div class="status-sidebar__container" role="region" aria-label="Declaration statistics">
          <h3 class="status-sidebar__title">Status</h3>
          <div class="status-sidebar__metrics">
            <article class="metric" data-variant="pending">
              <span class="metric__value" id="pendingCount">{pending.length}</span>
              <span class="metric__label">Pending</span>
            </article>
            <article class="metric" data-variant="applied">
              <span class="metric__value" id="appliedCount">{appliedCount}</span>
              <span class="metric__label">Applied</span>
            </article>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <script type="module">
    // --- Toast notification system ---
    const toastContainer = document.createElement('div');
    toastContainer.id = 'toastContainer';
    document.body.appendChild(toastContainer);

    function showToast(message, variant = 'error') {
      const toast = document.createElement('div');
      toast.className = `toast toast--${variant}`;
      toast.textContent = message;
      toastContainer.appendChild(toast);
      requestAnimationFrame(() => toast.classList.add('toast--visible'));
      setTimeout(() => {
        toast.classList.remove('toast--visible');
        toast.addEventListener('transitionend', () => toast.remove(), { once: true });
      }, 4500);
    }

    // --- Inline confirm system ---
    // Replaces browser confirm() with an inline button swap.
    // Returns a Promise<boolean> that resolves when the user confirms or cancels.
    function inlineConfirm(btn, message) {
      return new Promise((resolve) => {
        const parent = btn.parentElement;
        const originalDisplay = [];
        // Hide siblings
        for (const child of parent.children) {
          originalDisplay.push(child.style.display);
          child.style.display = 'none';
        }

        const wrap = document.createElement('div');
        wrap.className = 'inline-confirm';

        const msg = document.createElement('span');
        msg.className = 'inline-confirm__msg';
        msg.textContent = message;

        const yesBtn = document.createElement('button');
        yesBtn.className = 'action-btn inline-confirm__yes';
        yesBtn.textContent = 'Yes';

        const noBtn = document.createElement('button');
        noBtn.className = 'action-btn inline-confirm__no';
        noBtn.textContent = 'No';

        wrap.append(msg, yesBtn, noBtn);
        parent.appendChild(wrap);

        function cleanup(result) {
          wrap.remove();
          let i = 0;
          for (const child of parent.children) {
            child.style.display = originalDisplay[i++] || '';
          }
          resolve(result);
        }

        yesBtn.addEventListener('click', () => cleanup(true), { once: true });
        noBtn.addEventListener('click', () => cleanup(false), { once: true });
      });
    }

    const pendingList = document.getElementById('pendingList');
    const pendingCountEl = document.getElementById('pendingCount');
    const sectionCountEl = document.querySelector('.section__count');
    const appliedCountEl = document.getElementById('appliedCount');

    // Track applied IDs in sessionStorage so they stay hidden on reload
    // (Vercel Blob CDN can serve stale data briefly after a write)
    const APPLIED_KEY = 'contract_applied_ids';
    function getAppliedIds() {
      try { return JSON.parse(sessionStorage.getItem(APPLIED_KEY) || '[]'); }
      catch { return []; }
    }
    function markApplied(id) {
      const ids = getAppliedIds();
      ids.push(id);
      sessionStorage.setItem(APPLIED_KEY, JSON.stringify(ids));
    }

    // On page load, hide any cards that were already applied this session
    // (handles CDN stale reads returning "pending" after successful apply)
    const alreadyApplied = getAppliedIds();
    let hiddenOnLoad = 0;
    if (alreadyApplied.length > 0 && pendingList) {
      for (const id of alreadyApplied) {
        const card = pendingList.querySelector(`[data-id="${id}"]`);
        if (card) {
          card.remove();
          hiddenOnLoad++;
        }
      }
      // Update counts to reflect hidden cards
      if (hiddenOnLoad > 0) {
        [pendingCountEl, sectionCountEl].forEach(el => {
          if (!el) return;
          const current = parseInt(el.textContent || '0', 10);
          el.textContent = String(Math.max(0, current - hiddenOnLoad));
        });
        if (appliedCountEl) {
          const current = parseInt(appliedCountEl.textContent || '0', 10);
          appliedCountEl.textContent = String(current + hiddenOnLoad);
        }
        if (pendingList.querySelectorAll('.decl-card').length === 0) {
          showEmptyState();
        }
      }
    }

    function showEmptyState() {
      if (!pendingList) return;
      while (pendingList.firstChild) {
        pendingList.removeChild(pendingList.firstChild);
      }
      const emptyDiv = document.createElement('div');
      emptyDiv.className = 'empty-state';
      const p = document.createElement('p');
      p.className = 'empty-state__text';
      p.textContent = 'No pending declarations.';
      emptyDiv.appendChild(p);
      pendingList.appendChild(emptyDiv);
    }

    function updateCounts() {
      [pendingCountEl, sectionCountEl].forEach(el => {
        if (!el) return;
        const current = parseInt(el.textContent || '0', 10);
        el.textContent = String(Math.max(0, current - 1));
      });
      if (appliedCountEl) {
        const current = parseInt(appliedCountEl.textContent || '0', 10);
        appliedCountEl.textContent = String(current + 1);
      }
    }

    function removeCard(card) {
      card.classList.add('decl-card--fade');
      setTimeout(() => {
        card.remove();
        if (pendingList && pendingList.querySelectorAll('.decl-card').length === 0) {
          showEmptyState();
        }
      }, 500);
    }

    // Event delegation for pending card actions
    pendingList?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;

      const declarationId = btn.dataset.id;
      const playerName = btn.dataset.player;
      if (btn.dataset.action === 'dismiss') {
        handleDismiss(declarationId, playerName, btn);
      } else {
        handleApply(declarationId, playerName, btn);
      }
    });

    async function handleDismiss(declarationId, playerName, btn) {
      if (!await inlineConfirm(btn, `Dismiss ${playerName}?`)) return;

      btn.disabled = true;

      try {
        const res = await fetch('/api/contracts/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ declarationId }),
        });

        const data = await res.json();

        if (!res.ok) {
          showToast(`Failed to dismiss: ${data.error || 'Unknown error'}`);
          btn.disabled = false;
          return;
        }

        const card = btn.closest('.decl-card');
        removeCard(card);
        [pendingCountEl, sectionCountEl].forEach(el => {
          if (!el) return;
          const current = parseInt(el.textContent || '0', 10);
          el.textContent = String(Math.max(0, current - 1));
        });
        showToast(`Dismissed ${playerName}`, 'success');
      } catch (err) {
        console.error('Dismiss error:', err);
        showToast('Network error dismissing declaration.');
        btn.disabled = false;
      }
    }

    async function handleApply(declarationId, playerName, btn) {
      if (!await inlineConfirm(btn, `Apply ${playerName}?`)) return;

      btn.disabled = true;
      btn.textContent = 'Applying\u2026';

      try {
        const res = await fetch('/api/contracts/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ declarationId }),
        });

        const data = await res.json();

        if (!res.ok) {
          // Show specific error so user knows what went wrong
          const msg = data.error || 'Unknown error';
          if (res.status === 401) {
            showToast('Session expired. Please log in again via the sidebar, then retry.');
          } else if (res.status === 403) {
            showToast('Commissioner access required. Please log in as commissioner via the sidebar.');
          } else if (res.status === 502) {
            showToast(`MFL write failed: ${msg}. This usually means your MFL session expired.`);
          } else {
            showToast(`Failed to apply: ${msg}`);
          }
          btn.disabled = false;
          btn.textContent = 'Apply';
          return;
        }

        // Success — track applied ID so it stays hidden on reload
        markApplied(declarationId);

        const card = btn.closest('.decl-card');
        updateCounts();
        removeCard(card);
      } catch (err) {
        console.error('Apply error:', err);
        showToast('Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Apply';
      }
    }

    // Reapply + Delete handlers (for applied declarations)
    const appliedList = document.getElementById('appliedList');
    appliedList?.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      if (btn.dataset.action === 'reapply') {
        handleReapply(btn.dataset.id, btn.dataset.player, btn);
      } else if (btn.dataset.action === 'delete') {
        handleDelete(btn.dataset.id, btn.dataset.player, btn);
      }
    });

    async function handleReapply(declarationId, playerName, btn) {
      if (!await inlineConfirm(btn, `Reapply ${playerName}?`)) return;

      btn.disabled = true;
      btn.textContent = 'Applying\u2026';

      try {
        const res = await fetch('/api/contracts/approve', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ declarationId }),
        });

        const data = await res.json();

        if (!res.ok) {
          const msg = data.error || 'Unknown error';
          showToast(`Failed to reapply: ${msg}`);
          btn.disabled = false;
          btn.textContent = 'Reapply';
          return;
        }

        btn.textContent = 'Applied!';
        btn.style.background = 'var(--color-success)';
        setTimeout(() => {
          btn.textContent = 'Reapply';
          btn.style.background = '';
          btn.disabled = false;
        }, 2000);
      } catch (err) {
        console.error('Reapply error:', err);
        showToast('Network error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Reapply';
      }
    }

    async function handleDelete(declarationId, playerName, btn) {
      if (!await inlineConfirm(btn, `Delete ${playerName}?`)) return;

      btn.disabled = true;

      try {
        const res = await fetch('/api/contracts/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ declarationId }),
        });

        const data = await res.json();

        if (!res.ok) {
          showToast(`Failed to delete: ${data.error || 'Unknown error'}`);
          btn.disabled = false;
          return;
        }

        const row = btn.closest('.recent-item');
        row.style.transition = 'opacity 0.3s';
        row.style.opacity = '0';
        setTimeout(() => {
          row.remove();
          if (appliedCountEl) {
            const current = parseInt(appliedCountEl.textContent || '0', 10);
            appliedCountEl.textContent = String(Math.max(0, current - 1));
          }
          if (appliedList && appliedList.querySelectorAll('.recent-item').length === 0) {
            const emptyDiv = document.createElement('div');
            emptyDiv.className = 'empty-state';
            const p = document.createElement('p');
            p.className = 'empty-state__text';
            p.textContent = 'No applied contracts yet';
            emptyDiv.appendChild(p);
            appliedList.appendChild(emptyDiv);
          }
        }, 300);
      } catch (err) {
        console.error('Delete error:', err);
        showToast('Network error. Please try again.');
        btn.disabled = false;
      }
    }

    // Apply All handler
    const applyAllBtn = document.getElementById('applyAllBtn');
    applyAllBtn?.addEventListener('click', async () => {
      const cards = pendingList?.querySelectorAll('.decl-card');
      if (!cards || cards.length === 0) return;

      const count = cards.length;
      if (!await inlineConfirm(applyAllBtn, `Apply all ${count}?`)) return;

      applyAllBtn.disabled = true;
      applyAllBtn.textContent = 'Applying...';

      let applied = 0;
      let failed = 0;

      for (const card of cards) {
        const id = card.dataset.id;
        const btn = card.querySelector('[data-action="approve"]');
        const playerName = btn?.dataset?.player || 'Unknown';

        try {
          const res = await fetch('/api/contracts/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ declarationId: id }),
          });

          if (!res.ok) {
            const data = await res.json();
            console.error(`Failed to apply ${playerName}:`, data.error);
            failed++;
            continue;
          }

          markApplied(id);
          updateCounts();
          removeCard(card);
          applied++;
        } catch (err) {
          console.error(`Error applying ${playerName}:`, err);
          failed++;
        }
      }

      if (failed > 0) {
        applyAllBtn.textContent = `${applied} applied, ${failed} failed`;
        applyAllBtn.style.background = '#dc2626';
        setTimeout(() => {
          applyAllBtn.textContent = `Apply All (${failed})`;
          applyAllBtn.style.background = '';
          applyAllBtn.disabled = false;
        }, 3000);
      } else {
        applyAllBtn.textContent = 'All Applied!';
        setTimeout(() => { applyAllBtn.style.display = 'none'; }, 2000);
      }
    });

    // Verify MFL handler — fetches live salary data and compares
    const verifyBtn = document.getElementById('verifyMflBtn');
    verifyBtn?.addEventListener('click', async () => {
      verifyBtn.disabled = true;
      verifyBtn.textContent = 'Checking MFL...';

      try {
        const res = await fetch('/api/contracts/verify');
        if (!res.ok) {
          const data = await res.json();
          showToast(`Verify failed: ${data.error || res.statusText}`);
          verifyBtn.disabled = false;
          verifyBtn.textContent = 'Verify MFL';
          return;
        }

        const { contracts } = await res.json();

        // Compare each applied declaration with actual MFL data
        document.querySelectorAll('[data-mfl-check]').forEach(el => {
          const playerId = el.dataset.mflCheck;
          const item = el.closest('.recent-item');
          const requestedYears = item?.dataset?.requestedYears;
          const mfl = contracts[playerId];

          if (!mfl) {
            el.textContent = 'Not on MFL';
            el.className = 'recent-item__mfl-status mfl-status--missing';
          } else if (mfl.contractYear === requestedYears) {
            el.textContent = `MFL: ${mfl.contractYear}yr`;
            el.className = 'recent-item__mfl-status mfl-status--match';
          } else {
            el.textContent = `MFL: ${mfl.contractYear}yr`;
            el.className = 'recent-item__mfl-status mfl-status--mismatch';
          }
        });

        verifyBtn.textContent = 'Verified!';
        verifyBtn.style.background = 'var(--color-success, #16a34a)';
        setTimeout(() => {
          verifyBtn.textContent = 'Verify MFL';
          verifyBtn.style.background = '';
          verifyBtn.disabled = false;
        }, 3000);
      } catch (err) {
        console.error('Verify error:', err);
        showToast('Network error verifying MFL contracts.');
        verifyBtn.disabled = false;
        verifyBtn.textContent = 'Verify MFL';
      }
    });

    // Deadline countdown coloring
    document.querySelectorAll('[data-deadline]').forEach(el => {
      const deadline = new Date(el.dataset.deadline);
      const now = new Date();
      const hoursLeft = (deadline.getTime() - now.getTime()) / (1000 * 60 * 60);

      if (hoursLeft < 0) {
        el.classList.add('deadline--expired');
      } else if (hoursLeft < 4) {
        el.classList.add('deadline--critical');
      } else if (hoursLeft < 12) {
        el.classList.add('deadline--warning');
      }
    });

    // Reconcile handler — auto-fixes stuck pending declarations
    const reconcileBtn = document.getElementById('reconcileBtn');
    reconcileBtn?.addEventListener('click', async () => {
      if (!await inlineConfirm(reconcileBtn, 'Reconcile?')) return;

      reconcileBtn.disabled = true;
      reconcileBtn.textContent = 'Checking...';

      try {
        const res = await fetch('/api/contracts/reconcile', { method: 'POST' });
        const data = await res.json();

        if (!res.ok) {
          showToast(`Reconcile failed: ${data.error || res.statusText}`);
          return;
        }

        if (data.reconciled > 0) {
          showToast(`Reconciled ${data.reconciled} declaration(s). Refresh to see updates.`, 'success');
          location.reload();
        } else {
          showToast(data.message, 'info');
        }
      } catch (err) {
        console.error('Reconcile error:', err);
        showToast('Network error during reconcile.');
      } finally {
        reconcileBtn.disabled = false;
        reconcileBtn.textContent = 'Reconcile';
      }
    });

  </script>

