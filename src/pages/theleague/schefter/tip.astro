    gap: 0.25rem;
    align-self: flex-start;
    margin-top: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    transition: gap 0.15s;
  }
  .tip-rail-feed-link:hover {
    gap: 0.5rem;
  }
</style>

<script>
  const form = document.getElementById('tip-form') as HTMLFormElement | null;
  const textarea = document.getElementById('tip-text') as HTMLTextAreaElement | null;
  const counter = document.getElementById('tip-counter');
  const status = document.getElementById('tip-status');
  const submitBtn = document.getElementById('tip-submit') as HTMLButtonElement | null;
  const topicSelect = document.getElementById('tip-topic') as HTMLSelectElement | null;
  const franchiseSelect = document.getElementById('tip-franchise') as HTMLSelectElement | null;
  const commishOption = franchiseSelect?.querySelector<HTMLOptionElement>('option[data-commish]') ?? null;
  const remainingChip = document.getElementById('tip-remaining') as HTMLElement | null;
  const remainingText = document.getElementById('tip-remaining-text');

  function syncCommishOption() {
    if (!topicSelect || !franchiseSelect || !commishOption) return;
    const isTrade = topicSelect.value === 'trade';
    commishOption.hidden = isTrade;
    commishOption.disabled = isTrade;
    if (isTrade && franchiseSelect.value === 'commish') {
      franchiseSelect.value = 'league-wide';
    }
  }
  topicSelect?.addEventListener('change', syncCommishOption);
  syncCommishOption();

  // Phase 3 — rotating placeholders by topic
  const PLACEHOLDERS: Record<string, string> = {
    trade: "e.g. Hearing the Northwest is shopping their 1st for a vet WR…",
    roster: "e.g. Somebody in the East just gave up on their rebuild…",
    prediction: "e.g. Calling it now — Breece Hall isn't making it through Week 8…",
    commish: "e.g. The Commish keeps scheduling the auction when I'm on vacation. I see you.",
    other: "Tell me what's brewing.",
  };
  function syncPlaceholder() {
    if (!topicSelect || !textarea) return;
    const next = PLACEHOLDERS[topicSelect.value] ?? PLACEHOLDERS.other;
    textarea.placeholder = next;
  }
  topicSelect?.addEventListener('change', syncPlaceholder);
  syncPlaceholder();

  // Phase 1 — tips-remaining chip: fetch on mount, refresh after submit.
  function formatReset(resetsAt: number | null): string {
    if (!resetsAt) return '';
    const diffMs = resetsAt - Date.now();
    if (diffMs <= 0) return '';
    const totalMin = Math.ceil(diffMs / 60000);
    const h = Math.floor(totalMin / 60);
    const m = totalMin % 60;
    if (h >= 1) return `resets in ${h}h ${m}m`;
    return `resets in ${m}m`;
  }
  function renderRemaining(used: number, remaining: number, max: number, resetsAt: number | null) {
    if (!remainingChip || !remainingText) return;
    const state = remaining === 0 ? 'empty' : 'ok';
    remainingChip.setAttribute('data-state', state);
    if (remaining === 0) {
      const reset = formatReset(resetsAt);
      remainingText.textContent = reset
        ? `Daily cap hit — ${reset}`
        : `Daily cap hit — try again tomorrow`;
    } else {
      remainingText.textContent = `${remaining} of ${max} tips left today`;
    }
    if (submitBtn) {
      submitBtn.disabled = remaining === 0;
    }
  }
  async function refreshRemaining() {
    if (!remainingChip || !remainingText) return;
    try {
      const res = await fetch('/api/schefter/tips-remaining', { headers: { Accept: 'application/json' } });
      if (!res.ok) {
        remainingChip.setAttribute('data-state', 'ok');
        remainingText.textContent = '';
        return;
      }
      const data = await res.json();
      const used = Number(data?.used ?? 0);
      const max = Number(data?.max ?? 3);
      const remaining = Number.isFinite(data?.remaining) ? Number(data.remaining) : Math.max(0, max - used);
      const resetsAt = typeof data?.resetsAt === 'number' ? data.resetsAt : null;
      renderRemaining(used, remaining, max, resetsAt);
    } catch {
      remainingChip.setAttribute('data-state', 'ok');
      remainingText.textContent = '';
    }
  }
  refreshRemaining();

  // Phase 6 — tipster scorecard + leaderboard.
  const recordBody = document.querySelector('[data-tipster-record-body]') as HTMLElement | null;
  const leaderboardList = document.querySelector('[data-tipster-leaderboard-list]') as HTMLElement | null;
  const leaderboardSub = document.querySelector('[data-tipster-leaderboard-sub]') as HTMLElement | null;

  function escapeHtml(s: string): string {
    return String(s).replace(/[&<>"']/g, (c) =>
      c === '&' ? '&amp;' :
      c === '<' ? '&lt;' :
      c === '>' ? '&gt;' :
      c === '"' ? '&quot;' : '&#39;'
    );
  }

  function renderRecord(data: { me: { codename: string | null; rumorsTotal: number; rumorsSeason: number; badges?: string[] } | null }) {
    if (!recordBody) return;
    const me = data.me;
    if (!me || (!me.codename && (me.rumorsTotal ?? 0) === 0)) {
      recordBody.innerHTML = '<p class="tip-rail-record__empty">No rumors seeded yet. Tip something Schefter can run with and you\'ll earn a codename.</p>';
      return;
    }
    const codename = me.codename ? escapeHtml(me.codename) : 'Unnamed Source';
    const badges = Array.isArray(me.badges) ? me.badges : [];
    const badgeHtml = badges.length > 0
      ? `<div class="tip-rail-record__badges">${badges.map((b) => {
          const label = b.startsWith('totw-') ? `🏆 Tip of the Week · ${escapeHtml(b.slice(5))}` : `🏅 ${escapeHtml(b)}`;
          return `<span class="tip-rail-record__badge">${label}</span>`;
        }).join('')}</div>`
      : '';
    recordBody.innerHTML = `
      <span class="tip-rail-record__codename">Your codename · ${codename}</span>
      <div class="tip-rail-record__counts">
        <span>Season · <strong>${Number(me.rumorsSeason || 0)}</strong></span>
        <span>Lifetime · <strong>${Number(me.rumorsTotal || 0)}</strong></span>
      </div>
      ${badgeHtml}
    `;
  }

  function renderLeaderboard(data: { leaderboard: Array<{ codename: string; rumorsSeason: number; isMe: boolean }>; seasonYear: number }) {
    if (!leaderboardList) return;
    if (leaderboardSub) {
      leaderboardSub.textContent = `By rumors seeded · ${data.seasonYear}`;
    }
    const rows = Array.isArray(data.leaderboard) ? data.leaderboard : [];
    if (rows.length === 0) {
      leaderboardList.innerHTML = '<li class="tip-rail-leaderboard__empty">No one\'s on the board yet. Be the first.</li>';
      return;
    }
    leaderboardList.innerHTML = rows.slice(0, 10).map((row) => {
      const meClass = row.isMe ? ' tip-rail-leaderboard__row--me' : '';
      return `<li class="tip-rail-leaderboard__row${meClass}">
        <span class="tip-rail-leaderboard__codename">${escapeHtml(row.codename)}</span>
        <span class="tip-rail-leaderboard__count">${Number(row.rumorsSeason || 0)}</span>
      </li>`;
    }).join('');
  }

  async function refreshTipsterStats() {
    if (!recordBody && !leaderboardList) return;
    try {
      const res = await fetch('/api/schefter/tipster-stats', { headers: { Accept: 'application/json' } });
      if (!res.ok) {
        if (recordBody) recordBody.innerHTML = '<p class="tip-rail-record__empty">Stats are napping. Try again soon.</p>';
        if (leaderboardList) leaderboardList.innerHTML = '<li class="tip-rail-leaderboard__empty">Stats are napping.</li>';
        return;
      }
      const data = await res.json();
      renderRecord(data);
      renderLeaderboard(data);
    } catch {
      if (recordBody) recordBody.innerHTML = '<p class="tip-rail-record__empty">Network error. Try again.</p>';
      if (leaderboardList) leaderboardList.innerHTML = '<li class="tip-rail-leaderboard__empty">Network error.</li>';
    }
  }
  refreshTipsterStats();

  // Phase 8 — cooker timeline. Poll every 60s while the page is open.
  const cookerRoot = document.querySelector('[data-cooker-status]') as HTMLElement | null;
  const cookerBody = document.querySelector('[data-cooker-body]') as HTMLElement | null;
  const cookerSub = document.querySelector('[data-cooker-sub]') as HTMLElement | null;

  function formatCountdown(ms: number): string {
    if (ms <= 0) return 'any minute now';
    const totalMin = Math.ceil(ms / 60000);
    if (totalMin < 60) return `${totalMin}m`;
    const h = Math.floor(totalMin / 60);
    const m = totalMin % 60;
    return `${h}h ${m}m`;
  }

  async function refreshCooker() {
    if (!cookerRoot || !cookerBody) return;
    try {
      const res = await fetch('/api/schefter/cooker-status');
      if (!res.ok) {
        cookerRoot.setAttribute('data-state', 'empty');
        cookerBody.textContent = 'Cook stats are napping.';
        return;
      }
      const data = await res.json();
      const queueDepth = Number(data?.queueDepth ?? 0);
      const marinateStartedAt = typeof data?.marinateStartedAt === 'number' ? data.marinateStartedAt : null;
      const nextEarliestPostAt = typeof data?.nextEarliestPostAt === 'number' ? data.nextEarliestPostAt : null;
      const postsToday = Number(data?.postsToday ?? 0);
      const dailyCap = Number(data?.dailyCap ?? 3);
      const dailyCapHit = data?.dailyCapHit === true || postsToday >= dailyCap;

      if (dailyCapHit) {
        cookerRoot.setAttribute('data-state', 'capped');
        if (cookerSub) cookerSub.textContent = 'Daily cap reached';
        cookerBody.innerHTML = `Schefter's filed ${postsToday} of ${dailyCap} today. Next batch drops tomorrow — keep tipping.`;
        return;
      }

      if (queueDepth === 0) {
        cookerRoot.setAttribute('data-state', 'empty');
        if (cookerSub) cookerSub.textContent = `${postsToday} of ${dailyCap} rumors today`;
        cookerBody.textContent = 'Quiet right now. Drop a tip to start the pot.';
        return;
      }

      cookerRoot.setAttribute('data-state', 'cooking');
      if (cookerSub) cookerSub.textContent = `${postsToday} of ${dailyCap} rumors today`;
      const countdownMs = nextEarliestPostAt !== null ? nextEarliestPostAt - Date.now() : null;
      const tipWord = queueDepth === 1 ? 'tip' : 'tips';
      if (countdownMs === null) {
        cookerBody.innerHTML = `Schefter is marinating <strong>${queueDepth}</strong> ${tipWord}.`;
      } else if (countdownMs <= 0) {
        cookerBody.innerHTML = `Schefter is marinating <strong>${queueDepth}</strong> ${tipWord}. <span class="tip-rail-cooker__countdown">Any minute now</span>`;
      } else {
        cookerBody.innerHTML = `Schefter is marinating <strong>${queueDepth}</strong> ${tipWord}. Next rumor drops in <span class="tip-rail-cooker__countdown">${formatCountdown(countdownMs)}</span>`;
      }
    } catch {
      cookerRoot.setAttribute('data-state', 'empty');
      if (cookerBody) cookerBody.textContent = 'Network error.';
    }
  }
  refreshCooker();
  const cookerInterval = window.setInterval(refreshCooker, 60_000);
  window.addEventListener('beforeunload', () => window.clearInterval(cookerInterval), { once: true });

  // Phase 9 — hot topics chips.
  const TOPIC_LABELS: Record<string, string> = {
    trade: 'Trade interest',
    roster: 'Roster gripe',
    prediction: 'Bold prediction',
    commish: 'Beef',
    other: 'Other',
  };
  const hotChipsEl = document.querySelector('[data-hot-topics-chips]') as HTMLElement | null;

  async function refreshHotTopics() {
    if (!hotChipsEl) return;
    try {
      const res = await fetch('/api/schefter/hot-topics');
      if (!res.ok) {
        hotChipsEl.innerHTML = '<span class="tip-rail-hot__empty">Trending stats are napping.</span>';
        return;
      }
      const data = await res.json();
      const topics: Array<{ topic: string; count: number }> = Array.isArray(data?.topics) ? data.topics : [];
      const nonZero = topics.filter((t) => t.count > 0);
      if (nonZero.length === 0) {
        hotChipsEl.innerHTML = '<span class="tip-rail-hot__empty">Nothing buzzing this week.</span>';
        return;
      }
      hotChipsEl.innerHTML = nonZero.slice(0, 6).map((t, i) => {
        const label = TOPIC_LABELS[t.topic] ?? t.topic;
        return `<span class="tip-rail-hot__chip" data-rank="${i + 1}">
          ${escapeHtml(label)}
          <span class="tip-rail-hot__chip-count">${Number(t.count)}</span>
        </span>`;
      }).join('');
    } catch {
      hotChipsEl.innerHTML = '<span class="tip-rail-hot__empty">Network error.</span>';
    }
  }
  refreshHotTopics();

  function setStatus(message: string, state: 'success' | 'error' | '') {
    if (!status) return;
    status.textContent = message;
    if (state) status.setAttribute('data-state', state);
    else status.removeAttribute('data-state');
  }

  function updateCounter() {
    if (!textarea || !counter) return;
    counter.textContent = `${textarea.value.length} / 500`;
  }

  textarea?.addEventListener('input', updateCounter);
  updateCounter();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !textarea) return;

    const fd = new FormData(form);
    const text = String(fd.get('text') ?? '').trim();
    const topic = String(fd.get('topic') ?? '');
    const franchiseHint = String(fd.get('franchiseHint') ?? '');

    if (!text) {
      setStatus('Tip cannot be empty.', 'error');
      return;
    }

    submitBtn.disabled = true;
    setStatus('Sending…', '');

    try {
      const res = await fetch('/api/schefter/tip', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, topic, franchiseHint }),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok && data?.ok) {
        setStatus("Schefter's got it. He'll use it when the time is right.", 'success');
        form.reset();
        updateCounter();
        syncPlaceholder();
        refreshRemaining();
      } else {
        const msg = (data && typeof data.error === 'string' && data.error) ||
          (res.status === 429 ? "You've hit the 3-tips-per-24h cap. Try again tomorrow." :
           res.status === 401 ? 'Please sign in to tip Schefter.' :
           res.status === 503 ? 'Tip system is temporarily unavailable. Try again shortly.' :
           'Something went wrong. Try again.');
        setStatus(msg, 'error');
        if (res.status === 429) refreshRemaining();
      }
    } catch (err) {
      console.error('[tip] submit error', err);
      setStatus('Network error. Try again.', 'error');
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
