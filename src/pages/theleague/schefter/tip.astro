---
/**
 * Tip Schefter — /theleague/schefter/tip
 *
 * Thin wrapper: auth + layout. The whole page lives in the shared
 * components/schefter/TipPage.astro so TheLeague and the AFL render the
 * same form/rails and inherit improvements together.
 */
export const prerender = false;

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import TipPage from '../../../components/schefter/TipPage.astro';
import { getAuthUser } from '../../../utils/auth';
import { getLeagueBySlug } from '../../../config/leagues';
import { getSchefterFeed, getSchefterLeagueConfig } from '../../../utils/schefter-league';

const user = getAuthUser(Astro.request);
if (!user?.franchiseId) {
  return Astro.redirect('/theleague/login?redirect=/theleague/schefter/tip');
}

const league = getLeagueBySlug('theleague')!;
const feed = getSchefterFeed(league);
const teams = getSchefterLeagueConfig(league).teams;
---

<TheLeagueLayout title="Tip Schefter">
  <TipPage
    navSlug="theleague"
    base="/theleague"
    leagueName="The League"
    feed={feed}
    teams={teams}
  />
</TheLeagueLayout>
