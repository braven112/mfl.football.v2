---
/**
 * Tip Schefter — /theleague/schefter/tip
 *
 * Anonymous tip form for the Schefter Rumor Mill. Authenticated only.
 * Tips are hashed server-side (see utils/schefter-tipster-hash.ts) and
 * queued in Redis. Scanner drains the queue, anonymizes, and posts a
 * rumor-mill Schefter report at most 3x/day.
 */
export const prerender = false;

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import Breadcrumbs from '../../../components/theleague/Breadcrumbs.astro';
import { getAuthUser } from '../../../utils/auth';
import theLeagueConfig from '../../../data/theleague.config.json';
import { chooseTeamName } from '../../../utils/team-names';
import { getAuthor, getAuthorAvatar } from '../../../types/schefter';
import feedData from '../../../data/theleague/schefter-feed.json';
import type { SchefterFeed as FeedType } from '../../../types/schefter';
import '../../../styles/schefter-feed.css';

const feed = feedData as FeedType;
const schefterArticles = feed.posts
  .filter((p: any) => p.type === 'article' && (p.authorId === 'claude' || p.authorId === 'claude-schefter'))
  .sort((a: any, b: any) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime())
  .slice(0, 3);

// Phase 2 — last rumor dropped: newest rumor_mill post, for the sidebar.
const lastRumor = feed.posts
  .filter((p: any) => p.type === 'transaction' && p.transactionSubType === 'rumor_mill')
  .sort((a: any, b: any) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime())[0] ?? null;

const lastRumorSnippet = (() => {
  if (!lastRumor) return null;
  const raw = String(lastRumor.body ?? '').replace(/<[^>]+>/g, '').trim();
  if (!raw) return null;
  // Pull first sentence (end-of-sentence punctuation) or first ~100 chars.
  const match = raw.match(/^[^.!?]+[.!?]/);
  const sentence = match ? match[0] : raw;
  return sentence.length > 120 ? sentence.slice(0, 117).trimEnd() + '…' : sentence;
})();

const schefterAuthor = getAuthor('claude-schefter');
const schefterAvatar = schefterAuthor ? getAuthorAvatar(schefterAuthor) : '/assets/claude-schefter-avatar.webp';

const user = getAuthUser(Astro.request);
if (!user?.franchiseId) {
  return Astro.redirect('/theleague/login?redirect=/theleague/schefter/tip');
}

type TeamConfig = {
  franchiseId: string;
  name: string;
  nameMedium?: string;
  nameShort?: string;
  abbrev?: string;
  division?: string;
};

const teams = ((theLeagueConfig as { teams?: TeamConfig[] }).teams ?? [])
  .slice()
  .sort((a, b) => {
    const da = a.division ?? '';
    const db = b.division ?? '';
    if (da !== db) return da.localeCompare(db);
    return a.name.localeCompare(b.name);
  });

const franchiseOptions = teams.map((t) => ({
  franchiseId: t.franchiseId,
  label: chooseTeamName(
    {
      fullName: t.name,
      nameMedium: t.nameMedium,
      nameShort: t.nameShort,
      abbrev: t.abbrev,
    },
    'default',
  ),
  division: t.division,
}));
---

<TheLeagueLayout title="Tip Schefter">
  <main class="tip-page">
    <div class="tip-main">
      <header class="tip-hero tip-hero--persona">
        <Breadcrumbs items={[
          { label: 'The League', href: '/theleague' },
          { label: 'The Schefter Report', href: '/theleague/news' },
          { label: 'Tip Schefter' },
        ]} />
        <p class="tip-hero__eyebrow">Schefter Rumor Mill</p>
        <div class="sf-page-header tip-hero__persona-card">
          <div class="sf-page-header__persona">
            <img
              class="sf-page-header__avatar"
              src={schefterAvatar}
              alt=""
              aria-hidden="true"
              width="48"
              height="48"
              loading="eager"
            />
            <div>
              <h1 class="sf-page-header__name">{schefterAuthor?.name ?? 'Claude Schefter'}</h1>
              <div class="sf-page-header__handle">{schefterAuthor?.handle ?? '@ClaudeSchefter'}</div>
            </div>
          </div>
          <p class="sf-page-header__bio">{schefterAuthor?.bio}</p>
        </div>
        <p class="tip-hero__lede">
          Got a hunch, a grievance, a leak, or a straight-up personal shot at another owner?
          Schefter's listening. <strong>Go ahead — be as mean as you can think of.</strong> Every tip gets
          filtered through the beat-reporter desk before it's printed. Only innuendo, rumor, and
          feeling survive the edit. Nobody sees what you actually wrote.
        </p>
      </header>

      <form class="tip-card tip-form" id="tip-form" novalidate>
      <div class="section-header">
        <h2 class="section-header__title">Your tip</h2>
        <p class="section-header__sub">500 characters. Make it count.</p>
      </div>

      <div class="tip-field">
        <label class="tip-field__label" for="tip-text">Tip</label>
        <textarea
          class="tip-field__textarea"
          id="tip-text"
          name="text"
          maxlength="500"
          rows="6"
          placeholder="e.g. Hearing someone in the Northwest is shopping their 1st for a vet WR..."
          required
        ></textarea>
        <div class="tip-field__meta">
          <span class="tip-field__counter" id="tip-counter" aria-live="polite">0 / 500</span>
        </div>
      </div>

      <div class="tip-field-row">
        <div class="tip-field">
          <label class="tip-field__label" for="tip-topic">Topic</label>
          <select class="tip-field__select" id="tip-topic" name="topic" required>
            <option value="trade">Trade interest</option>
            <option value="roster">Roster gripe</option>
            <option value="prediction">Bold prediction</option>
            <option value="commish">Beef</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="tip-field">
          <label class="tip-field__label" for="tip-franchise">About which team?</label>
          <select class="tip-field__select" id="tip-franchise" name="franchiseHint">
            <option value="league-wide">League-wide</option>
            <option value="commish" data-commish>The Commish</option>
            {franchiseOptions.map((t) => (
              <option value={t.franchiseId}>{t.label}{t.division ? ` — ${t.division}` : ''}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="tip-actions">
        <button type="submit" class="tip-submit" id="tip-submit">Send tip</button>
        <span class="tip-remaining" id="tip-remaining" data-state="loading" aria-live="polite">
          <span class="tip-remaining__text" id="tip-remaining-text">Checking tips left…</span>
        </span>
        <p class="tip-status" id="tip-status" role="status" aria-live="polite"></p>
      </div>
    </form>

      <section class="tip-rail-card tip-rail-leaderboard" aria-labelledby="leaderboard-title" data-tipster-leaderboard>
        <div class="section-header">
          <h2 class="section-header__title" id="leaderboard-title">Top tipsters this season</h2>
          <p class="section-header__sub" data-tipster-leaderboard-sub>By rumors seeded.</p>
        </div>
        <ol class="tip-rail-leaderboard__list" data-tipster-leaderboard-list>
          <li class="tip-rail-leaderboard__loading" data-tipster-leaderboard-loading>Loading the board…</li>
        </ol>
      </section>

      <details class="tip-rail-card tip-rail-examples">
        <summary class="tip-rail-examples__summary">
          <span class="tip-rail-examples__label">Good tip vs. what Schefter prints</span>
          <svg class="tip-rail-examples__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </summary>
        <div class="tip-rail-examples__body">
          <p class="tip-rail-examples__intro">
            Schefter fuzzes every tip. Name a team and he'll generalize to the division — unless multiple
            owners whisper the same thing.
          </p>
          <div class="tip-rail-example">
            <span class="tip-rail-example__label">Single-source franchise mention</span>
            <div class="tip-rail-example__pair">
              <div class="tip-rail-example__row tip-rail-example__row--tip">
                <span class="tip-rail-example__row-label">You tip</span>
                <span class="tip-rail-example__row-text">"The Magicians are shopping their 1.03 for a WR."</span>
              </div>
              <div class="tip-rail-example__row tip-rail-example__row--print">
                <span class="tip-rail-example__row-label">Schefter prints</span>
                <span class="tip-rail-example__row-text">"Sources tell me a team in the East is dangling a top rookie pick for WR help. Developing."</span>
              </div>
            </div>
          </div>
          <div class="tip-rail-example">
            <span class="tip-rail-example__label">Multi-source franchise mention</span>
            <div class="tip-rail-example__pair">
              <div class="tip-rail-example__row tip-rail-example__row--tip">
                <span class="tip-rail-example__row-label">You + another owner</span>
                <span class="tip-rail-example__row-text">"The Magicians are shopping their 1.03."</span>
              </div>
              <div class="tip-rail-example__row tip-rail-example__row--print">
                <span class="tip-rail-example__row-label">Schefter prints</span>
                <span class="tip-rail-example__row-text">"League sources tell me multiple owners are talking about the Dark Magicians. Worth watching."</span>
              </div>
            </div>
          </div>
          <div class="tip-rail-example">
            <span class="tip-rail-example__label">The Commish</span>
            <div class="tip-rail-example__pair">
              <div class="tip-rail-example__row tip-rail-example__row--tip">
                <span class="tip-rail-example__row-label">You tip</span>
                <span class="tip-rail-example__row-text">"The Commish is sandbagging the trade review window."</span>
              </div>
              <div class="tip-rail-example__row tip-rail-example__row--print">
                <span class="tip-rail-example__row-label">Schefter prints</span>
                <span class="tip-rail-example__row-text">"Word around the league is the commissioner's office is drawing some static. Developing."</span>
              </div>
            </div>
          </div>
          <div class="tip-rail-example">
            <span class="tip-rail-example__label">Straight-up personal shot</span>
            <div class="tip-rail-example__pair">
              <div class="tip-rail-example__row tip-rail-example__row--tip">
                <span class="tip-rail-example__row-label">You tip</span>
                <span class="tip-rail-example__row-text">"Brandon plays baseball like a girl."</span>
              </div>
              <div class="tip-rail-example__row tip-rail-example__row--print">
                <span class="tip-rail-example__row-label">Schefter prints</span>
                <span class="tip-rail-example__row-text">"Tempers running hot this week. Somebody's not in a mood to respect the commissioner's office. We'll leave it there."</span>
              </div>
            </div>
          </div>
          <div class="tip-rail-example">
            <span class="tip-rail-example__label">Crude owner-on-owner shot</span>
            <div class="tip-rail-example__pair">
              <div class="tip-rail-example__row tip-rail-example__row--tip">
                <span class="tip-rail-example__row-label">You tip</span>
                <span class="tip-rail-example__row-text">"[Owner] is a bald loser who smells bad."</span>
              </div>
              <div class="tip-rail-example__row tip-rail-example__row--print">
                <span class="tip-rail-example__row-label">Schefter prints</span>
                <span class="tip-rail-example__row-text">"Patience wearing thin with one of the league's desks. Not every corner is harmonious this week. Developing."</span>
              </div>
            </div>
          </div>
        </div>
      </details>

      <section class="tip-rail-card" aria-labelledby="how-it-works-title">
        <div class="section-header">
          <h2 class="section-header__title" id="how-it-works-title">How this works</h2>
          <p class="section-header__sub">Anonymity is the whole point. So is the filter.</p>
        </div>
        <ul class="tip-rail-rules">
          <li class="tip-rail-rule">
            <span class="tip-rail-rule__label">Be mean</span>
            <p class="tip-rail-rule__text">
              The editorial filter is the feature. Pure shots, personal jabs, crude jokes — they all
              get translated into innuendo and feeling before the post goes out. Only the sentiment
              survives. Go for it.
            </p>
          </li>
          <li class="tip-rail-rule">
            <span class="tip-rail-rule__label">Anonymous</span>
            <p class="tip-rail-rule__text">
              Tips are stored with a one-way hash of your user id. Not even the commish can see who
              sent what.
            </p>
          </li>
          <li class="tip-rail-rule">
            <span class="tip-rail-rule__label">Rate</span>
            <p class="tip-rail-rule__text">
              At most <strong>3 rumor-mill posts per day</strong>. Schefter sits on every tip for an
              hour before saying anything.
            </p>
          </li>
          <li class="tip-rail-rule">
            <span class="tip-rail-rule__label">Fuzz</span>
            <p class="tip-rail-rule__text">
              Name a team and Schefter may generalize to the division unless multiple owners are
              whispering about the same franchise.
            </p>
          </li>
          <li class="tip-rail-rule">
            <span class="tip-rail-rule__label">Limits</span>
            <p class="tip-rail-rule__text"><strong>3 tips per owner per 24 hours.</strong> Make them count.</p>
          </li>
        </ul>
      </section>
    </div>

    <aside class="tip-rail" aria-label="How tips work and recent reports">
      {lastRumor && lastRumorSnippet && (
        <section class="tip-rail-card tip-rail-last-rumor" aria-labelledby="last-rumor-title">
          <div class="section-header">
            <h2 class="section-header__title" id="last-rumor-title">Last rumor dropped</h2>
            <p class="section-header__sub" data-relative-time={lastRumor.timestamp}>
              {new Date(lastRumor.timestamp).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })}
            </p>
          </div>
          <a href={`/theleague/news?source=theleague#${lastRumor.id}`} class="tip-rail-last-rumor__link">
            <span class="tip-rail-last-rumor__snippet">"{lastRumorSnippet}"</span>
            <span class="tip-rail-last-rumor__cta">
              Read the feed
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </span>
          </a>
        </section>
      )}

      <section class="tip-rail-card tip-rail-cooker" aria-labelledby="cooker-title" data-cooker-status>
        <div class="section-header">
          <h2 class="section-header__title" id="cooker-title">Schefter's kitchen</h2>
          <p class="section-header__sub" data-cooker-sub>Checking on the pot…</p>
        </div>
        <p class="tip-rail-cooker__body" data-cooker-body>Loading…</p>
      </section>

      <section class="tip-rail-card tip-rail-hot" aria-labelledby="hot-title" data-hot-topics>
        <div class="section-header">
          <h2 class="section-header__title" id="hot-title">Hot topics this week</h2>
          <p class="section-header__sub">Last 7 days · all tipsters.</p>
        </div>
        <div class="tip-rail-hot__chips" data-hot-topics-chips>
          <span class="tip-rail-hot__loading">Loading…</span>
        </div>
      </section>

      <section class="tip-rail-card tip-rail-record" aria-labelledby="record-title" data-tipster-record>
        <div class="section-header">
          <h2 class="section-header__title" id="record-title">Your record</h2>
          <p class="section-header__sub">Every tip is anonymous — this is between you and the hash.</p>
        </div>
        <div class="tip-rail-record__body" data-tipster-record-body>
          <p class="tip-rail-record__loading" data-tipster-record-loading>Checking the Rolodex…</p>
        </div>
      </section>

      {schefterArticles.length > 0 && (
        <section class="tip-rail-section" aria-label="Featured articles from Claude Schefter">
          <h2 class="tip-rail-section__title">From the Schefter Report</h2>
          <ul class="tip-rail-articles">
            {schefterArticles.map((article: any) => (
              <li class="tip-rail-articles__item">
                <a href={article.link ?? `/theleague/news/${article.id}`} class="tip-rail-article-card">
                  {article.image && (
                    <img
                      src={`/assets/schefter/${article.image}`}
                      alt={article.imageAlt ?? ''}
                      class="tip-rail-article-card__image"
                      width="240"
                      height="135"
                      loading="lazy"
                    />
                  )}
                  <div class="tip-rail-article-card__body">
                    <div class="tip-rail-article-card__meta">
                      {new Date(article.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                    </div>
                    <div class="tip-rail-article-card__headline">{article.headline}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
          <a href="/theleague/news" class="tip-rail-feed-link">
            Read the full feed
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
        </section>
      )}
    </aside>
  </main>
</TheLeagueLayout>

<style>
  .tip-page {
    max-width: 60rem;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 1.5rem;
    align-items: start;
    color: var(--color-gray-800, #1f2937);
  }

  .tip-main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-width: 0;
  }

  .tip-rail {
    position: sticky;
    top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  @media (max-width: 860px) {
    .tip-page {
      grid-template-columns: 1fr;
      max-width: 44rem;
    }
    .tip-rail {
      position: static;
    }
  }

  .tip-hero {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tip-hero--persona {
    gap: 0.75rem;
  }
  /* Neutralize the sf-page-header card chrome when embedded in the hero */
  .tip-hero__persona-card {
    padding: 0;
    background: transparent;
    border-bottom: none;
  }
  .tip-hero__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary, #1c497c);
    margin: 0;
  }
  .tip-hero__title {
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: var(--color-gray-900, #111827);
  }
  .tip-hero__lede {
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    color: var(--color-gray-600, #4b5563);
  }

  .tip-card {
    background: var(--color-white, #ffffff);
    border: 1px solid var(--color-gray-100, #f3f4f6);
    border-radius: 0.75rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }
  .section-header__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    color: var(--color-gray-800, #1f2937);
  }
  .section-header__sub {
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0;
  }

  .tip-detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .tip-detail-row {
    display: flex;
    gap: 1rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .tip-detail-row:last-child {
    border-bottom: none;
  }
  .tip-detail-row__label {
    flex: 0 0 5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500, #6b7280);
    padding-top: 0.0625rem;
  }
  .tip-detail-row__value {
    flex: 1;
    color: var(--color-gray-700, #374151);
  }
  .tip-detail-row__value strong {
    font-weight: 600;
    color: var(--color-gray-900, #111827);
    font-variant-numeric: tabular-nums;
  }

  .tip-form {
    gap: 1.25rem;
  }

  .tip-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .tip-field__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500, #6b7280);
  }
  .tip-field__textarea,
  .tip-field__select {
    font: inherit;
    font-size: 0.9375rem;
    color: var(--color-gray-900, #111827);
    background: var(--color-white, #ffffff);
    border: 1px solid var(--color-gray-200, #e5e7eb);
    border-radius: 0.5rem;
    padding: 0.625rem 0.75rem;
    width: 100%;
    box-sizing: border-box;
  }
  .tip-field__textarea {
    resize: vertical;
    min-height: 6rem;
    line-height: 1.5;
  }
  .tip-field__textarea:focus-visible,
  .tip-field__select:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 1px;
    border-color: var(--color-primary, #1c497c);
  }
  .tip-field__meta {
    display: flex;
    justify-content: flex-end;
  }
  .tip-field__counter {
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
    font-variant-numeric: tabular-nums;
  }

  .tip-field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 480px) {
    .tip-field-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .tip-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
  }
  .tip-actions .tip-status {
    flex-basis: 100%;
  }
  .tip-remaining {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gray-600, #4b5563);
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--color-gray-100, #f3f4f6);
    font-variant-numeric: tabular-nums;
  }
  .tip-remaining[data-state='empty'] {
    color: var(--color-error-dark, #b91c1c);
    background: color-mix(in srgb, var(--color-error-dark, #b91c1c) 8%, transparent);
    border-color: color-mix(in srgb, var(--color-error-dark, #b91c1c) 20%, transparent);
  }
  .tip-remaining[data-state='loading'] {
    opacity: 0.6;
  }
  .tip-submit {
    font: inherit;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-white, #ffffff);
