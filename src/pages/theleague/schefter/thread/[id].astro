---
/**
 * Rumor Thread Permalink — /theleague/schefter/thread/[threadId]
 *
 * Thin wrapper over the shared components/schefter/RumorThread.astro.
 * Server-rendered so we can gate the permalink at edge-middleware without
 * prerender caching stale thread state.
 */
export const prerender = false;

import TheLeagueLayout from '../../../../layouts/TheLeagueLayout.astro';
import RumorThread from '../../../../components/schefter/RumorThread.astro';
import { getLeagueBySlug } from '../../../../config/leagues';
import { getSchefterFeed } from '../../../../utils/schefter-league';

const { id } = Astro.params;
if (!id) return Astro.redirect('/theleague/news');

const feed = getSchefterFeed(getLeagueBySlug('theleague')!);
---

<TheLeagueLayout title="Rumor thread — The Schefter Report">
  <RumorThread
    navSlug="theleague"
    base="/theleague"
    leagueName="The League"
    feed={feed}
    threadId={id}
  />
</TheLeagueLayout>
