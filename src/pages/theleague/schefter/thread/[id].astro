  }
  .sf-thread__tip-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #1c497c);
    text-decoration: none;
  }
  .sf-thread__tip-link:hover {
    text-decoration: underline;
  }
</style>
