---
/**
 * /theleague/schefter — bare "/schefter" has no page of its own; the
 * Schefter Report feed lives at /news. People type or truncate the URL
 * (every schefter surface links deeper: /schefter/tip, /schefter/thread/…),
 * so send them to the feed instead of a 404.
 */
export const prerender = false;

return Astro.redirect('/theleague/news', 301);
---
