---
/**
 * Scheftner Article Detail Page
 *
 * Renders full-length articles from the Scheftner feed.
 * Follows the What's New editorial pattern with author card and metadata.
 * Prerendered at build time from article posts in scheftner-feed.json.
 */
export const prerender = true;

import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import ScheftnerReactionBar from '../../../components/shared/ScheftnerReactionBar.tsx';
import { formatRelativeTime } from '../../../utils/scheftner-feed';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import feedData from '../../../data/theleague/scheftner-feed.json';
import type { ScheftnerFeed, ScheftnerPost, AuctionGrade } from '../../../types/scheftner';
import '../../../styles/scheftner-feed.css';

export function getStaticPaths() {
  const feed = feedData as ScheftnerFeed;
  const articles = feed.posts.filter(p => p.type === 'article' && (p.content || p.grades));
  return articles.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: ScheftnerPost;
}

const { post } = Astro.props;
const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);
const imagePath = post.image ? `/assets/scheftner/${post.image}` : null;
const formattedDate = new Date(post.timestamp).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const isGradeArticle = !!(post.grades && post.grades.length > 0);

function gradeColor(grade: string): string {
  const letter = grade.charAt(0);
  if (letter === 'A') return '#16a34a'; // green
  if (letter === 'B') return '#2563eb'; // blue
  if (letter === 'C') return '#d97706'; // amber
  if (letter === 'D') return '#ea580c'; // orange
  return '#dc2626'; // red for F
}
---

<TheLeagueLayout title={`${post.headline} — The Scheftner Report`}>
  <main class="sf-article">

    <!-- Back link -->
    <a href={r('/theleague/news')} class="sf-article__back">
      <svg class="sf-article__back-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 3L5 8l5 5" />
      </svg>
      The Scheftner Report
    </a>

    <div class="sf-article__card">
      <!-- Hero image -->
      {imagePath && (
        <div class="sf-article__hero-wrap">
          <img
            src={imagePath}
            alt={post.imageAlt ?? post.headline}
            class="sf-article__hero-img"
            loading="eager"
          />
        </div>
      )}

      <!-- Header -->
      <div class="sf-article__header">
        <div class="sf-article__meta">
          <span class="sf-article__badge">Article</span>
          <span class="sf-article__meta-dot" aria-hidden="true"></span>
          <time class="sf-article__date" datetime={post.timestamp}>{formattedDate}</time>
        </div>

        <h1 class="sf-article__title">{post.headline}</h1>

        <!-- Author row -->
        <div class="sf-article__author">
          <img class="sf-article__author-avatar" src="/assets/claude-schefter-avatar.webp" alt="" aria-hidden="true" width="32" height="32" />
          <div>
            <span class="sf-article__author-name">Claude Schefter</span>
            <span class="sf-article__author-handle">@schefter</span>
          </div>
        </div>
      </div>

      <!-- Article body -->
      {isGradeArticle ? (
        <Fragment>
        <div class="sf-article__body">
          {/* Intro paragraphs */}
          {post.intro?.map(paragraph => (
            <p set:html={paragraph} />
          ))}
        </div>

        <div class="sf-grades">
          {post.grades!.map((g: AuctionGrade) => (
            <div class="sf-grade-card" style={`--grade-accent: ${g.color || '#666'};`}>
              <div class="sf-grade-card__header">
                <div class="sf-grade-card__team">
                  <span class="sf-grade-card__team-name">{g.teamName}</span>
                  <span class="sf-grade-card__headline">{g.headline}</span>
                </div>
                <div class="sf-grade-card__badge" style={`--grade-color: ${gradeColor(g.grade)};`}>
                  {g.grade}
                </div>
              </div>

              <div class="sf-grade-card__body" set:html={g.body} />

              <div class="sf-grade-card__stats">
                <div class="sf-grade-card__stat">
                  <span class="sf-grade-card__stat-value">{g.playerCount}</span>
                  <span class="sf-grade-card__stat-label">Players</span>
                </div>
                <div class="sf-grade-card__stat">
                  <span class="sf-grade-card__stat-value">{g.auctionSpendDisplay}</span>
                  <span class="sf-grade-card__stat-label">Spent</span>
                </div>
                <div class="sf-grade-card__stat">
                  <span class="sf-grade-card__stat-value">{g.postCapSpaceDisplay}</span>
                  <span class="sf-grade-card__stat-label">Cap Left</span>
                </div>
              </div>

              {/* Acquisitions list */}
              {g.pickups && g.pickups.length > 0 && (
                <div class="sf-grade-card__pickups">
                  <span class="sf-grade-card__pickups-title">Acquisitions</span>
                  <div class="sf-grade-card__pickups-list">
                    {g.pickups.map(p => (
                      <div class="sf-grade-card__pickup">
                        <span class="sf-grade-card__pickup-pos">{p.position}</span>
                        <span class="sf-grade-card__pickup-name">{p.name}</span>
                        <span class="sf-grade-card__pickup-salary">{p.salary}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Holes remaining warning */}
              {g.holesRemaining && g.holesRemaining.length > 0 && (
                <div class="sf-grade-card__holes">
                  Still need: {g.holesRemaining.join(', ')}
                </div>
              )}
            </div>
          ))}
        </div>
        </Fragment>
      ) : (
        <div class="sf-article__body">
          {post.content?.map(paragraph => (
            <p set:html={paragraph} />
          ))}
        </div>
      )}

      <!-- Reactions -->
      <div class="sf-article__reactions">
        <ScheftnerReactionBar
          client:visible
          postId={post.id}
          isAuthenticated={false}
        />
      </div>

      <!-- Back to feed -->
      <div class="sf-article__footer">
        <a href={r('/theleague/news')} class="sf-article__footer-link">
          ← More from The Scheftner Report
        </a>
      </div>
    </div>
  </main>
</TheLeagueLayout>

<style>
  .sf-article {
    max-width: 40rem;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .sf-article__back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sf-text-secondary, #536471);
    text-decoration: none;
    margin-bottom: 0.75rem;
    padding: 0.25rem 0;
  }

  .sf-article__back:hover {
    color: var(--sf-accent, #1c497c);
  }

  .sf-article__back-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .sf-article__card {
    background: var(--sf-bg, #fff);
    border: 1px solid var(--sf-border, #e5e7eb);
    border-radius: var(--radius-lg, 0.75rem);
    overflow: hidden;
  }

  .sf-article__hero-wrap {
    line-height: 0;
  }

  .sf-article__hero-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .sf-article__header {
    padding: 1.25rem 1.25rem 0;
  }

  .sf-article__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }

  .sf-article__badge {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-secondary, #2e8743) 12%, transparent);
    color: var(--color-secondary, #2e8743);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .sf-article__meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--sf-text-secondary, #536471);
  }

  .sf-article__date {
    font-size: 0.8125rem;
    color: var(--sf-text-secondary, #536471);
  }

  .sf-article__title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--sf-text-primary, #0f1419);
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .sf-article__author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--sf-border, #e5e7eb);
  }

  .sf-article__author-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .sf-article__author-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sf-text-primary, #0f1419);
  }

  .sf-article__author-handle {
    font-size: 0.8125rem;
    color: var(--sf-text-secondary, #536471);
    margin-left: 0.25rem;
  }

  .sf-article__body {
    padding: 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sf-text-body, #1f2937);
  }

  .sf-article__body p {
    margin: 0 0 1rem;
  }

  .sf-article__body p:last-child {
    margin-bottom: 0;
  }

  .sf-article__body :global(strong) {
    font-weight: 700;
    color: var(--sf-text-primary, #0f1419);
  }

  .sf-article__body :global(em) {
    font-style: italic;
  }

  .sf-article__reactions {
    padding: 0 1.25rem 1rem;
    border-top: 1px solid var(--sf-border, #e5e7eb);
    padding-top: 0.75rem;
  }

  .sf-article__footer {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--sf-border, #e5e7eb);
    text-align: center;
  }

  .sf-article__footer-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sf-accent, #1c497c);
    text-decoration: none;
  }

  .sf-article__footer-link:hover {
    text-decoration: underline;
  }

  /* ── Grade Cards ── */

  .sf-grades {
    padding: 0 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sf-grade-card {
    border: 1px solid var(--sf-border, #e5e7eb);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
    border-left: 3px solid var(--grade-accent, #666);
  }

  .sf-grade-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1rem 0.625rem;
    background: var(--color-gray-50, #f9fafb);
  }

  .sf-grade-card__team {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .sf-grade-card__team-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--sf-text-primary, #0f1419);
    line-height: 1.2;
  }

  .sf-grade-card__headline {
    font-size: 0.8125rem;
    color: var(--sf-text-secondary, #536471);
    font-style: italic;
    line-height: 1.3;
  }

  .sf-grade-card__badge {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--grade-color, #2563eb);
    color: #fff;
    font-size: 1.125rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .sf-grade-card__body {
    padding: 0.625rem 1rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--sf-text-body, #1f2937);
  }

  .sf-grade-card__body :global(p) {
    margin: 0;
  }

  .sf-grade-card__body :global(strong) {
    font-weight: 700;
    color: var(--sf-text-primary, #0f1419);
  }

  .sf-grade-card__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--sf-border, #e5e7eb);
    margin: 0 1rem;
    border-radius: var(--radius-sm, 0.25rem);
    overflow: hidden;
  }

  .sf-grade-card__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    padding: 0.5rem 0.25rem;
    background: var(--color-gray-50, #f9fafb);
  }

  .sf-grade-card__stat-value {
    font-size: 0.875rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--sf-text-primary, #0f1419);
  }

  .sf-grade-card__stat-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
  }

  .sf-grade-card__pickups {
    padding: 0.625rem 1rem 0.75rem;
  }

  .sf-grade-card__pickups-title {
    display: block;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
    margin-bottom: 0.375rem;
  }

  .sf-grade-card__pickups-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sf-grade-card__pickup {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  .sf-grade-card__pickup-pos {
    flex-shrink: 0;
    width: 2rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-gray-400, #9ca3af);
  }

  .sf-grade-card__pickup-name {
    flex: 1;
    min-width: 0;
    color: var(--sf-text-primary, #0f1419);
    font-weight: 500;
  }

  .sf-grade-card__pickup-salary {
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    color: var(--sf-text-secondary, #536471);
    font-size: 0.8125rem;
  }

  .sf-grade-card__holes {
    padding: 0.5rem 1rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-warning, #d97706);
    border-top: 1px solid var(--sf-border, #e5e7eb);
  }

  @media (max-width: 640px) {
    .sf-article {
      padding: 0.5rem 0;
    }

    .sf-article__title {
      font-size: 1.25rem;
    }

    .sf-article__header {
      padding: 1rem 1rem 0;
    }

    .sf-article__body {
      padding: 1rem;
    }

    .sf-article__reactions {
      padding: 0 1rem 0.75rem;
    }

    .sf-article__footer {
      padding: 0.75rem 1rem;
    }

    .sf-grades {
      padding: 0 0.75rem 1rem;
      gap: 0.75rem;
    }

    .sf-grade-card__header {
      padding: 0.75rem 0.75rem 0.5rem;
    }

    .sf-grade-card__body {
      padding: 0.5rem 0.75rem;
    }

    .sf-grade-card__stats {
      margin: 0 0.75rem;
    }

    .sf-grade-card__pickups {
      padding: 0.5rem 0.75rem 0.625rem;
    }

    .sf-grade-card__holes {
      padding: 0.375rem 0.75rem 0.625rem;
    }

    .sf-grade-card__badge {
      width: 2.5rem;
      height: 2.5rem;
      font-size: 1rem;
    }
  }
</style>
