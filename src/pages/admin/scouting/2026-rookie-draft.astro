---
/**
 * /admin/scouting/2026-rookie-draft
 *
 * Pre-draft scouting report for the 2026 rookie draft. Renders per-franchise
 * GM briefs and the assembled 3-round mock from the generator output.
 *
 * Generated by: pnpm scout:rookie-draft 2026
 */
import TheLeagueLayout from '../../../layouts/TheLeagueLayout.astro';
import { getAuthUser, isCommissionerOrAdmin } from '../../../utils/auth';
import leagueConfigData from '../../../data/theleague.config.json';
import type { EventReport, ReportMeta } from '../../../types/scouting-system';

export const prerender = false;

const user = getAuthUser(Astro.request);
if (!user) return Astro.redirect('/login?next=/admin/scouting/2026-rookie-draft');
if (!isCommissionerOrAdmin(user)) return Astro.redirect('/');

const REPORT_YEAR = 2026;
const EVENT_TYPE = 'rookie-draft';

// ── Load report (if generated) ──────────────────────────────────────
// import.meta.glob is graceful when files are missing — needed because the
// page must build even before the generator has written its output.
const getModuleData = (mod: unknown) =>
  mod && typeof mod === 'object' && 'default' in mod
    ? (mod as { default: unknown }).default
    : mod;

const reportModules = import.meta.glob(
  '../../../../data/fantasy-expert/scouting-system/reports/2026-rookie-draft/predictions.json',
  { eager: true },
);
const metaModules = import.meta.glob(
  '../../../../data/fantasy-expert/scouting-system/reports/2026-rookie-draft/meta.json',
  { eager: true },
);

const reportKey = Object.keys(reportModules)[0];
const metaKey = Object.keys(metaModules)[0];
const report = reportKey ? (getModuleData(reportModules[reportKey]) as EventReport) : null;
const meta = metaKey ? (getModuleData(metaModules[metaKey]) as ReportMeta) : null;

// ── Team config lookup ──────────────────────────────────────────────
type TeamCfg = { franchiseId: string; name: string; nameShort: string; abbrev: string; division: string; icon: string; color: string };
const teamsList = (leagueConfigData.teams ?? []) as TeamCfg[];
const teamById = new Map<string, TeamCfg>(teamsList.map(t => [t.franchiseId, t]));

const briefs = report?.briefs ?? [];
const mock = report?.mock ?? [];
const marketNotes = report?.marketNotes ?? [];

// Group mock by round
const mockByRound = new Map<number, typeof mock>();
for (const pick of mock) {
  const arr = mockByRound.get(pick.round) ?? [];
  arr.push(pick);
  mockByRound.set(pick.round, arr);
}
const sortedRounds = Array.from(mockByRound.keys()).sort((a, b) => a - b);
---

<TheLeagueLayout title="2026 Rookie Draft Scouting Report">
  <div class="scout-page">

    <header class="scout-hero">
      <div class="scout-hero__eyebrow">
        <a href="/admin/scouting" class="scout-hero__back">← Scouting Hub</a>
        <span>·</span>
        <span>2026 Rookie Draft</span>
      </div>
      <h1 class="scout-hero__title">2026 Rookie Draft Scouting Report</h1>
      <p class="scout-hero__meta">
        Per-franchise GM briefs and 3-round mock. Each owner is simulated independently using their dossier, RSP affinity, cap posture, and pick ownership.
      </p>
      {meta && (
        <div class="scout-hero__stamp">
          Generated {new Date(meta.generatedAt).toLocaleString()} · {meta.agentCallCount} agent calls · {meta.modelUsed}
        </div>
      )}
    </header>

    {!report && (
      <div class="scout-empty">
        <h2>No report generated yet</h2>
        <p>Run the generator locally and commit the result:</p>
        <pre><code>pnpm scout:rookie-draft 2026</code></pre>
        <p class="scout-empty__note">
          Output writes to <code>data/fantasy-expert/scouting-system/reports/2026-rookie-draft/</code>.
          Generation makes one Anthropic API call per franchise (~$0.50 total at current pricing).
        </p>
      </div>
    )}

    {report && (
      <>
        {marketNotes.length > 0 && (
          <section class="market-notes">
            <h2 class="section-title">Market Notes</h2>
            <ul class="market-notes__list">
              {marketNotes.map(note => <li>{note}</li>)}
            </ul>
          </section>
        )}

        <section class="mock-section">
          <h2 class="section-title">3-Round Mock Draft</h2>
          {sortedRounds.map(round => (
            <div class="mock-round">
              <h3 class="mock-round__title">Round {round}</h3>
              <div class="mock-round__list">
                {(mockByRound.get(round) ?? []).map(pick => {
                  const team = teamById.get(pick.franchiseId);
                  return (
                    <article class="mock-pick">
                      <div class="mock-pick__slot">
                        <span class="mock-pick__overall">{pick.overallPick}</span>
                        <span class="mock-pick__addr">{pick.round}.{String(pick.pickInRound).padStart(2, '0')}</span>
                      </div>
                      <div class="mock-pick__team">
                        {team?.icon && <img src={team.icon} alt={team.name} class="mock-pick__icon" />}
                        <div class="mock-pick__team-info">
                          <span class="mock-pick__team-name">{team?.nameShort ?? pick.franchiseName}</span>
                          <span class="mock-pick__pick-type">{pick.pickType}</span>
                        </div>
                      </div>
                      <div class="mock-pick__player">
                        <span class="mock-pick__player-name">{pick.player.name}</span>
                        <span class:list={['pos-pill', `pos-pill--${pick.player.position.toLowerCase()}`]}>{pick.player.position}</span>
                      </div>
                      <p class="mock-pick__reasoning">{pick.reasoning}</p>
                      {pick.alsoWantedBy && pick.alsoWantedBy.length > 0 && (
                        <p class="mock-pick__contested">
                          Also wanted by: {pick.alsoWantedBy.join(', ')}
                        </p>
                      )}
                    </article>
                  );
                })}
              </div>
            </div>
          ))}
        </section>

        <section class="briefs-section">
          <h2 class="section-title">Per-Franchise Briefs</h2>
          <div class="briefs-grid">
            {briefs.map(brief => {
              const team = teamById.get(brief.franchiseId);
              return (
                <article class="brief-card">
                  <header class="brief-card__header" style={`border-top-color: ${team?.color ?? '#1c497c'}`}>
                    {team?.icon && <img src={team.icon} alt={team.name} class="brief-card__icon" />}
                    <div>
                      <h3 class="brief-card__name">{team?.name ?? brief.franchiseName}</h3>
                      <p class="brief-card__cap">{brief.capPosture}</p>
                    </div>
                  </header>
                  <p class="brief-card__summary">{brief.summary}</p>

                  <div class="brief-card__section">
                    <h4 class="brief-card__section-title">Top Targets</h4>
                    <ol class="brief-card__targets">
                      {brief.topTargets.map(t => (
                        <li>
                          <div class="target-line">
                            <span class="target-name">{t.name}</span>
                            <span class:list={['pos-pill', `pos-pill--${t.position.toLowerCase()}`]}>{t.position}</span>
                            <span class="target-desire">{Math.round(t.desire * 100)}%</span>
                          </div>
                          <p class="target-reason">{t.reasoning}</p>
                        </li>
                      ))}
                    </ol>
                  </div>

                  {brief.wildcard && (
                    <div class="brief-card__section brief-card__section--wildcard">
                      <h4 class="brief-card__section-title">Wildcard</h4>
                      <div class="target-line">
                        <span class="target-name">{brief.wildcard.name}</span>
                        <span class:list={['pos-pill', `pos-pill--${brief.wildcard.position.toLowerCase()}`]}>{brief.wildcard.position}</span>
                      </div>
                      <p class="target-reason">{brief.wildcard.reasoning}</p>
                    </div>
                  )}

                  <div class="brief-card__section">
                    <h4 class="brief-card__section-title">Position Priority</h4>
                    <div class="brief-card__chips">
                      {brief.positionalPriority.map(p => (
                        <span class:list={['pos-pill', `pos-pill--${p.toLowerCase()}`]}>{p}</span>
                      ))}
                    </div>
                  </div>

                  {brief.taxiCandidates.length > 0 && (
                    <div class="brief-card__section">
                      <h4 class="brief-card__section-title">Taxi Candidates</h4>
                      <p class="brief-card__taxi">{brief.taxiCandidates.join(', ')}</p>
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      </>
    )}

  </div>
</TheLeagueLayout>

<style>
  .scout-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .scout-hero { margin-bottom: 1.5rem; }
  .scout-hero__eyebrow {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-500, #6b7280);
    margin-bottom: 0.375rem;
  }
  .scout-hero__back {
    color: var(--color-primary, #1c497c);
    text-decoration: none;
  }
  .scout-hero__back:hover { text-decoration: underline; }
  .scout-hero__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    color: var(--color-gray-900, #111827);
  }
  .scout-hero__meta {
    font-size: 0.875rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0 0 0.5rem;
  }
  .scout-hero__stamp {
    font-size: 0.75rem;
    color: var(--color-gray-400, #9ca3af);
    font-variant-numeric: tabular-nums;
  }

  .scout-empty {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px dashed var(--content-border, #e2e8f0);
    border-radius: 0.5rem;
    margin: 2rem 0;
  }
  .scout-empty h2 {
    font-size: 1.125rem;
    margin: 0 0 0.5rem;
    color: var(--color-gray-700, #374151);
  }
  .scout-empty p {
    color: var(--color-gray-500, #6b7280);
    margin: 0.5rem 0;
  }
  .scout-empty pre {
    display: inline-block;
    background: var(--color-gray-900, #111827);
    color: #f9fafb;
    padding: 0.625rem 1rem;
    border-radius: 0.375rem;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
    margin: 0.75rem 0;
  }
  .scout-empty__note {
    font-size: 0.75rem;
    color: var(--color-gray-400, #9ca3af);
    max-width: 36rem;
    margin: 1rem auto 0;
  }
  .scout-empty__note code {
    background: var(--color-gray-100, #f3f4f6);
    padding: 0.0625rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.6875rem;
  }

  .section-title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
    margin: 2rem 0 1rem;
    color: var(--color-gray-900, #111827);
  }

  .market-notes__list {
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 0.5rem;
    padding: 0.875rem 1.25rem 0.875rem 2.25rem;
    margin: 0;
  }
  .market-notes__list li {
    font-size: 0.875rem;
    color: var(--color-gray-700, #374151);
    line-height: 1.5;
    margin: 0.25rem 0;
  }

  /* ── Mock draft ─────────────────────────────────────────────────── */
  .mock-round { margin-bottom: 1.5rem; }
  .mock-round__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    margin: 0 0 0.625rem;
  }
  .mock-round__list {
    display: grid;
    gap: 0.5rem;
  }

  .mock-pick {
    display: grid;
    grid-template-columns: 64px 1fr 2fr;
    grid-template-areas:
      "slot team player"
      "reason reason reason";
    gap: 0.5rem 1rem;
    align-items: center;
    background: #fff;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
  }
  .mock-pick__slot {
    grid-area: slot;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }
  .mock-pick__overall {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .mock-pick__addr {
    font-size: 0.625rem;
    color: var(--color-gray-400, #9ca3af);
    font-variant-numeric: tabular-nums;
  }
  .mock-pick__team {
    grid-area: team;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  .mock-pick__icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .mock-pick__team-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .mock-pick__team-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-gray-800, #1f2937);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mock-pick__pick-type {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
  }
  .mock-pick__player {
    grid-area: player;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mock-pick__player-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
  }
  .mock-pick__reasoning {
    grid-area: reason;
    font-size: 0.8125rem;
    color: var(--color-gray-600, #4b5563);
    line-height: 1.4;
    margin: 0;
  }
  .mock-pick__contested {
    grid-area: reason;
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    margin: 0.25rem 0 0;
    font-style: italic;
  }

  /* ── Briefs grid ────────────────────────────────────────────────── */
  .briefs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
    gap: 1rem;
  }

  .brief-card {
    background: #fff;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .brief-card__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-top: 3px solid var(--color-primary, #1c497c);
    background: var(--color-gray-50, #f9fafb);
  }
  .brief-card__icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .brief-card__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    margin: 0;
  }
  .brief-card__cap {
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
    margin: 0.125rem 0 0;
  }
  .brief-card__summary {
    padding: 0.875rem 1rem;
    font-size: 0.8125rem;
    color: var(--color-gray-700, #374151);
    line-height: 1.5;
    margin: 0;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
  }
  .brief-card__section {
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
  }
  .brief-card__section:last-child { border-bottom: none; }
  .brief-card__section--wildcard {
    background: #fffbeb;
  }
  .brief-card__section-title {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
    margin: 0 0 0.375rem;
  }
  .brief-card__targets {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: target;
  }
  .brief-card__targets li {
    counter-increment: target;
    margin: 0.375rem 0;
    padding-left: 1.5rem;
    position: relative;
  }
  .brief-card__targets li::before {
    content: counter(target);
    position: absolute;
    left: 0;
    top: 0.0625rem;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-500, #6b7280);
    font-size: 0.625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .target-line {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.125rem;
  }
  .target-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-900, #111827);
  }
  .target-desire {
    margin-left: auto;
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-gray-400, #9ca3af);
    font-variant-numeric: tabular-nums;
  }
  .target-reason {
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
    line-height: 1.4;
    margin: 0;
  }
  .brief-card__chips {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .brief-card__taxi {
    font-size: 0.75rem;
    color: var(--color-gray-600, #4b5563);
    margin: 0;
  }

  .pos-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.0625rem 0.375rem;
    border-radius: 999px;
  }
  .pos-pill--qb { color: #1d4ed8; background: #eff6ff; }
  .pos-pill--rb { color: #15803d; background: #f0fdf4; }
  .pos-pill--wr { color: #b45309; background: #fffbeb; }
  .pos-pill--te { color: #7e22ce; background: #faf5ff; }

  @media (max-width: 640px) {
    .mock-pick {
      grid-template-columns: 50px 1fr;
      grid-template-areas:
        "slot team"
        "slot player"
        "reason reason";
    }
  }
</style>
