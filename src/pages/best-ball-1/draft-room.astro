---
/**
 * Best Ball League #1 — Official Draft Room (/best-ball-1/draft-room)
 *
 * THE main event for this league: the startup draft runs entirely on-site
 * through the shared DraftRoom island + PartyKit engine (the same machinery
 * as TheLeague's mock drafts, promoted to a draft of record — see
 * /api/best-ball-draft/create). No MFL deep-links, no live syncing: picks
 * are made here and exported to MFL once the draft completes
 * (scripts/export-best-ball-draft.mjs).
 *
 * States:
 *   - No official session yet → commissioner sees the create form,
 *     owners see a "draft not scheduled" notice.
 *   - Session exists → full draft room (lobby/active/paused/completed all
 *     handled inside the island).
 */

import TheLeagueLayout from '../../layouts/TheLeagueLayout.astro';
import DraftRoom from '../../components/theleague/draft-room/DraftRoom';
import bb1Config from '../../../data/best-ball-1/bb1.config.json';
import { getLeagueBySlug } from '../../config/leagues';
import { getLeagueYearForSlug, getCurrentLeagueYear } from '../../utils/league-year';
import { getAuthUser } from '../../utils/auth';
import { isAdminFranchise } from '../../config/nav-config';
import { getBestBall1Preference } from '../../utils/team-preferences';
import { buildDraftPlayers } from '../../utils/build-draft-players';
import { fetchOfficialDraftSession, officialDraftSessionId } from '../../utils/best-ball-draft';
import type { DraftRoomPageData, DraftRoomTeam } from '../../types/draft-room';

export const prerender = false;

const BB1 = getLeagueBySlug('best-ball-1')!;
const leagueYear = getLeagueYearForSlug(BB1.slug);

// ── Auth ──
const user = getAuthUser(Astro.request);
if (!user) {
  return Astro.redirect('/best-ball-1/login?next=/best-ball-1/draft-room');
}

const isBb1User = user.leagueId === BB1.id;
const isCommissioner =
  isBb1User && !!user.franchiseId && isAdminFranchise(user.franchiseId, 'bb1');

const cookiePref = getBestBall1Preference(Astro.cookies);
const userTeamId = (isBb1User ? user.franchiseId : null) || cookiePref?.franchiseId || '';

// ── Official session ──
const session = await fetchOfficialDraftSession(BB1, leagueYear);
const sessionId = officialDraftSessionId(BB1, leagueYear);

// ── Page data (only needed when the room renders) ──
let pageData: DraftRoomPageData | null = null;
if (session) {
  const teams: DraftRoomTeam[] = (bb1Config.teams ?? []).map((team: any) => ({
    franchiseId: team.franchiseId,
    name: team.name,
    nameMedium: team.nameMedium || team.name,
    nameShort: team.nameShort || team.name,
    abbrev: team.abbrev || '',
    icon: team.icon || '',
    colorPrimary: team.colorPrimary,
    colorSecondary: team.colorSecondary,
  }));

  // FULL veteran+rookie pool — a best-ball startup drafts the whole roster.
  // The player catalog feed is shared (see create route note); its directory
  // is keyed by the default league's year clock.
  const players = buildDraftPlayers(getCurrentLeagueYear(), {
    rookieOnly: false,
    viewerFranchiseId: user.franchiseId,
  });

  pageData = {
    leagueYear,
    draftKind: 'live',
    draftLimitHours: '',
    draftTimerSusp: '',
    totalRounds: session.totalRounds,
    picksPerRound: session.picksPerRound,
    teams,
    picks: [],
    players,
    partyHost: import.meta.env.PUBLIC_PARTYKIT_HOST || '',
    leagueId: BB1.id,
  };
}
---

<TheLeagueLayout title={`Draft Room | ${BB1.name}`} hideMobileNavIcons>
  {
    pageData ? (
      <DraftRoom
        client:load
        pageData={JSON.stringify(pageData)}
        userTeamId={userTeamId}
        mode="mock"
        mockSessionId={sessionId}
        draftContext="general"
      />
    ) : (
      <div class="bb-draft-setup">
        <img class="bb-draft-setup__logo" src="/assets/logos/bestball-logo.svg" alt="" aria-hidden="true" />
        <h1>The Draft</h1>
        {isCommissioner ? (
          <div class="bb-draft-setup__card">
            <p>
              No official draft session exists for {leagueYear} yet. Configure and
              create it — the room opens in lobby mode, and you start the clock
              when everyone's in.
            </p>
            <form id="bb-create-draft-form">
              <label>
                Pick clock
                <select name="timerSeconds">
                  <option value="30">30 seconds (test run)</option>
                  <option value="60">1 minute</option>
                  <option value="120" selected>2 minutes</option>
                  <option value="300">5 minutes</option>
                </select>
              </label>
              <label class="bb-draft-setup__check">
                <input type="checkbox" name="randomizeOrder" checked />
                Randomize the draft order
              </label>
              <button type="submit">Create Official Draft</button>
              <p class="bb-draft-setup__error" data-create-error hidden />
            </form>
          </div>
        ) : (
          <div class="bb-draft-setup__card">
            <p>
              The official {leagueYear} startup draft hasn't been scheduled yet.
              When the commissioner opens the room, this page becomes the live
              draft — check back soon.
            </p>
          </div>
        )}
      </div>
    )
  }
</TheLeagueLayout>

<script>
  // Commissioner create-draft form — no-ops on renders where the form is
  // absent (room already exists, or viewer isn't the commissioner).
  function initBbCreateDraftForm(): void {
    const form = document.getElementById('bb-create-draft-form') as HTMLFormElement | null;
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errEl = form.querySelector('[data-create-error]') as HTMLElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      errEl.hidden = true;
      try {
        const res = await fetch('/api/best-ball-draft/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            timerSeconds: parseInt((form.elements.namedItem('timerSeconds') as HTMLSelectElement).value, 10),
            randomizeOrder: (form.elements.namedItem('randomizeOrder') as HTMLInputElement).checked,
          }),
        });
        const data = await res.json();
        if (data.success) {
          window.location.reload();
        } else {
          errEl.textContent = data.message || 'Could not create the draft.';
          errEl.hidden = false;
          btn.disabled = false;
        }
      } catch {
        errEl.textContent = 'Network error — try again.';
        errEl.hidden = false;
        btn.disabled = false;
      }
    });
  }

  initBbCreateDraftForm();
  document.addEventListener('astro:page-load', initBbCreateDraftForm);
</script>

<style>
  .bb-draft-setup {
    max-width: 560px;
    margin: 3rem auto;
    padding: 0 var(--spacing-lg, 1.5rem);
    text-align: center;
  }

  .bb-draft-setup__logo {
    height: 84px;
    width: auto;
  }

  .bb-draft-setup h1 {
    margin: 0.75rem 0 1.25rem;
  }

  .bb-draft-setup__card {
    background: var(--card-bg, var(--content-bg, #ffffff));
    border: 1px solid var(--card-border, #dddddd);
    border-radius: var(--radius-lg, 10px);
    padding: 1.5rem;
    text-align: left;
  }

  .bb-draft-setup__card form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1rem;
  }

  .bb-draft-setup__card label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .bb-draft-setup__check {
    flex-direction: row !important;
    align-items: center;
  }

  .bb-draft-setup__card select {
    padding: 0.5rem;
    border: 1px solid var(--input-border, #d1d5db);
    border-radius: var(--radius-sm, 4px);
    background: var(--input-bg, #ffffff);
    color: inherit;
  }

  .bb-draft-setup__card button {
    align-self: flex-start;
    background: var(--league-accent, #0e8a5f);
    color: #ffffff;
    font-weight: 700;
    border: none;
    border-radius: var(--radius-sm, 4px);
    padding: 0.65rem 1.4rem;
    cursor: pointer;
  }

  .bb-draft-setup__card button:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .bb-draft-setup__error {
    color: #b91c1c;
    font-size: 0.85rem;
    margin: 0;
  }
</style>
