---
/**
 * What's New detail (Best Ball #1) — thin route wrapper.
 * Shared implementation lives in components/shared/whats-new/WhatsNewDetailPage.
 * The league's own schefter feed is imported here (static import specifiers
 * can't be runtime variables — see the AFL wrapper for the full rationale).
 * bb1's feed is empty by design (schefterFeed flag is off), so related-post
 * strips simply render nothing.
 */
import WhatsNewDetailPage from '../../../components/shared/whats-new/WhatsNewDetailPage.astro';
import { resolveWhatsNewDetail } from '../../../utils/whats-new-detail';
import type { SchefterFeed } from '../../../types/schefter';
import schefterFeedData from '../../../../data/best-ball-1/schefter-feed.json';

export const prerender = false;

const result = resolveWhatsNewDetail(Astro, 'best-ball-1');
if (result.redirectTo !== undefined) return Astro.redirect(result.redirectTo);
---

<WhatsNewDetailPage
  leagueSlug="best-ball-1"
  entry={result.entry}
  prev={result.prev}
  next={result.next}
  schefterPosts={(schefterFeedData as unknown as SchefterFeed).posts}
/>
