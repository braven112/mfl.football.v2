---
export const prerender = false;

import DrivingCoach from '../components/driving/DrivingCoach';
import { Font } from 'astro:assets';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐴</text></svg>" />
    <Font cssVariable="--font-vend-sans" />
    <title>Billy — WA Driving Coach</title>
  </head>
  <body>
    <div class="dc-page">
      <header class="dc-page__header">
        <div class="dc-page__header-inner">
          <img src="/assets/driving/billy-avatar.png" alt="" width="40" height="40" class="dc-page__logo" />
          <div class="dc-page__title-group">
            <h1 class="dc-page__title">Billy</h1>
            <p class="dc-page__subtitle">WA Driver's License Coach</p>
          </div>
        </div>
      </header>
      <main class="dc-page__main">
        <DrivingCoach client:load />
      </main>
    </div>
  </body>
</html>

<style is:global>
  /* ── Base Reset & Tokens ── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --dc-bg: #0f172a;
    --dc-surface: #1e293b;
    --dc-surface-hover: #334155;
    --dc-surface-light: #283548;
    --dc-border: #334155;
    --dc-border-light: #475569;
    --dc-text: #f1f5f9;
    --dc-text-muted: #94a3b8;
    --dc-text-dim: #64748b;
    --dc-primary: #3b82f6;
    --dc-primary-hover: #2563eb;
    --dc-primary-soft: rgba(59, 130, 246, 0.15);
    --dc-success: #22c55e;
    --dc-success-soft: rgba(34, 197, 94, 0.15);
    --dc-danger: #ef4444;
    --dc-danger-soft: rgba(239, 68, 68, 0.15);
    --dc-warning: #f59e0b;
    --dc-warning-soft: rgba(245, 158, 11, 0.15);
    --dc-accent: #8b5cf6;
    --dc-user-bg: #3b82f6;
    --dc-billy-bg: #1e293b;
    --dc-radius: 0.75rem;
    --dc-radius-sm: 0.5rem;
    --dc-font: var(--font-vend-sans), system-ui, -apple-system, sans-serif;
  }

  html {
    font-family: var(--dc-font);
    background: var(--dc-bg);
    color: var(--dc-text);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100dvh;
    background: var(--dc-bg);
  }

  a {
    color: var(--dc-primary);
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }

  /* ── Page Layout ── */
  .dc-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .dc-page__header {
    background: var(--dc-surface);
    border-bottom: 1px solid var(--dc-border);
    padding: 0.75rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }

  .dc-page__header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .dc-page__logo {
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--dc-primary);
  }

  .dc-page__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--dc-text);
    line-height: 1.2;
  }

  .dc-page__subtitle {
    font-size: 0.75rem;
    color: var(--dc-text-muted);
    font-weight: 500;
  }

  .dc-page__main {
    flex: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem;
  }

  /* ── Mode Switcher ── */
  .dc__modes {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .dc__mode-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--dc-radius);
    border: 1px solid var(--dc-border);
    background: var(--dc-surface);
    color: var(--dc-text-muted);
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--dc-font);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .dc__mode-btn:hover {
    background: var(--dc-surface-hover);
    color: var(--dc-text);
  }

  .dc__mode-btn--active {
    background: var(--dc-primary-soft);
    border-color: var(--dc-primary);
    color: var(--dc-primary);
  }

  /* ── Main Layout (2-column) ── */
  .dc__layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.5rem;
    align-items: start;
  }

  /* ── Chat Body ── */
  .dc__main {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .dc__chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: calc(100dvh - 280px);
    min-height: 400px;
  }

  .dc__error {
    background: var(--dc-danger-soft);
    border: 1px solid var(--dc-danger);
    color: var(--dc-text);
    padding: 0.625rem 1rem;
    border-radius: var(--dc-radius-sm);
    font-size: 0.8125rem;
    margin-bottom: 0.75rem;
  }

  /* ── Chat Messages ── */
  .dc-msg {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
    animation: dc-fadeIn 0.3s ease;
  }

  .dc-msg--user {
    flex-direction: row-reverse;
  }

  .dc-msg__avatar {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
  }

  .dc-msg__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .dc-msg__bubble {
    max-width: 80%;
    padding: 0.75rem 1rem;
    border-radius: var(--dc-radius);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .dc-msg--assistant .dc-msg__bubble {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-top-left-radius: 4px;
  }

  .dc-msg--user .dc-msg__bubble {
    background: var(--dc-user-bg);
    color: white;
    border-top-right-radius: 4px;
  }

  .dc-msg__name {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--dc-primary);
    margin-bottom: 0.25rem;
  }

  .dc-msg__content p {
    margin: 0;
  }

  .dc-msg__content p + p {
    margin-top: 0.625rem;
  }

  .dc-msg__content strong {
    color: var(--dc-text);
    font-weight: 600;
  }

  .dc-msg--user .dc-msg__content strong {
    color: white;
  }

  .dc-bullet {
    color: var(--dc-primary);
    margin-right: 0.375rem;
    font-weight: 700;
  }

  .dc-msg--latest {
    animation: dc-slideIn 0.4s ease;
  }

  /* Typing indicator */
  .dc-msg__typing {
    display: flex;
    gap: 4px;
    padding: 0.25rem 0;
  }

  .dc-msg__typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dc-text-dim);
    animation: dc-typing 1.2s infinite;
  }

  .dc-msg__typing span:nth-child(2) { animation-delay: 0.15s; }
  .dc-msg__typing span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes dc-typing {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

  @keyframes dc-fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes dc-slideIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Chat Input ── */
  .dc-input {
    margin-top: 0.75rem;
  }

  .dc-input__wrapper {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 0.5rem;
    transition: border-color 0.15s;
  }

  .dc-input__wrapper:focus-within {
    border-color: var(--dc-primary);
  }

  .dc-input__textarea {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--dc-text);
    font-family: var(--dc-font);
    font-size: 0.875rem;
    line-height: 1.5;
    resize: none;
    outline: none;
    padding: 0.25rem 0.5rem;
    min-height: 1.5rem;
    max-height: 120px;
  }

  .dc-input__textarea::placeholder {
    color: var(--dc-text-dim);
  }

  .dc-input__send {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--dc-primary);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .dc-input__send:hover:not(:disabled) {
    background: var(--dc-primary-hover);
  }

  .dc-input__send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .dc-input__spinner {
    animation: dc-spin 1.5s linear infinite;
  }

  @keyframes dc-spin {
    to { transform: rotate(360deg); }
  }

  .dc-input__hint {
    font-size: 0.6875rem;
    color: var(--dc-text-dim);
    margin-top: 0.375rem;
    padding-left: 0.5rem;
  }

  /* ── Sidebar ── */
  .dc__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 80px;
  }

  /* Billy personality card */
  .dc__billy-card {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 1.25rem;
    text-align: center;
  }

  .dc__billy-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--dc-primary);
    margin-bottom: 0.75rem;
  }

  .dc__billy-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--dc-text);
  }

  .dc__billy-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dc-primary);
    margin-bottom: 0.5rem;
  }

  .dc__billy-desc {
    font-size: 0.8125rem;
    color: var(--dc-text-muted);
    line-height: 1.5;
  }

  /* Topic browser */
  .dc-topics__title,
  .dc__info-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dc-text-muted);
    padding-left: 0.625rem;
    border-left: 2px solid var(--dc-primary);
    margin-bottom: 0.75rem;
  }

  .dc-topics__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.375rem;
  }

  .dc-topics__card {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem;
    border-radius: var(--dc-radius-sm);
    border: 1px solid var(--dc-border);
    background: var(--dc-surface);
    color: var(--dc-text-muted);
    font-family: var(--dc-font);
    font-size: 0.6875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
  }

  .dc-topics__card:hover {
    background: var(--dc-surface-hover);
    color: var(--dc-text);
    border-color: var(--dc-border-light);
  }

  .dc-topics__card--active {
    background: var(--dc-primary-soft);
    border-color: var(--dc-primary);
    color: var(--dc-primary);
  }

  .dc-topics__icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .dc-topics__label {
    line-height: 1.2;
  }

  /* Test info */
  .dc__test-info {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 1rem;
  }

  .dc__info-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .dc__info-stat {
    text-align: center;
    background: var(--dc-bg);
    border-radius: var(--dc-radius-sm);
    padding: 0.625rem 0.25rem;
  }

  .dc__info-stat-value {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--dc-primary);
    font-variant-numeric: tabular-nums;
  }

  .dc__info-stat-label {
    display: block;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dc-text-dim);
    margin-top: 0.125rem;
  }

  /* Resources */
  .dc__resources {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dc__resource-link {
    font-size: 0.8125rem;
    color: var(--dc-text-muted);
    display: flex;
    align-items: center;
    gap: 0.375rem;
    transition: color 0.15s;
  }

  .dc__resource-link:hover {
    color: var(--dc-primary);
    text-decoration: none;
  }

  /* ── Quiz Mode ── */
  .dc-quiz {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .dc-quiz__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
  }

  .dc-quiz__score {
    display: flex;
    flex-direction: column;
  }

  .dc-quiz__score-label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dc-text-dim);
  }

  .dc-quiz__score-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dc-text);
    font-variant-numeric: tabular-nums;
  }

  .dc-quiz__score-pct {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--dc-text-muted);
  }

  .dc-quiz__score-note {
    font-size: 0.6875rem;
    color: var(--dc-text-dim);
  }

  .dc-quiz__new-btn {
    padding: 0.5rem 1.25rem;
    border-radius: var(--dc-radius);
    border: none;
    background: var(--dc-primary);
    color: white;
    font-family: var(--dc-font);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .dc-quiz__new-btn:hover:not(:disabled) {
    background: var(--dc-primary-hover);
  }

  .dc-quiz__new-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Quiz question card */
  .dc-quiz__question-card {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 1.5rem;
    animation: dc-fadeIn 0.3s ease;
  }

  .dc-quiz__topic-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dc-accent);
    background: rgba(139, 92, 246, 0.15);
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    margin-bottom: 0.75rem;
  }

  .dc-quiz__question-text {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--dc-text);
    line-height: 1.45;
    margin-bottom: 1.25rem;
  }

  .dc-quiz__options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dc-quiz__option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: var(--dc-radius-sm);
    border: 1px solid var(--dc-border);
    background: var(--dc-bg);
    color: var(--dc-text);
    font-family: var(--dc-font);
    font-size: 0.875rem;
    text-align: left;
    cursor: pointer;
    transition: all 0.15s;
  }

  .dc-quiz__option:hover:not(:disabled) {
    border-color: var(--dc-primary);
    background: var(--dc-primary-soft);
  }

  .dc-quiz__option:disabled {
    cursor: default;
  }

  .dc-quiz__option--correct {
    border-color: var(--dc-success) !important;
    background: var(--dc-success-soft) !important;
  }

  .dc-quiz__option--wrong {
    border-color: var(--dc-danger) !important;
    background: var(--dc-danger-soft) !important;
  }

  .dc-quiz__option--dimmed {
    opacity: 0.4;
  }

  .dc-quiz__option-letter {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
    background: var(--dc-surface-hover);
    color: var(--dc-text-muted);
  }

  .dc-quiz__option--correct .dc-quiz__option-letter {
    background: var(--dc-success);
    color: white;
  }

  .dc-quiz__option--wrong .dc-quiz__option-letter {
    background: var(--dc-danger);
    color: white;
  }

  .dc-quiz__option-text {
    flex: 1;
    line-height: 1.4;
  }

  /* Quiz result */
  .dc-quiz__result {
    margin-top: 1.25rem;
    padding: 1rem;
    border-radius: var(--dc-radius-sm);
    animation: dc-fadeIn 0.3s ease;
  }

  .dc-quiz__result--correct {
    background: var(--dc-success-soft);
    border: 1px solid var(--dc-success);
  }

  .dc-quiz__result--wrong {
    background: var(--dc-warning-soft);
    border: 1px solid var(--dc-warning);
  }

  .dc-quiz__result-icon {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .dc-quiz__explanation {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--dc-text);
    margin-bottom: 0.75rem;
  }

  .dc-quiz__actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .dc-quiz__ask-btn,
  .dc-quiz__next-btn {
    padding: 0.4375rem 1rem;
    border-radius: var(--dc-radius-sm);
    border: 1px solid var(--dc-border);
    background: var(--dc-surface);
    color: var(--dc-text);
    font-family: var(--dc-font);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }

  .dc-quiz__ask-btn:hover:not(:disabled),
  .dc-quiz__next-btn:hover:not(:disabled) {
    background: var(--dc-surface-hover);
  }

  .dc-quiz__next-btn {
    background: var(--dc-primary);
    border-color: var(--dc-primary);
    color: white;
  }

  .dc-quiz__next-btn:hover:not(:disabled) {
    background: var(--dc-primary-hover);
  }

  .dc-quiz__ask-btn:disabled,
  .dc-quiz__next-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .dc-quiz__empty {
    background: var(--dc-surface);
    border: 1px solid var(--dc-border);
    border-radius: var(--dc-radius);
    padding: 2rem;
    text-align: center;
  }

  .dc-quiz__empty p {
    font-size: 0.9375rem;
    color: var(--dc-text-muted);
    line-height: 1.6;
  }

  .dc-quiz__empty p + p {
    margin-top: 0.5rem;
  }

  .dc-quiz__empty strong {
    color: var(--dc-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .dc__layout {
      grid-template-columns: 1fr;
    }

    .dc__sidebar {
      position: static;
      order: -1;
    }

    .dc__billy-card {
      display: none;
    }

    .dc__chat-body {
      max-height: calc(100dvh - 300px);
      min-height: 300px;
    }

    .dc-page__main {
      padding: 1rem;
    }
  }

  @media (max-width: 600px) {
    .dc-page__main {
      padding: 0.75rem;
    }

    .dc-topics__grid {
      grid-template-columns: 1fr;
    }

    .dc__modes {
      gap: 0.375rem;
    }

    .dc__mode-btn {
      font-size: 0.8125rem;
      padding: 0.4375rem 0.75rem;
    }

    .dc-msg__bubble {
      max-width: 90%;
    }

    .dc-quiz__question-card {
      padding: 1rem;
    }

    .dc-quiz__header {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
