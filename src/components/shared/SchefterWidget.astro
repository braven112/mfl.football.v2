---
/**
 * SchefterWidget — Compact homepage widget showing last N posts.
 * Headlines + timestamps with author avatar, no reactions.
 * Links to the full news page.
 */
import type { SchefterPost } from '../../types/schefter';
import { getAuthor, getAuthorAvatar } from '../../types/schefter';
import { formatRelativeTime } from '../../utils/schefter-feed';
import '../../styles/schefter-feed.css';

interface Props {
  posts: SchefterPost[];
  league: 'theleague' | 'afl';
  allNewsLink: string;
}

const { posts, allNewsLink } = Astro.props;
const now = new Date();
---

<section class="sf-widget" aria-labelledby="sf-widget-title">
  <div class="sf-widget__header">
    <h2 class="sf-widget__title" id="sf-widget-title">League News</h2>
    <a href={allNewsLink} class="sf-widget__view-all">View all →</a>
  </div>

  {posts.length === 0 ? (
    <p class="sf-empty__text" style="text-align: center; padding: 1rem 0; font-size: 0.8125rem;">
      No news yet.
    </p>
  ) : (
    <div class="sf-widget__list">
      {posts.map(post => {
        const author = getAuthor(post.authorId);
        const avatarSrc = getAuthorAvatar(author);
        return (
          <div class="sf-widget__item">
            <img class="sf-widget__avatar" src={avatarSrc} alt="" aria-hidden="true" width="18" height="18" loading="lazy" />
            <span class="sf-widget__headline">{post.headline}</span>
            <time class="sf-widget__item-time" datetime={post.timestamp}>{formatRelativeTime(post.timestamp, now)}</time>
          </div>
        );
      })}
    </div>
  )}
</section>
