---
/**
 * QuickLinks — shared discovery grid for the league homepages.
 *
 * Merges the former AflQuickLinks + HpQuickLinks into one component
 * parameterized by a `league` prop (canonical slug). The skeleton, card
 * markup and CSS are shared; the per-league differences (path filter,
 * sort/pin logic, href construction, empty state, and the `afl-`/`hp-`
 * CSS class prefix) are resolved from the league prop + registry so the
 * rendered output stays pixel-identical to the originals.
 */
import { spriteUrl } from '../../../utils/sprite-url';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import { getLeagueBySlug, type CanonicalLeagueSlug } from '../../../config/leagues';

interface Props {
  league: CanonicalLeagueSlug;
  isAuthenticated?: boolean;
}

interface PageEntry {
  id: string;
  title: string;
  description: string;
  path: string;
  icon: string;
  category: string;
  visibility: string;
  popularity: number;
}

const { league: leagueSlug, isAuthenticated } = Astro.props;
const league = getLeagueBySlug(leagueSlug)!;
const isAfl = leagueSlug === 'afl-fantasy';

// CSS class prefix — presentational, kept per-league so output stays
// pixel-identical (the AFL and TheLeague style blocks below reference the
// matching prefix). Not a registry constant; local to this component.
const CLASS_PREFIX: Record<CanonicalLeagueSlug, string> = {
  'afl-fantasy': 'afl-links',
  theleague: 'hp-links',
};
const cls = CLASS_PREFIX[leagueSlug];

const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

import pageDirectory from '../../../data/page-directory.json';
const allPages: PageEntry[] = pageDirectory as PageEntry[];

let pages: PageEntry[];
if (isAfl) {
  // Filter to this league's routes only and exclude the homepage itself +
  // admin pages, then sort by popularity and take up to 8.
  const leaguePages = allPages
    .filter(p => p.visibility === 'all')
    .filter(p => p.path.startsWith(`/${league.slug}/`) || p.path === `/${league.slug}`)
    .filter(p => p.id !== 'afl-homepage' && p.id !== 'homepage');
  pages = [...leaguePages].sort((a, b) => b.popularity - a.popularity).slice(0, 8);
} else {
  // Filter to visible, non-admin pages (except for authenticated users)
  const visible = allPages.filter(p => p.visibility === 'all' && p.id !== 'homepage' && p.id !== 'new-hp');

  // Sort: logged-in users get "my-team" tools first, then by popularity
  const sorted = [...visible].sort((a, b) => {
    if (isAuthenticated) {
      const aMyTeam = a.category === 'my-team' ? 1 : 0;
      const bMyTeam = b.category === 'my-team' ? 1 : 0;
      if (aMyTeam !== bMyTeam) return bMyTeam - aMyTeam;
    }
    return b.popularity - a.popularity;
  });

  // Pin the Stats & Reports hub so it always surfaces on the homepage.
  const PINNED_IDS = ['stats'];
  const pinned = PINNED_IDS
    .map(id => visible.find(p => p.id === id))
    .filter((p): p is PageEntry => Boolean(p));
  const rest = sorted.filter(p => !PINNED_IDS.includes(p.id));
  pages = [...pinned, ...rest].slice(0, 8);
}

const ctaHref = isAfl ? `/${league.slug}` : r(`/${league.slug}/search`);
const cardHref = (page: PageEntry) => (isAfl ? page.path : r(`/${league.slug}${page.path}`));
---

<section class={cls} aria-label="Quick links">
  <div class={`${cls}__header`}>
    <h3 class={`${cls}__title`}>Explore</h3>
    <a href={ctaHref} class={`${cls}__cta`}>
      All pages
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
  {isAfl && pages.length === 0 ? (
    <p class={`${cls}__empty`}>No AFL pages registered in the directory yet.</p>
  ) : (
    <div class={`${cls}__grid`}>
      {pages.map(page => (
        <a href={cardHref(page)} class={`${cls}__card`}>
          <svg class={`${cls}__icon`} width="20" height="20" aria-hidden="true">
            <use href={`${spriteUrl}#icon-${page.icon}`} />
          </svg>
          <div class={`${cls}__text`}>
            <span class={`${cls}__name`}>{page.title}</span>
            <span class={`${cls}__desc`}>{page.description}</span>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<style>
  /* ── afl-fantasy prefix (formerly AflQuickLinks) ───────────────────── */
  .afl-links {
    --afl-accent: var(--league-accent, #c41e3a);
    background: var(--card-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-md);
    padding: 1.5rem;
  }

  .afl-links__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .afl-links__title {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.625rem;
    border-left: 2px solid var(--afl-accent);
    margin: 0;
    line-height: 1;
    color: var(--color-gray-700, #374151);
  }

  .afl-links__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--afl-accent);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .afl-links__cta:hover {
    gap: 0.5rem;
  }

  .afl-links__empty {
    margin: 0;
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
  }

  .afl-links__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .afl-links__card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--color-gray-50, #f9fafb);
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .afl-links__card:hover {
    background: var(--color-gray-100, #f3f4f6);
    transform: translateY(-1px);
  }

  /* Dark mode: translucent tiles so the card's slate glow shows through
     instead of solid near-black wells. Resting = dark wash, hover lifts
     to the light wash. */
  :global(html.dark) .afl-links__card {
    background: rgba(0, 0, 0, 0.075);
  }

  :global(html.dark) .afl-links__card:hover {
    /* Slate-violet lift matching the card gradient's hue. */
    background: rgb(86 85 167 / 11%);
  }

  .afl-links__icon {
    flex-shrink: 0;
    color: var(--afl-accent);
    fill: currentColor;
    margin-top: 0.125rem;
  }

  .afl-links__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .afl-links__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-800, #1f2937);
    line-height: 1.3;
  }

  .afl-links__desc {
    font-size: 0.6875rem;
    color: var(--color-gray-500, #6b7280);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .afl-links {
      padding: 1.25rem;
    }

    .afl-links__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── theleague prefix (formerly HpQuickLinks) ──────────────────────── */
  .hp-links {
    --dh-accent: var(--league-accent, #1c497c);
    background: var(--card-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-md);
    padding: 1.5rem;
  }

  .hp-links__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .hp-links__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.625rem;
    border-left: 2px solid var(--dh-accent);
    margin: 0;
    line-height: 1;
    color: var(--color-gray-700, #374151);
  }

  .hp-links__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--dh-accent);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .hp-links__cta:hover {
    gap: 0.5rem;
  }

  .hp-links__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .hp-links__card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--color-gray-50, #f9fafb);
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .hp-links__card:hover {
    background: var(--color-gray-100, #f3f4f6);
    transform: translateY(-1px);
  }

  /* Dark mode: translucent tiles so the card's slate glow shows through
     instead of solid near-black wells. Resting = dark wash, hover lifts
     to the light wash. */
  :global(html.dark) .hp-links__card {
    background: rgba(0, 0, 0, 0.075);
  }

  :global(html.dark) .hp-links__card:hover {
    /* Slate-violet lift matching the card gradient's hue. */
    background: rgb(86 85 167 / 11%);
  }

  .hp-links__icon {
    flex-shrink: 0;
    color: var(--dh-accent);
    fill: currentColor;
    margin-top: 0.125rem;
  }

  .hp-links__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .hp-links__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-800, #1f2937);
    line-height: 1.3;
  }

  .hp-links__desc {
    font-size: 0.6875rem;
    color: var(--color-gray-500, #6b7280);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .hp-links {
      padding: 1.25rem;
    }

    .hp-links__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
