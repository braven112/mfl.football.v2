---
/**
 * PlayerHeroComposite — team-color media banner built from a transparent
 * ESPN headshot. No licensed photography: the visual is a CSS composite of
 * a dark→team-color gradient, a ghost team wordmark, a radial glow, and the
 * player's headshot with a drop shadow.
 *
 * Reusable anywhere a post/page needs player imagery (Schefter feed cards,
 * article heroes, matchup previews). Callers are responsible for gating:
 * only render this when the player has a transparent ESPN headshot
 * (`headshot` on espncdn.com) and is not a team defense.
 *
 * If the headshot 404s at load time the whole banner hides itself rather
 * than showing a broken gradient-only card.
 */
import { getNflTeamColors, getNflTeamNickname, hexToRgba } from '../../utils/nfl-team-colors';
import { normalizeTeamCode } from '../../utils/nfl-logo';

interface Props {
  /** Player display name — used for alt text */
  name: string;
  /** Transparent ESPN headshot URL */
  headshot: string;
  /** Position code (QB/RB/WR/TE/PK) */
  position: string;
  /** NFL team code in any format (MFL or ESPN) */
  nflTeam: string;
}

const { name, headshot, position, nflTeam } = Astro.props;

const teamCode = normalizeTeamCode(nflTeam);
const { primary } = getNflTeamColors(teamCode);
const wordmark = getNflTeamNickname(teamCode).toUpperCase();
const glow = hexToRgba(primary, 0.5);
---

<div
  class="phc"
  style={`--phc-team: ${primary}; --phc-glow: ${glow};`}
  aria-hidden="true"
>
  <span class="phc__wordmark">{wordmark}</span>
  <div class="phc__glow"></div>
  <img
    class="phc__headshot"
    src={headshot}
    alt=""
    loading="lazy"
    decoding="async"
    onerror="this.closest('.phc').style.display='none'"
  />
  <span class="phc__chip">{position} · {teamCode}</span>
  <span class="sr-only">{name}</span>
</div>

<style>
  .phc {
    position: relative;
    overflow: hidden;
    min-height: 160px;
    margin-top: 0.625rem;
    border-radius: var(--radius-md, 0.5rem);
    background: linear-gradient(105deg, #0b0e12 0%, #1a222c 46%, var(--phc-team, #1c497c) 130%);
  }

  .phc__wordmark {
    position: absolute;
    right: -0.5rem;
    top: -1.1rem;
    font-size: 5.5rem;
    font-weight: 800;
    font-style: italic;
    letter-spacing: -0.04em;
    line-height: 1;
    color: rgba(255, 255, 255, 0.045);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .phc__glow {
    position: absolute;
    right: -50px;
    top: -70px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, var(--phc-glow, rgba(28, 73, 124, 0.5)) 0%, transparent 65%);
    pointer-events: none;
  }

  .phc__headshot {
    position: absolute;
    right: 0.75rem;
    bottom: 0;
    width: 200px;
    max-width: 55%;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.55));
  }

  .phc__chip {
    position: absolute;
    left: 0.875rem;
    bottom: 0.75rem;
    color: #fff;
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: rgba(0, 0, 0, 0.4);
    padding: 0.3rem 0.55rem;
    border-radius: 4px;
    backdrop-filter: blur(2px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .phc {
      min-height: 130px;
    }

    .phc__headshot {
      width: 150px;
      right: 0;
    }

    .phc__wordmark {
      font-size: 4rem;
    }
  }
</style>
