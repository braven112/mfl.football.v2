---
/**
 * SchefterFeed — Server-rendered list of Schefter posts.
 *
 * All posts render as full cards. Breaking-tier posts get a left accent
 * and analysis block; standard and minor posts are regular cards with
 * varying levels of energy in the copy.
 *
 * Posts beyond initialLimit are hidden via CSS and revealed by
 * the "Load more" button in batches of PAGE_SIZE.
 */
import type { SchefterPost } from '../../types/schefter';
import type { SchefterReactionResponse } from '../../types/schefter';
import { getBatchReactions, getBatchAnonymousReactions } from '../../utils/schefter-reactions';
import { hashTipsterId } from '../../utils/schefter-tipster-hash';
import SchefterPostCard from './SchefterPostCard.astro';

interface Props {
  posts: SchefterPost[];
  isAuthenticated?: boolean;
  userFranchiseId?: string;
  userTeamName?: string;
  userTeamIcon?: string;
  /**
   * Authenticated user id — only used to derive the tipster hash for anonymous
   * rumor reactions. Never surfaced to the client.
   */
  userId?: string;
  /** Max posts to show initially (for pagination) */
  initialLimit?: number;
}

const { posts, isAuthenticated = false, userFranchiseId, userTeamName, userTeamIcon, userId, initialLimit = 25 } = Astro.props;
const now = new Date();

// Partition rumor_mill posts from the rest — they use the anonymous reaction
// namespace (keyed on hashedOwnerId) so reactor identity never leaks.
function isRumorPost(p: SchefterPost): boolean {
  return p.type === 'transaction' && p.transactionSubType === 'rumor_mill';
}

const rumorPostIds = posts.filter(isRumorPost).map((p) => p.id);
const regularPostIds = posts.filter((p) => !isRumorPost(p)).map((p) => p.id);

let userHashedOwnerId: string | undefined;
if (userId) {
  try {
    userHashedOwnerId = hashTipsterId(userId);
  } catch {
    userHashedOwnerId = undefined;
  }
}

const [regularReactions, anonymousReactions] = await Promise.all([
  getBatchReactions(regularPostIds, userFranchiseId),
  getBatchAnonymousReactions(rumorPostIds, userHashedOwnerId),
]);
const allReactions: Record<string, SchefterReactionResponse> = { ...regularReactions, ...anonymousReactions };
---

<div class="sf-feed sf-feed--page" data-initial-limit={initialLimit}>
  {posts.length === 0 ? (
    <div class="sf-empty">
      <div class="sf-empty__icon">🎙️</div>
      <p class="sf-empty__text">No news yet. Schefter is on assignment.</p>
    </div>
  ) : (
    posts.map((post, i) => (
      <div class:list={['sf-feed__item', { 'sf-feed__item--hidden': i >= initialLimit }]} data-feed-index={i}>
        <SchefterPostCard
          post={post}
          isAuthenticated={isAuthenticated}
          userFranchiseId={userFranchiseId}
          userTeamName={userTeamName}
          userTeamIcon={userTeamIcon}
          now={now}
          reactions={allReactions[post.id]}
        />
      </div>
    ))
  )}

  {posts.length > initialLimit && (
    <div class="sf-load-more">
      <button class="sf-load-more__btn" data-load-more>
        Load more
      </button>
    </div>
  )}
</div>

<script>
  // Phase 10 — rumor impression beacon. Fires once per rumor per session when
  // the card enters the viewport. Uses sessionStorage to dedupe so a user
  // scrolling past the same card twice doesn't double-count; the server also
  // enforces shape + 30d TTL so abuse is bounded.
  function initRumorImpressions() {
    if (typeof IntersectionObserver === 'undefined') return;
    const seenKey = 'schefter:rumor-impression-seen-v1';
    let seen: Record<string, true> = {};
    try {
      seen = JSON.parse(sessionStorage.getItem(seenKey) ?? '{}');
    } catch { /* ignore malformed session storage */ }

    const send = (postId: string) => {
      if (seen[postId]) return;
      seen[postId] = true;
      try { sessionStorage.setItem(seenKey, JSON.stringify(seen)); } catch { /* ignore quota */ }
      const body = JSON.stringify({ postId });
      try {
        if (typeof navigator.sendBeacon === 'function') {
          navigator.sendBeacon('/api/schefter/rumor-impression', new Blob([body], { type: 'application/json' }));
          return;
        }
      } catch { /* fall through to fetch */ }
      fetch('/api/schefter/rumor-impression', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body,
        keepalive: true,
      }).catch(() => {});
    };

    const rumorCards = document.querySelectorAll('[data-rumor-impression="true"][data-post-id]');
    if (rumorCards.length === 0) return;
    const obs = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const id = (entry.target as HTMLElement).dataset.postId;
        if (id) send(id);
        obs.unobserve(entry.target);
      }
    }, { threshold: 0.5 });
    rumorCards.forEach((card) => obs.observe(card));
  }

  function initLoadMore() {
    const feed = document.querySelector('.sf-feed--page');
    if (!feed) return;

    const btn = feed.querySelector('[data-load-more]') as HTMLButtonElement | null;
    if (!btn) return;

    const PAGE_SIZE = 25;
    const initialLimit = parseInt(feed.getAttribute('data-initial-limit') ?? '25', 10);
    let visibleCount = initialLimit;

    btn.addEventListener('click', () => {
      const items = feed.querySelectorAll('.sf-feed__item--hidden');
      let revealed = 0;

      items.forEach((item) => {
        if (revealed >= PAGE_SIZE) return;
        item.classList.remove('sf-feed__item--hidden');
        revealed++;
      });

      visibleCount += revealed;
      const remaining = feed.querySelectorAll('.sf-feed__item--hidden').length;

      if (remaining === 0) {
        btn.closest('.sf-load-more')?.remove();
      }
    });
  }

  document.addEventListener('astro:page-load', initLoadMore);
  document.addEventListener('astro:page-load', initRumorImpressions);
</script>

<style>
  .sf-feed__item--hidden {
    display: none;
  }
</style>
