---
/**
 * SchefterPostCardCompact — Compact post card for sidebar feed.
 *
 * Smaller text, 3-line body clamp, no analysis blocks or article images.
 * Renders reactions + reply thread toggle.
 */
import type { SchefterPost } from '../../types/schefter';
import { getAuthor, getAuthorAvatar } from '../../types/schefter';
import { formatRelativeTime } from '../../utils/schefter-feed';
import type { GroupMePostMeta } from '../../utils/groupme-storage';
import SchefterReactionBar from './SchefterReactionBar.tsx';
import SchefterReplyThread from './SchefterReplyThread.tsx';

interface Props {
  post: SchefterPost;
  isAuthenticated?: boolean;
  userFranchiseId?: string;
  userTeamName?: string;
  userTeamIcon?: string;
  now?: Date;
  /** Server-resolved reactions (avoids per-post client fetch) */
  reactions?: { reactions: Record<string, number>; userReaction: string | null };
}

const {
  post,
  isAuthenticated = false,
  userFranchiseId,
  userTeamName,
  userTeamIcon,
  now,
  reactions,
} = Astro.props;

const relTime = formatRelativeTime(post.timestamp, now);
const isGroupMe = post.type === 'groupme';
const gmMeta = isGroupMe ? (post as SchefterPost & { _groupMe: GroupMePostMeta })._groupMe : null;
const author = isGroupMe ? null : getAuthor(post.authorId);
const avatarSrc = isGroupMe ? (gmMeta?.avatar ?? '') : getAuthorAvatar(author!);
const displayName = isGroupMe ? (gmMeta?.name ?? 'Unknown') : author!.name;
const displayHandle = isGroupMe ? 'via GroupMe' : author!.handle;
const isExternal = post.type === 'external';
const tierClass = `sfc-post${post.tier === 'breaking' ? ' sfc-post--breaking' : ''}${isGroupMe ? ' sfc-post--groupme' : ''}`;

// GroupMe rich content
const gmImages = gmMeta?.attachments?.filter(a => a.type === 'image' && a.url) ?? [];
const gmBodyText = isGroupMe ? (post.body ?? '') : '';

const xPostRegex = /https?:\/\/(?:x|twitter)\.com\/(\w+)\/status\/(\d+)\S*/gi;
const instaRegex = /https?:\/\/(?:www\.)?instagram\.com\/(?:p|reel|tv)\/[\w-]+\S*/gi;
const genericUrlRegex = /https?:\/\/\S+/gi;

const xPostMatches = isGroupMe ? [...gmBodyText.matchAll(xPostRegex)] : [];
const instaMatches = isGroupMe ? [...gmBodyText.matchAll(instaRegex)] : [];
const specialUrls = new Set([...xPostMatches.map(m => m[0]), ...instaMatches.map(m => m[0])]);
const allUrls = isGroupMe ? [...gmBodyText.matchAll(genericUrlRegex)] : [];
const genericUrls = allUrls.map(m => m[0]).filter(url => !specialUrls.has(url)).map(url => url.replace(/[).,;:!?]+$/, ''));

const allUrlsToStrip = [...specialUrls, ...genericUrls];
let gmDisplayBody = gmBodyText;
for (const url of allUrlsToStrip) { gmDisplayBody = gmDisplayBody.replace(url, ''); }
gmDisplayBody = gmDisplayBody.replace(/\n{3,}/g, '\n\n').trim();

// Pick the first embed to show in compact view
const firstEmbedUrl = xPostMatches[0]?.[0]?.replace(/https?:\/\/twitter\.com/, 'https://x.com')
  ?? instaMatches[0]?.[0]
  ?? genericUrls[0]
  ?? null;
let firstEmbedLabel = '';
let firstEmbedDomain = '';
if (firstEmbedUrl) {
  if (xPostMatches.length > 0) { firstEmbedLabel = 'View on X'; firstEmbedDomain = 'x.com'; }
  else if (instaMatches.length > 0) { firstEmbedLabel = 'View on Instagram'; firstEmbedDomain = 'instagram.com'; }
  else { try { firstEmbedDomain = new URL(firstEmbedUrl).hostname.replace(/^www\./, ''); } catch { firstEmbedDomain = ''; } firstEmbedLabel = 'Open link'; }
}
---

<article class={tierClass} data-post-id={post.id} aria-label={`${displayName}: ${post.headline ?? post.body?.replace(/<[^>]+>/g, '').slice(0, 80) ?? 'Post'}`}>
  <img class={`sfc-avatar${isGroupMe ? ' sfc-avatar--groupme' : ''}`} src={avatarSrc} alt="" aria-hidden="true" width="32" height="32" loading="lazy" />

  <div class="sfc-post__content">
    <div class="sfc-post__header">
      <span class="sfc-post__name">{displayName}</span>
      <span class={`sfc-post__handle${isGroupMe ? ' sfc-post__handle--groupme' : ''}`}>{displayHandle}</span>
      <time class="sfc-post__time" datetime={post.timestamp}>{relTime}</time>
    </div>

    {isGroupMe ? (
      <>
        {gmDisplayBody && (
          <div class="sfc-post__body sfc-post__body--groupme">{gmDisplayBody}</div>
        )}
        {gmImages.length > 0 && (
          <div class="sfc-post__gm-thumb">
            <a href={gmImages[0].url} target="_blank" rel="noopener noreferrer">
              <img src={gmImages[0].url} alt="Shared image" class="sfc-post__gm-thumb-img" loading="lazy" />
            </a>
            {gmImages.length > 1 && (
              <span class="sfc-post__gm-thumb-more">+{gmImages.length - 1}</span>
            )}
          </div>
        )}
        {firstEmbedUrl && (
          <a href={firstEmbedUrl} target="_blank" rel="noopener noreferrer" class="sfc-post__embed-link">
            <span class="sfc-post__embed-domain">{firstEmbedDomain}</span>
            <span class="sfc-post__embed-sep">·</span>
            <span class="sfc-post__embed-cta">{firstEmbedLabel}</span>
          </a>
        )}
      </>
    ) : (
      <div class="sfc-post__body" set:html={post.body} />
    )}

    {post.link && (
      <a
        href={post.link}
        class="sfc-post__link"
        {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {post.linkLabel ?? (isExternal ? 'Read on ESPN →' : 'Read more')}
        {isExternal && <span style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0">(opens in new tab)</span>}
      </a>
    )}

    <div class="sfc-post__actions">
      <SchefterReplyThread
        client:idle
        postId={post.id}
        postHeadline={isGroupMe ? (gmMeta?.name ?? 'GroupMe') : post.headline}
        postAuthorId={post.authorId}
        isAuthenticated={isAuthenticated}
        userFranchiseId={userFranchiseId}
        userTeamName={userTeamName}
        userTeamIcon={userTeamIcon}
      />
      <SchefterReactionBar
        client:visible
        postId={post.id}
        isAuthenticated={isAuthenticated}
        initialReactions={reactions?.reactions}
        initialUserReaction={reactions?.userReaction}
        {...(isGroupMe && gmMeta && gmMeta.likeCount > 0 ? { baseReactions: { '❤️': gmMeta.likeCount } } : {})}
      />
    </div>
  </div>
</article>
