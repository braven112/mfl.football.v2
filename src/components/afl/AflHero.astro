---
/**
 * AflHero — Renders the AFL homepage hero from an AflHeroState.
 *
 * The branded AflEventHero renders EVERY promo state — calendar events, the
 * in-season daily slot rotation, fresh What's New entries, and the default
 * fallback. Each state carries a `view: EventHeroView` the resolver builds.
 * Only calendar-driven events get the gold border (`bordered` prop).
 *
 * High-stakes interactive phases keep their bespoke components for the day-of
 * / active week, because the promo hero can't replace what they do:
 *   - trade-deadline day      → TradeDeadlineHero (live countdown)
 *   - championship week       → AflChampionshipHero (matchup card)
 *   - conference playoffs     → AflPlayoffsHero (bracket)
 * In the LEAD-UP to each of those, AflEventHero takes over.
 *
 * HeroBanner is no longer used on the AFL homepage.
 */
import TradeDeadlineHero from '../theleague/TradeDeadlineHero';
import AflPlayoffsHero from './AflPlayoffsHero.astro';
import AflChampionshipHero from './AflChampionshipHero.astro';
import AflEventHero from './AflEventHero.astro';
import '../../styles/trade-deadline-hero.css';
import type { AflHeroState } from '../../utils/afl-hero-resolver';

/** Region label per state — gives screen-reader users a meaningful landmark cue. */
const REGION_LABEL: Record<string, string> = {
  'calendar-event': 'Featured league event',
  'regular-season': 'In-season hero',
  feature: "Fresh on the site",
  default: 'AFL hero',
};

interface Props {
  state: AflHeroState;
  /** AFL league config — required when rendering playoffs/championship heroes that need bracket data. */
  config?: any;
  /** Standings data from the AFL feed — same. */
  standings?: any[];
  /** User's franchise id, for highlighting in playoff brackets. */
  userFranchiseId?: string;
}

const { state, config, standings, userFranchiseId } = Astro.props;
---

{state.kind === 'trade-deadline' ? (
  <TradeDeadlineHero
    client:idle
    deadlineMidnightPT={state.deadlineMidnightPT}
    referenceNowISO={state.referenceNowISO}
  />
) : state.kind === 'playoffs' && config && standings ? (
  <AflPlayoffsHero
    teams={config.teams}
    standings={standings}
    config={config}
    userFranchiseId={userFranchiseId}
  />
) : state.kind === 'championship' && config && standings ? (
  <AflChampionshipHero
    teams={config.teams}
    standings={standings}
    config={config}
    userFranchiseId={userFranchiseId}
  />
) : (
  <AflEventHero
    {...state.view}
    bordered={state.kind === 'calendar-event'}
    regionLabel={REGION_LABEL[state.kind] ?? 'AFL hero'}
  />
)}
