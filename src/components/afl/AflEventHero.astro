---
/**
 * AflEventHero — branded full-bleed promotional hero for the AFL homepage.
 *
 * Drop-in renderer for AFL's calendar-driven promo states (keeper deadline,
 * conference draft, champion-crowned, offseason/default). Driven entirely by
 * props that AflHero.astro derives from the resolver's HeroContent + state, so
 * it stays wired into the existing event system — no new data source.
 *
 * Visual: deep-navy card, corner accent glow, condensed display headline with a
 * colored accent word, server-rendered day countdown, player cut-out on the
 * right, brand-red CTA. Colors fall back to AFL brand values but prefer the
 * site's CSS custom properties where they exist.
 */
import { spriteUrl } from '../../utils/sprite-url';
import ThemeImage from '../ThemeImage.astro';
import type { HeroModel } from '../../utils/hero-casting';
import { getNflTeamColors, hexToRgba } from '../../utils/nfl-team-colors';
import { normalizeTeamCode } from '../../utils/nfl-logo';

interface Props {
  /** Pill label, e.g. "2026 Keeper Deadline" */
  pill: string;
  /** White display line, e.g. "Lock in your" */
  headline: string;
  /** Colored display line appended after the headline, e.g. "core." */
  accentWord?: string;
  summary: string;
  link?: string;
  linkLabel?: string;
  isExternal?: boolean;
  /** Sprite glyph id WITHOUT the "icon-" prefix (e.g. "draft-podium"). Ignored when `badge` is set. */
  icon?: string;
  /** Optional tier/conference badge svg (e.g. /assets/afl/premier.svg). Replaces the icon chip. */
  badge?: string;
  /** Dark-mode variant of `badge` (e.g. /assets/afl/premier-dark.svg). Required whenever `badge` is set. */
  badgeDark?: string;
  badgeAlt?: string;
  /** Accent color for the headline word, countdown number and rail. */
  accent?: string;
  /** Rgba tint for the corner glow wash. */
  glow?: string;
  /** Player cut-out, e.g. /assets/hero-players/josh.webp */
  player?: string;
  playerAlt?: string;
  /** Feature screenshot filename relative to /assets/whats-new/ — shown in a
      browser frame (light/dark theme pair via the `-dark` suffix convention).
      Beats `player`; a cast `model` beats both. Hidden on mobile, where the
      AFL logo silhouette stands in. */
  screenshot?: string;
  /** Cast composite model — transparent ESPN cutout over a team-color glow
      with a frosted caption. Takes precedence over `player` when set. */
  model?: HeroModel | null;
  /** Big countdown value (number of days, or a short string like "LIVE"). */
  countValue?: string | number;
  /** Small caps label under the countdown number. */
  countLabel?: string;
  /** When true, draw the gold accent border. Reserved for calendar-driven events. */
  bordered?: boolean;
  /** Landmark label for the section element. Defaults to "AFL hero". */
  regionLabel?: string;
}

const {
  pill,
  headline,
  accentWord = '',
  summary,
  link,
  linkLabel = 'Learn more',
  isExternal = false,
  icon,
  badge,
  badgeDark,
  badgeAlt = '',
  accent = '#c9a94e',
  glow = 'rgba(196,30,58,.6)',
  player,
  playerAlt = '',
  screenshot,
  model = null,
  countValue,
  countLabel,
  bordered = false,
  regionLabel = 'AFL hero',
} = Astro.props;

// Composite model treatment: the model's NFL team primary color tints the
// glow behind the cutout (alpha differs per theme — white needs a lighter wash).
const modelTeamCode = model ? normalizeTeamCode(model.nflTeam) : '';
const modelColors = model ? getNflTeamColors(modelTeamCode) : null;
const modelGlowLight = modelColors ? hexToRgba(modelColors.primary, 0.22) : '';
const modelGlowDark = modelColors ? hexToRgba(modelColors.primary, 0.42) : '';
const modelStyle = model ? `--ev-model-glow-light:${modelGlowLight};--ev-model-glow-dark:${modelGlowDark};` : '';

// Feature screenshot theme pair (see capture-whats-new-screenshots.mjs).
const shotSrc = screenshot ? `/assets/whats-new/${screenshot}` : null;
const shotDarkSrc = shotSrc ? shotSrc.replace(/\.(\w+)$/, '-dark.$1') : null;
const shotFrameUrl = link ? `afl-fantasy.com${link.replace('/afl-fantasy', '')}` : 'afl-fantasy.com';

const hasCount = countValue !== undefined && countValue !== null && countValue !== '';
const hasFooter = hasCount || !!link;
// Compose an SR-friendly label for the count chip — value + label read as one phrase.
const countAriaLabel = hasCount
  ? countLabel
    ? `${countValue} — ${countLabel}`
    : String(countValue)
  : undefined;
---

<section
  class:list={['afl-event-hero', { 'afl-event-hero--bordered': bordered }]}
  style={`--ev-accent:${accent};--ev-glow:${glow};${modelStyle}`}
  aria-label={regionLabel}
>
  <span class="afl-event-hero__glow" aria-hidden="true"></span>

  {model ? (
    <>
      <div class="afl-event-hero__model" aria-hidden="true">
        <span class="afl-event-hero__model-glow"></span>
        <img
          class="afl-event-hero__cutout"
          src={model.headshot}
          alt=""
          loading="eager"
          fetchpriority="high"
          decoding="async"
          onerror="this.closest('.afl-event-hero').classList.add('afl-event-hero--no-model')"
        />
        <img class="afl-event-hero__logo-art afl-event-hero__logo-art--light" src="/assets/logos/afl-logo.svg" alt="" loading="lazy" />
        <img class="afl-event-hero__logo-art afl-event-hero__logo-art--dark" src="/assets/logos/afl-logo-dark.svg" alt="" loading="lazy" />
      </div>
      <span class="afl-event-hero__model-caption">
        <strong>{model.name}</strong>
        <span class="afl-event-hero__model-meta">{model.descriptor ? `${model.descriptor} · ` : ''}{model.position} · {modelTeamCode}</span>
      </span>
    </>
  ) : shotSrc ? (
    <>
      <div class="afl-event-hero__shot" aria-hidden="true">
        <div class="afl-event-hero__shot-bar">
          <span class="afl-event-hero__shot-dot afl-event-hero__shot-dot--red"></span>
          <span class="afl-event-hero__shot-dot afl-event-hero__shot-dot--yellow"></span>
          <span class="afl-event-hero__shot-dot afl-event-hero__shot-dot--green"></span>
          <span class="afl-event-hero__shot-url">{shotFrameUrl}</span>
        </div>
        <img
          class="afl-event-hero__shot-img afl-event-hero__shot-img--light"
          src={shotSrc}
          alt=""
          loading="eager"
          decoding="async"
          onerror="this.closest('.afl-event-hero').classList.add('afl-event-hero--no-shot')"
        />
        <img
          class="afl-event-hero__shot-img afl-event-hero__shot-img--dark"
          src={shotDarkSrc}
          alt=""
          loading="eager"
          decoding="async"
          onerror="this.closest('.afl-event-hero__shot').classList.add('afl-event-hero__shot--no-dark')"
        />
      </div>
      {/* Mobile (and light-capture 404) stand-in — the frame is hidden there */}
      <img class="afl-event-hero__shot-logo afl-event-hero__shot-logo--light" src="/assets/logos/afl-logo.svg" alt="" aria-hidden="true" loading="lazy" />
      <img class="afl-event-hero__shot-logo afl-event-hero__shot-logo--dark" src="/assets/logos/afl-logo-dark.svg" alt="" aria-hidden="true" loading="lazy" />
    </>
  ) : player && (
    <div class="afl-event-hero__player" aria-hidden="true">
      <img src={player} alt={playerAlt} loading="eager" fetchpriority="high" />
      <span class="afl-event-hero__fade afl-event-hero__fade--left"></span>
      <span class="afl-event-hero__fade afl-event-hero__fade--bottom"></span>
    </div>
  )}

  <div class="afl-event-hero__content">
    <div class="afl-event-hero__eyebrow">
      {badge ? (
        badgeDark ? (
          <ThemeImage class="afl-event-hero__badge" src={badge} darkSrc={badgeDark} alt={badgeAlt} />
        ) : (
          <img class="afl-event-hero__badge" src={badge} alt={badgeAlt} />
        )
      ) : icon ? (
        <span class="afl-event-hero__chip">
          <svg viewBox="0 0 24 24" aria-hidden="true"><use href={`${spriteUrl}#icon-${icon}`}></use></svg>
        </span>
      ) : null}
      <span class="afl-event-hero__pill">{pill}</span>
    </div>

    <h2 class="afl-event-hero__title">
      {headline}{accentWord && (<Fragment> <span class="afl-event-hero__accent">{accentWord}</span></Fragment>)}
    </h2>

    <p class="afl-event-hero__summary">{summary}</p>

    {hasFooter && (
      <div class="afl-event-hero__footer">
        {hasCount && (
          <div class="afl-event-hero__count" role="group" aria-label={countAriaLabel}>
            <span class="afl-event-hero__count-num" aria-hidden="true">{countValue}</span>
            {countLabel && <span class="afl-event-hero__count-label" aria-hidden="true">{countLabel}</span>}
          </div>
        )}
        {hasCount && link && <span class="afl-event-hero__divider" aria-hidden="true"></span>}
        {link && (
          <a
            class="afl-event-hero__cta"
            href={link}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
          >
            {linkLabel}
            <span class="afl-event-hero__cta-arrow" aria-hidden="true">→</span>
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  /* Theme surface: light editorial card by default; html.dark restores the
     deep-navy AFL brand chrome (matches the EventHeroShell theming pattern).
     AFL nuance: accent (gold) and glow (red) are different hues, so the light
     glow scales the passed --ev-glow's alpha instead of deriving from accent,
     and accent-colored TEXT darkens via --ev-accent-ink for contrast on white. */
  .afl-event-hero {
    --ev-surface: var(--color-white, #ffffff);
    --ev-ink: var(--color-gray-900, #111827);
    --ev-ink-soft: var(--color-gray-600, #4b5563);
    --ev-ink-faint: var(--color-gray-500, #6b7280);
    --ev-divider: var(--color-gray-200, #e5e7eb);
    --ev-glow-resolved: color-mix(in srgb, var(--ev-glow, rgba(196, 30, 58, 0.6)) 38%, transparent);
    --ev-accent-ink: color-mix(in srgb, var(--ev-accent, #c9a94e) 78%, #000);
    /* Light needs a wider/stronger photo wash than navy-on-navy — the photo
       contrasts far harder on white (same stops as EventHeroShell). */
    --ev-fade-left: linear-gradient(
      90deg,
      var(--ev-surface) 0%,
      color-mix(in srgb, var(--ev-surface) 92%, transparent) 22%,
      color-mix(in srgb, var(--ev-surface) 55%, transparent) 55%,
      color-mix(in srgb, var(--ev-surface) 18%, transparent) 82%,
      transparent 100%
    );
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: clamp(320px, 34vw, 380px);
    border-radius: var(--radius-lg, 0.75rem);
    background: var(--ev-surface);
    color: var(--ev-ink);
    box-shadow: var(--box-shadow-lg, 0 10px 28px rgba(0, 34, 68, 0.18));
    isolation: isolate;
  }

  :global(html.dark) .afl-event-hero {
    --ev-surface: #002244;
    --ev-ink: #ffffff;
    --ev-ink-soft: rgba(255, 255, 255, 0.72);
    --ev-ink-faint: rgba(255, 255, 255, 0.6);
    --ev-divider: rgba(255, 255, 255, 0.16);
    --ev-glow-resolved: var(--ev-glow, rgba(196, 30, 58, 0.6));
    --ev-accent-ink: var(--ev-accent, #c9a94e);
    --ev-fade-left: linear-gradient(
      90deg,
      var(--ev-surface) 0%,
      color-mix(in srgb, var(--ev-surface) 60%, transparent) 26%,
      color-mix(in srgb, var(--ev-surface) 10%, transparent) 60%,
      transparent 100%
    );
  }

  .afl-event-hero--bordered {
    border: 2px solid var(--ev-accent);
  }

  .afl-event-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(86% 92% at 3% -4%, var(--ev-glow-resolved), transparent 64%);
    pointer-events: none;
    /* Above the player cut-out so the wash continues over the photo feather
       (a tint stopping dead at the photo edge reads as a line on white). */
    z-index: 1;
  }

  /* ── Player panel ── */
  .afl-event-hero__player {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: clamp(220px, 36%, 360px);
  }
  .afl-event-hero__player img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 16%;
    display: block;
  }
  .afl-event-hero__fade {
    position: absolute;
    /* 1.5px overdraw: the replaced <img> and this overlay can snap to
       different pixel edges on fractional layouts, leaving a hairline photo
       sliver that reads as a vertical border on the light card. */
    inset: -1.5px;
    pointer-events: none;
  }
  .afl-event-hero__fade--left {
    background: var(--ev-fade-left);
  }
  .afl-event-hero__fade--bottom {
    background: linear-gradient(0deg, color-mix(in srgb, var(--ev-surface) 50%, transparent) 0%, transparent 42%);
  }

  /* ── Composite model panel (cast player) ── */
  /* Transparent ESPN cutout over a team-color glow — no fades needed (fades
     exist to blend rectangular photos; the cutout has no background). */
  .afl-event-hero {
    --ev-model-glow: var(--ev-model-glow-light, transparent);
    --ev-model-shadow: rgba(15, 30, 46, 0.3);
  }
  :global(html.dark) .afl-event-hero {
    --ev-model-glow: var(--ev-model-glow-dark, transparent);
    --ev-model-shadow: rgba(0, 0, 0, 0.5);
  }
  .afl-event-hero__model {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: clamp(240px, 38%, 400px);
    pointer-events: none;
    z-index: 1;
  }
  .afl-event-hero__model-glow {
    position: absolute;
    right: -70px;
    top: -90px;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, var(--ev-model-glow) 0%, transparent 65%);
  }
  .afl-event-hero__cutout {
    position: absolute;
    right: clamp(0.5rem, 2vw, 1.75rem);
    bottom: 0;
    width: clamp(230px, 28vw, 340px);
    max-height: 96%;
    object-fit: contain;
    object-position: bottom;
    filter: drop-shadow(0 16px 32px var(--ev-model-shadow));
  }
  /* Headshot 404 → hide the cutout + caption, show the AFL logo silhouette
     (theme pair) so the flank never sits empty. */
  .afl-event-hero__logo-art {
    display: none;
    position: absolute;
    right: clamp(1rem, 4vw, 3rem);
    top: 50%;
    transform: translateY(-50%) rotate(-6deg);
    width: clamp(170px, 22vw, 260px);
    opacity: 0.14;
  }
  .afl-event-hero--no-model .afl-event-hero__cutout {
    display: none;
  }
  .afl-event-hero--no-model .afl-event-hero__model-caption {
    display: none;
  }
  .afl-event-hero--no-model .afl-event-hero__logo-art--light {
    display: block;
  }
  :global(html.dark) .afl-event-hero--no-model .afl-event-hero__logo-art--light {
    display: none;
  }
  :global(html.dark) .afl-event-hero--no-model .afl-event-hero__logo-art--dark {
    display: block;
    opacity: 0.2;
  }
  .afl-event-hero__model-caption {
    position: absolute;
    z-index: 2;
    right: clamp(0.875rem, 2vw, 1.5rem);
    bottom: 0.875rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    text-align: right;
    /* Always white — the caption sits on its own dark frosted pill in both themes */
    color: #fff;
    background: rgba(6, 9, 13, 0.55);
    padding: 0.4rem 0.65rem;
    border-radius: 6px;
    backdrop-filter: blur(2px);
  }
  .afl-event-hero__model-caption strong {
    font-size: 0.8125rem;
    font-weight: 800;
    line-height: 1.1;
  }
  .afl-event-hero__model-meta {
    font-size: 0.575rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ── Feature screenshot (browser-framed) ──
     Fresh What's New art when the entry names no player: the feature itself
     in a browser frame. Light/dark captures are a theme pair; hidden on
     mobile (an unreadable thumbnail is decoration), where the AFL logo
     silhouette stands in. */
  .afl-event-hero__shot {
    position: absolute;
    z-index: 1;
    right: clamp(1rem, 2.5vw, 2rem);
    top: 50%;
    transform: translateY(-50%) rotate(-1.5deg);
    width: clamp(280px, 38%, 420px);
    border-radius: 0.5rem;
    overflow: hidden;
    background: #e5e7eb;
    box-shadow: 0 12px 32px var(--ev-model-shadow);
    pointer-events: none;
  }
  .afl-event-hero__shot-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: #e5e7eb;
  }
  .afl-event-hero__shot-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .afl-event-hero__shot-dot--red { background: #ff5f57; }
  .afl-event-hero__shot-dot--yellow { background: #ffbd2e; }
  .afl-event-hero__shot-dot--green { background: #28c840; }
  .afl-event-hero__shot-url {
    flex: 1;
    margin-left: 6px;
    background: #fff;
    border-radius: 3px;
    padding: 2px 8px;
    font-size: 10px;
    color: #6b7280;
    font-family: ui-monospace, monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .afl-event-hero__shot-img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top;
  }
  /* Theme pair: light capture by default, dark capture under html.dark. */
  .afl-event-hero__shot-img--dark {
    display: none;
  }
  :global(html.dark) .afl-event-hero .afl-event-hero__shot-img--light {
    display: none;
  }
  :global(html.dark) .afl-event-hero .afl-event-hero__shot-img--dark {
    display: block;
  }
  /* Dark capture 404 (entry not re-captured yet) → keep the light capture. */
  :global(html.dark) .afl-event-hero .afl-event-hero__shot--no-dark .afl-event-hero__shot-img--light {
    display: block;
  }
  :global(html.dark) .afl-event-hero .afl-event-hero__shot--no-dark .afl-event-hero__shot-img--dark {
    display: none;
  }
  /* Light capture 404 → drop the frame, logo silhouette returns. */
  .afl-event-hero--no-shot .afl-event-hero__shot {
    display: none;
  }
  /* Screenshot's logo stand-in: hidden while the frame is visible. */
  .afl-event-hero__shot-logo {
    display: none;
    position: absolute;
    z-index: 1;
    right: clamp(1rem, 4vw, 3rem);
    top: 50%;
    transform: translateY(-50%) rotate(-6deg);
    width: clamp(170px, 22vw, 260px);
    opacity: 0.14;
    pointer-events: none;
  }
  .afl-event-hero--no-shot .afl-event-hero__shot-logo--light {
    display: block;
  }
  :global(html.dark) .afl-event-hero--no-shot .afl-event-hero__shot-logo--light {
    display: none;
  }
  :global(html.dark) .afl-event-hero--no-shot .afl-event-hero__shot-logo--dark {
    display: block;
    opacity: 0.2;
  }

  /* ── Content ── */
  .afl-event-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.9rem;
    padding: clamp(1.5rem, 3vw, 2.4rem) clamp(1.5rem, 3vw, 2.75rem);
    max-width: 640px;
  }

  .afl-event-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  :global(.afl-event-hero__badge) {
    height: 46px;
    width: auto;
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.35));
  }
  .afl-event-hero__chip {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--ev-accent) 22%, transparent);
  }
  .afl-event-hero__chip svg {
    width: 24px;
    height: 24px;
    fill: var(--ev-accent-ink);
  }
  .afl-event-hero__pill {
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    background: var(--league-accent, #c41e3a);
    color: #fff;
  }

  .afl-event-hero__title {
    margin: 0;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: clamp(2.2rem, 4.4vw, 3.25rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--ev-ink);
    text-wrap: balance;
  }
  .afl-event-hero__accent {
    color: var(--ev-accent-ink);
  }

  .afl-event-hero__summary {
    margin: 0;
    max-width: 24rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--ev-ink-soft);
  }

  .afl-event-hero__footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .afl-event-hero__count {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .afl-event-hero__count-num {
    font-family: var(--font-numeric, 'UFC Sans', 'Vend Sans', system-ui, sans-serif);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: clamp(2.6rem, 5vw, 3.1rem);
    color: var(--ev-accent-ink);
  }
  .afl-event-hero__count-label {
    margin-top: 0.3rem;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ev-ink-faint);
  }
  .afl-event-hero__divider {
    width: 1px;
    height: 54px;
    background: var(--ev-divider);
  }

  .afl-event-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 50px;
    padding: 0 1.5rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--league-accent, #c41e3a);
    color: #fff;
