---
/**
 * Unified standings table (Phase 6).
 *
 * One config-driven, server-rendered component replacing StandingsTable,
 * LeagueStandingsTable, ConferenceLeagueStandingsTable and
 * TierAllPlayStandingsTable. Column set, team-cell mode, tiering, header and
 * accent glow are all data (see standings-table-config.ts). Zero client JS.
 *
 * The internal `variant` (std / league / conf / tier) selects the row model,
 * container chrome and the visual band it renders under. CSS is namespaced by
 * variant root class so each legacy table's exact look is preserved pixel-for-
 * pixel; the `accent` prop replaces the old `data-league` / `conferenceId`
 * selectors. See docs/standings-table-design.md.
 */
import PlayoffBadge from '../PlayoffBadge.astro';
import ThemeImage from '../../ThemeImage.astro';
import { HISTORICAL_TEAM_BANNER_FALLBACK } from '../../../utils/team-names';
import {
  parseWLT,
  safeParseFloat,
  safeParseInt,
  formatRecord,
  resolveAllPlayRecord,
  calculateGamesBack,
  formatGamesBack,
} from './standings-cells';
import {
  resolveBand,
  type StandingsColumn,
  type StandingsTableProps,
} from './standings-table-config';

const {
  teams,
  columns,
  teamCell,
  teamCellFallback = 'name',
  tiering,
  header,
  year = new Date().getFullYear(),
  preferredTeamId,
  rosterBaseUrl,
  franchiseBaseUrl,
  accent = 'league-blue',
  tierName = '',
  promotionCutoff,
} = Astro.props as StandingsTableProps;

// The tier variant is defined by its column set (rank circle + prize), not by
// the team-cell mode — deriving it from the columns keeps layout/skin selection
// decoupled from the presentational team-cell choice.
const isTierColumns = columns.some((c) => c.key === 'rankCircle' || c.key === 'prize');
const variant: 'std' | 'league' | 'conf' | 'tier' = isTierColumns
  ? 'tier'
  : tiering?.seedField === 'conferenceSeed'
    ? 'conf'
    : tiering?.seedField === 'seed'
      ? 'league'
      : 'std';

const isBranded = header?.kind === 'brandedDivision' && !!header.badgeSrc;
const showPlainDivision =
  !!header && (header.kind === 'division' || (header.kind === 'brandedDivision' && !header.badgeSrc));
const showConference = header?.kind === 'conference';
const showTier = header?.kind === 'tier';
const champ = header?.defendingChampion;

const containerClass = ['st-card', `v-${variant}`, `acc-${accent}`, isBranded ? 'branded' : '']
  .filter(Boolean)
  .join(' ');
// NL (conference-blue) drives the card glow + seed + your-team highlight to
// conference blue; AL / TheLeague fall through the CSS var chain.
const inlineStyle = accent === 'conference-blue' ? '--division-accent: #5b9bd5;' : undefined;

function colClass(col: StandingsColumn): string {
  switch (col.key) {
    case 'playoffBadge':
      return 'col-badge';
    case 'seedPlain':
    case 'seedAccent':
    case 'seedPill':
      return 'col-seed';
    case 'rankCircle':
      return 'col-rank';
    case 'team':
      return 'col-team';
    case 'overallRecord':
      return 'col-overall-record';
    case 'overallPct':
      return 'col-overall-pct';
    case 'divRecord':
      return 'col-div-record';
    case 'divPct':
      return 'col-div-pct';
    case 'allPlayRecord':
      return variant === 'league' || variant === 'conf' ? 'col-allplay' : 'col-record';
    case 'allPlayPct':
      return 'col-pct';
    case 'gamesBack':
      return 'col-gb';
    case 'streak':
      return 'col-streak';
    case 'pf':
      return 'col-pf';
    case 'pa':
      return 'col-pa';
    case 'pwr':
      return 'col-pwr';
    case 'vp':
      return 'col-vp';
    case 'prize':
      return 'col-prize';
    default:
      return '';
  }
}
const cellClass = (col: StandingsColumn) => `${colClass(col)}${col.hideBelow === 'sm' ? ' hide-sm' : ''}`;

function getPlayoffStatus(seed: number | undefined): 'division_winner' | 'wild_card' | null {
  if (seed && seed <= 4) return 'division_winner';
  if (seed && seed >= 5 && seed <= 7) return 'wild_card';
  return null;
}

// Text content for the simple (non-markup) column keys.
function cellText(col: StandingsColumn, team: (typeof teams)[number]): string {
  switch (col.key) {
    case 'overallRecord': {
      const r = parseWLT(team.h2hwlt);
      return `${r.w}-${r.l}-${r.t}`;
    }
    case 'overallPct':
      return safeParseFloat(team.h2hpct, 3);
    case 'divRecord': {
      const r = parseWLT(team.divwlt);
      return `${r.w}-${r.l}-${r.t}`;
    }
    case 'divPct':
      return safeParseFloat(team.divpct, 3);
    case 'allPlayRecord':
      return formatRecord(resolveAllPlayRecord(team, year), col.omitZeroTies);
    case 'allPlayPct':
      return safeParseFloat(team.all_play_pct, 3);
    case 'gamesBack':
      return formatGamesBack(calculateGamesBack(team, teams));
    case 'streak':
      return team.strk ?? '';
    case 'pf':
      return safeParseFloat(team.pf, 1);
    case 'pa':
      return safeParseFloat(team.pa, 1);
    case 'pwr':
      return safeParseFloat(team.pwr, 1);
    case 'vp':
      return safeParseInt(team.vp);
    default:
      return '';
  }
}

// --- Tier-table (AFL) row/border/prize logic (gated on the tier variant) -----
const TIER_PRIZES: Record<string, string[]> = {
  'Premier League': ['$225', '$150', '$100', '$50', '', '', '', '', '', '', '', ''],
  'D-League': ['$50', '', '', '', '', '', '', '', '', '', '', ''],
};
function tierRowClass(rank: number): string {
  if (tierName === 'Premier League') {
    if (rank === 1) return 'gold-tier';
    if (rank === 2) return 'silver-tier';
    if (rank === 3) return 'bronze-tier';
    if (rank === 4) return 'playoff-tier';
    if (rank === 9 || rank === 10) return 'relegation-danger';
    if (rank === 11 || rank === 12) return 'relegated';
  } else if (tierName === 'D-League') {
    if (rank === 1) return 'gold-tier';
    if (rank === 2) return 'second-place';
    if (rank === 3 || rank === 4) return 'dleague-playoff-tier';
    if (rank === 12) return 'last-place';
  }
  return '';
}
function tierBorderClass(rank: number): string {
  if (tierName === 'Premier League') {
    if (rank === 8) return 'border-below';
    if (rank === 10) return 'border-below-relegation';
  } else if (tierName === 'D-League') {
    if (rank === 2) return 'border-below-green';
    if (rank === 4) return 'border-below-playoff';
  }
  if (
    promotionCutoff !== undefined &&
    tierName !== 'Premier League' &&
    tierName !== 'D-League' &&
    rank === promotionCutoff
  ) {
    return 'border-below';
  }
  return '';
}

function bannerHrefFor(id: string): string | null {
  return franchiseBaseUrl ? `${franchiseBaseUrl}/${id}` : rosterBaseUrl ? `${rosterBaseUrl}?franchise=${id}` : null;
}
const bannerLabelFor = (name: string) =>
  franchiseBaseUrl ? `View ${name} franchise page` : `View ${name} roster`;
---

<div class={containerClass} style={inlineStyle}>
  {
    isBranded && (
      <div class="stand-head">
        <span class="sh-badge">
          <img src={header!.badgeSrc} alt={`${header!.title} division`} width="52" height="52" loading="lazy" decoding="async" />
        </span>
        <div class="sh-text">
          <h3 class:list={['sh-div', { 'sh-div--solo': !(champ && champ.logoSrc) }]}>{header!.title}</h3>
          {champ && champ.logoSrc && (
            <span class="sh-row">
              <span class="lbl">Defending Champion</span>
              <img class="sh-logo" src={champ.logoSrc} alt={champ.name} title={champ.name} loading="lazy" decoding="async" />
            </span>
          )}
        </div>
      </div>
    )
  }

  {
    showPlainDivision && (
      <div class="division-header-section">
        <div class="division-header-row">
          {header!.logoSrc && header!.logoDarkSrc && (
            <ThemeImage
              src={header!.logoSrc}
              darkSrc={header!.logoDarkSrc}
              alt={`${header!.title} logo`}
              class="division-conf-logo"
              loading="lazy"
              decoding="async"
            />
          )}
          <h3 class="division-header">{header!.title}</h3>
        </div>
        {champ && champ.name && (
          <p class="champion-subtitle">
            {champ.year} Division Champions: <strong>{champ.name}</strong>
          </p>
        )}
      </div>
    )
  }

  {
    showConference && (
      <h2 class="conference-title">
        {header!.logoSrc && header!.logoDarkSrc && (
          <ThemeImage
            src={header!.logoSrc}
            darkSrc={header!.logoDarkSrc}
            alt={`${header!.title} logo`}
            class="conference-logo"
            loading="lazy"
            decoding="async"
          />
        )}
        <span
          class="conference-title__name"
          style={`--conference-color: ${header!.accentColor}; --conference-color-dark: ${header!.accentColorDark};`}
        >
          {header!.title}
        </span>
      </h2>
    )
  }

  {
    showTier && (
      <div class="tier-header-section">
        {header!.logoSrc && header!.logoDarkSrc && (
          <ThemeImage src={header!.logoSrc} darkSrc={header!.logoDarkSrc} alt={`${header!.title} Logo`} class="tier-logo" />
        )}
        <h3 class="tier-header">{header!.title}</h3>
      </div>
    )
  }

  <div class="table-wrapper">
    <table class="st-table">
      <thead>
        <tr>
          {columns.map((col) => <th scope="col" class={cellClass(col)}>{col.header}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          teams.map((team, index) => {
            const rank = index + 1;
            const seedVal = tiering?.seedField === 'conferenceSeed' ? team.conferenceSeed : team.seed;
            const band = tiering ? resolveBand(seedVal, tiering) : '';
            const nextTeam = teams[index + 1];
            const nextSeedVal = nextTeam
              ? tiering?.seedField === 'conferenceSeed'
                ? nextTeam.conferenceSeed
                : nextTeam.seed
              : undefined;
            const nextBand = tiering && nextTeam ? resolveBand(nextSeedVal, tiering) : '';
            const isBoundary = Boolean(tiering && band !== nextBand && nextTeam);
            const isPreferred = Boolean(preferredTeamId && team.id === preferredTeamId);

            let rowClass = '';
            if (variant === 'std') {
              rowClass = `row-${index % 2 === 0 ? 'even' : 'odd'}${isPreferred ? ' preferred-team' : ''}`;
            } else if (variant === 'league' || variant === 'conf') {
              rowClass = `${band ? `tier-${band}` : ''} ${isBoundary ? 'tier-boundary' : ''}${isPreferred ? ' preferred-team' : ''}`.trim();
            } else {
              rowClass = `${tierRowClass(rank)} ${tierBorderClass(rank)}`.trim();
            }
            // Legacy std/league rows carried these data hooks; conf/tier did not.
            const withData = variant === 'std' || variant === 'league';

            const showBanner =
              teamCell === 'banner' &&
              (teamCellFallback === 'name'
                ? Boolean(team.teamBanner) && team.teamBanner !== HISTORICAL_TEAM_BANNER_FALLBACK
                : Boolean(team.teamBanner));
            const href = bannerHrefFor(team.id);

            return (
              <tr
                class={rowClass}
                data-preferred={withData && isPreferred ? 'true' : undefined}
                data-team-id={withData ? team.id : undefined}
              >
                {columns.map((col) => (
                  <td class={cellClass(col)}>
                    {col.key === 'playoffBadge' && (
                      <PlayoffBadge status={getPlayoffStatus(team.seed)} seed={team.seed} />
                    )}
                    {col.key === 'seedPlain' && <span class="seed-number">#{team.seed}</span>}
                    {col.key === 'seedAccent' && <span class="seed-number">#{team.conferenceSeed}</span>}
                    {col.key === 'seedPill' && <span class="seed-badge">#{team.seed}</span>}
                    {col.key === 'rankCircle' && <span class="rank-number">{rank}</span>}

                    {col.key === 'team' && teamCell === 'banner' && (
                      <div class="team-info">
                        {showBanner &&
                          (href ? (
                            <a href={href} class="team-banner-link" aria-label={bannerLabelFor(team.teamName)}>
                              <img src={team.teamBanner} alt={team.teamName} class="team-banner" title={team.teamName} />
                            </a>
                          ) : (
                            <img src={team.teamBanner} alt={team.teamName} class="team-banner" title={team.teamName} />
                          ))}
                        {teamCellFallback === 'name' && (
                          <span class={showBanner ? 'team-name' : 'team-name team-name--fallback'}>{team.teamName}</span>
                        )}
                      </div>
                    )}
                    {col.key === 'team' && teamCell === 'icon' &&
                      (rosterBaseUrl ? (
                        <a
                          href={`${rosterBaseUrl}?franchise=${team.id}`}
                          class="team-info team-info-link"
                          aria-label={`View ${team.teamName} roster`}
                        >
                          {team.teamIcon && <img src={team.teamIcon} alt={team.teamName} class="team-icon" loading="lazy" />}
                          <span class="team-name">{team.teamName}</span>
                        </a>
                      ) : (
                        <div class="team-info">
                          {team.teamIcon && <img src={team.teamIcon} alt={team.teamName} class="team-icon" loading="lazy" />}
                          <span class="team-name">{team.teamName}</span>
                        </div>
                      ))}

                    {col.key === 'prize' && (
                      <>
                        {TIER_PRIZES[tierName]?.[index] && <span class="prize-amount">{TIER_PRIZES[tierName][index]}</span>}
                        {tierName === 'D-League' && rank === 2 && <span class="promo-arrow rank-2">⬆</span>}
                        {tierName === 'D-League' && rank === 3 && <span class="promo-arrow rank-3">⬆</span>}
                        {tierName === 'D-League' && rank === 4 && <span class="promo-arrow rank-4">⬆</span>}
                        {tierName === 'Premier League' && rank === 9 && <span class="promo-arrow pl-rank-9">⬇</span>}
                        {tierName === 'Premier League' && rank === 10 && <span class="promo-arrow pl-rank-10">⬇</span>}
                        {tierName === 'Premier League' && rank === 11 && <span class="promo-arrow pl-rank-11">⬇</span>}
                        {tierName === 'Premier League' && rank === 12 && <span class="promo-arrow pl-rank-12">⬇</span>}
                        {promotionCutoff !== undefined && rank <= promotionCutoff && (
                          <span class="promo-arrow founders-promoted">⬆</span>
                        )}
                      </>
                    )}

                    {!['playoffBadge', 'seedPlain', 'seedAccent', 'seedPill', 'rankCircle', 'team', 'prize'].includes(
                      col.key
                    ) && cellText(col, team)}
                  </td>
                ))}
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</div>

<style>
  /* ===================================================================== */
  /* Shared: card containment + table wrapper                              */
  /* ===================================================================== */
  /* The card is frequently a grid/flex item (division/league/all-play grids,
     and AFL's two-up `.tier-grid`). Grid/flex items default to `min-width:auto`,
     whose content-based floor is the table's min-content — which, when a table
     is wider than a phone, propagates up and stretches the whole PAGE instead of
     scrolling inside the wrapper. `min-width: 0` lets the card shrink so the
     wrapper's `overflow-x: auto` engages; `max-width: 100%` is the belt to the
     suspenders. This is what stops horizontal PAGE scroll at every width; the
     per-column `.hide-sm` priorities below then keep phones from needing even
     the wrapper's scroll for the common tables. (See docs/standings-table-design.md.) */
  .st-card {
    min-width: 0;
    max-width: 100%;
  }
  .table-wrapper {
    overflow-x: auto;
  }
  /* `.hide-sm` (from a column's `hideBelow: 'sm'`) drops secondary columns below
     768px across EVERY variant, collapsing each table to rank/seed + team +
     primary record so phones show the hierarchy without sideways scroll. ≥768px
     is untouched — desktop renders exactly as before. */
  @media (max-width: 767px) {
    .hide-sm {
      display: none;
    }
  }

  /* ===================================================================== */
  /* VARIANT: std  (TheLeague/AFL division + TheLeague all-play)            */
  /* Source of truth: legacy StandingsTable.astro                          */
  /* ===================================================================== */
  .v-std {
    margin-bottom: 2rem;
    background: var(--card-bg, #fff);
    border-radius: 8px;
    box-shadow: var(--shadow-card);
    padding-block: var(--padding-md);
    overflow-x: auto;
  }
  :global(html.dark) .v-std {
    box-shadow: 0 0 0 1px var(--content-border, #555555), var(--shadow-lg);
  }
  .v-std.branded {
    padding-top: 0;
  }
  .v-std .stand-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--color-primary, #1c497c) 0%, #13365d 100%);
    border-radius: 8px 8px 0 0;
    padding: 22px 26px;
  }
  /* TL branded division dark glow (league-blue) */
  :global(html.dark) .v-std.branded {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.5) 0%, rgba(59, 130, 246, 0.16) 22%, var(--card-surface, #262626) 52%);
  }
  /* AFL division dark glow (red / NL blue) — replaces html.dark[data-league=afl] */
  :global(html.dark) .v-std.acc-afl-red,
  :global(html.dark) .v-std.acc-conference-blue {
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--division-accent, var(--league-accent, #ef5350)) 50%, transparent) 0%,
      color-mix(in srgb, var(--division-accent, var(--league-accent, #ef5350)) 16%, transparent) 22%,
      var(--card-surface, #16283c) 52%);
  }
  :global(html.dark) .v-std .stand-head {
    background: transparent;
  }
  .v-std .stand-head .sh-badge {
    flex-shrink: 0;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.3));
    display: flex;
  }
  .v-std .stand-head .sh-badge img {
    display: block;
    width: 52px;
    height: 52px;
  }
  .v-std .stand-head .sh-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .v-std .stand-head .sh-div {
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', sans-serif);
    font-weight: 700;
    font-size: 26px;
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: #fff;
    white-space: nowrap;
    margin: 0 0 -36px;
  }
  .v-std .stand-head .sh-div--solo {
    margin: 0;
  }
  .v-std .stand-head .sh-row {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    margin-top: 6px;
  }
  .v-std .stand-head .sh-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 50%;
    background: #fff;
    padding: 4px;
    flex-shrink: 0;
    margin-bottom: -6px;
  }
  .v-std .stand-head .lbl {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    white-space: nowrap;
  }
  .v-std .division-header-section {
    margin-bottom: 1.5rem;
    padding-inline: 1.5rem;
  }
  .v-std .division-header-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  :global(.division-conf-logo) {
    height: 1.75rem;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }
  .v-std .division-header {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0rem;
    color: var(--page-text, #1a1a1a);
    padding: 0;
  }
  .v-std .champion-subtitle {
    font-size: 0.95rem;
    color: var(--color-secondary, #2e8743);
    font-weight: 500;
    margin: 0;
    margin-top: 0.25rem;
  }
  /* AFL dark: champions read in trophy gold on the red/blue-glass card. */
  :global(html.dark) .v-std.acc-afl-red .champion-subtitle,
  :global(html.dark) .v-std.acc-conference-blue .champion-subtitle {
    color: var(--afl-trophy-gold, #c9a44c);
  }
  .v-std .st-table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--table-row-bg-alt, #f5f5f5);
    color: var(--page-text, #1a1a1a);
  }
  .v-std thead {
    background-color: var(--table-header-bg, #fff);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .v-std th {
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--table-header-text, #94a3b8);
    border-bottom: 2px solid var(--table-border, #d0d0d0);
  }
  .v-std td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--table-border, #e0e0e0);
    font-size: var(--table-cell-font-size, 0.75rem);
    color: var(--page-text, #1a1a1a);
  }
  .v-std tbody tr {
    background-color: var(--table-row-bg, #fff);
    transition: background-color 0.2s ease;
  }
  .v-std tbody tr:hover {
    background-color: var(--table-row-bg-hover, #f9f9f9);
  }
  .v-std tbody tr.row-odd {
    background-color: var(--table-row-bg-alt, #f5f5f5);
  }
  .v-std tbody tr.row-odd:hover {
    background-color: var(--table-row-bg-hover, #efefef);
  }
  :global(html.dark) .v-std .st-table {
    background-color: transparent;
  }
  :global(html.dark) .v-std td {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }
  :global(html.dark) .v-std th {
    border-bottom-color: rgba(255, 255, 255, 0.14);
  }
  :global(html.dark) .v-std thead {
    background-color: transparent;
  }
  :global(html.dark) .v-std tbody tr {
    background-color: rgba(255, 255, 255, 0.025);
  }
  :global(html.dark) .v-std tbody tr.row-odd {
    background-color: rgba(255, 255, 255, 0.055);
  }
  :global(html.dark) .v-std tbody tr:hover,
  :global(html.dark) .v-std tbody tr.row-odd:hover {
    background-color: rgba(0, 0, 0, 0.22);
  }
  .v-std .col-seed {
    width: 70px;
    text-align: center;
    font-weight: 600;
  }
  .v-std .col-badge {
    width: 100px;
    text-align: center;
    padding: 0.75rem 0.5rem;
  }
  .v-std .col-team {
    width: auto;
    min-width: 200px;
  }
  .v-std .col-record {
    width: 100px;
    text-align: center;
    white-space: nowrap;
  }
  .v-std .col-pct {
    width: 90px;
    text-align: center;
  }
  .v-std .col-pf,
  .v-std .col-pa {
    width: 100px;
    text-align: center;
  }
  .v-std .col-pwr,
  .v-std .col-vp {
    width: 90px;
    text-align: center;
  }
  .v-std .col-overall-record {
    width: 110px;
    text-align: center;
