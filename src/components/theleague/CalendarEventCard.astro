---
/**
 * CalendarEventCard - Event card for the full League Calendar page.
 * Shows event name, icon, date, description, countdown, and action/result links.
 *
 * Color system:
 * - Border-left: category color (preseason=blue, free-agency=green, draft=purple, regular-season=red)
 * - Badge: urgency indicator (active=green, urgent=amber, past=gray, default=neutral)
 * - Icon: category color, dimmed when past
 */
import type { ResolvedLeagueEvent } from '../../types/league-events';
import { formatEventDate, formatEventDateRange, getStatusText } from '../../utils/event-date-formatter';

export interface Props {
  event: ResolvedLeagueEvent;
}

const { event } = Astro.props;

const statusText = getStatusText(event.isActive, event.isPast, event.daysUntilStart);
const dateDisplay = event.definition.endDate
  ? formatEventDateRange(event.startDate, event.endDate)
  : formatEventDate(event.startDate);

const links = event.isPast ? event.resultLinks : event.actionLinks;
const iconId = event.definition.icon ? `icon-${event.definition.icon}` : null;
const category = event.definition.category;
const MULTICOLOR_ICONS = ['nfl'];
const isMulticolor = event.definition.icon ? MULTICOLOR_ICONS.includes(event.definition.icon) : false;

const cardClasses = [
  'calendar-card',
  `calendar-card--${category}`,
  event.isActive && 'calendar-card--active',
  event.isPast && 'calendar-card--past',
  event.isUrgent && 'calendar-card--urgent',
].filter(Boolean).join(' ');
---

<article class={cardClasses}>
  {(event.isPast || event.isActive) && (
    <span class="calendar-card__badge">{statusText}</span>
  )}
  <div class="calendar-card__header">
    {iconId && (
      <svg class={`calendar-card__icon${isMulticolor ? ' calendar-card__icon--multicolor' : ''}`} aria-hidden="true">
        <use href={`/assets/icons/sprite.svg#${iconId}`}></use>
      </svg>
    )}
    <h3 class="calendar-card__title">{event.definition.name}</h3>
  </div>
  <p class="calendar-card__date">{dateDisplay}</p>
  <p class="calendar-card__description">{event.definition.description}</p>
  {!event.isPast && !event.isActive && event.daysUntilStart > 0 && (
    <p class="calendar-card__countdown">{statusText}</p>
  )}
  {links.length > 0 && (
    <div class="calendar-card__links">
      {links.map((link) => (
        <a
          href={link.url}
          class="calendar-card__link"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          {link.label}
          {link.external && <span class="calendar-card__external-icon" aria-hidden="true">&nearr;</span>}
        </a>
      ))}
    </div>
  )}
</article>

<style>
  /* ── Category color tokens ── */
  :root {
    --cat-preseason: #60a5fa;
    --cat-free-agency: #2e8743;
    --cat-draft: #7c3aed;
    --cat-regular-season: #1c497c;
  }

  .calendar-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--content-bg, #fff);
    border-radius: 0.75rem;
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    border-left: 4px solid var(--card-category-color, var(--cat-preseason));
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    position: relative;
  }

  .calendar-card:hover {
    box-shadow: var(--box-shadow-hover, 0 4px 12px rgba(0, 0, 0, 0.08));
    transform: translateY(-2px);
  }

  /* ── Category variants (border-left + icon color) ── */
  .calendar-card--preseason { --card-category-color: var(--cat-preseason); }
  .calendar-card--free-agency { --card-category-color: var(--cat-free-agency); }
  .calendar-card--draft { --card-category-color: var(--cat-draft); }
  .calendar-card--regular-season { --card-category-color: var(--cat-regular-season); }

  /* ── State modifiers (affect badge, not border) ── */
  .calendar-card--past {
    opacity: 0.7;
    border-left-color: var(--color-gray-300, #d1d5db);
  }

  /* ── Badge (urgency/status indicator) ── */
  .calendar-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    width: fit-content;
    color: var(--text-secondary-color, #64748b);
    background: var(--color-gray-100, #f3f4f6);
  }

  .calendar-card--active .calendar-card__badge {
    color: #fff;
    background: var(--color-success, #10b981);
  }

  .calendar-card--urgent .calendar-card__badge {
    color: #fff;
    background: var(--color-warning, #f59e0b);
  }

  /* ── Header (icon + title) ── */
  .calendar-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ── Icon (category colored, gray when past) ── */
  .calendar-card__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    fill: currentColor;
    color: var(--card-category-color);
  }

  .calendar-card__icon--multicolor {
    fill: none;
    color: unset;
  }

  .calendar-card--past .calendar-card__icon {
    color: var(--color-gray-400, #9ca3af);
  }

  /* ── Title ── */
  .calendar-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
    color: var(--primary-link-default-text-color, #1c497c);
    line-height: 1.3;
  }

  /* ── Date ── */
  .calendar-card__date {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary-color, #64748b);
    margin: 0;
  }

  /* ── Description ── */
  .calendar-card__description {
    font-size: 0.875rem;
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Countdown ── */
  .calendar-card__countdown {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-info, #3b82f6);
    margin: 0;
  }

  .calendar-card--urgent .calendar-card__countdown {
    color: var(--color-warning, #f59e0b);
  }

  /* ── Links ── */
  .calendar-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .calendar-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    padding: 0.25rem 0.65rem;
    border-radius: 0.375rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--color-gray-200, #e5e7eb);
    transition: all 0.15s ease;
  }

  .calendar-card__link:hover {
    background: var(--color-primary, #1c497c);
    color: #fff;
    border-color: var(--color-primary, #1c497c);
  }

  .calendar-card__external-icon {
    font-size: 0.7rem;
  }

  @media (max-width: 767px) {
    .calendar-card {
      padding: 1rem;
    }

    .calendar-card__title {
      font-size: 1rem;
    }
  }
</style>
