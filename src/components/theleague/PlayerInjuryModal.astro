---
/**
 * PlayerInjuryModal - Displays detailed injury information for a player
 * Shows injury status and body part affected.
 *
 * Header is a composite mini hero (player-modal-band): the team-color
 * gradient is blended toward a red status accent, with the injury status as
 * the ghost wordmark and the player's ESPN cutout when one exists.
 */
import '../../styles/player-modal-band.css';

export interface Props {
  /** Additional CSS classes */
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['player-injury-modal', className]}>
  <div class="player-injury-modal__overlay"></div>
  <div class="player-injury-modal__content">
    <div class="player-injury-modal__header pmb" id="pim-band">
      <span class="pmb__ghost" aria-hidden="true"></span>
      <div class="pmb__glow" aria-hidden="true"></div>
      <img class="pmb__cutout" alt="" aria-hidden="true" loading="eager" decoding="async" />
      <div class="pim-band-info">
        <span class="pim-band-kicker">Injury Report</span>
        <h3 id="injury-modal-title">Player Injury Details</h3>
      </div>
      <button class="player-injury-modal__close" aria-label="Close" title="Close (ESC)">
        ×
      </button>
    </div>

    <div class="player-injury-modal__body">
      <div class="injury-info">
        <div class="injury-field">
          <span class="injury-label">Name</span>
          <span class="injury-value" id="injury-player-name">—</span>
        </div>
        <div class="injury-field">
          <span class="injury-label">Injury Status</span>
          <span class="injury-value" id="injury-status">—</span>
        </div>
        <div class="injury-field">
          <span class="injury-label">Body Part</span>
          <span class="injury-value" id="injury-body-part">—</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .player-injury-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1001;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .player-injury-modal.active {
    display: flex;
  }

  .player-injury-modal__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .player-injury-modal__content {
    position: relative;
    background: white;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    width: 100%;
    max-width: 400px;
    overflow: hidden;
  }

  /* Composite band header — .pmb paints gradient/ghost/glow/cutout
     (src/styles/player-modal-band.css); this block only lays out the text */
  .player-injury-modal__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    min-height: 84px;
    padding: 1.1rem 1.25rem 1rem 1.5rem;
  }

  .pim-band-info {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    /* Keep text clear of the cutout on the right */
    padding-right: clamp(64px, 24%, 110px);
  }

  .player-injury-modal__header.pmb--no-cutout .pim-band-info {
    padding-right: 2.25rem;
  }

  .pim-band-kicker {
    font-size: 0.625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.7);
  }

  .player-injury-modal__header h3 {
    /* Explicit white — sits on the team/status gradient */
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }

  .player-injury-modal__close {
    position: relative;
    z-index: 3;
    background: rgba(6, 9, 13, 0.4);
    backdrop-filter: blur(2px);
    border: none;
    font-size: 1.5rem;
    color: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    padding: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .player-injury-modal__close:hover {
    background: rgba(6, 9, 13, 0.65);
    color: #fff;
  }

  .player-injury-modal__body {
    padding: 1.5rem;
  }

  .injury-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .injury-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .injury-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .injury-value {
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
  }

  @media (max-width: 640px) {
    .player-injury-modal {
      padding: 0.5rem;
    }

    .player-injury-modal__content {
      max-width: 90%;
    }

    .player-injury-modal__header {
      min-height: 76px;
      padding: 0.9rem 1rem 0.8rem 1.25rem;
    }

    .player-injury-modal__body {
      padding: 1rem;
    }
  }
</style>

<script>
  import { applyPlayerModalBand } from '../../utils/player-modal-band';

  function initPlayerInjuryModal() {
    const modal = document.querySelector('.player-injury-modal');
    const overlay = document.querySelector('.player-injury-modal__overlay');
    const closeBtn = document.querySelector('.player-injury-modal__close');

    const closeModal = () => {
      if (modal) {
        modal.classList.remove('active');
      }
    };

    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal);
    }
    if (overlay) {
      overlay.addEventListener('click', closeModal);
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
        closeModal();
      }
    });

    window.openPlayerInjuryModal = function(injuryData: any) {
      const setElementText = (id: string, value: any) => {
        const el = document.getElementById(id);
        if (el) {
          el.textContent = value || 'N/A';
        }
      };

      setElementText('injury-modal-title', injuryData.name || 'Player Injury Details');
      setElementText('injury-player-name', injuryData.name);
      setElementText('injury-status', injuryData.injuryStatus);
      setElementText('injury-body-part', injuryData.injuryBodyPart);

      // Team gradient tinted toward the red status accent; the injury status
      // itself is the ghost wordmark ("QUESTIONABLE" behind the name).
      applyPlayerModalBand(document.getElementById('pim-band'), injuryData, {
        accent: '#dc2626',
        ghost: injuryData.injuryStatus || undefined,
      });

      if (modal) {
        modal.classList.add('active');
      }
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayerInjuryModal);
  } else {
    initPlayerInjuryModal();
  }
</script>
