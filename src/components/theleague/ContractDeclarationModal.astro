---
/**
 * ContractDeclarationModal — Inline contract declaration from the roster page
 *
 * Allows owners to declare contract years for eligible players:
 * - new-acquisition: BBID/auction players choose 2-5 years
 * - rookie-override: Rookies reduce from default 4yr RC to 1-3 years
 * - veteran-extension: Multi-step flow — step 1 = year select, step 2 = review
 *
 * Follows PlayerDetailsModal editorial design language.
 * Populated entirely by client-side JS — Astro renders the static shell.
 */
---

<div class="contract-declaration-modal" id="contract-declaration-modal">
  <div class="cdm-overlay"></div>
  <div
    id="cdm-announcer"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"
  ></div>
  <div class="cdm-content">
    <button class="cdm-close" aria-label="Close" title="Close (ESC)">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Step Indicator — veteran-extension only, sits above the scrollable body -->
    <div class="cdm-stepper" id="cdm-stepper" style="display: none;" aria-label="Progress">
      <div class="cdm-stepper__track">
        <button class="cdm-stepper__dot active" id="cdm-step-dot-1" aria-label="Go to step 1"><span>1</span></button>
        <div class="cdm-stepper__line" id="cdm-step-line-1"></div>
        <button class="cdm-stepper__dot" id="cdm-step-dot-2" aria-label="Step 2" disabled><span>2</span></button>
        <div class="cdm-stepper__line" id="cdm-step-line-2" style="display: none;"></div>
        <button class="cdm-stepper__dot" id="cdm-step-dot-3" aria-label="Step 3" disabled style="display: none;"><span>3</span></button>
      </div>
      <span class="cdm-stepper__label" id="cdm-stepper-label">Step 1 of ?</span>
    </div>

    <div class="cdm-body">
      <!-- Hero Identity -->
      <div class="cdm-hero">
        <div class="cdm-hero__avatar">
          <img id="cdm-headshot" src="" alt="Player headshot" />
        </div>
        <div class="cdm-hero__info">
          <h3 class="cdm-hero__name" id="cdm-player-name">&mdash;</h3>
          <div class="cdm-hero__meta">
            <img class="cdm-hero__team-logo" id="cdm-nfl-logo" src="" alt="" />
            <span class="cdm-hero__meta-text" id="cdm-meta-text">&mdash;</span>
          </div>
        </div>
      </div>

      <!-- Declaration Type Badge -->
      <div class="cdm-type-badge" id="cdm-type-badge">
        <span class="cdm-type-badge__dot"></span>
        <span class="cdm-type-badge__label" id="cdm-type-label">New Acquisition</span>
      </div>

      <!-- Key Contract Metrics (3-column grid) — hidden on step 2 of veteran-extension -->
      <div class="cdm-metrics" id="cdm-metrics">
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-salary">&mdash;</span>
          <span class="cdm-metric__label">Salary</span>
        </div>
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-years">&mdash;</span>
          <span class="cdm-metric__label">Years</span>
        </div>
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-designation">&mdash;</span>
          <span class="cdm-metric__label">Designation</span>
        </div>
      </div>

      <!-- Deadline Countdown -->
      <div class="cdm-deadline" id="cdm-deadline" style="display: none;">
        <span class="cdm-deadline__icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
        </span>
        <span class="cdm-deadline__text" id="cdm-deadline-text">Deadline in &mdash;</span>
      </div>

      <!-- Action Selection — step 1 for all salary-tool flows (franchise, extension, cut, trade) -->
      <div class="cdm-section" id="cdm-action-section" style="display: none;">
        <h4 class="cdm-section__title">Contract Action</h4>
        <div class="cdm-action-options" id="cdm-action-options">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- Year Selection (new-acquisition / rookie-override / veteran-extension step 1) -->
      <div class="cdm-section" id="cdm-year-section">
        <h4 class="cdm-section__title">Select Contract Length</h4>
        <div class="cdm-year-options" id="cdm-year-options">
          <!-- Populated by JS: radio-style year buttons -->
        </div>
      </div>

      <!-- Franchise Tag Panel (franchise-tag only) -->
      <div class="cdm-section" id="cdm-tag-section" style="display: none;">
        <h4 class="cdm-section__title">Tag Salary</h4>
        <div class="cdm-salary-comparison">
          <div class="cdm-salary-comparison__col">
            <span class="cdm-salary-comparison__label">Current</span>
            <span class="cdm-salary-comparison__value" id="cdm-tag-current">&mdash;</span>
          </div>
          <svg class="cdm-salary-comparison__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
          <div class="cdm-salary-comparison__col cdm-salary-comparison__col--new">
            <span class="cdm-salary-comparison__label">Tag Salary</span>
            <span class="cdm-salary-comparison__value cdm-salary-comparison__value--highlight" id="cdm-tag-new">&mdash;</span>
          </div>
        </div>
        <div class="cdm-tag-basis" id="cdm-tag-basis">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
          </svg>
          <span id="cdm-tag-basis-text">&mdash;</span>
        </div>
      </div>

      <!-- Cut Review — step 2 for cut action -->
      <div class="cdm-section" id="cdm-cut-section" style="display: none;">
        <h4 class="cdm-section__title">Financial Breakdown</h4>
        <div class="cdm-metrics">
          <div class="cdm-metric">
            <span class="cdm-metric__value cdm-metric__value--warning" id="cdm-cut-current-hit">&mdash;</span>
            <span class="cdm-metric__label">Cap Hit Now</span>
          </div>
          <div class="cdm-metric">
            <span class="cdm-metric__value" id="cdm-cut-future-hit">&mdash;</span>
            <span class="cdm-metric__label">Future Dead $</span>
          </div>
          <div class="cdm-metric">
            <span class="cdm-metric__value cdm-metric__value--positive" id="cdm-cut-savings">&mdash;</span>
            <span class="cdm-metric__label">Cap Saved</span>
          </div>
        </div>
        <p class="cdm-cut-note" id="cdm-cut-note">&mdash;</p>
      </div>

      <!-- Review Panel — step 2 content (veteran-extension) + immediate for other types -->
      <div class="cdm-review-panel" id="cdm-review-panel">

        <!-- Extension Panel (veteran-extension / rookie-extension) -->
        <div class="cdm-section" id="cdm-extension-section" style="display: none;">
          <h4 class="cdm-section__title">Extension Terms</h4>
          <div class="cdm-salary-comparison">
            <div class="cdm-salary-comparison__col">
              <span class="cdm-salary-comparison__label">Current</span>
              <span class="cdm-salary-comparison__value" id="cdm-ext-current">&mdash;</span>
            </div>
            <svg class="cdm-salary-comparison__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <div class="cdm-salary-comparison__col cdm-salary-comparison__col--new">
              <span class="cdm-salary-comparison__label">After Extension</span>
              <span class="cdm-salary-comparison__value cdm-salary-comparison__value--highlight" id="cdm-ext-new">&mdash;</span>
            </div>
          </div>
          <!-- Years comparison row -->
          <div class="cdm-ext-years-row" id="cdm-ext-years-row">
            <span class="cdm-ext-years-row__label">Term</span>
            <div class="cdm-ext-years-row__vals">
              <span id="cdm-ext-years-current">&mdash;</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
              <span class="cdm-ext-years-row__new" id="cdm-ext-years-new">&mdash;</span>
            </div>
          </div>
        </div>

        <!-- Formula Accordion (veteran-extension only, expanded by default) -->
        <div class="cdm-formula-section" id="cdm-formula-section" style="display: none;">
          <button class="cdm-formula-toggle" aria-expanded="false" id="cdm-formula-toggle">
            <span class="cdm-formula-toggle__label">Formula Breakdown</span>
            <svg class="cdm-formula-toggle__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div class="cdm-formula-body" id="cdm-formula-body">
            <div class="cdm-formula__equation" id="cdm-formula-equation"></div>
            <div class="cdm-formula__steps" id="cdm-formula-steps"></div>
            <div class="cdm-formula__result" id="cdm-formula-result"></div>
          </div>
        </div>

        <!-- Salary Projection Table (year-based selections + extension) -->
        <div class="cdm-section" id="cdm-projection-section" style="display: none;">
          <h4 class="cdm-section__title">Salary Projection</h4>
          <div class="cdm-projection-wrapper">
            <table class="cdm-projection-table">
              <thead>
                <tr id="cdm-projection-head">
                  <th>Season</th>
                  <th class="cdm-projection-th--right">Age</th>
                  <th class="cdm-projection-th--salary">Salary</th>
                </tr>
              </thead>
              <tbody id="cdm-projection-body">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
        </div>

        <!-- Team Cap Impact (shown alongside salary projection) -->
        <div class="cdm-section" id="cdm-cap-impact-section" style="display: none;">
          <h4 class="cdm-section__title">Team Cap Impact</h4>
          <div class="cdm-projection-wrapper">
            <table class="cdm-cap-impact-table">
              <thead>
                <tr>
                  <th>Season</th>
                  <th class="cdm-projection-th--salary">Contract</th>
                  <th class="cdm-projection-th--salary">Committed</th>
                  <th class="cdm-projection-th--salary">Available</th>
                </tr>
              </thead>
              <tbody id="cdm-cap-impact-body">
                <!-- Populated by JS -->
              </tbody>
            </table>
          </div>
        </div>

      </div><!-- /cdm-review-panel -->
    </div><!-- /cdm-body -->

    <!-- Footer — Back + Submit, always visible regardless of scroll -->
    <div class="cdm-footer" id="cdm-footer">
      <div class="cdm-footer__messages">
        <div class="cdm-error" id="cdm-error" style="display: none;"></div>
        <div class="cdm-success" id="cdm-success" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span>Declaration submitted for commissioner review</span>
        </div>
      </div>
      <div class="cdm-footer__actions">
        <button class="cdm-footer__back" id="cdm-back-btn" style="display: none;">Back</button>
        <button class="cdm-submit" id="cdm-submit" disabled>Declare Contract</button>
      </div>
    </div>
  </div>
</div>

<style>
  /* ================================================================
     Modal Shell — matches PlayerDetailsModal
     ================================================================ */
  .contract-declaration-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1001;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .contract-declaration-modal.active {
    display: flex;
  }

  .cdm-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .cdm-content {
    position: relative;
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 440px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: cdm-enter 0.22s ease-out;
  }

  @keyframes cdm-enter {
    from { opacity: 0; transform: scale(0.97) translateY(6px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .cdm-content.slide-from-right {
    animation: cdm-slide-from-right 0.26s ease-out;
  }

  @keyframes cdm-slide-from-right {
    from { opacity: 0; transform: translateX(32px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ================================================================
     Close Button
     ================================================================ */
  .cdm-close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    background: var(--color-gray-100, #f3f4f6);
    border: none;
    border-radius: var(--radius-full, 9999px);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cdm-close:hover {
    background: var(--color-gray-200, #dddedf);
    color: var(--color-gray-800, #1f2937);
  }

  /* ================================================================
     Step Indicator — header strip, matches ContractDemoOverlay cdemo-stepper
     Sits above the scrollable body with a separator line
     ================================================================ */
  .cdm-stepper {
    display: none; /* shown via JS */
    flex-direction: column;
    align-items: flex-start;
    gap: 0.375rem;
    padding: 0.875rem 1.75rem 0.875rem;
    border-bottom: 1px solid var(--content-border, #e2e8f0);
    flex-shrink: 0;
  }

  .cdm-stepper__track {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .cdm-stepper__dot {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full, 9999px);
    border: 2px solid var(--color-gray-200, #e5e7eb);
    background: var(--color-white, #fff);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    transition: border-color 0.2s ease, background 0.2s ease;
    flex-shrink: 0;
    padding: 0;
    font-family: inherit;
  }

  .cdm-stepper__dot span {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-gray-400, #9ca3af);
    transition: color 0.2s ease;
    pointer-events: none;
  }

  .cdm-stepper__dot.active {
    border-color: var(--color-primary, #1c497c);
    background: var(--color-primary, #1c497c);
  }

  .cdm-stepper__dot.active span { color: #fff; }

  .cdm-stepper__dot.completed {
    border-color: var(--color-primary, #1c497c);
    background: color-mix(in srgb, var(--color-primary, #1c497c) 10%, white);
    cursor: pointer;
  }

  .cdm-stepper__dot.completed:hover {
    background: color-mix(in srgb, var(--color-primary, #1c497c) 18%, white);
  }

  .cdm-stepper__dot.completed span {
    color: var(--color-primary, #1c497c);
  }

  .cdm-stepper__line {
    width: 2rem;
    height: 2px;
    background: var(--color-gray-200, #e5e7eb);
    transition: background 0.3s ease;
  }

  .cdm-stepper__line.completed {
    background: var(--color-primary, #1c497c);
  }

  .cdm-stepper__label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
  }

  /* ================================================================
     Body (scrollable middle section)
     ================================================================ */
  .cdm-body {
    overflow-y: auto;
    padding: 1.75rem 1.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
    min-height: 0;
  }

  /* ================================================================
     Hero — editorial identity block (matches PlayerDetailsModal)
     ================================================================ */
  .cdm-hero {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .cdm-hero__avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-lg, 1rem);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-gray-100, #f3f4f6);
    box-shadow: var(--shadow-md);
  }

  .cdm-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .cdm-hero__info {
    flex: 1;
    min-width: 0;
    padding-top: 0.25rem;
  }

  .cdm-hero__name {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    margin: 0 0 0.375rem;
    line-height: 1.2;
    padding-right: 2rem;
  }

  .cdm-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .cdm-hero__team-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .cdm-hero__meta-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-600, #4b5563);
  }

  /* ================================================================
     Type Badge — editorial accent chip
     ================================================================ */
  .cdm-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-primary, #1c497c);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-primary, #1c497c);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    align-self: flex-start;
  }

  .cdm-type-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full, 9999px);
    background: var(--color-primary, #1c497c);
  }

  .cdm-type-badge[data-type="rookie-override"] {
    border-left-color: var(--color-warning, #f59e0b);
    color: var(--color-warning-dark, #d97706);
  }

  .cdm-type-badge[data-type="rookie-override"] .cdm-type-badge__dot {
    background: var(--color-warning, #f59e0b);
  }

  .cdm-type-badge[data-type="franchise-tag"],
  .cdm-type-badge[data-type="veteran-extension"],
  .cdm-type-badge[data-type="rookie-extension"] {
    border-left-color: var(--color-success-dark, #059669);
    color: var(--color-success-dark, #059669);
  }

  .cdm-type-badge[data-type="franchise-tag"] .cdm-type-badge__dot,
  .cdm-type-badge[data-type="veteran-extension"] .cdm-type-badge__dot,
  .cdm-type-badge[data-type="rookie-extension"] .cdm-type-badge__dot {
    background: var(--color-success-dark, #059669);
  }

  /* ================================================================
     Key Metrics — 3-column grid (matches PlayerDetailsModal)
     ================================================================ */
  .cdm-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
  }

  .cdm-metric {
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }

  .cdm-metric__value {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }

  .cdm-metric__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400, #9ca3af);
    margin-top: 0.25rem;
  }

  .cdm-metric__value--warning {
    color: var(--color-error, #dc2626);
  }

  .cdm-metric__value--positive {
    color: var(--color-success-dark, #059669);
  }

  .cdm-cut-note {
    font-size: 0.75rem;
    color: var(--color-gray-400, #9ca3af);
    margin: 0.375rem 0 0;
    line-height: 1.4;
  }

  /* ================================================================
     Deadline — warning strip
     ================================================================ */
  .cdm-deadline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-warning, #f59e0b) 8%, white);
    border: 1px solid color-mix(in srgb, var(--color-warning, #f59e0b) 20%, white);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-warning-dark, #d97706);
  }

  .cdm-deadline--urgent {
    background: color-mix(in srgb, var(--color-error, #dc2626) 6%, white);
    border-color: color-mix(in srgb, var(--color-error, #dc2626) 15%, white);
    color: var(--color-error-dark, #b91c1c);
  }

  .cdm-deadline--critical {
    background: color-mix(in srgb, var(--color-error, #dc2626) 6%, white);
    border-color: color-mix(in srgb, var(--color-error, #dc2626) 15%, white);
    color: var(--color-error-dark, #b91c1c);
    animation: cdm-pulse 2s ease-in-out infinite;
  }

  @keyframes cdm-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .cdm-deadline__icon {
    display: flex;
    flex-shrink: 0;
  }

  /* ================================================================
     Review Panel — wraps step-2 sections for slide animation
     ================================================================ */
  .cdm-review-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cdm-review-panel.panel-enter {
    animation: cdm-panel-in 0.28s ease-out;
  }

  @keyframes cdm-panel-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ================================================================
     Section Title — canonical editorial pattern
     ================================================================ */
  .cdm-section {
    display: flex;
    flex-direction: column;
  }

  .cdm-section__title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  /* ================================================================
     Salary Comparison — before/after layout for tag + extension
     ================================================================ */
  .cdm-salary-comparison {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
  }

  .cdm-salary-comparison__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .cdm-salary-comparison__label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
  }

  .cdm-salary-comparison__value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-700, #374151);
    font-variant-numeric: tabular-nums;
  }

  .cdm-salary-comparison__value--highlight {
    color: var(--color-success-dark, #059669);
    font-size: 1.125rem;
  }

  .cdm-salary-comparison__arrow {
    color: var(--color-gray-400, #9ca3af);
    flex-shrink: 0;
  }

  .cdm-salary-comparison__col--new {
    text-align: right;
    align-items: flex-end;
  }

  /* Extension years comparison row */
  .cdm-ext-years-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 0.875rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    margin-top: 0.375rem;
  }

  .cdm-ext-years-row__label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
  }

  .cdm-ext-years-row__vals {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-gray-600, #4b5563);
    font-variant-numeric: tabular-nums;
  }

  .cdm-ext-years-row__vals svg {
    color: var(--color-gray-400, #9ca3af);
    flex-shrink: 0;
  }

  .cdm-ext-years-row__new {
    font-weight: 700;
    color: var(--color-success-dark, #059669);
  }

  /* Tag basis note */
  .cdm-tag-basis {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
  }

  /* ================================================================
     Year Options — editorial card tiles
     :global() needed because buttons are created dynamically via JS
     ================================================================ */
  .cdm-year-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(3.5rem, 1fr));
    gap: 0.5rem;
  }

  .cdm-year-options :global(.cdm-year-btn) {
    appearance: none;
    position: relative;
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-gray-300, #d1d5db);
    background: var(--color-gray-50, #f9fafb);
    border-radius: var(--radius-sm, 0.25rem);
    padding: 0.625rem 0.5rem 0.5rem;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    text-align: center;
  }

  .cdm-year-options :global(.cdm-year-btn__number) {
    font-size: 1.25rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-gray-700, #374151);
    line-height: 1;
    letter-spacing: -0.01em;
    transition: color 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn__label) {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    line-height: 1;
    transition: color 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn:hover) {
    border-color: var(--color-gray-400, #9ca3af);
    border-left-color: var(--color-primary, #1c497c);
    background: var(--color-gray-100, #f3f4f6);
  }

  .cdm-year-options :global(.cdm-year-btn:hover .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
  }

  .cdm-year-options :global(.cdm-year-btn.selected) {
    border-color: color-mix(in srgb, var(--color-primary, #1c497c) 25%, transparent);
    border-left: 2px solid var(--color-primary, #1c497c);
    background: color-mix(in srgb, var(--color-primary, #1c497c) 6%, white);
    box-shadow: var(--shadow-sm);
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
    font-weight: 700;
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__label) {
    color: var(--color-gray-600, #4b5563);
  }

  /* ================================================================
     Action Options — step 1 action selection buttons (salary-tool flows)
     :global() needed because buttons are created dynamically via JS
     ================================================================ */
  .cdm-action-options {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .cdm-action-options :global(.cdm-action-option) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-gray-200, #e5e7eb);
    border-radius: var(--radius-sm, 0.25rem);
    cursor: pointer;
    transition: all 0.18s ease;
    text-align: left;
    font-family: inherit;
    width: 100%;
  }

  .cdm-action-options :global(.cdm-action-option:hover) {
    background: var(--color-gray-100, #f3f4f6);
  }

  .cdm-action-options :global(.cdm-action-option:disabled),
  .cdm-action-options :global(.cdm-action-option--disabled) {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .cdm-action-options :global(.cdm-action-option__icon) {
    width: 30px;
    height: 30px;
    border-radius: var(--radius-sm, 0.25rem);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-500, #6b7280);
    transition: background 0.18s ease, color 0.18s ease;
  }
  .cdm-action-options :global(.cdm-action-option__icon svg) {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .cdm-action-options :global(.cdm-action-option__text) {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .cdm-action-options :global(.cdm-action-option__label) {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-800, #1f2937);
  }

  .cdm-action-options :global(.cdm-action-option__desc) {
    font-size: 0.6875rem;
    color: var(--color-gray-500, #6b7280);
  }

  .cdm-action-options :global(.cdm-action-option__chevron) {
    color: var(--color-gray-300, #d1d5db);
    flex-shrink: 0;
    transition: color 0.18s ease;
  }

  /* Color variants on hover */
  .cdm-action-options :global(.cdm-action-option--franchise:hover) {
    border-left-color: var(--color-success-dark, #059669);
  }
  .cdm-action-options :global(.cdm-action-option--franchise:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-success, #10b981) 12%, white);
    color: var(--color-success-dark, #059669);
  }

  .cdm-action-options :global(.cdm-action-option--extension:hover) {
    border-left-color: var(--color-primary, #1c497c);
  }
  .cdm-action-options :global(.cdm-action-option--extension:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-primary, #1c497c) 10%, white);
    color: var(--color-primary, #1c497c);
  }

  .cdm-action-options :global(.cdm-action-option--cut:hover) {
    border-left-color: var(--color-error, #dc2626);
  }
  .cdm-action-options :global(.cdm-action-option--cut:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-error, #dc2626) 8%, white);
    color: var(--color-error, #dc2626);
  }

  .cdm-action-options :global(.cdm-action-option--trade:hover),
  .cdm-action-options :global(.cdm-action-option--trade-simulate:hover) {
    border-left-color: var(--color-warning, #f59e0b);
  }
  .cdm-action-options :global(.cdm-action-option--trade:hover .cdm-action-option__icon),
  .cdm-action-options :global(.cdm-action-option--trade-simulate:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-warning, #f59e0b) 12%, white);
    color: var(--color-warning-dark, #d97706);
  }

  .cdm-action-options :global(.cdm-action-option--trade-block:hover) {
    border-left-color: var(--color-primary, #1c497c);
  }
  .cdm-action-options :global(.cdm-action-option--trade-block:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-primary, #1c497c) 10%, white);
    color: var(--color-primary, #1c497c);
  }

  .cdm-action-options :global(.cdm-action-option--trade-builder:hover) {
    border-left-color: var(--color-gray-500, #6b7280);
  }

  /* Trade block success state */
  .cdm-action-options :global(.cdm-action-option--success) {
    border-left-color: var(--color-success, #10b981);
    background: color-mix(in srgb, var(--color-success, #10b981) 8%, white);
  }
  .cdm-action-options :global(.cdm-action-option--success .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-success, #10b981) 15%, white);
    color: var(--color-success-dark, #059669);
  }
  .cdm-action-options :global(.cdm-action-option--success .cdm-action-option__label) {
    color: var(--color-success-dark, #059669);
  }

  /* Trade block error state */
  .cdm-action-options :global(.cdm-action-option--error) {
    border-left-color: var(--color-error, #dc2626);
  }
  .cdm-action-options :global(.cdm-action-option--error .cdm-action-option__desc) {
    color: var(--color-error, #dc2626);
  }

  .cdm-action-options :global(.cdm-action-option--cut-real .cdm-action-option__label) {
    color: var(--color-error, #dc2626);
  }
  .cdm-action-options :global(.cdm-action-option--cut-real:hover) {
    border-left-color: var(--color-error, #dc2626);
    background: color-mix(in srgb, var(--color-error, #dc2626) 5%, white);
  }
  .cdm-action-options :global(.cdm-action-option--cut-real:hover .cdm-action-option__icon) {
    background: color-mix(in srgb, var(--color-error, #dc2626) 12%, white);
    color: var(--color-error, #dc2626);
  }

  /* Danger confirmation state (cut-real after first click) */
  .cdm-action-options :global(.cdm-action-option--danger) {
    border-left-color: var(--color-error, #dc2626);
    background: color-mix(in srgb, var(--color-error, #dc2626) 10%, white);
    animation: cdm-danger-pulse 0.3s ease;
  }
  .cdm-action-options :global(.cdm-action-option--danger .cdm-action-option__icon) {
    background: var(--color-error, #dc2626);
    color: white;
  }
  .cdm-action-options :global(.cdm-action-option--danger .cdm-action-option__label) {
    color: var(--color-error, #dc2626);
    font-weight: 700;
  }
  .cdm-action-options :global(.cdm-action-option--danger .cdm-action-option__desc) {
    color: var(--color-error, #dc2626);
  }
  .cdm-action-options :global(.cdm-action-option--danger:hover) {
    background: color-mix(in srgb, var(--color-error, #dc2626) 15%, white);
  }
  .cdm-action-options :global(.cdm-action-option--danger.loading) {
    opacity: 0.7;
    pointer-events: none;
  }
  @keyframes cdm-danger-pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.015); }
    100% { transform: scale(1); }
  }

  /* Back-to-actions link within sub-views */
  .cdm-action-options :global(.cdm-action-back) {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: none;
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    padding: 0.25rem 0 0.5rem;
    transition: color 0.15s ease;
  }
  .cdm-action-options :global(.cdm-action-back:hover) {
    color: var(--color-gray-800, #1f2937);
  }
  .cdm-action-options :global(.cdm-action-back:focus-visible) {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 0.25rem);
  }

  /* ================================================================
     Roster Move Sub-Step (Move to IR / Practice + reverse directions)
     Direction-to-worse-state options ("Move to ...") get a 2px red
     left-border accent per the Negative/Warning State Pattern.
     ================================================================ */
  .cdm-action-options :global(.cdm-action-option--move-to-ir),
  .cdm-action-options :global(.cdm-action-option--move-to-practice) {
    border-left: 2px solid var(--color-error, #dc2626);
  }

  .cdm-action-options :global(.cdm-roster-move-subtitle) {
    margin: 0.5rem 0 0.75rem;
    font-size: 0.875rem;
    color: var(--color-gray-700, #374151);
    line-height: 1.4;
  }

  .cdm-action-options :global(.cdm-roster-move-note) {
    margin: 0 0 0.75rem;
    padding: 0.625rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-gray-700, #374151);
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    line-height: 1.4;
  }

  .cdm-action-options :global(.cdm-roster-move-card) {
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.625rem 0.75rem;
    margin-bottom: 0.75rem;
    transition: opacity 0.2s ease;
  }
  .cdm-action-options :global(.cdm-roster-move-card__row) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
  }
  .cdm-action-options :global(.cdm-roster-move-card__row:last-child) {
    border-bottom: none;
  }
  .cdm-action-options :global(.cdm-roster-move-card__label) {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-500, #6b7280);
  }
  .cdm-action-options :global(.cdm-roster-move-card__value) {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-700, #374151);
    font-variant-numeric: tabular-nums;
  }
  .cdm-action-options :global(.cdm-roster-move-card__delta--neg) {
    color: var(--color-success-dark, #047857);
    font-weight: 600;
  }
  .cdm-action-options :global(.cdm-roster-move-card__delta--pos) {
    color: var(--color-error-dark, #b91c1c);
    font-weight: 600;
  }

  .cdm-action-options :global(.cdm-roster-move-error) {
    min-height: 1.25rem;
    margin-bottom: 0.5rem;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--color-error-dark, #b91c1c);
    line-height: 1.35;
  }
  .cdm-action-options :global(.cdm-roster-move-error:empty) {
    display: none;
  }
  .cdm-action-options :global(.cdm-roster-move-error:focus-visible) {
    outline: 2px solid var(--color-error, #dc2626);
    outline-offset: 2px;
    border-radius: var(--radius-sm, 0.25rem);
  }

  .cdm-action-options :global(.cdm-roster-move-cta) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    background: var(--btn-primary-bg, #1c497c);
    color: var(--btn-primary-text, #fff);
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .cdm-action-options :global(.cdm-roster-move-cta:hover:not(:disabled)) {
    background: var(--btn-primary-bg-hover, #164066);
  }
  .cdm-action-options :global(.cdm-roster-move-cta:focus-visible) {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }
  .cdm-action-options :global(.cdm-roster-move-cta:disabled),
  .cdm-action-options :global(.cdm-roster-move-cta[aria-disabled="true"]) {
    background: var(--color-gray-300, #d1d5db);
    color: var(--color-gray-600, #4b5563);
    cursor: not-allowed;
  }
  .cdm-action-options :global(.cdm-roster-move-cta--success) {
    background: var(--color-success-dark, #047857);
  }
  .cdm-action-options :global(.cdm-roster-move-cta--success:hover) {
    background: var(--color-success-dark, #047857);
  }

  /* ================================================================
     Formula Accordion — veteran-extension breakdown
     ================================================================ */
  .cdm-formula-section {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
  }

  .cdm-formula-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    background: var(--color-gray-50, #f9fafb);
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .cdm-formula-toggle:hover {
    background: var(--color-gray-100, #f3f4f6);
  }

  .cdm-formula-toggle__label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-500, #6b7280);
  }

  .cdm-formula-toggle__chevron {
    color: var(--color-gray-400, #9ca3af);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .cdm-formula-toggle[aria-expanded="true"] .cdm-formula-toggle__chevron {
    transform: rotate(180deg);
  }

  .cdm-formula-body {
    padding: 0.75rem 0.875rem;
    border-top: 1px solid var(--content-border, #e2e8f0);
    display: none;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cdm-formula-body.expanded {
    display: flex;
  }

  .cdm-formula__equation {
    font-size: 0.75rem;
    color: var(--color-gray-600, #4b5563);
    font-family: ui-monospace, monospace;
    line-height: 1.6;
  }

  .cdm-formula__steps {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-top: 1px solid var(--color-gray-100, #f3f4f6);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }

  :global(.cdm-formula__step) {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--color-gray-600, #4b5563);
  }

  :global(.cdm-formula__step-label) {
    color: var(--color-gray-400, #9ca3af);
  }

  :global(.cdm-formula__step-value) {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .cdm-formula__result {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    margin-top: 0.25rem;
  }

  :global(.cdm-formula__result-label) {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400, #9ca3af);
  }

  :global(.cdm-formula__result-value) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-success-dark, #059669);
    font-variant-numeric: tabular-nums;
  }

  /* ================================================================
     Salary Projection Table — canonical editorial table
     ================================================================ */
  .cdm-projection-wrapper {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
  }

  .cdm-projection-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .cdm-projection-table th {
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-400, #9ca3af);
    font-weight: 600;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.75rem;
    text-align: left;
