---
/**
 * ContractDeclarationModal — Inline contract declaration from the roster page
 *
 * Allows owners to declare contract years for eligible players:
 * - new-acquisition: BBID/auction players choose 2-5 years
 * - rookie-override: Rookies reduce from default 4yr RC to 1-3 years
 *
 * Follows PlayerDetailsModal design language.
 * Populated entirely by client-side JS — Astro renders the static shell.
 */
---

<div class="contract-declaration-modal" id="contract-declaration-modal">
  <div class="cdm-overlay"></div>
  <div class="cdm-content">
    <button class="cdm-close" aria-label="Close" title="Close (ESC)">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="cdm-body">
      <!-- Player Hero -->
      <div class="cdm-hero">
        <div class="cdm-hero__avatar">
          <img id="cdm-headshot" src="" alt="Player headshot" />
        </div>
        <div class="cdm-hero__info">
          <h3 class="cdm-hero__name" id="cdm-player-name">&mdash;</h3>
          <div class="cdm-hero__meta">
            <img class="cdm-hero__team-logo" id="cdm-nfl-logo" src="" alt="" />
            <span class="cdm-hero__meta-text" id="cdm-meta-text">&mdash;</span>
          </div>
        </div>
      </div>

      <!-- Declaration Type Badge -->
      <div class="cdm-type-badge" id="cdm-type-badge">
        <span class="cdm-type-badge__dot"></span>
        <span class="cdm-type-badge__label" id="cdm-type-label">New Acquisition</span>
      </div>

      <!-- Current Contract Info -->
      <div class="cdm-section">
        <h4 class="cdm-section__title">Current Contract</h4>
        <div class="cdm-contract-info">
          <div class="cdm-detail">
            <span class="cdm-detail__label">Salary</span>
            <span class="cdm-detail__value" id="cdm-current-salary">&mdash;</span>
          </div>
          <div class="cdm-detail">
            <span class="cdm-detail__label">Years</span>
            <span class="cdm-detail__value" id="cdm-current-years">&mdash;</span>
          </div>
          <div class="cdm-detail">
            <span class="cdm-detail__label">Designation</span>
            <span class="cdm-detail__value" id="cdm-current-designation">&mdash;</span>
          </div>
        </div>
      </div>

      <!-- Deadline Countdown -->
      <div class="cdm-deadline" id="cdm-deadline" style="display: none;">
        <span class="cdm-deadline__icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
        </span>
        <span class="cdm-deadline__text" id="cdm-deadline-text">Deadline in —</span>
      </div>

      <!-- Year Selection -->
      <div class="cdm-section">
        <h4 class="cdm-section__title">Select Contract Length</h4>
        <div class="cdm-year-options" id="cdm-year-options">
          <!-- Populated by JS: radio-style year buttons -->
        </div>
      </div>

      <!-- Salary Projection Table -->
      <div class="cdm-section" id="cdm-projection-section" style="display: none;">
        <h4 class="cdm-section__title">Salary Projection</h4>
        <table class="cdm-projection-table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Salary</th>
            </tr>
          </thead>
          <tbody id="cdm-projection-body">
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>

      <!-- Submit -->
      <div class="cdm-actions">
        <button class="cdm-submit" id="cdm-submit" disabled>Declare Contract</button>
        <div class="cdm-error" id="cdm-error" style="display: none;"></div>
        <div class="cdm-success" id="cdm-success" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span>Declaration submitted for commissioner review</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ================================================================
     Modal Shell — matches PlayerDetailsModal
     ================================================================ */
  .contract-declaration-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1001;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .contract-declaration-modal.active {
    display: flex;
  }

  .cdm-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .cdm-content {
    position: relative;
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 440px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: cdm-enter 0.22s ease-out;
  }

  @keyframes cdm-enter {
    from { opacity: 0; transform: scale(0.97) translateY(6px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ================================================================
     Close Button
     ================================================================ */
  .cdm-close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    background: var(--color-gray-100, #f3f4f6);
    border: none;
    border-radius: var(--radius-full, 9999px);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cdm-close:hover {
    background: var(--color-gray-200, #e5e7eb);
    color: var(--color-gray-700, #374151);
  }

  /* ================================================================
     Body & Hero
     ================================================================ */
  .cdm-body {
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cdm-hero {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .cdm-hero__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: #f3f4f6;
    border: 1px solid #e2e8f0;
    flex-shrink: 0;
  }

  .cdm-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cdm-hero__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .cdm-hero__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: #111;
    margin: 0;
    line-height: 1.2;
  }

  .cdm-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: #64748b;
    font-size: 0.8125rem;
  }

  .cdm-hero__team-logo {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* ================================================================
     Type Badge
     ================================================================ */
  .cdm-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: #f0f9ff;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #0369a1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    align-self: flex-start;
  }

  .cdm-type-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #0ea5e9;
  }

  .cdm-type-badge[data-type="rookie-override"] {
    background: #fefce8;
    color: #a16207;
  }

  .cdm-type-badge[data-type="rookie-override"] .cdm-type-badge__dot {
    background: #eab308;
  }

  /* ================================================================
     Sections & Details — matches PlayerDetailsModal language
     ================================================================ */
  .cdm-section__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #475569;
    margin: 0 0 0.75rem;
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  .cdm-contract-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cdm-detail {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f1f5f9;
  }

  .cdm-detail:last-child {
    border-bottom: none;
  }

  .cdm-detail__label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    width: 5.5rem;
    flex-shrink: 0;
  }

  .cdm-detail__value {
    font-size: 0.9rem;
    font-weight: 300;
    color: #1a1a1a;
    font-variant-numeric: tabular-nums;
  }

  /* ================================================================
     Deadline
     ================================================================ */
  .cdm-deadline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: #fffbeb;
    border-radius: 6px;
    font-size: 0.8125rem;
    color: #92400e;
  }

  .cdm-deadline--urgent {
    background: #fef2f2;
    color: #991b1b;
  }

  .cdm-deadline--critical {
    background: #fef2f2;
    color: #991b1b;
    animation: cdm-pulse 2s ease-in-out infinite;
  }

  @keyframes cdm-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .cdm-deadline__icon {
    display: flex;
    flex-shrink: 0;
  }

  /* ================================================================
     Year Options — editorial card tiles
     :global() needed because buttons are created dynamically via JS
     ================================================================ */
  .cdm-year-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(4.5rem, 1fr));
    gap: 0.5rem;
  }

  .cdm-year-options :global(.cdm-year-btn) {
    appearance: none;
    position: relative;
    border: 1px solid #e2e8f0;
    border-left: 2px solid #cbd5e1;
    background: #fafbfc;
    border-radius: 6px;
    padding: 0.625rem 0.5rem 0.5rem;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    text-align: center;
  }

  .cdm-year-options :global(.cdm-year-btn__number) {
    font-size: 1.25rem;
    font-weight: 300;
    font-variant-numeric: tabular-nums;
    color: #334155;
    line-height: 1;
    letter-spacing: -0.01em;
    transition: color 0.18s ease, font-weight 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn__label) {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    line-height: 1;
    transition: color 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn:hover) {
    border-color: #94a3b8;
    border-left-color: var(--color-primary, #1c497c);
    background: #f1f5f9;
  }

  .cdm-year-options :global(.cdm-year-btn:hover .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
  }

  .cdm-year-options :global(.cdm-year-btn.selected) {
    border-color: rgba(28, 73, 124, 0.2);
    border-left: 2px solid var(--color-primary, #1c497c);
    background: linear-gradient(135deg, #f0f5fa 0%, #e8eff7 100%);
    box-shadow: 0 1px 3px rgba(28, 73, 124, 0.08);
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
    font-weight: 600;
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__label) {
    color: #64748b;
  }

  /* ================================================================
     Salary Projection Table
     ================================================================ */
  .cdm-projection-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .cdm-projection-table th {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
    text-align: left;
    padding: 0.375rem 0.5rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .cdm-projection-table :global(td) {
    padding: 0.375rem 0.5rem;
    color: #334155;
    border-bottom: 1px solid #f1f5f9;
  }

  .cdm-projection-table :global(tr:last-child td) {
    border-bottom: none;
  }

  /* ================================================================
     Actions
     ================================================================ */
  .cdm-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cdm-submit {
    appearance: none;
    border: none;
    background: var(--color-primary, #1c497c);
    color: #fff;
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, opacity 0.15s ease;
    width: 100%;
  }

  .cdm-submit:hover:not(:disabled) {
    background: #163d68;
  }

  .cdm-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cdm-submit.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .cdm-error {
    font-size: 0.8125rem;
    color: #dc2626;
    padding: 0.5rem 0.75rem;
    background: #fef2f2;
    border-radius: 6px;
  }

  .cdm-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #059669;
    padding: 0.5rem 0.75rem;
    background: #ecfdf5;
    border-radius: 6px;
  }

  /* ================================================================
     Mobile
     ================================================================ */
  @media (max-width: 600px) {
    .cdm-content {
      max-height: 92vh;
      border-radius: 1rem 1rem 0 0;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      max-width: 100%;
      animation: cdm-slide-up 0.25s ease-out;
    }

    @keyframes cdm-slide-up {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }

    .cdm-body {
      padding: 1.25rem;
    }

    .cdm-hero__avatar {
      width: 48px;
      height: 48px;
    }

    .cdm-hero__name {
      font-size: 1rem;
    }
  }
</style>
