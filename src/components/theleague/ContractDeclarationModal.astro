---
/**
 * ContractDeclarationModal — Inline contract declaration from the roster page
 *
 * Allows owners to declare contract years for eligible players:
 * - new-acquisition: BBID/auction players choose 2-5 years
 * - rookie-override: Rookies reduce from default 4yr RC to 1-3 years
 *
 * Follows PlayerDetailsModal editorial design language.
 * Populated entirely by client-side JS — Astro renders the static shell.
 */
---

<div class="contract-declaration-modal" id="contract-declaration-modal">
  <div class="cdm-overlay"></div>
  <div class="cdm-content">
    <button class="cdm-close" aria-label="Close" title="Close (ESC)">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="cdm-body">
      <!-- Hero Identity -->
      <div class="cdm-hero">
        <div class="cdm-hero__avatar">
          <img id="cdm-headshot" src="" alt="Player headshot" />
        </div>
        <div class="cdm-hero__info">
          <h3 class="cdm-hero__name" id="cdm-player-name">&mdash;</h3>
          <div class="cdm-hero__meta">
            <img class="cdm-hero__team-logo" id="cdm-nfl-logo" src="" alt="" />
            <span class="cdm-hero__meta-text" id="cdm-meta-text">&mdash;</span>
          </div>
        </div>
      </div>

      <!-- Declaration Type Badge -->
      <div class="cdm-type-badge" id="cdm-type-badge">
        <span class="cdm-type-badge__dot"></span>
        <span class="cdm-type-badge__label" id="cdm-type-label">New Acquisition</span>
      </div>

      <!-- Key Contract Metrics (3-column grid) -->
      <div class="cdm-metrics">
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-salary">&mdash;</span>
          <span class="cdm-metric__label">Salary</span>
        </div>
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-years">&mdash;</span>
          <span class="cdm-metric__label">Years</span>
        </div>
        <div class="cdm-metric">
          <span class="cdm-metric__value" id="cdm-current-designation">&mdash;</span>
          <span class="cdm-metric__label">Designation</span>
        </div>
      </div>

      <!-- Deadline Countdown -->
      <div class="cdm-deadline" id="cdm-deadline" style="display: none;">
        <span class="cdm-deadline__icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
        </span>
        <span class="cdm-deadline__text" id="cdm-deadline-text">Deadline in &mdash;</span>
      </div>

      <!-- Year Selection -->
      <div class="cdm-section">
        <h4 class="cdm-section__title">Select Contract Length</h4>
        <div class="cdm-year-options" id="cdm-year-options">
          <!-- Populated by JS: radio-style year buttons -->
        </div>
      </div>

      <!-- Salary Projection Table -->
      <div class="cdm-section" id="cdm-projection-section" style="display: none;">
        <h4 class="cdm-section__title">Salary Projection</h4>
        <div class="cdm-projection-wrapper">
          <table class="cdm-projection-table">
            <thead>
              <tr>
                <th>Year</th>
                <th class="cdm-projection-th--salary">Salary</th>
              </tr>
            </thead>
            <tbody id="cdm-projection-body">
              <!-- Populated by JS -->
            </tbody>
          </table>
        </div>
      </div>

      <!-- Submit -->
      <div class="cdm-actions">
        <button class="cdm-submit" id="cdm-submit" disabled>Declare Contract</button>
        <div class="cdm-error" id="cdm-error" style="display: none;"></div>
        <div class="cdm-success" id="cdm-success" style="display: none;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span>Declaration submitted for commissioner review</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ================================================================
     Modal Shell — matches PlayerDetailsModal
     ================================================================ */
  .contract-declaration-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1001;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .contract-declaration-modal.active {
    display: flex;
  }

  .cdm-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .cdm-content {
    position: relative;
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 440px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: cdm-enter 0.22s ease-out;
  }

  @keyframes cdm-enter {
    from { opacity: 0; transform: scale(0.97) translateY(6px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ================================================================
     Close Button
     ================================================================ */
  .cdm-close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    background: var(--color-gray-100, #f3f4f6);
    border: none;
    border-radius: var(--radius-full, 9999px);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cdm-close:hover {
    background: var(--color-gray-200, #dddedf);
    color: var(--color-gray-800, #1f2937);
  }

  /* ================================================================
     Body (scrollable)
     ================================================================ */
  .cdm-body {
    overflow-y: auto;
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ================================================================
     Hero — editorial identity block (matches PlayerDetailsModal)
     ================================================================ */
  .cdm-hero {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .cdm-hero__avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-lg, 1rem);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-gray-100, #f3f4f6);
    box-shadow: var(--shadow-md);
  }

  .cdm-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .cdm-hero__info {
    flex: 1;
    min-width: 0;
    padding-top: 0.25rem;
  }

  .cdm-hero__name {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    margin: 0 0 0.375rem;
    line-height: 1.2;
    padding-right: 2rem;
  }

  .cdm-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .cdm-hero__team-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .cdm-hero__meta-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-600, #4b5563);
  }

  /* ================================================================
     Type Badge — editorial accent chip
     ================================================================ */
  .cdm-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.625rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-primary, #1c497c);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-primary, #1c497c);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    align-self: flex-start;
  }

  .cdm-type-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full, 9999px);
    background: var(--color-primary, #1c497c);
  }

  .cdm-type-badge[data-type="rookie-override"] {
    border-left-color: var(--color-warning, #f59e0b);
    color: var(--color-warning-dark, #d97706);
  }

  .cdm-type-badge[data-type="rookie-override"] .cdm-type-badge__dot {
    background: var(--color-warning, #f59e0b);
  }

  /* ================================================================
     Key Metrics — 3-column grid (matches PlayerDetailsModal)
     ================================================================ */
  .cdm-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
  }

  .cdm-metric {
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }

  .cdm-metric__value {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }

  .cdm-metric__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400, #9ca3af);
    margin-top: 0.25rem;
  }

  /* ================================================================
     Deadline — warning strip
     ================================================================ */
  .cdm-deadline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-warning, #f59e0b) 8%, white);
    border: 1px solid color-mix(in srgb, var(--color-warning, #f59e0b) 20%, white);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-warning-dark, #d97706);
  }

  .cdm-deadline--urgent {
    background: color-mix(in srgb, var(--color-error, #dc2626) 6%, white);
    border-color: color-mix(in srgb, var(--color-error, #dc2626) 15%, white);
    color: var(--color-error-dark, #b91c1c);
  }

  .cdm-deadline--critical {
    background: color-mix(in srgb, var(--color-error, #dc2626) 6%, white);
    border-color: color-mix(in srgb, var(--color-error, #dc2626) 15%, white);
    color: var(--color-error-dark, #b91c1c);
    animation: cdm-pulse 2s ease-in-out infinite;
  }

  @keyframes cdm-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .cdm-deadline__icon {
    display: flex;
    flex-shrink: 0;
  }

  /* ================================================================
     Section Title — canonical editorial pattern
     ================================================================ */
  .cdm-section {
    display: flex;
    flex-direction: column;
  }

  .cdm-section__title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  /* ================================================================
     Year Options — editorial card tiles
     :global() needed because buttons are created dynamically via JS
     ================================================================ */
  .cdm-year-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(4.5rem, 1fr));
    gap: 0.5rem;
  }

  .cdm-year-options :global(.cdm-year-btn) {
    appearance: none;
    position: relative;
    border: 1px solid var(--content-border, #e2e8f0);
    border-left: 2px solid var(--color-gray-300, #d1d5db);
    background: var(--color-gray-50, #f9fafb);
    border-radius: var(--radius-sm, 0.25rem);
    padding: 0.625rem 0.5rem 0.5rem;
    cursor: pointer;
    transition: all 0.18s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
    text-align: center;
  }

  .cdm-year-options :global(.cdm-year-btn__number) {
    font-size: 1.25rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-gray-700, #374151);
    line-height: 1;
    letter-spacing: -0.01em;
    transition: color 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn__label) {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    line-height: 1;
    transition: color 0.18s ease;
  }

  .cdm-year-options :global(.cdm-year-btn:hover) {
    border-color: var(--color-gray-400, #9ca3af);
    border-left-color: var(--color-primary, #1c497c);
    background: var(--color-gray-100, #f3f4f6);
  }

  .cdm-year-options :global(.cdm-year-btn:hover .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
  }

  .cdm-year-options :global(.cdm-year-btn.selected) {
    border-color: color-mix(in srgb, var(--color-primary, #1c497c) 25%, transparent);
    border-left: 2px solid var(--color-primary, #1c497c);
    background: color-mix(in srgb, var(--color-primary, #1c497c) 6%, white);
    box-shadow: var(--shadow-sm);
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__number) {
    color: var(--color-primary, #1c497c);
    font-weight: 700;
  }

  .cdm-year-options :global(.cdm-year-btn.selected .cdm-year-btn__label) {
    color: var(--color-gray-600, #4b5563);
  }

  /* ================================================================
     Salary Projection Table — canonical editorial table
     ================================================================ */
  .cdm-projection-wrapper {
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    overflow: hidden;
  }

  .cdm-projection-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .cdm-projection-table th {
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-400, #9ca3af);
    font-weight: 600;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--content-border, #e2e8f0);
  }

  .cdm-projection-th--salary {
    text-align: right;
  }

  .cdm-projection-table :global(td) {
    padding: 0.4rem 0.75rem;
    color: var(--color-gray-700, #374151);
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    font-size: 0.8125rem;
  }

  .cdm-projection-table :global(td:last-child) {
    text-align: right;
    font-weight: 600;
    color: var(--color-gray-900, #111827);
  }

  .cdm-projection-table :global(tr:last-child td) {
    border-bottom: none;
  }

  .cdm-projection-table :global(tbody tr:hover) {
    background: var(--color-gray-50, #f9fafb);
  }

  /* ================================================================
     Actions
     ================================================================ */
  .cdm-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .cdm-submit {
    appearance: none;
    border: none;
    background: var(--color-primary, #1c497c);
    color: #fff;
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, opacity 0.15s ease;
    width: 100%;
  }

  .cdm-submit:hover:not(:disabled) {
    background: var(--color-primary-dark, #164066);
  }

  .cdm-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cdm-submit.loading {
    opacity: 0.7;
    pointer-events: none;
  }

  .cdm-error {
    font-size: 0.8125rem;
    color: var(--color-error, #dc2626);
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-error, #dc2626) 5%, white);
    border: 1px solid color-mix(in srgb, var(--color-error, #dc2626) 12%, white);
    border-radius: var(--radius-sm, 0.25rem);
  }

  .cdm-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-success-dark, #059669);
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-success, #10b981) 6%, white);
    border: 1px solid color-mix(in srgb, var(--color-success, #10b981) 15%, white);
    border-radius: var(--radius-sm, 0.25rem);
  }

  /* ================================================================
     Mobile — bottom-sheet pattern
     ================================================================ */
  @media (max-width: 600px) {
    .contract-declaration-modal {
      align-items: flex-end;
      padding: 0;
    }

    .cdm-content {
      max-height: 92vh;
      border-radius: var(--radius-lg, 1rem) var(--radius-lg, 1rem) 0 0;
      max-width: 100%;
      animation: cdm-slide-up 0.25s ease-out;
    }

    @keyframes cdm-slide-up {
      from { transform: translateY(100%); }
      to { transform: translateY(0); }
    }

    .cdm-body {
      padding: 1.25rem;
    }

    .cdm-hero__avatar {
      width: 56px;
      height: 56px;
      border-radius: var(--radius-md, 0.5rem);
    }

    .cdm-hero__name {
      font-size: 1.125rem;
    }

    .cdm-hero__meta-text {
      font-size: 0.8125rem;
    }

    .cdm-metrics {
      gap: 0.5rem;
    }

    .cdm-metric {
      padding: 0.625rem 0.375rem;
    }

    .cdm-metric__value {
      font-size: 1rem;
    }

    .cdm-metric__label {
      font-size: 0.625rem;
    }
  }
</style>
