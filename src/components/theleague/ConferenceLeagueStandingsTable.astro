---
import type { TeamStanding } from '../../types/standings';
import { getConferenceLogo, getConferenceLogoDark, type ConferenceId } from '../../utils/afl-conference';
import ThemeImage from '../ThemeImage.astro';

export interface Props {
  conferenceName: string;
  conferenceId?: ConferenceId;
  teams: TeamStanding[];
  year?: number;
  preferredTeamId?: string;
  rosterBaseUrl?: string;
  /**
   * How many of the top conference seeds are division winners. Defaults to the
   * current 2-divisions-per-conference layout; historical seasons (2003-2012)
   * had three divisions per conference, so pass 3 there.
   */
  divisionWinnerCount?: number;
}

const {
  conferenceName,
  conferenceId,
  teams,
  year = new Date().getFullYear(),
  preferredTeamId,
  rosterBaseUrl,
  divisionWinnerCount = 2,
} = Astro.props;

const conferenceLogo = conferenceId ? getConferenceLogo(conferenceId) : null;
const conferenceLogoDark = conferenceId ? getConferenceLogoDark(conferenceId) : null;
// Conference accent color for the title — AL red, NL blue (matches each logo).
// Set as a CSS custom property so the dark-mode rule below can brighten it
// (the raw brand hexes fail contrast against the dark card background).
const conferenceColor = conferenceId === '01' ? '#1d4f91' : '#c41e3a';
const conferenceColorDark = conferenceId === '01' ? '#5b9bd5' : '#f47a8f';

function parseWLT(wlt: string | undefined) {
  if (!wlt) return { w: 0, l: 0, t: 0 };
  const parts = wlt.split('-').map(Number);
  return { w: parts[0] || 0, l: parts[1] || 0, t: parts[2] || 0 };
}

// Derive all_play_wlt from percentage when the record is missing. A zero pct
// with no record means the feed simply predates all-play tracking (pre-2017) —
// deriving 0-240-0 from it would fabricate a season, so treat it as no data.
function deriveAllPlayWLT(pct: string | undefined, seasonYear: number): { w: number; l: number; t: number } | null {
  if (!pct) return null;
  const TOTAL_GAMES = seasonYear >= 2021 ? 255 : 240;
  const percentage = parseFloat(pct);
  if (isNaN(percentage) || percentage <= 0) return null;
  const wins = Math.round(TOTAL_GAMES * percentage);
  const losses = TOTAL_GAMES - wins;
  return { w: wins, l: losses, t: 0 };
}

function safeParseFloat(value: string | undefined, decimals: number): string {
  if (!value) return (0).toFixed(decimals);
  return parseFloat(value).toFixed(decimals);
}

function safeParseInt(value: string | undefined): string {
  if (!value) return '0';
  return parseInt(value).toString();
}

// Top seeds are division winners, the rest of the playoff field (top 4 per
// conference in every AFL era) are wild cards.
function getRowColor(seed: number | undefined): string {
  if (!seed) return '';
  if (seed <= divisionWinnerCount) return 'tier-division-winners';
  if (seed <= 4) return 'tier-wild-cards';
  return 'tier-eliminated';
}
---
<div class="conference-standings-container">
  <h2 class="conference-title">
    {conferenceLogo && conferenceLogoDark && (
      <ThemeImage
        src={conferenceLogo}
        darkSrc={conferenceLogoDark}
        alt={`${conferenceName} logo`}
        class="conference-logo"
        loading="lazy"
        decoding="async"
      />
    )}
    <span
      class="conference-title__name"
      style={`--conference-color: ${conferenceColor}; --conference-color-dark: ${conferenceColorDark};`}
    >{conferenceName}</span>
  </h2>

  <div class="table-wrapper">
    <table class="conference-standings-table">
      <thead>
        <tr>
          <th class="col-seed">Seed</th>
          <th class="col-team">Team</th>
          <th class="col-overall-record">Overall</th>
          <th class="col-overall-pct">PCT</th>
          <th class="col-div-record">Div</th>
          <th class="col-div-pct">PCT</th>
          <th class="col-allplay">All Play</th>
          <th class="col-pf">PF</th>
          <th class="col-pwr">PWR</th>
          <th class="col-vp">VP</th>
          <th class="col-pa">PA</th>
        </tr>
      </thead>
      <tbody>
        {teams.map((team, index) => {
          const overallRecord = parseWLT(team.h2hwlt);
          const divRecord = parseWLT(team.divwlt);
          const allPlayRecord = team.all_play_wlt
            ? parseWLT(team.all_play_wlt)
            : deriveAllPlayWLT(team.all_play_pct, year);
          const rowColor = getRowColor(team.conferenceSeed);
          const nextTeam = teams[index + 1];
          const nextTier = nextTeam ? getRowColor(nextTeam.conferenceSeed) : '';
          const isTierBoundary = rowColor !== nextTier && nextTeam;

          // Add preferred team class
          const isPreferredTeam = preferredTeamId && team.id === preferredTeamId;
          const preferredClass = isPreferredTeam ? 'preferred-team' : '';

          return (
            <tr class={`conference-row ${rowColor} ${isTierBoundary ? 'tier-boundary' : ''} ${preferredClass}`}>
              <td class="col-seed">
                <span class="seed-number">#{team.conferenceSeed}</span>
              </td>
              <td class="col-team">
                <div class="team-info">
                  {team.teamBanner && (
                    rosterBaseUrl ? (
                      <a
                        href={`${rosterBaseUrl}?franchise=${team.id}`}
                        class="team-banner-link"
                        aria-label={`View ${team.teamName} roster`}
                      >
                        <img
                          src={team.teamBanner}
                          alt={team.teamName}
                          class="team-banner"
                          title={team.teamName}
                        />
                      </a>
                    ) : (
                      <img
                        src={team.teamBanner}
                        alt={team.teamName}
                        class="team-banner"
                        title={team.teamName}
                      />
                    )
                  )}
                </div>
              </td>
              <td class="col-overall-record">
                {overallRecord.w}-{overallRecord.l}-{overallRecord.t}
              </td>
              <td class="col-overall-pct">
                {safeParseFloat(team.h2hpct, 3)}
              </td>
              <td class="col-div-record">
                {divRecord.w}-{divRecord.l}-{divRecord.t}
              </td>
              <td class="col-div-pct">
                {safeParseFloat(team.divpct, 3)}
              </td>
              <td class="col-allplay">
                {allPlayRecord ? `${allPlayRecord.w}-${allPlayRecord.l}-${allPlayRecord.t}` : 'N/A'}
              </td>
              <td class="col-pf">
                {safeParseFloat(team.pf, 1)}
              </td>
              <td class="col-pwr">
                {safeParseFloat(team.pwr, 1)}
              </td>
              <td class="col-vp">
                {safeParseInt(team.vp)}
              </td>
              <td class="col-pa">
                {safeParseFloat(team.pa, 1)}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>

<style>
  .conference-standings-container {
    margin-bottom: 2rem;
    background-color: var(--card-bg, #fff);
    border-radius: 1rem;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
    overflow: hidden;
  }

  /* Dark mode: raised-card treatment — shadow alone can't separate
     the section from the page background; add the border ring. */
  :global(html.dark) .conference-standings-container {
    box-shadow:
      0 0 0 1px var(--content-border, #555555),
      0 10px 15px -3px rgb(0 0 0 / 0.1);
  }

  .conference-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.75rem;
    font-weight: 700;
    padding: 1.5rem 2rem;
    margin: 0;
    background: var(--card-bg, #fff);
    border-bottom: 1px solid var(--content-border, #e2e8f0);
  }

  :global(.conference-logo) {
    height: 2.25rem;
    width: auto;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }

  .conference-title__name {
    color: var(--conference-color);
  }

  :global(html.dark) .conference-title__name {
    color: var(--conference-color-dark);
  }

  .table-wrapper {
    overflow-x: auto;
    padding: 1.5rem 2rem;
  }

  .conference-standings-table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background-color: var(--table-header-bg, #f8fafc);
    border-bottom: 2px solid var(--table-border, #e2e8f0);
  }

  th {
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--table-header-text, #475569);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--table-border, #e2e8f0);
    font-size: 0.875rem;
    color: var(--page-text, #1e293b);
  }

  tbody tr {
    transition: background-color 0.2s ease;
  }

  tbody tr:hover {
    background-color: var(--table-row-bg-hover, #f8fafc);
  }

  /* Tier Color Schemes — fixed pastel bands with explicit dark text;
     dark mode gets darker bands + light text so the pairing still moves
     together (see tier-boundary note below for the same pattern). */
  .tier-division-winners {
    background-color: #fef8e7;
    color: #1a1a1a;
  }

  .tier-wild-cards {
    background-color: #f3f3f3;
    color: #1a1a1a;
  }

  .tier-eliminated {
    background-color: var(--table-row-bg, #fff);
  }

  /* Dark tier bands: whisper-tints mixed into the card surface (matches
     LeagueStandingsTable) — resolves against AFL's navy card too. */
  :global(html.dark) .tier-division-winners {
    background-color: color-mix(in srgb, #d4a856 12%, var(--card-bg, #1e1e1e));
    color: #ededed;
  }

  :global(html.dark) .tier-wild-cards {
    background-color: color-mix(in srgb, #dad8d5 7%, var(--card-bg, #1e1e1e));
    color: #ededed;
  }

  /* Tier Boundary Dividers */
  .tier-division-winners.tier-boundary {
    border-bottom: 3px solid #d4a856 !important;
  }

  .tier-wild-cards.tier-boundary {
    border-bottom: 3px solid #cbd5e1 !important;
  }

  :global(html.dark) .tier-division-winners.tier-boundary {
    border-bottom-color: #8a6d2e !important;
  }

  :global(html.dark) .tier-wild-cards.tier-boundary {
    border-bottom-color: #4a4a4a !important;
  }

  /* Column Widths */
  .col-seed {
    width: 80px;
    text-align: center;
    font-weight: 700;
    color: #c41e3a;
    font-size: 1.125rem;
  }

  :global(html.dark) .col-seed {
    color: #f47a8f;
  }

  .col-team {
    width: auto;
    min-width: 250px;
  }

  .col-overall-record {
    width: 110px;
    text-align: center;
    white-space: nowrap;
    font-weight: 600;
  }

  .col-overall-pct {
    width: 90px;
    text-align: center;
  }

  .col-div-record {
    width: 110px;
    text-align: center;
    white-space: nowrap;
  }

  .col-div-pct {
    width: 90px;
    text-align: center;
  }

  .col-allplay {
    width: 110px;
    text-align: center;
    white-space: nowrap;
  }

  .col-pf,
  .col-pa {
    width: 110px;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  .col-pwr {
    width: 100px;
    text-align: center;
  }

  .col-vp {
    width: 90px;
    text-align: center;
  }

  /* Team Info */
  .team-info {
    display: flex;
    align-items: center;
  }

  .team-banner {
    width: 100%;
    max-width: 400px;
    height: auto;
    object-fit: contain;
  }

  .team-banner-link {
    display: inline-block;
    line-height: 0;
    border-radius: 4px;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .team-banner-link:hover,
  .team-banner-link:focus-visible {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .team-banner-link:focus-visible {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  .seed-number {
    font-weight: 700;
    font-size: 1rem;
    display: inline-block;
  }

  /* Preferred Team Highlighting */
  tbody tr.preferred-team {
    background-color: color-mix(in srgb, var(--color-secondary, #2e743d) 12%, var(--table-row-bg, #fff)) !important;
    border-left: 3px solid var(--color-secondary, #2e743d);
  }

  tbody tr.preferred-team:hover {
    background-color: color-mix(in srgb, var(--color-secondary, #2e743d) 22%, var(--table-row-bg, #fff)) !important;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .conference-title {
      font-size: 1.5rem;
      padding: 1rem 1.5rem;
    }

    :global(.conference-logo) {
      height: 1.75rem;
    }

    .table-wrapper {
      padding: 1rem 1.5rem;
    }

    .col-team {
      min-width: 100px;
    }

    th,
    td {
      padding: 0.5rem;
      font-size: 0.75rem;
    }

    .team-banner {
      max-width: 200px;
    }

    .seed-number {
      font-size: 0.9rem;
    }

    /* Hide some columns on mobile */
    .col-div-pct,
    .col-pwr,
    .col-pa {
      display: none;
    }
  }
</style>
