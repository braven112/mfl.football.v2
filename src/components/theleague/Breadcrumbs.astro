---
/**
 * Breadcrumbs — hierarchical page-level navigation above the page H1.
 *
 * Renders a linked trail of parent paths, with the last item marked as the
 * current page (non-link, aria-current="page").
 */
import { resolveLeaguePath } from '../../utils/nav-utils';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const resolvedItems = items.map((item) => ({
  ...item,
  href: item.href ? resolveLeaguePath(item.href, hideLeaguePrefix) : undefined,
}));
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumbs__list">
    {resolvedItems.map((item, idx) => {
      const isLast = idx === resolvedItems.length - 1;
      return (
        <li class="breadcrumbs__item">
          {item.href && !isLast ? (
            <a href={item.href} class="breadcrumbs__link">{item.label}</a>
          ) : (
            <span class="breadcrumbs__current" aria-current="page">{item.label}</span>
          )}
          {!isLast && (
            <span class="breadcrumbs__separator" aria-hidden="true">/</span>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 0.5rem;
  }

  .breadcrumbs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .breadcrumbs__item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .breadcrumbs__link {
    color: var(--color-gray-500, #6b7280);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumbs__link:hover,
  .breadcrumbs__link:focus-visible {
    color: var(--color-primary, #1c497c);
    text-decoration: underline;
  }

  .breadcrumbs__current {
    color: var(--color-gray-700, #374151);
    font-weight: 600;
  }

  .breadcrumbs__separator {
    color: var(--color-gray-500, #6b7280);
    font-weight: 600;
    user-select: none;
  }
</style>
