---
/**
 * TagExtensionHero — franchise tag & extension window (Jan 8 → Feb 14). Wears
 * the shared branded EventHeroShell (blue accent) with a countdown to the
 * tagging deadline, the key tag mechanic folded into the summary, and a
 * manage-roster CTA.
 */
import EventHeroShell from './EventHeroShell.astro';
import { randomHeroPlayer } from '../../utils/hero-players';
import { CATEGORY_ACCENT, CATEGORY_GLOW } from '../../utils/league-event-hero-view';

export interface Props {
  resolveLeaguePath: (path: string) => string;
  referenceDate: Date;
}

const { resolveLeaguePath: r, referenceDate } = Astro.props;

// Calendar-day countdown to the Feb 14 deadline, so the count hits 0 (and the
// "Deadline today" label shows) on Feb 14 itself rather than only after it passes.
const startOfDay = (d: Date) => { const o = new Date(d); o.setHours(0, 0, 0, 0); return o; };
const deadline = new Date(referenceDate.getFullYear(), 1, 14); // Feb 14
const daysRemaining = Math.max(0, Math.round((startOfDay(deadline).getTime() - startOfDay(referenceDate).getTime()) / 86_400_000));
const isDeadlineDay = daysRemaining === 0;
const deadlineFormatted = deadline.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });

const summary = isDeadlineDay
  ? 'Last day to protect your core — file franchise tags and extensions before the new league year begins tonight.'
  : `Tag players to keep exclusive rights, or extend anyone with 2+ years left. A tag costs the higher of 120% of salary or the top-3 positional average. Deadline ${deadlineFormatted}.`;
---

<EventHeroShell
  pill="Tag window"
  headline="Protect your"
  accentWord="core."
  summary={summary}
  icon="franchise-tag"
  accent={CATEGORY_ACCENT.preseason}
  glow={CATEGORY_GLOW.preseason}
  bordered
  countValue={daysRemaining}
  countLabel={isDeadlineDay ? 'Deadline today' : 'Days to tag deadline'}
  link={r('/theleague/rosters')}
  linkLabel="Manage roster"
  player={randomHeroPlayer(referenceDate)}
  regionLabel="Franchise tags & extensions"
/>
