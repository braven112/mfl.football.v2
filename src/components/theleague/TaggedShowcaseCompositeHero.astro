---
/**
 * TaggedShowcaseCompositeHero — the franchise-tag showcase (Feb 15 → auction
 * start), composite edition. Every tagged player gets a team-gradient panel
 * (matchup-card style), his transparent ESPN cutout over his NFL team's logo
 * watermark, chipped with the tagging franchise + position. A green "still on
 * the market" band underneath carries the count and the CTA.
 *
 * Resilience mirrors the UDFA board: the caller passes MORE panels than show
 * (up to 8), and a post-load script keeps the first four whose headshot
 * actually loads, swapping in spares for any that 404 — deep tagged players
 * sometimes lack an ESPN photo. Even a kept panel always has the team logo
 * behind the player, so a slow photo never leaves an empty flank.
 *
 * The router falls back to the branded TaggedPlayerShowcaseHero when fewer
 * than two tagged players resolve to a composite (or none are tagged yet).
 */
import type { HeroModel } from '../../utils/hero-casting';
import { getNflTeamColors, hexToRgba } from '../../utils/nfl-team-colors';
import { normalizeTeamCode, getNFLTeamLogo } from '../../utils/nfl-logo';

interface Props {
  /** Composite panels in filed order — pass up to 8: four show, the rest are
      spares that swap in when a headshot 404s. Each carries the tagging
      franchise's short name for the chip. */
  panels: Array<{ model: HeroModel; franchiseName: string }>;
  /** Total tagged players this year (may exceed the compositable panel count). */
  taggedCount: number;
  leagueYear: number;
  resolveLeaguePath: (path: string) => string;
}

const { panels: rawPanels, taggedCount, leagueYear, resolveLeaguePath: r } = Astro.props;

const panels = rawPanels.slice(0, 8).map(({ model, franchiseName }, index) => {
  const teamCode = normalizeTeamCode(model.nflTeam);
  const { primary } = getNflTeamColors(teamCode);
  return {
    model,
    franchiseName,
    teamCode,
    spare: index >= 4,
    gradient: `linear-gradient(160deg, #0b0e12 0%, ${primary} 150%)`,
    glow: hexToRgba(primary, 0.35),
    teamLogo: getNFLTeamLogo(teamCode),
  };
});

// Band copy scales with the number of tags — the composite face count can be
// smaller than taggedCount (some tagged players have no usable cutout).
const shown = Math.min(4, panels.length);
const numberWords = ['no', 'one', 'two', 'three', 'four'];
const countWord = taggedCount <= 4 ? numberWords[taggedCount] : String(taggedCount);
const title =
  taggedCount === 1
    ? 'One star just came off the market'
    : `${countWord.charAt(0).toUpperCase()}${countWord.slice(1)} stars just came off the market`;
---

<section class="tsh" aria-label="Franchise-tagged players open for offers">
  <div class="tsh__panels" data-shown={shown}>
    {panels.map(({ model, franchiseName, teamCode, spare, gradient, glow, teamLogo }) => (
      <div class="tsh__panel" style={`background: ${gradient};`} data-spare={spare ? 'true' : undefined} hidden={spare}>
        <span class="tsh__panel-glow" style={`background: radial-gradient(circle, ${glow} 0%, transparent 65%);`} aria-hidden="true"></span>
        <img class="tsh__logo" src={teamLogo} alt="" aria-hidden="true" loading="eager" />
        <span class="tsh__chip" aria-hidden="true">{franchiseName} · {model.position}</span>
        <img
          class="tsh__cutout"
          src={model.headshot}
          alt=""
          aria-hidden="true"
          loading="eager"
          decoding="async"
          onerror="this.style.visibility='hidden'"
        />
        <span class="tsh__player">
          <strong>{model.name}</strong>
          <span class="tsh__player-meta">{model.position} · {teamCode}</span>
        </span>
      </div>
    ))}
  </div>

  <div class="tsh__band">
    <div class="tsh__band-left">
      <p class="tsh__eyebrow">Franchise tags · {leagueYear}</p>
      <h2 class="tsh__title">{title}</h2>
    </div>
    <a class="tsh__cta" href={r('/theleague/rosters')}>
      See every tag
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  // Keep the first four panels whose headshot actually loads; swap in spares
  // for any that 404, then renumber nothing (tags have chips, not ranks). The
  // team-logo watermark means a panel still reads complete while its photo
  // settles. Mirrors the UDFA board resolver.
  const MAX_PANELS = 4;

  function settle(img: HTMLImageElement): Promise<boolean> {
    if (img.complete) return Promise.resolve(img.naturalWidth > 0);
    return new Promise((resolve) => {
      img.addEventListener('load', () => resolve(true), { once: true });
      img.addEventListener('error', () => resolve(false), { once: true });
    });
  }

  async function resolvePanels(hero: HTMLElement) {
    const panels = [...hero.querySelectorAll<HTMLElement>('.tsh__panel')];
    let shown = 0;
    for (const panel of panels) {
      if (shown >= MAX_PANELS) {
        panel.hidden = true;
        continue;
      }
      const cutout = panel.querySelector<HTMLImageElement>('.tsh__cutout');
      const ok = cutout ? await settle(cutout) : false;
      if (ok) {
        panel.hidden = false;
        shown += 1;
      } else {
        panel.hidden = true;
      }
    }
    // Fewer than four loaded (thin tag year / offline): show the first four
    // regardless so the hero is never barren — the team logos carry them.
    if (shown < MAX_PANELS) {
      let filled = 0;
      for (const panel of panels) {
        if (filled >= MAX_PANELS) break;
        panel.hidden = false;
        filled += 1;
      }
    }
  }

  function run() {
    document.querySelectorAll<HTMLElement>('.tsh').forEach((hero) => resolvePanels(hero));
  }

  run();
  document.addEventListener('astro:page-load', run);
</script>

<style>
  .tsh {
    --tsh-border: rgba(46, 135, 67, 0.35);
    --tsh-band-bg: #0b0e12;
    --tsh-band-ink: #ffffff;
    --tsh-accent: #4ade80;

    overflow: hidden;
    border-radius: var(--radius-lg, 0.75rem);
    border: 1px solid var(--tsh-border);
    display: flex;
    flex-direction: column;
  }

  .tsh__panels {
    display: flex;
  }

  .tsh__panel {
    position: relative;
    flex: 1;
    min-height: clamp(190px, 19vw, 230px);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .tsh__panel[hidden] {
    display: none;
  }

  .tsh__panel-glow {
    position: absolute;
    inset: -40% -30% auto -30%;
    height: 140%;
    pointer-events: none;
  }

  /* Permanent team-logo watermark behind every player */
  .tsh__logo {
    position: absolute;
    top: 46%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(120px, 15vw, 190px);
    opacity: 0.16;
    pointer-events: none;
    user-select: none;
  }

  .tsh__chip {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    right: 0.625rem;
    z-index: 3;
    color: #fff;
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 0, 0, 0.45);
    padding: 0.28rem 0.5rem;
    border-radius: 4px;
    backdrop-filter: blur(2px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tsh__cutout {
    position: relative;
    z-index: 1;
    width: clamp(120px, 14vw, 175px);
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.5));
  }

  .tsh__player {
    position: absolute;
    z-index: 2;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.45rem 0.625rem;
    color: #fff;
    background: linear-gradient(transparent, rgba(6, 9, 13, 0.85));
  }

  .tsh__player strong {
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tsh__player-meta {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.65);
  }

  .tsh__band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    background: var(--tsh-band-bg);
    color: var(--tsh-band-ink);
  }

  .tsh__eyebrow {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--tsh-accent);
    margin: 0 0 0.2rem;
  }

  .tsh__title {
    color: var(--tsh-band-ink);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
  }

  .tsh__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #ffffff;
    color: #0b0e12;
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.6rem 1.05rem;
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    transition: transform 120ms ease;
  }

  .tsh__cta:hover {
    transform: translateY(-1px);
  }

  .tsh__cta:focus-visible {
    outline: 2px solid var(--tsh-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tsh__cta {
      transition: none;
    }

    .tsh__cta:hover {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .tsh__panels {
      flex-wrap: wrap;
    }

    .tsh__panel {
      flex: 1 1 50%;
      min-height: 160px;
    }

    .tsh__cutout {
      width: 110px;
    }

    .tsh__band {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.625rem;
    }
  }
</style>
