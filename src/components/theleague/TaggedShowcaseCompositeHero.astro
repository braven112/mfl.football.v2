---
/**
 * TaggedShowcaseCompositeHero — the franchise-tag showcase (Feb 15 → auction
 * start), composite edition. Every tagged player gets a team-gradient panel
 * (matchup-card style, exactly like the UDFA board): his transparent ESPN
 * cutout over his NFL-team-color gradient, chipped with the tagging franchise
 * + position, with the tagging franchise's crest as a permanent background
 * watermark and a green "Tagged" badge. A green-accent band underneath carries
 * the count and the CTA to the rosters.
 *
 * Where UDFA watermarks the NFL team logo (it's about NFL rookies), this hero
 * watermarks the FRANCHISE crest — a franchise tag is a fantasy-team story, so
 * the tagging team's mark belongs behind the player.
 *
 * Resilience mirrors the UDFA board: the caller passes MORE panels than show
 * (up to 8), and a post-load script keeps the first four whose headshot
 * actually loads, swapping in spares for any that 404 — deep tagged players
 * sometimes lack an ESPN photo. Even a kept panel always has the franchise
 * crest behind the player, so a slow photo never leaves an empty flank.
 *
 * The router falls back to the branded TaggedPlayerShowcaseHero when fewer
 * than two tagged players resolve to a composite (or none are tagged yet).
 */
import type { HeroModel } from '../../utils/hero-casting';
import { getNflTeamColors, hexToRgba } from '../../utils/nfl-team-colors';
import { normalizeTeamCode } from '../../utils/nfl-logo';

interface Props {
  /** Composite panels in filed order — pass up to 8: four show, the rest are
      spares that swap in when a headshot 404s. Each carries the tagging
      franchise's short name (for the chip) and crest src (for the watermark). */
  panels: Array<{ model: HeroModel; franchiseName: string; franchiseCrest: string }>;
  /** Total tagged players this year (may exceed the compositable panel count). */
  taggedCount: number;
  leagueYear: number;
  resolveLeaguePath: (path: string) => string;
}

const { panels: rawPanels, taggedCount, leagueYear, resolveLeaguePath: r } = Astro.props;

const panels = rawPanels.slice(0, 8).map(({ model, franchiseName, franchiseCrest }, index) => {
  const teamCode = normalizeTeamCode(model.nflTeam);
  const { primary } = getNflTeamColors(teamCode);
  return {
    model,
    franchiseName,
    franchiseCrest,
    teamCode,
    spare: index >= 4,
    gradient: `linear-gradient(160deg, #0b0e12 0%, ${primary} 150%)`,
    glow: hexToRgba(primary, 0.35),
  };
});

// Band copy scales with the number of tags — the composite face count can be
// smaller than taggedCount (some tagged players have no usable ESPN cutout).
const title =
  taggedCount === 1
    ? 'One player just got the franchise tag'
    : `${taggedCount} players just got the franchise tag`;
---

<section class="tsh" aria-label="Franchise-tagged players open for offers">
  <div class="tsh__panels">
    {panels.map(({ model, franchiseName, franchiseCrest, teamCode, spare, gradient, glow }) => (
      <div class="tsh__panel" style={`background: ${gradient};`} data-spare={spare ? 'true' : undefined} hidden={spare}>
        <span class="tsh__panel-glow" style={`background: radial-gradient(circle, ${glow} 0%, transparent 65%);`} aria-hidden="true"></span>
        {franchiseCrest && <img class="tsh__crest" src={franchiseCrest} alt="" aria-hidden="true" loading="eager" decoding="async" />}
        <span class="tsh__chip" aria-hidden="true">{[franchiseName, model.position].filter(Boolean).join(' · ')}</span>
        <span class="tsh__tag" aria-hidden="true">Tagged</span>
        <img
          class="tsh__cutout"
          src={model.headshot}
          alt=""
          aria-hidden="true"
          loading="eager"
          decoding="async"
          onerror="this.style.visibility='hidden'"
        />
        <span class="tsh__player">
          <strong>{model.name}</strong>
          <span class="tsh__player-meta">{[model.position, teamCode].filter(Boolean).join(' · ')}</span>
        </span>
      </div>
    ))}
  </div>

  <div class="tsh__band">
    <div class="tsh__band-left">
      <p class="tsh__eyebrow">Franchise tags · {leagueYear}</p>
      <h2 class="tsh__title">{title}</h2>
    </div>
    <a class="tsh__cta" href={r('/theleague/rosters')}>
      See every tag
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  // Keep the first four panels whose headshot actually loads; swap in spares
  // for any that 404. Tagged panels carry franchise chips (not ranks), so
  // nothing needs renumbering. The franchise-crest watermark means a panel
  // still reads as complete while its photo settles. Mirrors the UDFA board.
  const MAX_PANELS = 4;

  function settle(img: HTMLImageElement): Promise<boolean> {
    if (img.complete) return Promise.resolve(img.naturalWidth > 0);
    return new Promise((resolve) => {
      img.addEventListener('load', () => resolve(true), { once: true });
      img.addEventListener('error', () => resolve(false), { once: true });
    });
  }

  async function resolvePanels(hero: HTMLElement) {
    const panels = [...hero.querySelectorAll<HTMLElement>('.tsh__panel')];
    const settled = await Promise.all(
      panels.map(async (panel) => {
        const cutout = panel.querySelector<HTMLImageElement>('.tsh__cutout');
        return { panel, ok: cutout ? await settle(cutout) : false };
      }),
    );
    // Show the first four panels whose headshot loaded (filed order preserved),
    // dropping any that 404 — a photoless panel next to real faces looks broken.
    // Only when NOTHING loaded (thin tag year / offline) do we fall back to the
    // first few panels regardless, so the hero is never barren: the permanent
    // franchise-crest watermark + name band carry a photoless card.
    const loaded = settled.filter((s) => s.ok).map((s) => s.panel);
    const shown = loaded.length > 0 ? loaded : panels;
    const chosen = new Set(shown.slice(0, MAX_PANELS));

    for (const panel of panels) {
      panel.hidden = !chosen.has(panel);
    }
  }

  function run() {
    document.querySelectorAll<HTMLElement>('.tsh').forEach((hero) => resolvePanels(hero));
  }

  run();
  // Re-run after ClientRouter (view transitions) swaps in a fresh homepage.
  document.addEventListener('astro:page-load', run);
</script>

<style>
  .tsh {
    /* The player panels are always dark team-gradient "trading cards"; only
       the info band + frame follow the theme. Light band by default; the
       html.dark block below swaps to the dark band. Green accent throughout —
       a tag keeps a player claimable, and green reads "still in play". */
    --tsh-border: rgba(46, 135, 67, 0.3);
    --tsh-band-bg: var(--color-surface, #ffffff);
    --tsh-band-ink: var(--color-gray-900, #0f1419);
    --tsh-accent: #15803d;
    --tsh-cta-bg: var(--color-primary, #1c497c);
    --tsh-cta-ink: #ffffff;

    overflow: hidden;
    border-radius: var(--radius-lg, 0.75rem);
    border: 1px solid var(--tsh-border);
    display: flex;
    flex-direction: column;
  }

  :global(html.dark) .tsh {
    --tsh-border: rgba(74, 222, 128, 0.22);
    --tsh-band-bg: #0b0e12;
    --tsh-band-ink: #ffffff;
    --tsh-accent: #4ade80;
    --tsh-cta-bg: #ffffff;
    --tsh-cta-ink: #0b0e12;
  }

  .tsh__panels {
    display: flex;
  }

  .tsh__panel {
    position: relative;
    flex: 1;
    min-height: clamp(190px, 19vw, 230px);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .tsh__panel[hidden] {
    display: none;
  }

  .tsh__panel-glow {
    position: absolute;
    inset: -40% -30% auto -30%;
    height: 140%;
    pointer-events: none;
  }

  /* Permanent franchise-crest watermark behind every player */
  .tsh__crest {
    position: absolute;
    top: 46%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(120px, 15vw, 185px);
    height: clamp(120px, 15vw, 185px);
    object-fit: contain;
    opacity: 0.16;
    pointer-events: none;
    user-select: none;
  }

  .tsh__chip {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    max-width: calc(100% - 5rem);
    z-index: 3;
    color: #fff;
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 0, 0, 0.45);
    padding: 0.28rem 0.5rem;
    border-radius: 4px;
    backdrop-filter: blur(2px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Green "Tagged" badge — reinforces the mechanic on every panel */
  .tsh__tag {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    z-index: 3;
    color: #052e16;
    font-size: 0.55rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: #4ade80;
    padding: 0.28rem 0.5rem;
    border-radius: 4px;
  }

  .tsh__cutout {
    position: relative;
    z-index: 1;
    width: clamp(120px, 14vw, 175px);
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.5));
  }

  .tsh__player {
    position: absolute;
    z-index: 2;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.45rem 0.625rem;
    color: #fff;
    background: linear-gradient(transparent, rgba(6, 9, 13, 0.85));
  }

  .tsh__player strong {
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1.15;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tsh__player-meta {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.65);
  }

  .tsh__band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    background: var(--tsh-band-bg);
    color: var(--tsh-band-ink);
  }

  .tsh__eyebrow {
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--tsh-accent);
    margin: 0 0 0.2rem;
  }

  .tsh__title {
    color: var(--tsh-band-ink);
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
  }

  .tsh__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--tsh-cta-bg);
    color: var(--tsh-cta-ink);
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.6rem 1.05rem;
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    transition: transform 120ms ease;
  }

  .tsh__cta:hover {
    transform: translateY(-1px);
  }

  .tsh__cta:focus-visible {
    outline: 2px solid var(--tsh-accent);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tsh__cta {
      transition: none;
    }

    .tsh__cta:hover {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .tsh__panels {
      flex-wrap: wrap;
    }

    .tsh__panel {
      flex: 1 1 50%;
      min-height: 160px;
    }

    .tsh__cutout {
      width: 110px;
    }

    .tsh__band {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.625rem;
    }
  }
</style>
