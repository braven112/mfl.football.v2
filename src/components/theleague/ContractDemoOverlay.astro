---
/**
 * ContractDemoOverlay — Guided walkthrough for contract declarations
 *
 * Floating trigger button + 3-step tutorial modal + exit button.
 * All interactivity handled by client-side JS in rosters.astro.
 */
import PlayerCell from './PlayerCell.astro';
import { getPlayerHeadshot } from '../../constants/roster-constants';
---

<!-- ================================================================
     Floating Trigger Button — right edge of viewport
     ================================================================ -->
<button class="cdemo-trigger" id="cdemo-trigger" aria-label="How contract declarations work">
  <span class="cdemo-trigger__badge">New</span>
  <span class="cdemo-trigger__icon">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>
  </span>
  <span class="cdemo-trigger__label">How It Works</span>
</button>

<!-- ================================================================
     Exit Demo Button — replaces trigger when demo is active
     ================================================================ -->
<button class="cdemo-exit" id="cdemo-exit" aria-label="Exit demo mode">
  <span class="cdemo-exit__icon">
    <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M14 4L4 14M4 4l10 10"/>
    </svg>
  </span>
  <span class="cdemo-exit__label">Exit Demo</span>
</button>

<!-- ================================================================
     Demo Banner — persistent top banner during demo mode
     ================================================================ -->
<div class="cdemo-banner" id="cdemo-banner">
  <span class="cdemo-banner__dot"></span>
  <span class="cdemo-banner__text">Demo Mode — explore how contract declarations work</span>
  <button class="cdemo-banner__dismiss" id="cdemo-banner-exit" aria-label="Exit demo">
    Exit Demo
    <svg width="12" height="12" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M14 4L4 14M4 4l10 10"/>
    </svg>
  </button>
</div>

<!-- ================================================================
     Tutorial Modal — 3-step walkthrough
     ================================================================ -->
<div class="cdemo-tutorial" id="cdemo-tutorial">
  <div class="cdemo-tutorial__overlay"></div>
  <div class="cdemo-tutorial__card">
    <button class="cdemo-tutorial__close" id="cdemo-tutorial-close" aria-label="Close tutorial">
      <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M14 4L4 14M4 4l10 10"/>
      </svg>
    </button>

    <!-- Step Indicator -->
    <div class="cdemo-stepper">
      <div class="cdemo-stepper__track">
        <button class="cdemo-stepper__dot active" data-step="1"><span>1</span></button>
        <div class="cdemo-stepper__line"></div>
        <button class="cdemo-stepper__dot" data-step="2"><span>2</span></button>
        <div class="cdemo-stepper__line"></div>
        <button class="cdemo-stepper__dot" data-step="3"><span>3</span></button>
        <div class="cdemo-stepper__line"></div>
        <button class="cdemo-stepper__dot" data-step="4"><span>4</span></button>
      </div>
    </div>

    <!-- Step 1: What are contract declarations? -->
    <div class="cdemo-panel active" data-step="1">
      <div class="cdemo-panel__kicker">Now Live</div>
      <h2 class="cdemo-panel__title">Contract declarations are built into your roster.</h2>
      <p class="cdemo-panel__body">
        Every player action now has a declaration — set right here, no message
        board required. Four types cover everything from a waiver pickup to a
        veteran 1st rounder entering their option year.
      </p>
      <div class="cdemo-panel__cards">
        <div class="cdemo-minicard cdemo-minicard--acquisition">
          <div class="cdemo-minicard__badge">
            <span class="cdemo-minicard__badge-dot"></span>
            New Acquisition
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Default</span>
            <span class="cdemo-minicard__value">1 year</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Options</span>
            <span class="cdemo-minicard__value">2 – 5 years</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Window</span>
            <span class="cdemo-minicard__value">24h / 48h</span>
          </div>
        </div>
        <div class="cdemo-minicard cdemo-minicard--rookie">
          <div class="cdemo-minicard__badge cdemo-minicard__badge--rookie">
            <span class="cdemo-minicard__badge-dot"></span>
            Rookie Override
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Default</span>
            <span class="cdemo-minicard__value">4 years (RC)</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Options</span>
            <span class="cdemo-minicard__value">1 – 3 years</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Window</span>
            <span class="cdemo-minicard__value">3rd Sun. in Aug</span>
          </div>
        </div>
        <div class="cdemo-minicard cdemo-minicard--team-option">
          <div class="cdemo-minicard__badge cdemo-minicard__badge--team-option">
            <span class="cdemo-minicard__badge-dot"></span>
            Team Option
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Who</span>
            <span class="cdemo-minicard__value">1st round picks</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Window</span>
            <span class="cdemo-minicard__value">Before Year 4</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Adds</span>
            <span class="cdemo-minicard__value">+1 year</span>
          </div>
        </div>
        <div class="cdemo-minicard cdemo-minicard--extension">
          <div class="cdemo-minicard__badge cdemo-minicard__badge--extension">
            <span class="cdemo-minicard__badge-dot"></span>
            Rookie Extension
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Who</span>
            <span class="cdemo-minicard__value">Drafted rookies (RC)</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Window</span>
            <span class="cdemo-minicard__value">Before Year 4</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Adds</span>
            <span class="cdemo-minicard__value">+2 years</span>
          </div>
        </div>
      </div>
      <div class="cdemo-panel__footer">
        <button class="cdemo-glossary-link" id="cdemo-step4-link" type="button">
          Glossary of terms
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Step 2: Glossary -->
    <div class="cdemo-panel" data-step="2">
      <div class="cdemo-panel__kicker">Reference</div>
      <h2 class="cdemo-panel__title">Contract terms, decoded.</h2>
      <div class="cdemo-iglos">
        <dl class="cdemo-iglos__list">
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">RC</dt>
            <dd class="cdemo-iglos__def">Rookie Contract — the default 4-year deal assigned to all drafted rookies.</dd>
          </div>
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">TO</dt>
            <dd class="cdemo-iglos__def">Team Option — 1st-round picks carry a TO flag signaling a pending 5th-year decision before Year 4.</dd>
          </div>
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">New Acquisition</dt>
            <dd class="cdemo-iglos__def">Any player added via waiver or FA signing. Declaration required within 24h (in-season) or 48h (offseason).</dd>
          </div>
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">Rookie Override</dt>
            <dd class="cdemo-iglos__def">Optional shorter deal (1–3 yrs) instead of the default 4-year RC. Must be declared before the 3rd Sunday in August.</dd>
          </div>
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">Team Option</dt>
            <dd class="cdemo-iglos__def">Guaranteed 5th year at the top-10 positional salary average. Must be exercised (or declined) before the player enters Year 4.</dd>
          </div>
          <div class="cdemo-iglos__item">
            <dt class="cdemo-iglos__term">Rookie Extension</dt>
            <dd class="cdemo-iglos__def">Adds 2 years to an RC deal. Uses the same formula as a 2-year veteran extension. Before Year 4 only.</dd>
          </div>
        </dl>
        <button class="cdemo-iglos__expand" id="cdemo-glossary-open" type="button">
          View full glossary
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Step 3: Spotting eligible players -->
    <div class="cdemo-panel" data-step="3">
      <div class="cdemo-panel__kicker">Reading the Board</div>
      <h2 class="cdemo-panel__title">Every eligible player is marked — you can't miss them.</h2>
      <p class="cdemo-panel__body">
        Blue chips in the <strong>Years</strong> column are clickable — tap to declare.
        For rookie extensions and team options, use the <strong>⋮ action button</strong> — it gives you a menu to exercise the team option, extend as a rookie deal, or let the player play out their contract.
        1st round picks also show a blue <strong>TO</strong> badge you can tap directly.
        Deadline badges count down in real time.
      </p>
      <div class="cdemo-panel__mockup">
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Hopkins, DeAndre"
            headshot={getPlayerHeadshot(undefined, '15795')}
            position="WR"
            nflTeam="BAL"
            espnId="15795"
            size="compact"
          />
          <span class="yrs-chip yrs-chip--eligible" role="img" aria-label="1 year, new acquisition">
            <span class="yrs-chip__value">1</span>
            <span class="yrs-chip__deadline yrs-chip__deadline--critical">17h</span>
          </span>
        </div>
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Mendoza, Fernando"
            headshot={getPlayerHeadshot('17462', '4837248')}
            position="QB"
            nflTeam="LVR"
            mflId="17462"
            espnId="4837248"
            size="compact"
          />
          <span class="yrs-chip yrs-chip--eligible" role="img" aria-label="4 years, rookie override">
            <span class="yrs-chip__value">4</span>
            <span class="yrs-chip__deadline">168d</span>
          </span>
        </div>
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Hailmary, Hank"
            headshot={getPlayerHeadshot('16585', '4360698')}
            position="QB"
            nflTeam="DAL"
            mflId="16585"
            espnId="4360698"
            size="compact"
          />
          <div class="cdemo-action-group">
            <span class="cdemo-to-badge">TO</span>
            <button class="ufa-action-btn cdemo-action-btn-mock" disabled aria-label="Manage contract" title="Open contract actions">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Misack, Buck"
            headshot={getPlayerHeadshot('15777', '4243389')}
            position="WR"
            nflTeam="PIT"
            mflId="15777"
            espnId="4243389"
            size="compact"
          />
          <button class="ufa-action-btn cdemo-action-btn-mock" disabled aria-label="Manage contract" title="Open contract actions">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Step 4: Try it -->
    <div class="cdemo-panel" data-step="4">
      <div class="cdemo-panel__kicker">Try It Now</div>
      <h2 class="cdemo-panel__title">Four players, four scenarios — click through all of them.</h2>
      <p class="cdemo-panel__body">
        We've added four sandbox players to your roster, one for each declaration
        type. Click the blue chip or TO badge to open the declaration modal,
        make a selection, and explore. These are demos — nothing is submitted
        or saved.
      </p>
      <div class="cdemo-panel__tips">
        <div class="cdemo-tip">
          <span class="cdemo-tip__icon cdemo-tip__icon--to">TO</span>
          <span>For Team Options, you get three paths: exercise the option year, extend as a rookie deal, or let the player play out their final year.</span>
        </div>
        <div class="cdemo-tip">
          <span class="cdemo-tip__icon cdemo-tip__icon--yrs">
            <span class="yrs-chip yrs-chip--eligible cdemo-tip__yrs-chip">
              <span class="yrs-chip__value">4</span>
            </span>
          </span>
          <span>Submitted declarations appear in the commissioner queue and are reflected on your roster once approved.</span>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="cdemo-nav">
      <button class="cdemo-nav__back" id="cdemo-back">Back</button>
      <button class="cdemo-nav__next" id="cdemo-next">Next</button>
      <button class="cdemo-nav__start" id="cdemo-start">Try It Now</button>
    </div>
  </div>
</div>

<!-- ================================================================
     Glossary Modal
     ================================================================ -->
<div class="cdemo-glossary" id="cdemo-glossary" role="dialog" aria-modal="true" aria-label="Contract Terms Glossary">
  <div class="cdemo-glossary__overlay" id="cdemo-glossary-overlay"></div>
  <div class="cdemo-glossary__card">
    <div class="cdemo-glossary__header">
      <div>
        <div class="cdemo-glossary__kicker">Reference</div>
        <h2 class="cdemo-glossary__title">Contract Terms</h2>
      </div>
      <button class="cdemo-glossary__close" id="cdemo-glossary-close" aria-label="Close glossary">
        <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M14 4L4 14M4 4l10 10"/>
        </svg>
      </button>
    </div>
    <dl class="cdemo-glossary__list">
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">RC</dt>
        <dd class="cdemo-glossary__def">Rookie Contract. The initial 4-year deal for all drafted rookies. RC players are eligible for overrides, extensions, and team options depending on their round.</dd>
      </div>
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">TO</dt>
        <dd class="cdemo-glossary__def">Team Option designation. 1st-round picks carry a TO flag, signaling that a 5th-year option decision is pending. Owners must exercise it, extend the rookie deal, or let it expire — all before Year 4.</dd>
      </div>
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">New Acquisition</dt>
        <dd class="cdemo-glossary__def">Any player added to a roster via BBID waiver or free-agent signing. A contract declaration is required within 24 hours during the season or 48 hours in the offseason.</dd>
      </div>
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">Rookie Override</dt>
        <dd class="cdemo-glossary__def">An optional shorter deal (1–3 years) for RC players in their first year, declared instead of the default 4-year rookie contract. Must be submitted before the 3rd Sunday in August.</dd>
      </div>
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">Team Option</dt>
        <dd class="cdemo-glossary__def">A guaranteed 5th year added to a 1st-round pick's contract, paid at the top-10 positional salary average. Must be exercised (or declined) before the player enters Year 4.</dd>
      </div>
      <div class="cdemo-glossary__item">
        <dt class="cdemo-glossary__term">Rookie Extension</dt>
        <dd class="cdemo-glossary__def">Adds 2 years to an RC player's deal. Uses the same formula as a 2-year veteran extension. Before Year 4 only.</dd>
      </div>
    </dl>
  </div>
</div>

<style>
  /* ================================================================
     Floating Trigger Button
     ================================================================ */
  .cdemo-trigger {
    position: fixed;
    right: 0;
    bottom: 6rem;
    z-index: 900;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.875rem 0.75rem;
    background: linear-gradient(180deg, #1f5590 0%, #1c497c 100%);
    color: #fff;
    border: none;
    border-radius: 10px 0 0 10px;
    cursor: pointer;
    box-shadow:
      -3px 3px 14px rgba(28, 73, 124, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    font-family: inherit;
    writing-mode: horizontal-tb;
    animation: cdemo-trigger-enter 0.5s ease-out 1.5s both;
  }

  @keyframes cdemo-trigger-enter {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  .cdemo-trigger:hover {
    transform: translateX(-3px);
    box-shadow:
      -5px 4px 22px rgba(28, 73, 124, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  .cdemo-trigger__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .cdemo-trigger__label {
    font-size: 0.5625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-align: center;
  }

  .cdemo-trigger__badge {
    font-size: 0.4375rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: #f59e0b;
    color: #451a03;
    padding: 1px 5px;
    border-radius: 2px;
    line-height: 1.4;
  }

  .cdemo-trigger[hidden] { display: none; }

  /* ================================================================
     Exit Demo Button
     ================================================================ */
  .cdemo-exit {
    position: fixed;
    right: 0;
    bottom: 6rem;
    z-index: 900;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.875rem 0.75rem;
    background: linear-gradient(180deg, #334155 0%, #1e293b 100%);
    color: #fff;
    border: none;
    border-radius: 10px 0 0 10px;
    cursor: pointer;
    box-shadow: -3px 3px 14px rgba(30, 41, 59, 0.35);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    font-family: inherit;
    animation: cdemo-trigger-enter 0.3s ease-out both;
  }

  .cdemo-exit.active { display: flex; }

  .cdemo-exit:hover {
    transform: translateX(-3px);
  }

  .cdemo-exit__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .cdemo-exit__label {
    font-size: 0.5625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-align: center;
  }

  /* ================================================================
     Demo Banner
     ================================================================ */
  .cdemo-banner {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #1c497c 0%, #163d68 100%);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    position: sticky;
    top: 0;
    z-index: 899;
  }

  .cdemo-banner.active { display: flex; }

  .cdemo-banner__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: cdemo-pulse 2s ease-in-out infinite;
  }

  @keyframes cdemo-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .cdemo-banner__text { opacity: 0.9; }

  .cdemo-banner__dismiss {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease;
    font-family: inherit;
  }

  .cdemo-banner__dismiss:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* ================================================================
     Tutorial Modal — Shell
     ================================================================ */
  .cdemo-tutorial {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1002;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .cdemo-tutorial.active { display: flex; }

  .cdemo-tutorial__overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(3px);
  }

  .cdemo-tutorial__card {
    position: relative;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(0, 0, 0, 0.04);
    box-sizing: border-box;
    width: 100%;
    max-width: 520px;
    padding: 2rem 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    animation: cdemo-card-enter 0.32s ease-out;
  }

  @keyframes cdemo-card-enter {
    from { opacity: 0; transform: scale(0.96) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .cdemo-tutorial__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    background: #f3f4f6;
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cdemo-tutorial__close:hover {
    background: #e5e7eb;
    color: #374151;
  }

  /* ================================================================
     Step Indicator
     ================================================================ */
  .cdemo-stepper {
    margin-bottom: 1.5rem;
  }

  .cdemo-stepper__track {
    display: flex;
    align-items: center;
    gap: 0;
    width: fit-content;
  }

