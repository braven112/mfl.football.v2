<script>
  // Glossary modal + step 2 navigation
  (function () {
    const glossary = document.getElementById('cdemo-glossary');
    const openBtn  = document.getElementById('cdemo-glossary-open'); // "View full glossary" in step 2
    const closeBtn = document.getElementById('cdemo-glossary-close');
    const overlay  = document.getElementById('cdemo-glossary-overlay');
    const step4Link = document.getElementById('cdemo-step4-link');  // "Glossary of terms →" in step 1

    function openGlossary() {
      if (!glossary || !closeBtn) return;
      glossary.classList.add('active');
      closeBtn.focus();
    }
    function closeGlossary() {
      if (!glossary) return;
      glossary.classList.remove('active');
    }

    if (openBtn) openBtn.addEventListener('click', openGlossary);
    if (closeBtn) closeBtn.addEventListener('click', closeGlossary);
    overlay?.addEventListener('click', closeGlossary);
    glossary?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeGlossary();
    });

    // "Glossary of terms →" in step 1: jump to step 2 in the tutorial
    if (step4Link) {
      step4Link.addEventListener('click', () => {
        if (typeof (window as any).__cdemoSetStep === 'function') {
          (window as any).__cdemoSetStep(2);
        } else {
          openGlossary(); // fallback if tutorial JS not loaded
        }
      });
    }
  })();
</script>
