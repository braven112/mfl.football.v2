---
/**
 * ContractDemoOverlay — Guided walkthrough for contract declarations
 *
 * Floating trigger button + 3-step tutorial modal + exit button.
 * All interactivity handled by client-side JS in rosters.astro.
 */
import PlayerCell from './PlayerCell.astro';
import { getPlayerHeadshot } from '../../constants/roster-constants';
---

<!-- ================================================================
     Floating Trigger Button — right edge of viewport
     ================================================================ -->
<button class="cdemo-trigger" id="cdemo-trigger" aria-label="Preview contract declarations feature">
  <span class="cdemo-trigger__badge">Coming Soon</span>
  <span class="cdemo-trigger__icon">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
    </svg>
  </span>
  <span class="cdemo-trigger__label">Preview</span>
</button>

<!-- ================================================================
     Exit Demo Button — replaces trigger when demo is active
     ================================================================ -->
<button class="cdemo-exit" id="cdemo-exit" aria-label="Exit demo mode">
  <span class="cdemo-exit__icon">
    <svg width="14" height="14" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M14 4L4 14M4 4l10 10"/>
    </svg>
  </span>
  <span class="cdemo-exit__label">Exit Demo</span>
</button>

<!-- ================================================================
     Demo Banner — persistent top banner during demo mode
     ================================================================ -->
<div class="cdemo-banner" id="cdemo-banner">
  <span class="cdemo-banner__dot"></span>
  <span class="cdemo-banner__text">Preview Mode — this feature is coming soon, we want your feedback</span>
  <button class="cdemo-banner__dismiss" id="cdemo-banner-exit" aria-label="Exit demo">
    Exit Demo
    <svg width="12" height="12" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M14 4L4 14M4 4l10 10"/>
    </svg>
  </button>
</div>

<!-- ================================================================
     Tutorial Modal — 3-step walkthrough
     ================================================================ -->
<div class="cdemo-tutorial" id="cdemo-tutorial">
  <div class="cdemo-tutorial__overlay"></div>
  <div class="cdemo-tutorial__card">
    <button class="cdemo-tutorial__close" id="cdemo-tutorial-close" aria-label="Close tutorial">
      <svg width="16" height="16" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M14 4L4 14M4 4l10 10"/>
      </svg>
    </button>

    <!-- Step Indicator -->
    <div class="cdemo-stepper">
      <div class="cdemo-stepper__track">
        <button class="cdemo-stepper__dot active" data-step="1"><span>1</span></button>
        <div class="cdemo-stepper__line"></div>
        <button class="cdemo-stepper__dot" data-step="2"><span>2</span></button>
        <div class="cdemo-stepper__line"></div>
        <button class="cdemo-stepper__dot" data-step="3"><span>3</span></button>
      </div>
    </div>

    <!-- Step 1: What are contract declarations? -->
    <div class="cdemo-panel active" data-step="1">
      <div class="cdemo-panel__kicker">Coming Soon</div>
      <h2 class="cdemo-panel__title">Every acquisition needs a contract.</h2>
      <p class="cdemo-panel__body">
        We're building contract declarations directly into the roster page.
        When a player joins your roster, you'll set the terms right here — no
        more message board posts. New pickups default to 1 year but you can lock
        them in for up to 5. Rookies default to a 4-year deal, but you can
        reduce it for more flexibility. Miss the deadline and the default sticks.
      </p>
      <div class="cdemo-panel__cards">
        <div class="cdemo-minicard cdemo-minicard--acquisition">
          <div class="cdemo-minicard__badge">
            <span class="cdemo-minicard__badge-dot"></span>
            New Acquisition
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Default</span>
            <span class="cdemo-minicard__value">1 year</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Options</span>
            <span class="cdemo-minicard__value">2 – 5 years</span>
          </div>
        </div>
        <div class="cdemo-minicard cdemo-minicard--rookie">
          <div class="cdemo-minicard__badge cdemo-minicard__badge--rookie">
            <span class="cdemo-minicard__badge-dot"></span>
            Rookie Override
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Default</span>
            <span class="cdemo-minicard__value">4 years (RC)</span>
          </div>
          <div class="cdemo-minicard__detail">
            <span class="cdemo-minicard__label">Options</span>
            <span class="cdemo-minicard__value">1 – 3 years</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 2: Spotting eligible players -->
    <div class="cdemo-panel" data-step="2">
      <div class="cdemo-panel__kicker">Reading the Board</div>
      <h2 class="cdemo-panel__title">Eligible players are highlighted in the Years column.</h2>
      <p class="cdemo-panel__body">
        Look for the blue chips in the Years column — they're buttons. Deadline
        badges show time remaining. Red means urgent. Click a chip to open
        the declaration modal.
      </p>
      <div class="cdemo-panel__mockup">
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Hopkins, DeAndre"
            headshot={getPlayerHeadshot(undefined, '15795')}
            position="WR"
            nflTeam="BAL"
            espnId="15795"
            size="compact"
          />
          <span class="yrs-chip yrs-chip--eligible" role="img" aria-label="1 year, 17 hours remaining">
            <span class="yrs-chip__value">1</span>
            <span class="yrs-chip__deadline yrs-chip__deadline--critical">17h</span>
          </span>
        </div>
        <div class="cdemo-mockrow">
          <PlayerCell
            name="Mendoza, Fernando"
            headshot={getPlayerHeadshot('17462', '4837248')}
            position="QB"
            nflTeam="LVR"
            mflId="17462"
            espnId="4837248"
            size="compact"
          />
          <span class="yrs-chip yrs-chip--eligible" role="img" aria-label="4 years, 168 days remaining">
            <span class="yrs-chip__value">4</span>
            <span class="yrs-chip__deadline">168d</span>
          </span>
        </div>
      </div>
    </div>

    <!-- Step 3: Try it & give feedback -->
    <div class="cdemo-panel" data-step="3">
      <div class="cdemo-panel__kicker">Test Drive</div>
      <h2 class="cdemo-panel__title">Try it out, tell us what you think.</h2>
      <p class="cdemo-panel__body">
        We've added two mock players to your roster so you can take the full
        flow for a spin. Click the blue years cell, pick a contract length,
        and review the salary projection. Nothing is saved — this is a
        sandbox.
      </p>
      <div class="cdemo-panel__feedback">
        <div class="cdemo-feedback__header">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          We want your feedback
        </div>
        <p class="cdemo-feedback__body">
          Does this flow make sense? Is anything confusing? Drop your
          thoughts on the message board — we'll tune it before launch.
        </p>
      </div>
    </div>

    <!-- Navigation -->
    <div class="cdemo-nav">
      <button class="cdemo-nav__back" id="cdemo-back">Back</button>
      <button class="cdemo-nav__next" id="cdemo-next">Next</button>
      <button class="cdemo-nav__start" id="cdemo-start">Start Exploring</button>
    </div>
  </div>
</div>

<style>
  /* ================================================================
     Floating Trigger Button
     ================================================================ */
  .cdemo-trigger {
    position: fixed;
    right: 0;
    bottom: 6rem;
    z-index: 900;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.875rem 0.75rem;
    background: linear-gradient(180deg, #1f5590 0%, #1c497c 100%);
    color: #fff;
    border: none;
    border-radius: 10px 0 0 10px;
    cursor: pointer;
    box-shadow:
      -3px 3px 14px rgba(28, 73, 124, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    font-family: inherit;
    writing-mode: horizontal-tb;
    animation: cdemo-trigger-enter 0.5s ease-out 1.5s both;
  }

  @keyframes cdemo-trigger-enter {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  .cdemo-trigger:hover {
    transform: translateX(-3px);
    box-shadow:
      -5px 4px 22px rgba(28, 73, 124, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  .cdemo-trigger__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .cdemo-trigger__label {
    font-size: 0.5625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-align: center;
  }

  .cdemo-trigger__badge {
    font-size: 0.4375rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: #f59e0b;
    color: #451a03;
    padding: 1px 5px;
    border-radius: 2px;
    line-height: 1.4;
  }

  .cdemo-trigger[hidden] { display: none; }

  /* ================================================================
     Exit Demo Button
     ================================================================ */
  .cdemo-exit {
    position: fixed;
    right: 0;
    bottom: 6rem;
    z-index: 900;
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.875rem 0.75rem;
    background: linear-gradient(180deg, #334155 0%, #1e293b 100%);
    color: #fff;
    border: none;
    border-radius: 10px 0 0 10px;
    cursor: pointer;
    box-shadow: -3px 3px 14px rgba(30, 41, 59, 0.35);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    font-family: inherit;
    animation: cdemo-trigger-enter 0.3s ease-out both;
  }

  .cdemo-exit.active { display: flex; }

  .cdemo-exit:hover {
    transform: translateX(-3px);
  }

  .cdemo-exit__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .cdemo-exit__label {
    font-size: 0.5625rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-align: center;
  }

  /* ================================================================
     Demo Banner
     ================================================================ */
  .cdemo-banner {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #1c497c 0%, #163d68 100%);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    position: sticky;
    top: 0;
    z-index: 899;
  }

  .cdemo-banner.active { display: flex; }

  .cdemo-banner__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34d399;
    animation: cdemo-pulse 2s ease-in-out infinite;
  }

  @keyframes cdemo-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .cdemo-banner__text { opacity: 0.9; }

  .cdemo-banner__dismiss {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.75rem;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease;
    font-family: inherit;
  }

  .cdemo-banner__dismiss:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* ================================================================
     Tutorial Modal — Shell
     ================================================================ */
  .cdemo-tutorial {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1002;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .cdemo-tutorial.active { display: flex; }

  .cdemo-tutorial__overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.5);
    backdrop-filter: blur(3px);
  }

  .cdemo-tutorial__card {
    position: relative;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(0, 0, 0, 0.04);
    box-sizing: border-box;
    width: 100%;
    max-width: 520px;
    padding: 2rem 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    animation: cdemo-card-enter 0.32s ease-out;
  }

  @keyframes cdemo-card-enter {
    from { opacity: 0; transform: scale(0.96) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .cdemo-tutorial__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    background: #f3f4f6;
    border: none;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cdemo-tutorial__close:hover {
    background: #e5e7eb;
    color: #374151;
  }

  /* ================================================================
     Step Indicator
     ================================================================ */
  .cdemo-stepper {
    margin-bottom: 1.5rem;
  }

  .cdemo-stepper__track {
    display: flex;
    align-items: center;
    gap: 0;
    width: fit-content;
  }

  .cdemo-stepper__dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #e2e8f0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: default;
    transition: all 0.25s ease;
    padding: 0;
    font-family: inherit;
  }

  .cdemo-stepper__dot span {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #94a3b8;
    transition: color 0.25s ease;
  }

  .cdemo-stepper__dot.active {
    border-color: var(--color-primary, #1c497c);
    background: var(--color-primary, #1c497c);
  }

  .cdemo-stepper__dot.active span { color: #fff; }

  .cdemo-stepper__dot.completed {
    border-color: var(--color-primary, #1c497c);
    background: rgba(28, 73, 124, 0.08);
  }

  .cdemo-stepper__dot.completed span {
    color: var(--color-primary, #1c497c);
  }

  .cdemo-stepper__line {
    width: 2rem;
    height: 2px;
    background: #e2e8f0;
    transition: background 0.25s ease;
  }

  .cdemo-stepper__line.completed {
    background: var(--color-primary, #1c497c);
  }

  /* ================================================================
     Step Panels
     ================================================================ */
  .cdemo-panel {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
    animation: cdemo-panel-in 0.3s ease-out;
  }

  .cdemo-panel.active { display: flex; }

  @keyframes cdemo-panel-in {
    from { opacity: 0; transform: translateX(16px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .cdemo-panel__kicker {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary, #1c497c);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  .cdemo-panel__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    line-height: 1.3;
  }

  .cdemo-panel__body {
    font-size: 0.875rem;
    font-weight: 300;
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }

  /* ================================================================
     Mini Cards (Step 1)
     ================================================================ */
  .cdemo-panel__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .cdemo-minicard {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    background: #fafbfc;
  }

  .cdemo-minicard__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #0369a1;
    background: #f0f9ff;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    align-self: flex-start;
  }

  .cdemo-minicard__badge--rookie {
    color: #a16207;
    background: #fefce8;
  }

  .cdemo-minicard__badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #0ea5e9;
  }

  .cdemo-minicard__badge--rookie .cdemo-minicard__badge-dot {
    background: #eab308;
  }

  .cdemo-minicard__detail {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .cdemo-minicard__label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #64748b;
  }

  .cdemo-minicard__value {
    font-size: 0.8125rem;
    font-weight: 300;
    color: #1a1a1a;
    font-variant-numeric: tabular-nums;
  }

  /* ================================================================
     Mock Row Preview (Step 2)
     ================================================================ */
  .cdemo-panel__mockup {
    margin-top: 0.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  .cdemo-mockrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .cdemo-mockrow:last-child { border-bottom: none; }

  .cdemo-mockrow .player-cell {
    --player-avatar-size: 32px;
  }

  /* Chip in mockup — uses the global .yrs-chip styles from rosters.astro.
     The chip is rendered as a static <span> in the mockup (not a button). */
  .cdemo-mockrow .yrs-chip {
    flex-shrink: 0;
  }

  /* ================================================================
     Mock Buttons & Projection (Step 3)
     ================================================================ */
  .cdemo-mock-buttons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    padding: 1rem;
    border-bottom: 1px solid #f1f5f9;
  }

  .cdemo-mock-btn {
    border: 1px solid #e2e8f0;
    border-left: 2px solid #cbd5e1;
    background: #fafbfc;
    border-radius: 6px;
    padding: 0.5rem 0.375rem 0.375rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.0625rem;
    text-align: center;
  }

  .cdemo-mock-btn--selected {
    border-color: rgba(28, 73, 124, 0.2);
    border-left: 2px solid var(--color-primary, #1c497c);
    background: linear-gradient(135deg, #f0f5fa 0%, #e8eff7 100%);
    box-shadow: 0 1px 3px rgba(28, 73, 124, 0.08);
  }

  .cdemo-mock-btn__num {
    font-size: 1rem;
    font-weight: 300;
    color: #334155;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .cdemo-mock-btn--selected .cdemo-mock-btn__num {
    color: var(--color-primary, #1c497c);
    font-weight: 600;
  }

  .cdemo-mock-btn__label {
    font-size: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    line-height: 1;
  }

  .cdemo-mock-btn--selected .cdemo-mock-btn__label { color: #64748b; }

  .cdemo-mock-projection {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cdemo-mock-projection__row {
    display: flex;
    justify-content: space-between;
    padding: 0.375rem 0;
    border-bottom: 1px solid #f8fafc;
    font-size: 0.8125rem;
    color: #334155;
    font-variant-numeric: tabular-nums;
  }

  .cdemo-mock-projection__row:last-child { border-bottom: none; }

  /* ================================================================
     Feedback Card (Step 3)
     ================================================================ */
  .cdemo-panel__feedback {
    margin-top: 0.75rem;
    border: 1px solid #e0e7ef;
    border-left: 3px solid var(--color-primary, #1c497c);
    border-radius: 0 8px 8px 0;
    padding: 0.875rem 1rem;
    background: #f8fafc;
  }

  .cdemo-feedback__header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary, #1c497c);
    margin-bottom: 0.375rem;
  }

  .cdemo-feedback__body {
    font-size: 0.8125rem;
    font-weight: 300;
    color: #475569;
    line-height: 1.55;
    margin: 0;
  }

  /* ================================================================
     Navigation
     ================================================================ */
  .cdemo-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    gap: 0.75rem;
  }

  .cdemo-nav__back,
  .cdemo-nav__next,
  .cdemo-nav__start {
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 8px;
    padding: 0.625rem 1.25rem;
    cursor: pointer;
    transition: all 0.15s ease;
    border: none;
  }

  .cdemo-nav__back {
    background: transparent;
    color: #64748b;
    padding-left: 0;
  }

  .cdemo-nav__back:hover { color: #334155; }

  .cdemo-nav__back[hidden] { visibility: hidden; }

  .cdemo-nav__next {
    background: var(--color-primary, #1c497c);
    color: #fff;
