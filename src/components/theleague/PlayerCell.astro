---
/**
 * PlayerCell - Reusable player lockup component
 * Shows player avatar, name, position, and NFL team logo.
 *
 * Handles DEF position automatically: when position is "DEF", the avatar
 * shows the NFL team logo and the meta row hides the duplicate logo.
 *
 * Supports optional modal integration via `playerData` prop — when provided,
 * the player name becomes clickable and stores data for PlayerDetailsModal.
 *
 * @example Basic usage (auto-derives NFL logo from nflTeam):
 * ```astro
 * <PlayerCell name="Patrick Mahomes" headshot={url} position="QB" nflTeam="KC" />
 * ```
 *
 * @example Compact size:
 * ```astro
 * <PlayerCell name="Ja'Marr Chase" headshot={url} position="WR" nflTeam="CIN" size="compact" />
 * ```
 *
 * @example With modal data + badges:
 * ```astro
 * <PlayerCell name={player.name} headshot={player.headshot} position={player.position}
 *   nflTeam={player.nflTeam} playerData={player}>
 *   <span slot="after-name" class="injury-badge">(I)</span>
 * </PlayerCell>
 * ```
 */

import '../../styles/player-cell.css';
import { buildHeadshotOnerror, getPlayerHeadshot } from '../../constants/roster-constants';
import { normalizeTeamCode } from '../../utils/nfl-logo';
import { getPlayerAvatarBackground, getPlayerAvatarBorder, getPlayerAvatarRing, getPlayerAvatarRingDark } from '../../utils/nfl-team-colors';
import type { PlayerModalData } from '../../utils/player-modal-trigger';

export interface Props {
  /** Player name */
  name: string;
  /** Player headshot URL (raw — DEF swap handled automatically) */
  headshot?: string;
  /** Player position (QB, RB, WR, TE, PK, DEF) */
  position?: string;
  /** NFL team code in any format (MFL or standard — normalized automatically) */
  nflTeam?: string;
  /** Explicit NFL team logo URL. If omitted, auto-derived from nflTeam. */
  nflLogo?: string;
  /** Size variant */
  size?: 'default' | 'compact';
  /** When provided, makes the name clickable and stores data for PlayerDetailsModal */
  playerData?: PlayerModalData;
  /** MFL player ID (for headshot fallback). Falls back to playerData.id if omitted. */
  mflId?: string;
  /** ESPN player ID (for college headshot fallback). Falls back to playerData.espnId if omitted. */
  espnId?: string;
  /** Contract status code (RC, TO) — displayed after position */
  contractStatus?: string;
  /** Additional CSS classes */
  class?: string;
  /**
   * The avatar image is a logo (team/franchise/placeholder) rather than a
   * player headshot. Reuses the DEF avatar treatment — full-bleed
   * `object-fit: contain`, no crop/scale, transparent chip — so the logo
   * isn't cropped by the headshot circle.
   */
  isLogoAvatar?: boolean;
  /**
   * Render the avatar with the eligible-highlight treatment
   * (`player-cell__avatar--eligible`: neutral chip, blue pulsing ring) —
   * the same class rosters.astro toggles at runtime for declaration-eligible
   * players. Used by demo/mock rows that need the look server-rendered.
   */
  eligibleAvatar?: boolean;
}

const {
  name,
  headshot,
  position,
  nflTeam,
  nflLogo: explicitNflLogo,
  size = 'default',
  playerData,
  mflId: explicitMflId,
  espnId: explicitEspnId,
  contractStatus,
  class: className,
  isLogoAvatar = false,
  eligibleAvatar = false,
} = Astro.props;

// Resolve IDs for headshot fallback chain (explicit props take priority over playerData)
const resolvedMflId = explicitMflId ?? playerData?.id;
const resolvedEspnId = explicitEspnId ?? playerData?.espnId;

// --- DEF handling ---
const isDef = position?.toUpperCase() === 'DEF';
const isLogo = isDef || isLogoAvatar;
const normalizedTeam = nflTeam ? normalizeTeamCode(nflTeam) : '';
const teamLogoUrl = normalizedTeam ? `/assets/nfl-logos/${normalizedTeam}.svg` : '';

// Prefer the caller-supplied headshot URL — server-side builders pick the
// right endpoint (ESPN NFL direct, college-football, or MFL photo) based on
// the IDs they have available. When no headshot URL is passed, fall through
// to getPlayerHeadshot, which is the same cascade PlayerDetailsModal uses:
//   - ESPN NFL direct URL when we have an NFL espn_id
//   - MFL photo URL when we only have an MFL id
//   - DEFAULT_HEADSHOT_URL when neither is present
// The previous version skipped from "no espnId" straight to DEFAULT, which
// meant any player missing an espn_id rendered as the MFL silhouette even
// when MFL had a perfectly good photo (Breece Hall on the AFL feed — his
// row showed the silhouette, his click-through modal loaded fine because
// PlayerDetailsModal does try the MFL photo URL as a step before default).
const resolvedHeadshot = headshot || getPlayerHeadshot(resolvedMflId, resolvedEspnId);
// Avatar: DEF uses team logo, others use headshot
const avatarSrc = isDef && teamLogoUrl ? teamLogoUrl : resolvedHeadshot;

// NFL logo in meta row: DEF hides it, others show it
const nflLogoUrl = isDef ? '' : (explicitNflLogo || teamLogoUrl || '/assets/nfl-logos/NFL.svg');
const showNflLogo = !!nflLogoUrl;

// Team-color backdrop behind the headshot (logo chips keep transparent).
const avatarBg = isLogo ? undefined : getPlayerAvatarBackground(nflTeam ?? '');
const avatarBorder = isLogo ? undefined : getPlayerAvatarBorder(nflTeam ?? '');
const avatarRing = isLogo ? undefined : getPlayerAvatarRing(nflTeam ?? '');
const avatarRingDark = isLogo ? undefined : getPlayerAvatarRingDark(nflTeam ?? '');

const sizeClass = size === 'compact' ? 'player-cell--compact' : '';
const avatarStyle = avatarBg
  ? `--player-avatar-bg: ${avatarBg}; --player-avatar-border: ${avatarBorder}; --player-avatar-ring: ${avatarRing}; --player-avatar-ring-dark: ${avatarRingDark}`
  : undefined;
---

<div class:list={['player-cell', sizeClass, className]}>
  <div class:list={['player-cell__avatar', isLogo && 'player-cell__avatar--def', eligibleAvatar && 'player-cell__avatar--eligible']} style={avatarStyle}>
    <img
      src={avatarSrc}
      alt={isDef ? `${nflTeam ?? 'DEF'} logo` : isLogoAvatar ? `${name} logo` : `${name} headshot`}
      loading="lazy"
      decoding="async"
      onerror={isLogo ? 'this.onerror=null' : buildHeadshotOnerror(resolvedMflId, resolvedEspnId)}
    />
  </div>
  <div class="player-cell__info">
    {playerData ? (
      <strong
        class="player-cell__name player-cell__name--clickable"
        data-player-modal={JSON.stringify(playerData)}
        title="Click to view player details"
      >
        {name}<slot name="after-name" />
      </strong>
    ) : (
      <strong class="player-cell__name">
        {name}<slot name="after-name" />
      </strong>
    )}
    {(showNflLogo || position) && (
      <div class="player-meta">
        {showNflLogo && (
          <img
            src={nflLogoUrl}
            alt={`${normalizedTeam || nflTeam || 'FA'} logo`}
            class="player-meta__logo"
            loading="lazy"
            decoding="async"
          />
        )}
        {position && <span class="player-meta__pos">{position}{contractStatus ? ` - ${contractStatus}` : ''}</span>}
      </div>
    )}
  </div>
</div>
