---
/**
 * Stub: Standings Hero
 * Placeholder for Monday standings display — replaced in Phase D.
 */
import '../../../styles/hero-stub.css';
---

<div class="hero-stub">
  <h3 class="hero-stub__title">Standings</h3>
  <div class="hero-stub__body">
    <svg class="hero-stub__icon" viewBox="0 0 24 24" aria-hidden="true">
      <rect x="3" y="14" width="4" height="8" rx="1" fill="currentColor" opacity="0.5"/>
      <rect x="10" y="6" width="4" height="16" rx="1" fill="currentColor" opacity="0.7"/>
      <rect x="17" y="10" width="4" height="12" rx="1" fill="currentColor" opacity="0.6"/>
    </svg>
    <p class="hero-stub__label">League Standings</p>
    <p class="hero-stub__desc">Current standings, streaks, and playoff picture at a glance.</p>
  </div>
</div>
