---
/**
 * EventHeroShell — the shared deep-navy hero card chrome for TheLeague.
 *
 * Owns the branded card: glow wash, eyebrow (badge/icon-chip + green pill),
 * condensed headline with a per-event accent word, summary, and the footer
 * (day countdown + divider + green CTA). The right region is either a
 * decorative player cut-out (promo heroes) OR a functional `panel` slot
 * (data heroes like CutWatch). The accent (headline word, countdown, border,
 * panel rail) varies per hero via the `accent` prop; the pill and CTA stay
 * brand green so a stable brand element is always present.
 *
 * Wrappers:
 *   - LeagueEventHero.astro — promo (no panel; uses the player cut-out).
 *   - CutWatchHero.astro     — promo + `panel` slot (over-the-limit teams).
 *
 * Reusable panel styles are exposed as :global(.tl-hero-panel*) so any hero
 * slotting `panel` content shares one on-navy list look.
 */
import { spriteUrl } from '../../utils/sprite-url';

interface Props {
  pill: string;
  headline: string;
  accentWord?: string;
  summary: string;
  link?: string;
  linkLabel?: string;
  isExternal?: boolean;
  /** Sprite glyph id WITHOUT the "icon-" prefix. Ignored when `badge` is set. */
  icon?: string;
  badge?: string;
  badgeAlt?: string;
  /** Accent color for the headline word, countdown number, border and panel rail. */
  accent?: string;
  glow?: string;
  /** Decorative player cut-out (promo heroes). Ignored when a `panel` slot is supplied. */
  player?: string;
  playerAlt?: string;
  countValue?: string | number;
  countLabel?: string;
  bordered?: boolean;
  regionLabel?: string;
}

const {
  pill,
  headline,
  accentWord = '',
  summary,
  link,
  linkLabel = 'Learn more',
  isExternal = false,
  icon,
  badge,
  badgeAlt = '',
  accent = '#1c497c',
  glow = 'rgba(28,73,124,.55)',
  player,
  playerAlt = '',
  countValue,
  countLabel,
  bordered = false,
  regionLabel = 'League hero',
} = Astro.props;

// A functional right-hand panel (slotted) takes the place of the player cut-out.
const hasPanel = Astro.slots.has('panel');

const hasCount = countValue !== undefined && countValue !== null && countValue !== '';
const hasFooter = hasCount || !!link;
const countAriaLabel = hasCount
  ? countLabel
    ? `${countValue} — ${countLabel}`
    : String(countValue)
  : undefined;
---

<section
  class:list={['tl-event-hero', { 'tl-event-hero--bordered': bordered, 'tl-event-hero--paneled': hasPanel }]}
  style={`--ev-accent:${accent};--ev-glow:${glow};`}
  aria-label={regionLabel}
>
  <span class="tl-event-hero__glow" aria-hidden="true"></span>

  {!hasPanel && player && (
    <div class="tl-event-hero__player" aria-hidden="true">
      <img src={player} alt={playerAlt} loading="eager" fetchpriority="high" />
      <span class="tl-event-hero__fade tl-event-hero__fade--left"></span>
      <span class="tl-event-hero__fade tl-event-hero__fade--bottom"></span>
    </div>
  )}

  <div class="tl-event-hero__content">
    <div class="tl-event-hero__eyebrow">
      {badge ? (
        <img class="tl-event-hero__badge" src={badge} alt={badgeAlt} />
      ) : icon ? (
        <span class="tl-event-hero__chip">
          <svg viewBox="0 0 24 24" aria-hidden="true"><use href={`${spriteUrl}#icon-${icon}`}></use></svg>
        </span>
      ) : null}
      <span class="tl-event-hero__pill">{pill}</span>
    </div>

    <h2 class="tl-event-hero__title">
      {headline}{accentWord && (<Fragment> <span class="tl-event-hero__accent">{accentWord}</span></Fragment>)}
    </h2>

    <p class="tl-event-hero__summary">{summary}</p>

    {hasFooter && (
      <div class="tl-event-hero__footer">
        {hasCount && (
          <div class="tl-event-hero__count" role="group" aria-label={countAriaLabel}>
            <span class="tl-event-hero__count-num" aria-hidden="true">{countValue}</span>
            {countLabel && <span class="tl-event-hero__count-label" aria-hidden="true">{countLabel}</span>}
          </div>
        )}
        {hasCount && link && <span class="tl-event-hero__divider" aria-hidden="true"></span>}
        {link && (
          <a
            class="tl-event-hero__cta"
            href={link}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener noreferrer' : undefined}
          >
            {linkLabel}
            <span class="tl-event-hero__cta-arrow" aria-hidden="true">→</span>
          </a>
        )}
      </div>
    )}
  </div>

  {hasPanel && (
    <div class="tl-event-hero__panel">
      <slot name="panel" />
    </div>
  )}
</section>

<style>
  .tl-event-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: clamp(320px, 34vw, 380px);
    border-radius: var(--radius-lg, 0.75rem);
    background: #0f1e2e;
    color: #fff;
    box-shadow: var(--box-shadow-lg, 0 10px 28px rgba(15, 30, 46, 0.4));
    isolation: isolate;
  }

  .tl-event-hero--bordered {
    border: 2px solid var(--ev-accent);
  }

  /* Functional layout: content column + right data panel (replaces player cut-out). */
  .tl-event-hero--paneled {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 264px);
    align-items: stretch;
  }
  .tl-event-hero--paneled .tl-event-hero__content {
    max-width: none;
  }

  .tl-event-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(86% 92% at 3% -4%, var(--ev-glow), transparent 64%);
    pointer-events: none;
  }

  /* ── Player panel ── */
  .tl-event-hero__player {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: clamp(220px, 36%, 360px);
  }
  .tl-event-hero__player img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 52% 16%;
    display: block;
  }
  .tl-event-hero__fade {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .tl-event-hero__fade--left {
    background: linear-gradient(90deg, #0f1e2e 0%, rgba(15, 30, 46, 0.6) 26%, rgba(15, 30, 46, 0.1) 60%, transparent 100%);
  }
  .tl-event-hero__fade--bottom {
    background: linear-gradient(0deg, rgba(15, 30, 46, 0.5) 0%, transparent 42%);
  }
  /* ── Content ── */
  .tl-event-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.9rem;
    padding: clamp(1.5rem, 3vw, 2.4rem) clamp(1.5rem, 3vw, 2.75rem);
    max-width: 640px;
  }

  .tl-event-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .tl-event-hero__badge {
    height: 46px;
    width: auto;
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.35));
  }
  .tl-event-hero__chip {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--ev-accent) 22%, transparent);
  }
  .tl-event-hero__chip svg {
    width: 24px;
    height: 24px;
    fill: var(--ev-accent);
  }
  .tl-event-hero__pill {
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    background: var(--ev-accent);
    color: #fff;
  }

  .tl-event-hero__title {
    margin: 0;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: clamp(2.2rem, 4.4vw, 3.25rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #fff;
    text-wrap: balance;
  }
  .tl-event-hero__accent {
    color: var(--ev-accent);
  }

  .tl-event-hero__summary {
    margin: 0;
    max-width: 24rem;
    font-size: 1rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.72);
  }

  .tl-event-hero__footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }
  .tl-event-hero__count {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .tl-event-hero__count-num {
    font-family: var(--font-numeric, 'UFC Sans', 'Vend Sans', system-ui, sans-serif);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: clamp(2.6rem, 5vw, 3.1rem);
    color: var(--ev-accent);
  }
  .tl-event-hero__count-label {
    margin-top: 0.3rem;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
  .tl-event-hero__divider {
    width: 1px;
    height: 54px;
    background: rgba(255, 255, 255, 0.16);
  }

  .tl-event-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 50px;
    padding: 0 1.5rem;
    border-radius: var(--radius-md, 0.5rem);
    background: #fff;
    color: #0f1e2e;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: filter 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .tl-event-hero__cta:hover {
    filter: brightness(0.92);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
  }
  .tl-event-hero__cta-arrow {
    font-size: 1.1rem;
    transition: transform 0.15s ease;
  }
  .tl-event-hero__cta:hover .tl-event-hero__cta-arrow {
    transform: translateX(2px);
  }

  /* ── Right data panel (slotted) ── */
  .tl-event-hero__panel {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(1.25rem, 2.5vw, 1.9rem) clamp(1.25rem, 2.5vw, 1.6rem) clamp(1.25rem, 2.5vw, 1.9rem) 0;
  }

  /* Reusable on-navy panel primitives — shared by any hero slotting `panel`. */
  :global(.tl-hero-panel) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }
  :global(.tl-hero-panel__title) {
    margin: 0;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ev-accent);
    border-left: 3px solid var(--ev-accent);
    padding-left: 0.5rem;
  }
  :global(.tl-hero-panel__row) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.55rem 0.7rem;
  }
  :global(.tl-hero-panel__more-link) {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    padding-left: 0.15rem;
  }
  :global(.tl-hero-panel__more-link:hover) {
    color: rgba(255, 255, 255, 0.85);
  }
  :global(.tl-hero-panel__empty) {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .tl-event-hero__player {
      width: 42%;
      opacity: 0.5;
    }
    .tl-event-hero__fade--left {
      background: linear-gradient(90deg, #0f1e2e 0%, rgba(15, 30, 46, 0.75) 45%, rgba(15, 30, 46, 0.2) 100%);
    }
    .tl-event-hero__content {
      max-width: none;
    }
    .tl-event-hero--paneled {
      grid-template-columns: 1fr;
    }
    .tl-event-hero__panel {
      padding: 0 clamp(1.5rem, 3vw, 2.75rem) clamp(1.5rem, 3vw, 2.4rem);
    }
  }
</style>
