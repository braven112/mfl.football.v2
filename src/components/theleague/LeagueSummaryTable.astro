---
import type { TeamSummary, CategoryDefinition } from '../../utils/league-summary-utils';

interface Props {
  teams: TeamSummary[];
  years: number[];
  categories: CategoryDefinition[];
}

const { teams, years, categories } = Astro.props;

// Serialize data for client-side JS
const serializedData = JSON.stringify({ teams, years, categories });
---

<div class="league-summary" id="league-summary" data-config={serializedData}>
  <!-- Controls -->
  <div class="league-summary__controls">
    <div class="league-summary__category-group">
      <select id="category-select" class="league-summary__select" aria-label="Category">
        <optgroup label="Core Metrics">
          {categories.filter(c => c.milestone === 1).map(c => (
            <option value={c.id} selected={c.id === 'capSpace'}>{c.name}</option>
          ))}
        </optgroup>
        <optgroup label="Advanced Metrics">
          {categories.filter(c => c.milestone === 2).map(c => (
            <option value={c.id}>{c.name}</option>
          ))}
        </optgroup>
      </select>
    </div>

    <span class="league-summary__description" id="category-description">
      {categories.find(c => c.id === 'capSpace')?.description ?? ''}
    </span>

    <div class="league-summary__subcategory-group" id="subcategory-group" style="display: none;">
      <div class="league-summary__pills" id="subcategory-pills" role="group" aria-label="Position filter"></div>
    </div>
  </div>

  <!-- Screen reader announcement -->
  <div class="sr-only" aria-live="polite" id="summary-announcement"></div>

  <!-- Table -->
  <div class="league-summary__table-wrapper">
    <table class="league-summary__table" id="summary-table">
      <thead>
        <tr>
          <th class="league-summary__th league-summary__th--team" data-sort="team" aria-sort="none">
            <button type="button" class="league-summary__sort-btn">Team</button>
          </th>
          {years.map((year, yi) => (
            <th class="league-summary__th league-summary__th--year" data-sort={String(yi)} aria-sort="none">
              <button type="button" class="league-summary__sort-btn">{year}</button>
            </th>
          ))}
        </tr>
      </thead>
      <tbody id="summary-tbody">
        {teams.map(team => (
          <tr class="league-summary__row" data-franchise-id={team.franchiseId}>
            <td class="league-summary__td league-summary__td--team">
              <div class="league-summary__team-cell">
                {team.teamIcon && (
                  <img src={team.teamIcon} alt="" class="league-summary__team-icon" loading="lazy" />
                )}
                <span class="league-summary__team-name league-summary__team-name--default">{team.teamName}</span>
                <span class="league-summary__team-name league-summary__team-name--short">{team.teamNameShort || team.teamName}</span>
              </div>
            </td>
            {years.map((_, yi) => (
              <td class="league-summary__td league-summary__td--value" data-year-index={String(yi)}></td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Legend -->
  <div class="league-summary__legend">
    <span class="league-summary__legend-item">
      <span class="league-summary__legend-swatch league-summary__legend-swatch--top"></span>
      Top quartile
    </span>
    <span class="league-summary__legend-item">
      <span class="league-summary__legend-swatch league-summary__legend-swatch--bottom"></span>
      Bottom quartile
    </span>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('league-summary');
    if (!container || container.dataset.initialized) return;
    container.dataset.initialized = 'true';

    const config = JSON.parse(container.dataset.config || '{}');
    const { teams, years, categories } = config;

    // State
    let selectedCategory = 'capSpace';
    let selectedSubCategory: string | null = null;
    let sortColumn = 'team';
    let sortDirection = 'asc';
    let preferredTeamId: string | null = null;

    // Read preferred team from URL param or cookie
    try {
      const myTeamParam = new URLSearchParams(window.location.search).get('myteam');
      if (myTeamParam) {
        preferredTeamId = myTeamParam.padStart(4, '0');
      } else {
        const cookie = document.cookie.split('; ').find(r => r.startsWith('theleague_team_pref='));
        if (cookie) {
          const pref = JSON.parse(decodeURIComponent(cookie.split('=')[1]));
          preferredTeamId = pref?.franchiseId ?? null;
        }
      }
    } catch {}

    // DOM references
    const categorySelect = document.getElementById('category-select') as HTMLSelectElement;
    const descriptionEl = document.getElementById('category-description');
    const tbody = document.getElementById('summary-tbody');
    const subcategoryGroup = document.getElementById('subcategory-group');
    const subcategoryPills = document.getElementById('subcategory-pills');
    const headerCells = container.querySelectorAll('.league-summary__th');
    const announcementEl = document.getElementById('summary-announcement');

    // Rank color CSS custom properties
    const styles = getComputedStyle(container);
    const rankTopColor = styles.getPropertyValue('--rank-top').trim() || 'hsl(142, 60%, 35%)';
    const rankBottomColor = styles.getPropertyValue('--rank-bottom').trim() || 'hsl(0, 70%, 40%)';

    // Helpers
    function getCategory() {
      return categories.find((c: any) => c.id === selectedCategory) || categories[0];
    }

    function getTeamValue(team: any, yearIndex: number): number {
      const cat = getCategory();
      if (cat.id === 'positionalDepth' && selectedSubCategory) {
        return team.positionalDepth[yearIndex]?.[selectedSubCategory] ?? 0;
      }
      if (cat.id === 'positionalSpend' && selectedSubCategory) {
        return team.positionalSpend[yearIndex]?.[selectedSubCategory] ?? 0;
      }
      return team.metrics[cat.id]?.[yearIndex] ?? 0;
    }

    function formatValue(value: number, format: string): string {
      if (!Number.isFinite(value)) return '\u2014';
      switch (format) {
        case 'currency':
          return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(value);
        case 'compactCurrency': {
          if (Math.abs(value) >= 1_000_000) return `$${(value / 1_000_000).toFixed(1)}M`;
          if (Math.abs(value) >= 1_000) return `$${(value / 1_000).toFixed(0)}K`;
          return `$${value.toFixed(0)}`;
        }
        case 'number': return String(Math.round(value));
        case 'decimal': case 'age': return value.toFixed(1);
        case 'percentage': return `${value.toFixed(1)}%`;
        default: return String(value);
      }
    }

    function rankTeamsForColumn(values: number[], direction: string): number[] {
      const indexed = values.map((v, i) => ({ i, v }));
      indexed.sort((a, b) => direction === 'asc' ? b.v - a.v : a.v - b.v);
      const ranks = new Array(values.length);
      indexed.forEach((item, rank) => { ranks[item.i] = rank + 1; });
      return ranks;
    }

    function getCellColor(rank: number, total: number, direction: string): string {
      const quartile = Math.ceil(total / 4);
      const isTop = direction === 'asc' ? rank <= quartile : rank > total - quartile;
      const isBottom = direction === 'asc' ? rank > total - quartile : rank <= quartile;
      if (isTop) return rankTopColor;
      if (isBottom) return rankBottomColor;
      return '';
    }

    function renderTable() {
      if (!tbody) return;
      const cat = getCategory();

      // Sort teams
      const sorted = [...teams];
      sorted.sort((a: any, b: any) => {
        if (sortColumn === 'team') {
          return sortDirection === 'asc'
            ? a.teamName.localeCompare(b.teamName)
            : b.teamName.localeCompare(a.teamName);
        }
        const yi = Number(sortColumn);
        const aVal = getTeamValue(a, yi);
        const bVal = getTeamValue(b, yi);
        return sortDirection === 'asc' ? aVal - bVal : bVal - aVal;
      });

      // Calculate ranks per year column
      const ranksByYear = years.map((_: any, yi: number) => {
        const values = sorted.map((t: any) => getTeamValue(t, yi));
        return rankTeamsForColumn(values, cat.direction);
      });

      // Reorder rows
      sorted.forEach((team: any) => {
        const row = tbody.querySelector(`[data-franchise-id="${team.franchiseId}"]`);
        if (row) tbody.appendChild(row);
      });

      // Update cells
      sorted.forEach((team: any, teamIndex: number) => {
        const row = tbody.querySelector(`[data-franchise-id="${team.franchiseId}"]`) as HTMLElement;
        if (!row) return;

        // Preferred team highlight
        row.classList.toggle('league-summary__row--preferred', team.franchiseId === preferredTeamId);

        // Update value cells
        const cells = row.querySelectorAll('.league-summary__td--value');
        cells.forEach((cell: Element, yi: number) => {
          const value = getTeamValue(team, yi);
          (cell as HTMLElement).textContent = formatValue(value, cat.format);
          const rank = ranksByYear[yi][teamIndex];
          const color = getCellColor(rank, teams.length, cat.direction);
          (cell as HTMLElement).style.color = color;
          (cell as HTMLElement).style.fontWeight = color ? '600' : '';
          (cell as HTMLElement).style.backgroundColor = '';
        });
      });

      // Update sort indicators and ARIA on headers
      headerCells.forEach((th: Element) => {
        const sortKey = (th as HTMLElement).dataset.sort;
        const isSorted = sortKey === sortColumn;
        th.classList.toggle('league-summary__th--sorted', isSorted);

        // Update aria-sort
        if (isSorted) {
          th.setAttribute('aria-sort', sortDirection === 'asc' ? 'ascending' : 'descending');
        } else {
          th.setAttribute('aria-sort', 'none');
        }

        // Update button text with arrow indicator
        const btn = th.querySelector('.league-summary__sort-btn');
        if (btn) {
          const baseText = sortKey === 'team' ? 'Team' : years[Number(sortKey)];
          btn.textContent = isSorted
            ? `${baseText} ${sortDirection === 'asc' ? '\u25B2' : '\u25BC'}`
            : String(baseText);
        }
      });

      // Screen reader announcement
      if (announcementEl) {
        const sortLabel = sortColumn === 'team' ? 'Team' : years[Number(sortColumn)];
        announcementEl.textContent = `Showing ${cat.name} for ${teams.length} teams, sorted by ${sortLabel} ${sortDirection === 'asc' ? 'ascending' : 'descending'}`;
      }
    }

    function renderSubCategories() {
      if (!subcategoryGroup || !subcategoryPills) return;
      const cat = getCategory();
      if (cat.subCategories && cat.subCategories.length > 0) {
        subcategoryGroup.style.display = '';
        // Build pills using DOM API for safety
        subcategoryPills.textContent = '';
        cat.subCategories.forEach((sub: any) => {
          const btn = document.createElement('button');
          btn.className = `league-summary__pill${selectedSubCategory === sub.id ? ' league-summary__pill--active' : ''}`;
          btn.dataset.subId = sub.id;
          btn.setAttribute('aria-pressed', String(selectedSubCategory === sub.id));
          btn.textContent = sub.name;
          btn.addEventListener('click', () => {
            selectedSubCategory = sub.id;
            renderSubCategories();
            renderTable();
          });
          subcategoryPills.appendChild(btn);
        });
      } else {
        subcategoryGroup.style.display = 'none';
        selectedSubCategory = null;
      }
    }

    // Event: category change
    categorySelect?.addEventListener('change', () => {
      selectedCategory = categorySelect.value;
      const cat = getCategory();
      if (descriptionEl) descriptionEl.textContent = cat.description;

      // Reset sub-category
      if (cat.subCategories && cat.subCategories.length > 0) {
        selectedSubCategory = cat.subCategories[0].id;
      } else {
        selectedSubCategory = null;
      }

      renderSubCategories();
      renderTable();
    });

    // Event: column sorting via <button> inside <th>
    headerCells.forEach((th: Element) => {
      const btn = th.querySelector('.league-summary__sort-btn');
      if (btn) {
        btn.addEventListener('click', () => {
          const col = (th as HTMLElement).dataset.sort || 'team';
          if (sortColumn === col) {
            sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
          } else {
            sortColumn = col;
            const cat = getCategory();
            sortDirection = cat.direction === 'asc' ? 'desc' : 'asc';
          }
          renderTable();
        });
      }
    });

    // Initial render
    renderSubCategories();
    renderTable();
  });
</script>

<style>
  .league-summary {
    font-family: var(--font-family-base);
    max-width: 100%;
    overflow: visible;
    --rank-top: hsl(142, 60%, 28%);
    --rank-bottom: hsl(0, 70%, 33%);
  }

  /* Editorial section title */
  .league-summary__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .league-summary__subcategory-group {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .league-summary__select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    font-size: 0.875rem;
    color: var(--color-gray-900, #111827);
    background: var(--input-bg, #ffffff);
    cursor: pointer;
    min-width: 220px;
  }

  .league-summary__select:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
    box-shadow: var(--shadow-focus-ring);
  }

  .league-summary__pills {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  :global(.league-summary__pill) {
    padding: 0.375rem 0.625rem;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-sm, 0.25rem);
    background: var(--input-bg, #ffffff);
    color: var(--color-gray-500, #6b7280);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast, 150ms ease);
  }

  :global(.league-summary__pill:hover) {
    border-color: var(--color-primary, #1c497c);
    color: var(--color-primary, #1c497c);
  }

  :global(.league-summary__pill:focus-visible) {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
    box-shadow: var(--shadow-focus-ring);
  }

  :global(.league-summary__pill--active) {
    background: var(--color-primary, #1c497c);
    color: var(--color-white, #ffffff);
    border-color: var(--color-primary-dark, #164066);
  }

  .league-summary__description {
    font-size: 0.8125rem;
    color: var(--color-gray-400, #9ca3af);
    align-self: center;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .league-summary__table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: 0;
    box-shadow: var(--shadow-sm);
    box-sizing: border-box;
    margin-left: -1.125rem;
    margin-right: -1.125rem;
    width: calc(100% + 2.25rem);
    border-left: none;
    border-right: none;
  }

  .league-summary__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    white-space: nowrap;
  }

  /* Editorial table header */
  .league-summary__th {
    padding: 0.5rem 0.375rem;
    background: var(--color-gray-50, #f9fafb);
    border-bottom: 1px solid var(--content-border, #e2e8f0);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    text-align: right;
    user-select: none;
    transition: background var(--transition-fast, 150ms ease);
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .league-summary__th:hover {
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-600, #4b5563);
  }

  .league-summary__th:global(.league-summary__th--sorted) {
    color: var(--color-primary, #1c497c);
    background: rgba(28, 73, 124, 0.06);
  }

  /* Sort button inside th — reset all button styles */
  .league-summary__sort-btn {
    all: unset;
    display: block;
    cursor: pointer;
    font: inherit;
    color: inherit;
    text-transform: inherit;
    letter-spacing: inherit;
    white-space: nowrap;
    width: 100%;
    text-align: inherit;
  }

  .league-summary__sort-btn:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .league-summary__th--team {
    text-align: left;
    position: sticky;
    left: 0;
    z-index: 3;
    min-width: 160px;
    padding-left: 1.5rem;
  }

  .league-summary__th--year {
    min-width: 100px;
  }

  .league-summary__th:last-child {
    padding-right: 1.125rem;
  }

  .league-summary__row {
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    transition: background 0.1s ease;
  }

  .league-summary__row:hover {
    background: var(--color-gray-50, #f9fafb);
  }

  .league-summary__row:global(.league-summary__row--preferred) .league-summary__td--team {
    box-shadow: inset 3px 0 0 var(--color-primary, #1c497c);
    background: rgba(28, 73, 124, 0.05);
    font-weight: 600;
  }

  .league-summary__td {
    padding: 0.3rem 0.5rem;
    font-size: 0.75rem;
    color: var(--color-gray-700, #374151);
  }

  .league-summary__td--team {
    position: sticky;
    left: 0;
    background: var(--content-bg, #ffffff);
    z-index: 1;
    border-right: 1px solid var(--content-border, #e2e8f0);
    padding-left: 1.5rem;
  }

  .league-summary__td--value {
    text-align: right;
    font-variant-numeric: tabular-nums;
    transition: color 0.2s ease;
  }

  .league-summary__td:last-child {
    padding-right: 1.125rem;
  }

  .league-summary__team-cell {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .league-summary__team-icon {
    width: var(--team-icon-md, 40px);
    height: var(--team-icon-md, 40px);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .league-summary__team-name {
    font-weight: var(--font-weight-semibold, 600);
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .league-summary__team-name--short {
    display: none;
  }

  .league-summary__legend {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-gray-500, #6b7280);
  }

  .league-summary__legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .league-summary__legend-swatch {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
  }

  .league-summary__legend-swatch--top {
    background-color: var(--rank-top);
  }

  .league-summary__legend-swatch--bottom {
    background-color: var(--rank-bottom);
  }

  @media (max-width: 640px) {
    .league-summary__controls {
      flex-direction: column;
      align-items: stretch;
    }

    .league-summary__select {
      min-width: unset;
      width: 100%;
    }

    .league-summary__table {
      font-size: 0.75rem;
      table-layout: fixed;
      width: 100%;
    }

    .league-summary__th--team {
      min-width: unset;
      width: 28%;
    }

    .league-summary__th--year {
      min-width: unset;
    }

    .league-summary__th {
      padding: 0.5rem 0.25rem;
    }

    .league-summary__td {
      padding: 0.375rem 0.25rem;
    }

    .league-summary__td--team {
      padding: 0.375rem 0.375rem;
      padding-left: 1rem;
    }

    .league-summary__th--team {
      padding-left: 1rem;
    }

    .league-summary__th:last-child {
      padding-right: 1.5rem;
    }

    .league-summary__td:last-child {
      padding-right: 1.5rem;
    }

    .league-summary__team-icon {
      width: var(--team-icon-xs, 24px);
      height: var(--team-icon-xs, 24px);
    }

    .league-summary__team-name--default {
      display: none;
    }

    .league-summary__team-name--short {
      display: inline;
    }

    .league-summary__team-cell {
      gap: 0.25rem;
    }
  }
</style>
