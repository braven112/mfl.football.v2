---
/**
 * ChampionCrownedHero — Celebratory hero displayed for 7 days after the
 * championship game. Custom layout so the winning team's logo can sit large
 * in the background with all content flowing over it.
 */
import type { HeroState } from '../../types/hero-state';

export interface Props {
  championProps: NonNullable<HeroState['championProps']>;
  resolveLeaguePath: (path: string) => string;
  userFranchiseId?: string;
}

const { championProps, resolveLeaguePath: r, userFranchiseId } = Astro.props;
const {
  winnerFranchiseId, winnerName, winnerIcon, winnerGroupMeIcon,
  loserName, winnerScore, loserScore,
} = championProps;

const isUserChampion = userFranchiseId === winnerFranchiseId;

const quips = [
  'The confetti has settled. A dynasty chapter has been written.',
  'When you win it all, the salary cap feels a little less painful.',
  'Championship rosters are built in the offseason. This one was no exception.',
  'Not luck. Not a fluke. Just better roster management.',
  'Every trade, every waiver claim, every draft pick — it all led here.',
];
const summary = isUserChampion
  ? "That's yours. Every trade, every waiver claim, every sleeper — it all led right here."
  : quips[Math.floor(Math.random() * quips.length)];
---

<section class="champ-hero" aria-label="League Champion">
  <span class="champ-hero__glow" aria-hidden="true"></span>

  <img src={winnerGroupMeIcon} alt="" aria-hidden="true" class="champ-hero__bg-logo" />

  <div class="champ-hero__content">
    <div class="champ-hero__eyebrow">
      <img src={winnerIcon} alt={`${winnerName} team icon`} class="champ-hero__badge" />
      <span class="champ-hero__pill">Champion Crowned</span>
    </div>

    <h2 class="champ-hero__title">
      {winnerName} <span class="champ-hero__accent">Champions.</span>
    </h2>

    <p class="champ-hero__summary">{summary}</p>

    <div class="champ-hero__footer">
      <div class="champ-hero__count">
        <span class="champ-hero__count-num">{winnerScore}</span>
        <span class="champ-hero__count-label">Final · vs {loserName}</span>
      </div>
      <span class="champ-hero__divider" aria-hidden="true"></span>
      <a href={r('/theleague/playoffs')} class="champ-hero__cta">
        Championship Recap <span class="champ-hero__cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  /* Theme surface: light editorial card by default; html.dark restores the
     deep-navy chrome (matches the EventHeroShell theming pattern). */
  .champ-hero {
    /* Light mode is a saturated bronze-gold trophy card (white ink), mirroring
       dark mode's drama — the bright gold pill/accent/border/glow supply the
       celebratory pop. Deep-navy chrome applied under html.dark. */
    --champ-surface: linear-gradient(115deg, #7c5510 0%, #5a3d0c 52%, #2f2206 100%);
    --champ-ink: #ffffff;
    --champ-ink-soft: rgba(255, 255, 255, 0.78);
    --champ-ink-faint: rgba(255, 255, 255, 0.6);
    --champ-divider: rgba(255, 255, 255, 0.18);
    --champ-cta-bg: #ffffff;
    --champ-cta-ink: #2f2206;
    --champ-glow-alpha: 0.4;
    /* Pale gold for TEXT (accent word, score) — pops on the deep-gold surface;
       the border/pill keep the brighter brand gold in both themes. */
    --champ-accent-ink: #fde68a;
    /* Surface is dark in both themes now, so the winner-crest watermark uses
       the same on-dark opacity as dark mode. */
    --champ-logo-opacity: 0.5;
    --champ-logo-opacity-mobile: 0.35;
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: clamp(320px, 34vw, 380px);
    border-radius: var(--radius-lg, 0.75rem);
    background: var(--champ-surface);
    border: 2px solid var(--color-warning, #f59e0b);
    color: var(--champ-ink);
    box-shadow: var(--box-shadow-lg, 0 10px 28px rgba(15, 30, 46, 0.4));
    isolation: isolate;
  }

  :global(html.dark) .champ-hero {
    --champ-surface: var(--color-navy-900, #0f1e2e);
    --champ-ink: #ffffff;
    --champ-ink-soft: rgba(255, 255, 255, 0.72);
    --champ-ink-faint: rgba(255, 255, 255, 0.6);
    --champ-divider: rgba(255, 255, 255, 0.16);
    --champ-cta-bg: #ffffff;
    --champ-cta-ink: #0f1e2e;
    --champ-glow-alpha: 0.4;
    --champ-accent-ink: var(--color-warning, #f59e0b);
    --champ-logo-opacity: 0.5;
    --champ-logo-opacity-mobile: 0.35;
  }

  .champ-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(86% 92% at 3% -4%, rgba(245, 158, 11, var(--champ-glow-alpha)), transparent 64%);
    pointer-events: none;
    z-index: 0;
  }

  .champ-hero__bg-logo {
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(260px, 52%, 460px);
    height: auto;
    object-fit: contain;
    opacity: var(--champ-logo-opacity);
    pointer-events: none;
    z-index: 1;
  }

  .champ-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.9rem;
    padding: clamp(1.5rem, 3vw, 2.4rem) clamp(1.5rem, 3vw, 2.75rem);
    max-width: 640px;
  }

  .champ-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .champ-hero__badge {
    height: 46px;
    width: auto;
    filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.35));
  }

  .champ-hero__pill {
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    background: var(--color-warning, #f59e0b);
    color: var(--color-white, #fff);
  }

  .champ-hero__title {
    margin: 0;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: clamp(2.2rem, 4.4vw, 3.25rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--champ-ink);
    text-wrap: balance;
  }

  .champ-hero__accent {
    color: var(--champ-accent-ink);
  }

  .champ-hero__summary {
    margin: 0;
    max-width: 24rem;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--champ-ink-soft);
  }

  .champ-hero__footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .champ-hero__count {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .champ-hero__count-num {
    font-family: var(--font-numeric, 'UFC Sans', system-ui, sans-serif);
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: clamp(2.6rem, 5vw, 3.1rem);
    color: var(--champ-accent-ink);
  }

  .champ-hero__count-label {
    margin-top: 0.3rem;
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--champ-ink-faint);
  }

  .champ-hero__divider {
    width: 1px;
    height: 54px;
    background: var(--champ-divider);
  }

  .champ-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 50px;
    padding: 0 1.5rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--champ-cta-bg);
    color: var(--champ-cta-ink);
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', 'Oswald', sans-serif);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: filter 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }

  .champ-hero__cta:hover {
    filter: brightness(0.92);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
  }

  .champ-hero__cta:focus-visible {
    outline: 3px solid var(--color-warning, #f59e0b);
    outline-offset: 3px;
  }

  .champ-hero__cta-arrow {
    font-size: 1.1rem;
    transition: transform 0.15s ease;
  }

  .champ-hero__cta:hover .champ-hero__cta-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 640px) {
    .champ-hero__bg-logo {
      width: 55%;
      opacity: var(--champ-logo-opacity-mobile);
    }
    .champ-hero__content {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .champ-hero__cta,
    .champ-hero__cta-arrow {
      transition: none;
    }
  }
</style>
