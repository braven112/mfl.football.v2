---
/**
 * ChampionCrownedHero — Celebratory hero displayed for 7 days after
 * the championship game. Shows the winning team icon, final score,
 * and a one-line quip. Gold accent treatment; special confetti
 * gradient when the logged-in user is the champion.
 */
import type { HeroState } from '../../types/hero-state';

export interface Props {
  championProps: NonNullable<HeroState['championProps']>;
  resolveLeaguePath: (path: string) => string;
  spriteUrl: string;
  userFranchiseId?: string;
}

const { championProps, resolveLeaguePath: r, spriteUrl, userFranchiseId } = Astro.props;
const {
  winnerFranchiseId, winnerName, winnerIcon, winnerColor,
  loserFranchiseId, loserName, winnerScore, loserScore,
} = championProps;

const isUserChampion = userFranchiseId === winnerFranchiseId;

const quips = [
  'The confetti has settled. A dynasty chapter has been written.',
  'When you win it all, the salary cap feels a little less painful.',
  'Championship rosters are built in the offseason. This one was no exception.',
  'Not luck. Not a fluke. Just better roster management.',
  'Every trade, every waiver claim, every draft pick — it all led here.',
];
const quip = quips[Math.floor(Math.random() * quips.length)];
---

<section
  class={`champion-hero${isUserChampion ? ' champion-hero--user-champ' : ''}`}
  aria-label="League Champion"
>
  <div class="champion-hero__badge-row">
    <span class="champion-hero__badge">Champion Crowned</span>
  </div>

  <div class="champion-hero__trophy-row">
    <img
      src={winnerIcon}
      alt={`${winnerName} team icon`}
      class="champion-hero__team-icon"
      width="64"
      height="64"
      loading="eager"
    />
    <svg class="champion-hero__trophy-icon" aria-hidden="true">
      <use href={`${spriteUrl}#icon-trophy`}></use>
    </svg>
  </div>

  <h2 class="champion-hero__title">{winnerName} Wins the Championship</h2>

  <p class="champion-hero__score">
    <span class="champion-hero__score-value">{winnerScore}</span>
    <span class="champion-hero__score-sep">&ndash;</span>
    <span class="champion-hero__score-value">{loserScore}</span>
    <span class="champion-hero__score-opponent">vs {loserName}</span>
  </p>

  <p class="champion-hero__quip">{quip}</p>

  {isUserChampion && (
    <p class="champion-hero__congrats">Congratulations, champ. You earned this one.</p>
  )}

  <a href={r('/theleague/playoffs')} class="champion-hero__cta">
    <svg class="champion-hero__cta-icon" aria-hidden="true">
      <use href={`${spriteUrl}#icon-trophy`}></use>
    </svg>
    Championship Recap
    <span class="champion-hero__cta-arrow" aria-hidden="true">&rarr;</span>
  </a>
</section>

<style>
  .champion-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem 2rem;
  }

  .champion-hero--user-champ {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-warning, #d97706) 6%, transparent) 0%,
      color-mix(in srgb, var(--color-warning, #d97706) 12%, transparent) 100%
    );
    border-radius: var(--radius-lg, 0.75rem);
    border: 1px solid color-mix(in srgb, var(--color-warning, #d97706) 25%, transparent);
  }

  .champion-hero__badge-row {
    display: flex;
    justify-content: center;
  }

  .champion-hero__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-warning, #d97706) 15%, var(--color-gray-100, #f3f4f6));
    color: var(--color-warning, #d97706);
  }

  .champion-hero__trophy-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .champion-hero__team-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .champion-hero__trophy-icon {
    width: 2rem;
    height: 2rem;
    fill: currentColor;
    color: var(--color-warning, #d97706);
  }

  .champion-hero__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-dark, #0f1e2e);
    line-height: 1.25;
    margin: 0;
  }

  .champion-hero__score {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-gray-600, #4b5563);
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .champion-hero__score-value {
    font-weight: 700;
    color: var(--color-gray-800, #1f2937);
  }

  .champion-hero__score-sep {
    color: var(--color-gray-400, #9ca3af);
  }

  .champion-hero__score-opponent {
    font-weight: 400;
    font-size: 1rem;
    color: var(--color-gray-500, #6b7280);
    margin-left: 0.25rem;
  }

  .champion-hero__quip {
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--color-gray-500, #6b7280);
    max-width: 48ch;
    line-height: 1.5;
    margin: 0;
  }

  .champion-hero__congrats {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-warning, #d97706);
    margin: 0;
  }

  .champion-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    background: var(--color-warning, #d97706);
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
  }

  .champion-hero__cta:hover {
    filter: brightness(0.92);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-warning, #d97706) 35%, transparent);
  }

  .champion-hero__cta:focus-visible {
    outline: 2px solid var(--color-warning, #d97706);
    outline-offset: 2px;
  }

  .champion-hero__cta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    fill: currentColor;
  }

  .champion-hero__cta-arrow {
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .champion-hero__cta:hover .champion-hero__cta-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 640px) {
    .champion-hero {
      padding: 1rem 0.75rem 1.5rem;
    }

    .champion-hero__team-icon {
      width: 48px;
      height: 48px;
    }

    .champion-hero__score {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .champion-hero__cta,
    .champion-hero__cta-arrow {
      transition: none;
    }
  }
</style>
