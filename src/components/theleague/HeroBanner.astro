---
/**
 * HeroBanner - Reusable promotional banner for the homepage.
 *
 * Displays a prominent, full-width card to highlight new features,
 * upcoming events, or other important announcements. The content is
 * driven by props — the intelligence for what to show lives in
 * hero-resolver.ts.
 *
 * Can be used standalone with custom props or driven by the resolver.
 */
export interface Props {
  title: string;
  summary: string;
  link?: string;
  linkLabel?: string;
  icon?: string;
  /** CSS value for the accent color (e.g., "var(--color-secondary)") */
  accentColor?: string;
  /** Visual variant: editorial (magazine-style, large title), feature, event, default */
  variant?: 'editorial' | 'feature' | 'event' | 'default';
  /** Event-only: formatted date or date range */
  dateDisplay?: string;
  /** Event-only: countdown or status text */
  statusText?: string;
  /** Event-only: whether the event is currently active */
  isActive?: boolean;
  /** Event-only: whether the event is urgent */
  isUrgent?: boolean;
  /** Event-only: whether the CTA link is external */
  isExternal?: boolean;
  /** Optional screenshot image filename relative to /assets/whats-new/ */
  image?: string;
  /** Alt text for the screenshot image */
  imageAlt?: string;
  /** Editorial-only: eyebrow badge label (e.g., "New Feature", "League Event") */
  kicker?: string;
  /** Editorial-only: date shown next to the eyebrow badge (e.g., "Mar 2, 2026") */
  kickerDate?: string;
  /** Editorial-only: "All news" text link URL (shown next to CTA button) */
  allNewsLink?: string;
  /** Editorial-only: label for the all-news link (default: "All releases") */
  allNewsLabel?: string;
}

const {
  title,
  summary,
  link,
  linkLabel = 'Check it out',
  icon,
  accentColor,
  variant = 'default',
  dateDisplay,
  statusText,
  isActive = false,
  isUrgent = false,
  isExternal = false,
  image,
  imageAlt,
  kicker,
  kickerDate,
  allNewsLink,
  allNewsLabel = 'All releases',
} = Astro.props;

import { spriteUrl } from '../../utils/sprite-url';
const iconId = icon ? `icon-${icon}` : null;
const MULTICOLOR_ICONS = ['nfl'];
const isMulticolor = icon ? MULTICOLOR_ICONS.includes(icon) : false;
const isEvent = variant === 'event';
const isEditorial = variant === 'editorial';
const imagePath = image ? `/assets/whats-new/${image}` : null;
---

{isEditorial ? (
  <section
    class={`hero-banner hero-banner--editorial${imagePath ? ' hero-banner--editorial-with-image' : ''}`}
    aria-label="Featured announcement"
  >
    <div class="hero-banner__content">
      <div class="hero-banner__editorial-body">
        {(kicker || kickerDate) && (
          <div class="hero-banner__eyebrow">
            {kicker && <span class="hero-banner__kicker">{kicker}</span>}
            {kicker && kickerDate && <span class="hero-banner__eyebrow-sep" aria-hidden="true">·</span>}
            {kickerDate && <span class="hero-banner__eyebrow-date">{kickerDate}</span>}
          </div>
        )}
        <h2 class="hero-banner__editorial-title">{title}</h2>
        <p class="hero-banner__editorial-summary">{summary}</p>
        {(link || allNewsLink) && (
          <div class="hero-banner__editorial-actions">
            {link && (
              <a
                href={link}
                class="hero-banner__cta"
                target={isExternal ? '_blank' : undefined}
                rel={isExternal ? 'noopener noreferrer' : undefined}
              >
                {linkLabel}
                <span class="hero-banner__cta-arrow" aria-hidden="true">{isExternal ? '\u2197' : '\u2192'}</span>
              </a>
            )}
            {allNewsLink && (
              <a href={allNewsLink} class="hero-banner__all-news">
                {allNewsLabel}
                <span aria-hidden="true"> &rarr;</span>
              </a>
            )}
          </div>
        )}
      </div>

      {imagePath && (
        <div class="hero-banner__editorial-image">
          <div class="browser-frame">
            <div class="browser-frame__bar">
              <span class="browser-frame__dot browser-frame__dot--red"></span>
              <span class="browser-frame__dot browser-frame__dot--yellow"></span>
              <span class="browser-frame__dot browser-frame__dot--green"></span>
              <span class="browser-frame__url">{link ? `theleague.us${link.replace('/theleague', '')}` : 'theleague.us'}</span>
            </div>
            <img
              src={imagePath}
              alt={imageAlt || title}
              class="hero-banner__image-img"
              loading="eager"
            />
          </div>
        </div>
      )}

    </div>
  </section>
) : (

<section
  class={`hero-banner hero-banner--${variant}${imagePath ? ' hero-banner--has-image' : ''}`}
  style={accentColor ? `--hero-accent: ${accentColor};` : undefined}
  aria-label="Featured announcement"
>
  <div class="hero-banner__content">
    {imagePath && (
      <div class="hero-banner__image">
        <div class="browser-frame">
          <div class="browser-frame__bar">
            <span class="browser-frame__dot browser-frame__dot--red"></span>
            <span class="browser-frame__dot browser-frame__dot--yellow"></span>
            <span class="browser-frame__dot browser-frame__dot--green"></span>
            <span class="browser-frame__url">{link ? `theleague.us${link.replace('/theleague', '')}` : 'theleague.us'}</span>
          </div>
          <img
            src={imagePath}
            alt={imageAlt || title}
            class="hero-banner__image-img"
            loading="eager"
          />
        </div>
      </div>
    )}
    {imagePath ? (
      <div class="hero-banner__body">
        <div class="hero-banner__text">
          {isEvent && (
            <span class={`hero-banner__badge${isActive ? ' hero-banner__badge--active' : ''}${isUrgent ? ' hero-banner__badge--urgent' : ''}`}>
              {isActive ? 'Happening Now' : isUrgent ? 'Coming Up' : 'League Event'}
            </span>
          )}
          <div class="hero-banner__header">
            {iconId && (
              <svg class={`hero-banner__icon${isMulticolor ? ' hero-banner__icon--multicolor' : ''}`} aria-hidden="true">
                <use href={`${spriteUrl}#${iconId}`}></use>
              </svg>
            )}
            <h2 class="hero-banner__title">{title}</h2>
          </div>
          {isEvent && dateDisplay && (
            <p class="hero-banner__date">{dateDisplay}</p>
          )}
          <p class="hero-banner__summary">{summary}</p>
          {isEvent && statusText && !isActive && (
            <p class={`hero-banner__countdown${isUrgent ? ' hero-banner__countdown--urgent' : ''}`}>{statusText}</p>
          )}
        </div>
        {link && (
          <div class="hero-banner__actions">
            <a
              href={link}
              class="hero-banner__cta"
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener noreferrer' : undefined}
            >
              {linkLabel}
              <span class="hero-banner__cta-arrow" aria-hidden="true">{isExternal ? '\u2197' : '\u2192'}</span>
            </a>
          </div>
        )}
      </div>
    ) : (
      <Fragment>
        <div class="hero-banner__text">
          {isEvent && (
            <span class={`hero-banner__badge${isActive ? ' hero-banner__badge--active' : ''}${isUrgent ? ' hero-banner__badge--urgent' : ''}`}>
              {isActive ? 'Happening Now' : isUrgent ? 'Coming Up' : 'League Event'}
            </span>
          )}
          <div class="hero-banner__header">
            {iconId && (
              <svg class={`hero-banner__icon${isMulticolor ? ' hero-banner__icon--multicolor' : ''}`} aria-hidden="true">
                <use href={`${spriteUrl}#${iconId}`}></use>
              </svg>
            )}
            <h2 class="hero-banner__title">{title}</h2>
          </div>
          {isEvent && dateDisplay && (
            <p class="hero-banner__date">{dateDisplay}</p>
          )}
          <p class="hero-banner__summary">{summary}</p>
          {isEvent && statusText && !isActive && (
            <p class={`hero-banner__countdown${isUrgent ? ' hero-banner__countdown--urgent' : ''}`}>{statusText}</p>
          )}
        </div>
        {link && (
          <div class="hero-banner__actions">
            <a
              href={link}
              class="hero-banner__cta"
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener noreferrer' : undefined}
            >
              {linkLabel}
              <span class="hero-banner__cta-arrow" aria-hidden="true">{isExternal ? '\u2197' : '\u2192'}</span>
            </a>
          </div>
        )}
      </Fragment>
    )}
  </div>
</section>

)}

<style>
  .hero-banner {
    --hero-accent: var(--color-primary, #1c497c);
    position: relative;
    background: var(--content-bg, #fff);
    border-radius: 0.75rem;
    box-shadow: var(--box-shadow-lg, 0 10px 15px -3px rgb(0 0 0 / 0.1));
    border-left: 5px solid var(--hero-accent);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .hero-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      transparent 0%,
      color-mix(in srgb, var(--hero-accent) 4%, transparent) 100%
    );
    pointer-events: none;
  }

  .hero-banner:hover {
    box-shadow: var(--box-shadow-hover, 0 4px 12px rgba(0, 0, 0, 0.08));
    transform: translateY(-1px);
  }

  .hero-banner__content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg, 1.5rem);
    padding: var(--spacing-lg, 1.5rem) var(--spacing-xl, 2rem);
  }

  .hero-banner__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm, 0.5rem);
    flex: 1;
    min-width: 0;
  }

  .hero-banner__header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm, 0.5rem);
  }

  .hero-banner__icon {
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
    fill: currentColor;
    color: var(--hero-accent);
  }

  .hero-banner__icon--multicolor {
    fill: none;
    color: unset;
  }

  .hero-banner__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--primary-link-default-text-color, #1c497c);
    margin: 0;
    line-height: 1.25;
  }

  .hero-banner__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    width: fit-content;
    color: var(--text-secondary-color, #64748b);
    background: var(--color-gray-100, #f3f4f6);
  }

  .hero-banner__badge--active {
    color: #fff;
    background: var(--color-success, #10b981);
  }

  .hero-banner__badge--urgent {
    color: #fff;
    background: var(--color-warning, #f59e0b);
  }

  .hero-banner__date {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary-color, #64748b);
    margin: 0;
  }

  .hero-banner__summary {
    font-size: var(--font-size-base, 1rem);
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    line-height: var(--line-height-base, 1.5);
    max-width: 60ch;
  }

  .hero-banner__countdown {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-info, #3b82f6);
    margin: 0;
  }

  .hero-banner__countdown--urgent {
    color: var(--color-warning, #f59e0b);
  }

  .hero-banner__actions {
    flex-shrink: 0;
  }

  .hero-banner__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--btn-primary-text, #fff);
    background: var(--hero-accent);
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }

  .hero-banner__cta:hover {
    filter: brightness(0.9);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--hero-accent) 35%, transparent);
    transform: translateY(-1px);
  }

  .hero-banner__cta:active {
    transform: translateY(0);
  }

  .hero-banner__cta-arrow {
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .hero-banner__cta:hover .hero-banner__cta-arrow {
    transform: translateX(2px);
  }

  /* ── Image support ── */
  .hero-banner--has-image {
    border-left: none;
  }

  .hero-banner--has-image::before {
    display: none;
  }

  .hero-banner--has-image .hero-banner__content {
    flex-direction: row-reverse;
    padding: 0;
    gap: 0;
  }

  .hero-banner__image {
    flex: 0 0 48%;
    max-width: 48%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-lg, 1.5rem);
    background: color-mix(in srgb, var(--hero-accent) 80%, var(--content-bg, #fff));
    overflow: hidden;
    box-sizing: border-box;
  }

  .hero-banner__image .browser-frame {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    background: #e5e7eb;
    transform: rotate(-1.5deg);
  }

  .hero-banner__image-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .hero-banner__body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--spacing-lg, 1.5rem) var(--spacing-xl, 2rem);
    gap: var(--spacing-md, 1rem);
  }

  .hero-banner__body .hero-banner__actions {
    padding: 0;
  }

  /* ── Browser frame (macOS-style chrome) ── */
  .browser-frame__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: #e5e7eb;
  }

  .browser-frame__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .browser-frame__dot--red { background: #ff5f57; }
  .browser-frame__dot--yellow { background: #ffbd2e; }
  .browser-frame__dot--green { background: #28c840; }

  .browser-frame__url {
    flex: 1;
    margin-left: 6px;
    background: #fff;
    border-radius: 3px;
    padding: 2px 8px;
    font-size: 10px;
    color: #6b7280;
    font-family: ui-monospace, monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Variant overrides ── */
  .hero-banner--feature {
    --hero-accent: var(--color-secondary, #2e8743);
  }

  .hero-banner--event {
    /* accent set via inline style from resolver */
  }

  .hero-banner--default {
    --hero-accent: var(--color-primary, #1c497c);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-banner--has-image .hero-banner__content {
      flex-direction: column;
    }

    .hero-banner__image {
      flex: none;
      max-width: 100%;
    }

    .hero-banner__body {
      padding: var(--spacing-md, 1rem) var(--spacing-lg, 1.5rem) var(--spacing-lg, 1.5rem);
    }
  }

  @media (max-width: 640px) {
    .hero-banner__content {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--spacing-md, 1rem) var(--spacing-lg, 1.5rem);
    }

    .hero-banner--has-image .hero-banner__content {
      padding: 0;
    }

    .hero-banner__title {
      font-size: var(--font-size-lg, 1.25rem);
    }

    .hero-banner__cta {
      width: auto;
    }
  }

  /* ════════════════════════════════════════════════════
     Editorial Variant — Magazine-style hero
     Text left, image right, large bold title, eyebrow
     ════════════════════════════════════════════════════ */

  .hero-banner--editorial {
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    border-left: none;
    overflow: visible;
  }

  .hero-banner--editorial::before {
    display: none;
  }

  .hero-banner--editorial:hover {
    transform: none;
    box-shadow: none;
  }

  .hero-banner--editorial .hero-banner__content {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2.5rem;
    padding: 0.5rem 0 1.5rem;
  }

  /* Text block — always on the left */
  .hero-banner__editorial-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Eyebrow: badge · date */
  .hero-banner__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-banner__kicker {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-600, #4b5563);
  }

  .hero-banner__eyebrow-sep {
    font-size: 0.875rem;
    color: var(--color-gray-400, #9ca3af);
  }

  .hero-banner__eyebrow-date {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-gray-500, #6b7280);
  }

  /* Large editorial title */
  .hero-banner__editorial-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-dark, #0f1e2e);
    line-height: 1.25;
    max-width: 24ch;
    margin: 0;
  }

  /* Summary paragraph */
  .hero-banner__editorial-summary {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-gray-600, #4b5563);
    max-width: 54ch;
    margin: 0;
  }

  /* CTA row: primary button + text link */
  .hero-banner__editorial-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .hero-banner__all-news {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    white-space: nowrap;
  }

  .hero-banner__all-news:hover {
    text-decoration: underline;
  }

  /* Image — on the right, browser-frame chrome */
  .hero-banner__editorial-image {
    flex: 0 0 46%;
    max-width: 46%;
  }

  .hero-banner__editorial-image .browser-frame {
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
    background: #e5e7eb;
    transform: rotate(-1deg);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-banner__editorial-image {
      flex: 0 0 42%;
      max-width: 42%;
    }
  }

  @media (max-width: 700px) {
    .hero-banner--editorial .hero-banner__content {
      flex-direction: column;
      gap: 1.5rem;
      padding-inline: var(--spacing-sm, 0.5rem);
    }

    .hero-banner__editorial-image {
      flex: none;
      max-width: 100%;
      width: 100%;
    }

    .hero-banner__editorial-title {
      font-size: 1.25rem;
    }
  }
</style>
