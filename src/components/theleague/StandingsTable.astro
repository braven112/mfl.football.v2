---
import type { TeamStanding } from '../../types/standings';
import PlayoffBadge from './PlayoffBadge.astro';
import { getConferenceLogo, getConferenceLogoDark, getConferenceName, type ConferenceId } from '../../utils/afl-conference';
import ThemeImage from '../ThemeImage.astro';
import { HISTORICAL_TEAM_BANNER_FALLBACK } from '../../utils/team-names';

export interface Props {
  teams: TeamStanding[];
  view: 'division' | 'league' | 'all_play';
  showDivisionHeader?: boolean;
  divisionName?: string;
  /** AFL only — when set, the division header shows its conference logo. */
  conferenceId?: ConferenceId;
  defendingChampion?: string;
  defendingChampionYear?: number;
  /** Square team-icon for the defending champion, shown on a white circle in the branded header. */
  defendingChampionLogo?: string;
  /** Compass-badge SVG path for the division. When set, the branded division header is rendered. */
  divisionBadge?: string;
  year?: number;
  preferredTeamId?: string;
  rosterBaseUrl?: string;
  franchiseBaseUrl?: string;
}

const { teams, view, showDivisionHeader = false, divisionName = '', conferenceId, defendingChampion = '', defendingChampionYear, defendingChampionLogo = '', divisionBadge = '', year = new Date().getFullYear(), preferredTeamId, rosterBaseUrl, franchiseBaseUrl } = Astro.props;

const conferenceLogo = conferenceId ? getConferenceLogo(conferenceId) : null;
const conferenceLogoDark = conferenceId ? getConferenceLogoDark(conferenceId) : null;
const conferenceName = conferenceId ? getConferenceName(conferenceId) : '';

// Branded compass-badge header — when present, the banner bleeds flush to the
// card edges (no container padding above or beside it).
const hasBrandedHeader = Boolean(showDivisionHeader && divisionName && divisionBadge);

function parseWLT(wlt: string | undefined) {
  if (!wlt) return { w: 0, l: 0, t: 0 };
  const parts = wlt.split('-').map(Number);
  return { w: parts[0] || 0, l: parts[1] || 0, t: parts[2] || 0 };
}

// Derive all_play_wlt from percentage when the record is missing
// NFL schedule: 16 weeks × 15 opponents = 240 games (2020 and earlier)
//               17 weeks × 15 opponents = 255 games (2021+)
// Returns null if percentage data is not available. A zero pct with no record
// means the feed predates all-play tracking (pre-2017) — deriving 0-240-0 from
// it would fabricate a season, so treat that as no data too.
function deriveAllPlayWLT(pct: string | undefined, seasonYear: number): { w: number; l: number; t: number } | null {
  if (!pct) return null; // No data available
  const TOTAL_GAMES = seasonYear >= 2021 ? 255 : 240;
  const percentage = parseFloat(pct);
  if (isNaN(percentage) || percentage <= 0) return null;
  const wins = Math.round(TOTAL_GAMES * percentage);
  const losses = TOTAL_GAMES - wins;
  return { w: wins, l: losses, t: 0 };
}

function safeParseFloat(value: string | undefined, decimals: number): string {
  if (!value) return (0).toFixed(decimals);
  return parseFloat(value).toFixed(decimals);
}

function safeParseInt(value: string | undefined): string {
  if (!value) return '0';
  return parseInt(value).toString();
}

function getPlayoffStatus(team: TeamStanding): 'division_winner' | 'wild_card' | null {
  if (team.seed && team.seed <= 4) return 'division_winner';
  if (team.seed && team.seed >= 5 && team.seed <= 7) return 'wild_card';
  return null;
}

function calculateGamesBack(team: TeamStanding, allTeamsInDivision: TeamStanding[]): number {
  if (allTeamsInDivision.length === 0) return 0;

  // Find the team with the best record
  const best = allTeamsInDivision.reduce((prev, current) => {
    const prevWins = parseInt(prev.divw);
    const currentWins = parseInt(current.divw);
    return currentWins > prevWins ? current : prev;
  });

  const bestWins = parseInt(best.divw);
  const bestLosses = parseInt(best.divl);
  const teamWins = parseInt(team.divw);
  const teamLosses = parseInt(team.divl);

  return ((bestWins - teamWins) + (teamLosses - bestLosses)) / 2;
}
---

<div class:list={['standings-container', { 'standings-container--branded': hasBrandedHeader }]}>
  {hasBrandedHeader && (
    <div class="stand-head">
      <span class="sh-badge">
        <img src={divisionBadge} alt={`${divisionName} division`} width="52" height="52" loading="lazy" decoding="async" />
      </span>
      <div class="sh-text">
        <h3 class:list={['sh-div', { 'sh-div--solo': !(defendingChampion && defendingChampionLogo) }]}>{divisionName}</h3>
        {defendingChampion && defendingChampionLogo && (
          <span class="sh-row">
            <span class="lbl">Defending Champion</span>
            <img class="sh-logo" src={defendingChampionLogo} alt={defendingChampion} title={defendingChampion} loading="lazy" decoding="async" />
          </span>
        )}
      </div>
    </div>
  )}

  {showDivisionHeader && divisionName && !divisionBadge && (
    <div class="division-header-section">
      <div class="division-header-row">
        {conferenceLogo && conferenceLogoDark && (
          <ThemeImage
            src={conferenceLogo}
            darkSrc={conferenceLogoDark}
            alt={`${conferenceName} logo`}
            class="division-conf-logo"
            loading="lazy"
            decoding="async"
          />
        )}
        <h3 class="division-header">{divisionName}</h3>
      </div>
      {defendingChampion && (
        <p class="champion-subtitle">{defendingChampionYear} Division Champions: <strong>{defendingChampion}</strong></p>
      )}
    </div>
  )}

  <div class="table-wrapper">
    <table class="standings-table">
      <thead>
        <tr>
          {view === 'league' && <th scope="col" class="col-seed">Seed</th>}
          {(view === 'division' || view === 'all_play') && <th scope="col" class="col-badge">Seed</th>}
          <th scope="col" class="col-team">Team</th>
          {view === 'division' && <th scope="col" class="col-overall-record">Overall</th>}
          {view === 'division' && <th scope="col" class="col-overall-pct">PCT</th>}
          {view === 'division' && <th scope="col" class="col-gb">GB</th>}
          {view === 'division' && <th scope="col" class="col-streak">Strk</th>}
          {view === 'division' && <th scope="col" class="col-div-record">Div</th>}
          {view === 'division' && <th scope="col" class="col-pf">PF</th>}
          {view === 'division' && <th scope="col" class="col-pa">PA</th>}
          {view !== 'division' && <th scope="col" class="col-record">Record</th>}
          {view !== 'division' && <th scope="col" class="col-pct">PCT</th>}
          {view !== 'division' && <th scope="col" class="col-pf">PF</th>}
          {view !== 'division' && <th scope="col" class="col-pa">PA</th>}
          {view !== 'division' && <th scope="col" class="col-pwr">PWR</th>}
          {view !== 'division' && <th scope="col" class="col-vp">VP</th>}
        </tr>
      </thead>
      <tbody>
        {teams.map((team, index) => {
          // For all_play view, derive record from percentage if not available
          const record = view === 'all_play'
            ? (team.all_play_wlt
              ? parseWLT(team.all_play_wlt)
              : deriveAllPlayWLT(team.all_play_pct, year))
            : parseWLT(team.divwlt);

          const pct = view === 'all_play'
            ? team.all_play_pct
            : team.divpct;

          const overallRecord = parseWLT(team.h2hwlt);
          const divRecord = parseWLT(team.divwlt);
          const playoffStatus = getPlayoffStatus(team);
          const gamesBack = view === 'division' ? calculateGamesBack(team, teams) : 0;

          const isPreferredTeam = preferredTeamId && team.id === preferredTeamId;

          // Historical eras with no surviving banner art resolve to the shared
          // placeholder — show the team name text instead of a generic image.
          const hasBannerImage = Boolean(team.teamBanner) && team.teamBanner !== HISTORICAL_TEAM_BANNER_FALLBACK;

          const bannerHref = franchiseBaseUrl
            ? `${franchiseBaseUrl}/${team.id}`
            : rosterBaseUrl
              ? `${rosterBaseUrl}?franchise=${team.id}`
              : null;
          const bannerLabel = franchiseBaseUrl
            ? `View ${team.teamName} franchise page`
            : `View ${team.teamName} roster`;

          return (
            <tr
              class={`row-${index % 2 === 0 ? 'even' : 'odd'}${isPreferredTeam ? ' preferred-team' : ''}`}
              data-preferred={isPreferredTeam ? 'true' : undefined}
              data-team-id={team.id}
            >
              {view === 'league' && (
                <td class="col-seed">
                  <span class="seed-badge">#{team.seed}</span>
                </td>
              )}
              {(view === 'division' || view === 'all_play') && (
                <td class="col-badge">
                  <PlayoffBadge status={playoffStatus} seed={team.seed} />
                </td>
              )}
              <td class="col-team">
                <div class="team-info">
                  {hasBannerImage && (
                    bannerHref ? (
                      <a
                        href={bannerHref}
                        class="team-banner-link"
                        aria-label={bannerLabel}
                      >
                        <img
                          src={team.teamBanner}
                          alt={team.teamName}
                          class="team-banner"
                          title={team.teamName}
                        />
                      </a>
                    ) : (
                      <img
                        src={team.teamBanner}
                        alt={team.teamName}
                        class="team-banner"
                        title={team.teamName}
                      />
                    )
                  )}
                  <span class={hasBannerImage ? 'team-name' : 'team-name team-name--fallback'}>{team.teamName}</span>
                </div>
              </td>
              {view === 'division' && (
                <>
                  <td class="col-overall-record">
                    {overallRecord.w}-{overallRecord.l}-{overallRecord.t}
                  </td>
                  <td class="col-overall-pct">
                    {safeParseFloat(team.h2hpct, 3)}
                  </td>
                  <td class="col-gb">
                    {gamesBack === 0 ? '—' : gamesBack.toFixed(1)}
                  </td>
                  <td class="col-streak">
                    {team.strk}
                  </td>
                  <td class="col-div-record">
                    {divRecord.w}-{divRecord.l}-{divRecord.t}
                  </td>
                  <td class="col-pf">
                    {safeParseFloat(team.pf, 1)}
                  </td>
                  <td class="col-pa">
                    {safeParseFloat(team.pa, 1)}
                  </td>
                </>
              )}
              {view !== 'division' && (
                <>
                  <td class="col-record">
                    {record ? `${record.w}-${record.l}-${record.t}` : 'N/A'}
                  </td>
                  <td class="col-pct">
                    {safeParseFloat(pct, 3)}
                  </td>
                  <td class="col-pf">
                    {safeParseFloat(team.pf, 1)}
                  </td>
                  <td class="col-pa">
                    {safeParseFloat(team.pa, 1)}
                  </td>
                  <td class="col-pwr">
                    {safeParseFloat(team.pwr, 1)}
                  </td>
                  <td class="col-vp">
                    {safeParseInt(team.vp)}
                  </td>
                </>
              )}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>

<style>
  .standings-container {
    margin-bottom: 2rem;
    background: var(--card-bg, #fff);
    border-radius: 8px;
    box-shadow: var(--shadow-card);
    padding-block: var(--padding-md);
    overflow-x: auto;
  }

  /* Dark mode: raised-card treatment — 1px border ring via box-shadow (no
     layout shift, light stays borderless) layered under the strong dark
     shadow, per the PlayerDetailsModal recipe. */
  :global(html.dark) .standings-container {
    box-shadow:
      0 0 0 1px var(--content-border, #555555),
      var(--shadow-lg);
  }

  /* ===== Branded division header (compass badge + defending champion) ===== */
  /* The banner bleeds flush to the card edges: the container drops its top
     padding and the banner's top corners inherit the card radius. */
  .standings-container--branded {
    padding-top: 0;
  }

  .stand-head {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--color-primary, #1c497c) 0%, #13365d 100%);
    border-radius: 8px 8px 0 0;
    padding: 22px 26px;
  }

  /* Dark mode: accent bleeds from the upper-left and fades into the card
     surface (calendar-card style) instead of a full-bleed blue banner. */
  :global(html.dark) .stand-head {
    background: linear-gradient(115deg,
      rgba(59, 130, 246, 0.55) 0%,
      rgba(59, 130, 246, 0.18) 34%,
      var(--card-surface, #262626) 72%);
  }

  .stand-head .sh-badge {
    flex-shrink: 0;
    filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.3));
    display: flex;
  }

  .stand-head .sh-badge img {
    display: block;
    width: 52px;
    height: 52px;
  }

  .stand-head .sh-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .stand-head .sh-div {
    font-family: var(--font-display, 'UFC Sans Condensed', 'Arial Narrow', sans-serif);
    font-weight: 700;
    font-size: 26px;
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: #fff;
    white-space: nowrap;
    margin: 0 0 -36px;
  }

  /* No defending champion (e.g. the earliest season) — don't pull the name
     down into an empty row. */
  .stand-head .sh-div--solo {
    margin: 0;
  }

  .stand-head .sh-row {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    margin-top: 6px;
  }

  .stand-head .sh-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    border-radius: 50%;
    background: #fff;
    padding: 4px;
    flex-shrink: 0;
    margin-bottom: -6px;
  }

  .stand-head .lbl {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.62);
    white-space: nowrap;
  }
  /* ===================================================================== */

  .division-header-section {
    margin-bottom: 1.5rem;
    padding-inline: 1.5rem;
  }

  .division-header-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  :global(.division-conf-logo) {
    height: 1.75rem;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  .division-header {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0rem;
    color: var(--page-text, #1a1a1a);
    padding: 0;
  }

  .champion-subtitle {
    font-size: 0.95rem;
    color: var(--color-secondary, #2e8743);
    font-weight: 500;
    margin: 0;
    margin-top: 0.25rem;
  }

  .table-wrapper {
    overflow-x: auto;
  }

  .standings-table {
    width: 100%;
    border-collapse: collapse;
    background-color: var(--table-row-bg-alt, #f5f5f5);
    color: var(--page-text, #1a1a1a);
  }

  thead {
    background-color: var(--table-header-bg, #fff);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  th {
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--table-header-text, #94a3b8);
    border-bottom: 2px solid var(--table-border, #d0d0d0);
  }

  td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--table-border, #e0e0e0);
    font-size: var(--table-cell-font-size, .75rem);
    color: var(--page-text, #1a1a1a);
  }

  tbody tr {
    background-color: var(--table-row-bg, #fff);
    transition: background-color 0.2s ease;
  }

  tbody tr:hover {
    background-color: var(--table-row-bg-hover, #f9f9f9);
  }

  tbody tr.row-odd {
    background-color: var(--table-row-bg-alt, #f5f5f5);
  }

  tbody tr.row-odd:hover {
    background-color: var(--table-row-bg-hover, #efefef);
  }

  /* Column Widths */
  .col-seed {
    width: 70px;
    text-align: center;
    font-weight: 600;
  }

  .col-badge {
    width: 100px;
    text-align: center;
    padding: 0.75rem 0.5rem;
  }

  .col-team {
    width: auto;
    min-width: 200px;
  }

  .col-record {
    width: 100px;
    text-align: center;
    white-space: nowrap;
  }

  .col-pct {
    width: 90px;
    text-align: center;
  }

  .col-pf,
  .col-pa {
    width: 100px;
    text-align: center;
  }

  .col-pwr,
  .col-vp {
    width: 90px;
    text-align: center;
  }

  .col-overall-record {
    width: 110px;
    text-align: center;
    white-space: nowrap;
  }

  .col-overall-pct {
    width: 90px;
    text-align: center;
  }

  .col-div-record {
    width: 110px;
    text-align: center;
    white-space: nowrap;
  }

  .col-div-pct {
    width: 90px;
    text-align: center;
  }

  .col-allplay {
    width: 110px;
    text-align: center;
    white-space: nowrap;
  }

  .col-ap-record {
    width: 110px;
    text-align: center;
  }

  .col-h2h {
    width: 90px;
    text-align: center;
  }

  .col-gb {
    width: 80px;
    text-align: center;
  }

  .col-streak {
    width: 100px;
    text-align: center;
  }

  /* Team Info */
  .team-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .team-banner {
    width: 100%;
    max-width: 400px;
    height: auto;
    object-fit: contain;
  }

  .team-banner-link {
    display: inline-block;
    line-height: 0;
    border-radius: 4px;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .team-banner-link:hover,
  .team-banner-link:focus-visible {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .team-banner-link:focus-visible {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 2px;
  }

  .team-name {
    display: none;
  }

  .team-name--fallback {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .seed-badge {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--page-text, #1a1a1a);
    background-color: var(--content-bg-muted, #e8e8e8);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
  }

  /* Preferred team highlighting */
  tr.preferred-team {
    background-color: color-mix(in srgb, var(--color-secondary, #2e743d) 12%, var(--table-row-bg, #fff)) !important;
    border-left: 3px solid var(--color-secondary, #2e743d);
    font-weight: 600;
  }

  tr.preferred-team:hover {
    background-color: color-mix(in srgb, var(--color-secondary, #2e743d) 22%, var(--table-row-bg, #fff)) !important;
  }

  tr.preferred-team .team-name {
    color: var(--color-secondary, #2e743d);
  }

  /* Responsive */
  @media (max-width: 767px) {
    .col-team {
      min-width: 100px;
    }

    .col-pwr,
    .col-vp,
    .col-pct,
    .col-h2h,
    .col-gb,
    .col-streak {
      font-size: 0.8rem;
      padding: 0.5rem;
    }

    th {
      font-size: 0.75rem;
      padding: 0.5rem;
    }

    .team-banner {
      max-width: 100px;
    }

    .team-name {
      font-size: 0.9rem;
    }
  }
</style>
