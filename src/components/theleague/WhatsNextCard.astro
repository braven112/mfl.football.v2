---
/**
 * WhatsNextCard - Individual event card for the "What's Next" timeline.
 * Shows event name, date, description, countdown, and relevant links.
 */
import type { ResolvedLeagueEvent } from '../../types/league-events';
import { formatEventDate, formatEventDateRange, getStatusText } from '../../utils/event-date-formatter';
import { spriteUrl } from '../../utils/sprite-url';

export interface Props {
  event: ResolvedLeagueEvent | null;
  position: 'current' | 'next' | 'upcoming';
}

const { event, position } = Astro.props;

if (!event) return;

const positionLabels = {
  current: event.isActive ? 'Happening Now' : 'Most Recent',
  next: 'Up Next',
  upcoming: 'Coming Soon',
};

const statusText = getStatusText(event.isActive, event.isPast, event.daysUntilStart);
const dateDisplay = event.definition.endDate
  ? formatEventDateRange(event.startDate, event.endDate)
  : formatEventDate(event.startDate);

const links = event.isPast ? event.resultLinks : event.actionLinks;
const iconId = event.definition.icon ? `icon-${event.definition.icon}` : null;
const category = event.definition.category;
const MULTICOLOR_ICONS = ['nfl'];
const isMulticolor = event.definition.icon ? MULTICOLOR_ICONS.includes(event.definition.icon) : false;

const cardClasses = [
  'whats-next-card',
  `whats-next-card--${position}`,
  `whats-next-card--${category}`,
  event.isActive && 'whats-next-card--active',
  event.isPast && 'whats-next-card--past',
  event.isUrgent && 'whats-next-card--urgent',
].filter(Boolean).join(' ');
---

<article class={cardClasses}>
  <span class="whats-next-card__badge">{positionLabels[position]}</span>
  <div class="whats-next-card__header">
    {iconId && (
      <svg class={`whats-next-card__icon${isMulticolor ? ' whats-next-card__icon--multicolor' : ''}`} aria-hidden="true">
        <use href={`${spriteUrl}#${iconId}`}></use>
      </svg>
    )}
    <h3 class="whats-next-card__title">{event.definition.name}</h3>
  </div>
  <p class="whats-next-card__date">{dateDisplay}</p>
  <p class="whats-next-card__description">{event.definition.description}</p>
  {!event.isPast && !event.isActive && (
    <p class="whats-next-card__countdown">{statusText}</p>
  )}
  {links.length > 0 && (
    <div class="whats-next-card__links">
      {links.map((link) => (
        <a
          href={link.url}
          class="whats-next-card__link"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          {link.label}
          {link.external && <span class="whats-next-card__external-icon" aria-hidden="true">&nearr;</span>}
        </a>
      ))}
    </div>
  )}
</article>

<style>
  /* ── Category color tokens ── */
  :root {
    --cat-preseason: #60a5fa;
    --cat-free-agency: #2e8743;
    --cat-draft: #7c3aed;
    --cat-regular-season: #1c497c;
  }

  .whats-next-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--content-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-md);
    border-left: 4px solid var(--card-category-color, var(--cat-preseason));
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    position: relative;
  }

  .whats-next-card:hover {
    box-shadow: var(--box-shadow-hover, 0 4px 12px rgba(0, 0, 0, 0.08));
    transform: translateY(-2px);
  }

  /* ── Category variants (border-left + icon color) ── */
  .whats-next-card--preseason { --card-category-color: var(--cat-preseason); }
  .whats-next-card--free-agency { --card-category-color: var(--cat-free-agency); }
  .whats-next-card--draft { --card-category-color: var(--cat-draft); }
  .whats-next-card--regular-season { --card-category-color: var(--cat-regular-season); }

  /* Position variants (opacity only for upcoming) */
  .whats-next-card--upcoming {
    opacity: 0.85;
  }

  /* ── State modifiers (affect badge, not border) ── */
  .whats-next-card--past {
    opacity: 0.7;
    border-left-color: var(--color-gray-300, #d1d5db);
  }

  /* Badge */
  .whats-next-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    width: fit-content;
    color: var(--text-secondary-color, #64748b);
    background: var(--color-gray-100, #f3f4f6);
  }

  .whats-next-card--active .whats-next-card__badge {
    color: #fff;
    background: var(--color-success, #10b981);
  }

  .whats-next-card--urgent .whats-next-card__badge {
    color: #fff;
    background: var(--color-warning, #f59e0b);
  }

  /* Header (icon + title) */
  .whats-next-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Icon (category colored, gray when past) */
  .whats-next-card__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    fill: currentColor;
    color: var(--card-category-color);
  }

  .whats-next-card__icon--multicolor {
    fill: none;
    color: unset;
  }

  .whats-next-card--past .whats-next-card__icon {
    color: var(--color-gray-400, #9ca3af);
  }

  /* Title */
  .whats-next-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0;
    color: var(--primary-link-default-text-color, #1c497c);
    line-height: 1.3;
  }

  /* Date */
  .whats-next-card__date {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary-color, #64748b);
    margin: 0;
  }

  /* Description */
  .whats-next-card__description {
    font-size: 0.875rem;
    color: var(--muted-text-color, #6b7280);
    margin: 0;
    line-height: 1.5;
  }

  /* Countdown */
  .whats-next-card__countdown {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-info, #3b82f6);
    margin: 0;
  }

  .whats-next-card--urgent .whats-next-card__countdown {
    color: var(--color-warning, #f59e0b);
  }

  /* Links */
  .whats-next-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .whats-next-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary, #1c497c);
    text-decoration: none;
    padding: 0.25rem 0.65rem;
    border-radius: 0.375rem;
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--color-gray-200, #e5e7eb);
    transition: all 0.15s ease;
  }

  .whats-next-card__link:hover {
    background: var(--color-primary, #1c497c);
    color: #fff;
    border-color: var(--color-primary, #1c497c);
  }

  .whats-next-card__external-icon {
    font-size: 0.7rem;
  }

  @media (max-width: 767px) {
    .whats-next-card {
      padding: 1rem;
    }

    .whats-next-card__title {
      font-size: 1rem;
    }
  }
</style>
