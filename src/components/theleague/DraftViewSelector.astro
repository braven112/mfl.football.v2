---
import { spriteUrl } from '../../utils/sprite-url';

export interface Props {
  activeView: 'projected' | 'final' | 'history';
}

const { activeView } = Astro.props;

const VIEWS = [
  { key: 'final', label: 'Final', icon: 'icon-podium-persona', aria: 'Final Draft Order' },
  { key: 'projected', label: 'Base', icon: 'icon-podium-empty', aria: 'Projected Draft Order' },
  { key: 'history', label: 'History', icon: 'icon-history', aria: 'Draft History' },
] as const;

// Build each tab's href from the current URL so other params (e.g. ?year=)
// are preserved. Real <a> links work without JS and survive view transitions,
// unlike the previous button + click-handler approach (the handler never bound
// under the ClientRouter, leaving the tabs dead).
function viewHref(view: string): string {
  const url = new URL(Astro.url.href);
  url.searchParams.set('view', view);
  return url.pathname + url.search + url.hash;
}
---

<div class="view-selector">
  {VIEWS.map((v) => (
    <a
      href={viewHref(v.key)}
      class={`view-tab ${activeView === v.key ? 'active' : ''}`}
      data-active={activeView === v.key ? 'true' : 'false'}
      aria-label={v.aria}
      aria-current={activeView === v.key ? 'page' : undefined}
      title={v.label}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="view-tab__icon">
        <use href={`${spriteUrl}#${v.icon}`}></use>
      </svg>
      <span class="view-tab__label">{v.label}</span>
    </a>
  ))}
</div>

<style>
  .view-selector {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .view-tab {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    border: 2px solid transparent;
    border-radius: 0.5rem;
    background: var(--color-gray-50, #f8fafc);
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    min-width: 69px;
    text-decoration: none;
    color: inherit;
  }
  @media (min-width: 640px) {
    .view-tab {
      padding: 0.75rem;
    }
  }

  .view-tab:hover {
    background: var(--color-gray-100, #e2e8f0);
    border-color: var(--color-gray-200, #cbd5e1);
  }

  .view-tab:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }

  .view-tab[data-active="true"] {
    background: var(--color-info-light, #dbeafe);
    border-color: var(--color-primary, #1c497c);
  }

  .view-tab__icon {
    max-width: var(--icon-btn-default-size, 30px);
    max-height: var(--icon-btn-default-size, 30px);
    width: 100%;
    height: 100%;
    fill: var(--icon-btn-default-text-color);
    color: var(--icon-btn-default-text-color);
  }

  .view-tab[data-active="true"] .view-tab__icon {
    fill: var(--icon-btn-default-focus-color);
    color: var(--icon-btn-default-focus-color);
  }

  .view-tab__label {
    position: absolute;
    bottom: -1.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .view-tab:hover .view-tab__label,
  .view-tab:focus .view-tab__label {
    opacity: 1;
  }

  .view-tab[data-active="true"] .view-tab__label {
    color: var(--color-primary, #1c497c);
  }

  @media (max-width: 640px) {

    .view-tab__label {
      position: static;
      transform: none;
      opacity: 1;
      font-size: 0.7rem;
      margin-top: 0.25rem;
    }
  }
</style>
