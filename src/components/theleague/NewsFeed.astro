---
/**
 * NewsFeed - Sidebar component with trending NFL players and latest news.
 *
 * Section 1: Sleeper Trending Players (client-side fetch with localStorage cache)
 * Section 2: Latest News (placeholder articles for phase 1)
 */

const placeholderArticles = [
  {
    headline: '2026 NFL Free Agency: Live Updates',
    date: 'Mar 12, 2026',
    description: 'Latest signings, trades, cuts and contract restructures as free agency unfolds.',
    url: 'https://www.espn.com/nfl/story/_/id/47899175/2026-nfl-free-agency-tracker-live-updates-signings-trades-cuts-contracts-rumors',
  },
  {
    headline: 'NFL Free Agency: Team-by-Team Tracker',
    date: 'Mar 10, 2026',
    description: 'Every team\'s offseason moves, signings, and trades in one place.',
    url: 'https://www.espn.com/nfl/story/_/id/48054795/indianapolis-colts-2026-free-agency-tracker-offseason-moves-signings-trades',
  },
  {
    headline: 'NFL News & Scores',
    date: 'Mar 8, 2026',
    description: 'Headlines, scores, and analysis from around the league.',
    url: 'https://www.espn.com/nfl/',
  },
];
---

<aside class="news-feed" aria-label="News and trending players">
  <div class="news-feed__section">
    <h3 class="news-feed__heading">
      <svg class="news-feed__heading-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/>
      </svg>
      Trending Players
    </h3>
    <div id="trending-players" class="news-feed__trending">
      <div class="news-feed__skeleton">
        <div class="news-feed__skeleton-bar"></div>
        <div class="news-feed__skeleton-bar"></div>
        <div class="news-feed__skeleton-bar"></div>
        <div class="news-feed__skeleton-bar"></div>
      </div>
    </div>
  </div>

  <div class="news-feed__section">
    <h3 class="news-feed__heading">
      <svg class="news-feed__heading-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v4H5V6zm6 6H5v2h6v-2z" clip-rule="evenodd"/>
        <path d="M15 7h1a2 2 0 012 2v5.5a1.5 1.5 0 01-3 0V7z"/>
      </svg>
      Latest News
    </h3>
    <div class="news-feed__articles">
      {placeholderArticles.map((article) => (
        <a href={article.url} class="news-feed__article" target="_blank" rel="noopener noreferrer">
          <span class="news-feed__article-date">{article.date}</span>
          <span class="news-feed__article-headline">{article.headline}</span>
          <span class="news-feed__article-desc">{article.description}</span>
        </a>
      ))}
    </div>
  </div>
</aside>

<script>
  const TRENDING_API = 'https://api.sleeper.app/v1/players/nfl/trending/add?lookback_hours=24&limit=10';
  const PLAYERS_API = 'https://api.sleeper.app/v1/players/nfl';
  const CACHE_KEY = 'sleeper_players_nfl';
  const CACHE_TS_KEY = 'sleeper_players_nfl_ts';
  const CACHE_TTL_MS = 24 * 60 * 60 * 1000; // 24 hours
  const FETCH_TIMEOUT_MS = 8000; // 8s timeout for the large players fetch

  interface SleeperPlayer {
    player_id: string;
    full_name?: string;
    first_name?: string;
    last_name?: string;
    position?: string;
    team?: string;
  }

  interface TrendingEntry {
    player_id: string;
    count: number;
  }

  type PlayersMap = Record<string, SleeperPlayer>;

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function fetchWithTimeout(url: string, timeoutMs: number): Promise<Response> {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), timeoutMs);
    return fetch(url, { signal: controller.signal }).finally(() => clearTimeout(timer));
  }

  function getCachedPlayers(): PlayersMap | null {
    try {
      const ts = localStorage.getItem(CACHE_TS_KEY);
      if (!ts) return null;
      const age = Date.now() - parseInt(ts, 10);
      if (age > CACHE_TTL_MS) return null;
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      return JSON.parse(raw) as PlayersMap;
    } catch {
      return null;
    }
  }

  async function fetchAndCachePlayers(): Promise<PlayersMap> {
    const resp = await fetchWithTimeout(PLAYERS_API, FETCH_TIMEOUT_MS);
    if (!resp.ok) throw new Error(`Players API returned ${resp.status}`);
    const data: PlayersMap = await resp.json();
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify(data));
      localStorage.setItem(CACHE_TS_KEY, String(Date.now()));
    } catch {
      // localStorage may be full; silently continue
    }
    return data;
  }

  function renderTrendingList(trending: TrendingEntry[], players: PlayersMap | null): string {
    if (!trending.length) {
      return '<p class="news-feed__empty">No trending players right now.</p>';
    }

    const items = trending.map((entry, i) => {
      const p = players?.[entry.player_id];
      const rawName = p?.full_name
        || (p ? `${p.first_name || ''} ${p.last_name || ''}`.trim() : '')
        || `Player ${entry.player_id}`;
      const name = esc(rawName);
      const position = esc(p?.position || '—');
      const team = esc(p?.team || 'FA');
      const rank = i + 1;

      return `
        <li class="news-feed__player" data-player-id="${esc(entry.player_id)}">
          <span class="news-feed__player-rank">${rank}</span>
          <div class="news-feed__player-info">
            <span class="news-feed__player-name">${name}</span>
            <span class="news-feed__player-meta">${position} · ${team}</span>
          </div>
          <span class="news-feed__player-count" title="Adds in last 24h">+${entry.count.toLocaleString()}</span>
        </li>`;
    }).join('');

    return `<ol class="news-feed__player-list">${items}</ol>`;
  }

  function updatePlayerNames(container: HTMLElement, players: PlayersMap) {
    container.querySelectorAll('[data-player-id]').forEach(li => {
      const id = li.getAttribute('data-player-id') || '';
      const p = players[id];
      if (!p) return;
      const nameEl = li.querySelector('.news-feed__player-name');
      const metaEl = li.querySelector('.news-feed__player-meta');
      if (nameEl) nameEl.textContent = p.full_name || `${p.first_name || ''} ${p.last_name || ''}`.trim();
      if (metaEl) metaEl.textContent = `${p.position || '—'} · ${p.team || 'FA'}`;
    });
  }

  async function init() {
    const container = document.getElementById('trending-players');
    if (!container) return;

    try {
      // Step 1: Fetch trending data (small payload, fast)
      const trendingResp = await fetchWithTimeout(TRENDING_API, 5000);
      if (!trendingResp.ok) throw new Error(`Trending API returned ${trendingResp.status}`);
      const trending: TrendingEntry[] = await trendingResp.json();

      // Step 2: Try cached players first for instant render
      const cached = getCachedPlayers();
      container.innerHTML = renderTrendingList(trending, cached);

      // Step 3: If no cache, fetch player names in background and update in-place
      if (!cached) {
        fetchAndCachePlayers()
          .then(players => updatePlayerNames(container, players))
          .catch(err => console.warn('NewsFeed: player names unavailable', err));
      }
    } catch (err) {
      console.error('NewsFeed: failed to load trending players', err);
      container.innerHTML = '<p class="news-feed__empty">Unable to load trending data.</p>';
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .news-feed {
    position: sticky;
    top: 1rem;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md, 1rem);
  }

  .news-feed__section {
    background: var(--content-bg, #fff);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-card);
    padding: var(--spacing-md, 1rem);
    overflow: hidden;
  }

  .news-feed__heading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-primary, #1c497c);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.75rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-gray-100, #f3f4f6);
  }

  .news-feed__heading-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-primary, #1c497c);
  }

  /* ── Trending Players ── */

  .news-feed__trending {
    max-height: 420px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-gray-300, #d1d5db) transparent;
  }

  .news-feed__trending::-webkit-scrollbar {
    width: 5px;
  }

  .news-feed__trending::-webkit-scrollbar-track {
    background: transparent;
  }

  .news-feed__trending::-webkit-scrollbar-thumb {
    background: var(--color-gray-300, #d1d5db);
    border-radius: var(--radius-full, 9999px);
  }

  /* Skeleton loading animation */
  .news-feed__skeleton {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .news-feed__skeleton-bar {
    height: 2.5rem;
    background: linear-gradient(
      90deg,
      var(--color-gray-100, #f3f4f6) 25%,
      var(--color-gray-50, #f9fafb) 50%,
      var(--color-gray-100, #f3f4f6) 75%
    );
    background-size: 200% 100%;
    border-radius: var(--radius-sm, 0.25rem);
    animation: news-feed-shimmer 1.5s ease-in-out infinite;
  }

  @keyframes news-feed-shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Dynamically rendered player list - use :global() for client-side HTML */
  :global(.news-feed__player-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.news-feed__player) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.35rem;
    border-bottom: 1px solid var(--color-gray-100, #f3f4f6);
    transition: background-color var(--transition-fast, 150ms ease);
  }

  :global(.news-feed__player:last-child) {
    border-bottom: none;
  }

  :global(.news-feed__player:hover) {
    background: var(--color-gray-50, #f9fafb);
  }

  :global(.news-feed__player-rank) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold, 700);
    color: var(--color-white, #fff);
    background: var(--color-primary, #1c497c);
    border-radius: var(--radius-full, 9999px);
    flex-shrink: 0;
  }

  :global(.news-feed__player-info) {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  :global(.news-feed__player-name) {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-gray-800, #1f2937);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.news-feed__player-meta) {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-gray-500, #6b7280);
  }

  :global(.news-feed__player-count) {
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-success, #10b981);
    white-space: nowrap;
    flex-shrink: 0;
  }

  :global(.news-feed__empty) {
    font-size: var(--font-size-sm, 0.875rem);
    color: var(--color-gray-500, #6b7280);
    text-align: center;
    padding: 1rem 0;
    margin: 0;
  }

  /* ── Latest News Articles ── */

  .news-feed__articles {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .news-feed__article {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.6rem 0.35rem;
    border-bottom: 1px solid var(--color-gray-100, #f3f4f6);
    text-decoration: none;
    transition: background-color var(--transition-fast, 150ms ease);
    border-radius: var(--radius-sm, 0.25rem);
  }

  .news-feed__article:last-child {
    border-bottom: none;
  }

  .news-feed__article:hover {
    background: var(--color-gray-50, #f9fafb);
  }

  .news-feed__article-date {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-gray-400, #9ca3af);
    font-weight: var(--font-weight-medium, 500);
  }

  .news-feed__article-headline {
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-gray-800, #1f2937);
    line-height: var(--line-height-tight, 1.25);
  }

  .news-feed__article:hover .news-feed__article-headline {
    color: var(--color-primary, #1c497c);
  }

  .news-feed__article-desc {
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--color-gray-500, #6b7280);
    line-height: var(--line-height-base, 1.5);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ── */

  @media (max-width: 1023px) {
    .news-feed {
      position: static;
    }
  }

  @media (max-width: 767px) {
    .news-feed__section {
      padding: 0.75rem;
    }

    .news-feed__trending {
      max-height: 300px;
    }
  }
</style>
