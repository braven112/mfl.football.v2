---
/**
 * AuctionStrip - Compact auction navigation bar for mid/late auction season.
 *
 * Displays after the 30-day full AuctionHero window ends, persisting until
 * the 3rd Sunday of August (FA close). Sits above the normal hero banner
 * with 5 key auction links in a single horizontal row.
 */
export interface Props {
  /** League year for constructing MFL external URLs */
  leagueYear: number;
  /** MFL host for external links */
  mflHost?: string;
  /** MFL league ID */
  leagueId?: string;
  /** Path resolver function from layout */
  resolveLeaguePath: (path: string) => string;
  /** Cache-busted sprite URL */
  spriteUrl: string;
  /** Messaging variant — 'auction-udfa' adds undrafted rookie callout */
  variant?: 'auction' | 'auction-udfa';
}

const {
  leagueYear,
  mflHost = 'www49.myfantasyleague.com',
  leagueId = '13522',
  resolveLeaguePath: r,
  spriteUrl,
  variant = 'auction',
} = Astro.props;

const showUdfaNote = variant === 'auction-udfa';

const mflBase = `https://${mflHost}/${leagueYear}/options?L=${leagueId}`;

interface StripLink {
  label: string;
  href: string;
  icon: string;
  external: boolean;
}

const primaryLink: StripLink = {
  label: 'Place Bid',
  href: `${mflBase}&O=43`,
  icon: 'gavel',
  external: true,
};

const freeAgentsLink: StripLink = {
  label: 'Free Agents',
  href: r('/theleague/players'),
  icon: 'binoculars',
  external: false,
};

const secondaryLinks: StripLink[] = [
  { label: 'Completed Auctions', href: `${mflBase}&O=43`, icon: 'check', external: true },
  { label: 'Auction Summary', href: `${mflBase}&O=44`, icon: 'bar-chart', external: true },
];
---

<div class="auction-strip" role="region" aria-label={showUdfaNote ? 'Free Agent Auction quick links — undrafted rookies available' : 'Free Agent Auction quick links'}>
  <div class="auction-strip__body">
    <div class="auction-strip__row auction-strip__row--primary">
      <span class="auction-strip__title">Free Agent Auction</span>
      {showUdfaNote && <span class="auction-strip__udfa-note">+ Undrafted rookies available</span>}
    </div>

    <div class="auction-strip__row auction-strip__row--secondary">
      <a
        href={freeAgentsLink.href}
        class="auction-strip__text-link"
      >
        {freeAgentsLink.label}
      </a>
      {secondaryLinks.map(link => (
        <>
          <span class="auction-strip__sep" aria-hidden="true">·</span>
          <a
            href={link.href}
            class="auction-strip__text-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${link.label} (opens in new tab)`}
          >
            {link.label} <span class="auction-strip__ext" aria-hidden="true">&#8599;</span>
          </a>
        </>
      ))}
    </div>
  </div>

  <a
    href={primaryLink.href}
    class="auction-strip__cta"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Place Auction Bid (opens in new tab)"
  >
    <svg class="auction-strip__icon auction-strip__icon--cta" aria-hidden="true">
      <use href={`${spriteUrl}#icon-${primaryLink.icon}`}></use>
    </svg>
    <span>{primaryLink.label}</span>
    <span class="auction-strip__ext" aria-hidden="true">&#8599;</span>
  </a>
</div>

<style>
  /* ── Container ── */
  .auction-strip {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: color-mix(in srgb, var(--color-primary, #1c497c) 4%, var(--content-bg, #fff));
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-lg, 0.75rem);
    padding: 1.25rem 2rem;
  }

  /* ── Body (left side: two rows) ── */
  .auction-strip__body {
    flex: 1;
    min-width: 0;
  }

  /* ── Rows ── */
  .auction-strip__row--primary {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .auction-strip__row--secondary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.25rem;
    padding-left: 0.625rem;
  }

  /* ── Title (editorial section-title variant) ── */
  .auction-strip__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-700, #374151);
    padding-left: 0.625rem;
    border-left: 2px solid var(--cat-free-agency, #2e8743);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── UDFA note (post-draft variant) ── */
  .auction-strip__udfa-note {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--cat-draft, #7c3aed);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Primary CTA ── */
  .auction-strip__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--color-primary, #1c497c);
    color: #fff;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
  }

  .auction-strip__cta:hover {
    filter: brightness(0.92);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--color-primary, #1c497c) 30%, transparent);
  }

  .auction-strip__cta:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }

  /* ── Simple text links (row 2) ── */
  .auction-strip__text-link {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-gray-500, #6b7280);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .auction-strip__text-link:hover {
    color: var(--color-primary, #1c497c);
    text-decoration: underline;
  }

  .auction-strip__text-link:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }

  .auction-strip__sep {
    color: var(--color-gray-300, #d1d5db);
    font-size: 0.6875rem;
  }

  /* ── Icons ── */
  .auction-strip__icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    fill: currentColor;
  }

  .auction-strip__icon--cta {
    width: 0.9375rem;
    height: 0.9375rem;
  }

  .auction-strip__ext {
    font-size: 0.6875rem;
    opacity: 0.6;
  }

  .auction-strip__cta .auction-strip__ext {
    opacity: 0.8;
  }

  /* ── Responsive (container query — responds to main content width) ── */
  @container (max-width: 767px) {
    .auction-strip {
      flex-direction: column;
      align-items: stretch;
      padding: 1rem 1.25rem;
    }

    .auction-strip__row--primary {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .auction-strip__row--secondary {
      flex-wrap: wrap;
    }

    .auction-strip__title {
      flex: 1;
    }

    .auction-strip__cta {
      align-self: stretch;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .auction-strip__cta,
    .auction-strip__text-link {
      transition: none;
    }
  }
</style>
