---
/**
 * UDFAHero — Simple CTA hero for the UDFA window (7 days after rookie draft
 * completes). Points users to the free agents page to find undrafted rookies.
 */
export interface Props {
  resolveLeaguePath: (path: string) => string;
  spriteUrl: string;
}

const { resolveLeaguePath: r, spriteUrl } = Astro.props;
---

<section class="udfa-hero" aria-label="Undrafted Free Agents">
  <div class="udfa-hero__content">
    <div class="udfa-hero__text">
      <div class="udfa-hero__eyebrow">
        <span class="udfa-hero__badge">UDFA Window</span>
      </div>
      <h2 class="udfa-hero__title">Undrafted Free Agents Available</h2>
      <p class="udfa-hero__summary">
        The draft is over but the bargains aren't. Undrafted rookies are now free agents —
        pick up the sleepers everyone else missed.
      </p>
    </div>

    <a href={r('/theleague/players')} class="udfa-hero__cta">
      <svg class="udfa-hero__cta-icon" aria-hidden="true">
        <use href={`${spriteUrl}#icon-binoculars`}></use>
      </svg>
      <span>Browse Free Agents</span>
      <span class="udfa-hero__cta-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  .udfa-hero {
    padding: 0.5rem 0 1rem;
  }

  .udfa-hero__content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .udfa-hero__text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .udfa-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .udfa-hero__badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--cat-draft, #7c3aed) 15%, var(--color-gray-100, #f3f4f6));
    color: var(--cat-draft, #7c3aed);
  }

  .udfa-hero__title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-dark, #0f1e2e);
    line-height: 1.25;
    margin: 0;
  }

  .udfa-hero__summary {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-gray-600, #4b5563);
    max-width: 54ch;
    margin: 0;
  }

  .udfa-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--color-primary, #1c497c);
    color: #fff;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 700;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
  }

  .udfa-hero__cta:hover {
    filter: brightness(0.92);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--color-primary, #1c497c) 35%, transparent);
  }

  .udfa-hero__cta:focus-visible {
    outline: 2px solid var(--color-primary, #1c497c);
    outline-offset: 2px;
  }

  .udfa-hero__cta-icon {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    fill: currentColor;
  }

  .udfa-hero__cta-arrow {
    font-size: 1rem;
    transition: transform 0.15s ease;
  }

  .udfa-hero__cta:hover .udfa-hero__cta-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .udfa-hero__title {
      font-size: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .udfa-hero__cta,
    .udfa-hero__cta-arrow {
      transition: none;
    }
  }
</style>
