---
/**
 * UDFAHero — promo for the UDFA window (7 days after the rookie draft completes).
 * Points owners to the free-agent pool to scoop up undrafted rookies. Wears the
 * shared branded LeagueEventHero look (draft-purple accent, player cut-out).
 */
import LeagueEventHero from './LeagueEventHero.astro';
import { randomHeroPlayer } from '../../utils/hero-players';

export interface Props {
  resolveLeaguePath: (path: string) => string;
  /** Reference date (from the resolver) — seeds the day-stable player cut-out. */
  referenceDate?: Date;
}

const { resolveLeaguePath: r, referenceDate } = Astro.props;
---

<LeagueEventHero
  pill="UDFA window"
  headline="Undrafted free agents"
  accentWord="available."
  summary="The draft is over but the bargains aren't. Undrafted rookies are now free agents — grab the sleepers everyone else missed."
  icon="binoculars"
  accent="#2e8743"
  glow="rgba(46,135,67,.5)"
  player={randomHeroPlayer(referenceDate ?? new Date())}
  link={r('/theleague/players')}
  linkLabel="Browse free agents"
  regionLabel="Undrafted free agents"
/>
