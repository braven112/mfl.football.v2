---
/**
 * FranchiseOptions - Displays likely franchise tag options for consideration
 *
 * Eligibility (rank OR points OR salary, whichever qualifies):
 * - On their last year (contractYears === 1)
 * - Top N at their position by imported ranking position rank OR season points
 *   position rank (QB/TE/RB/PK/DEF: top 5, WR: top 7)
 * - OR top 3 at their position by salary (if someone's paying that much, they're tag-worthy)
 *
 * Server-side uses points + salary only (no localStorage access).
 * Client-side script enhances with imported rankings when available.
 */

import { currencyFormatter } from '../../utils/formatters';
import PlayerCell from './PlayerCell.astro';

export interface Props {
  players: Array<{
    id: string;
    name: string;
    position: string;
    salary: number;
    points: number;
    franchiseId: string;
    nflTeam: string;
    headshot: string;
    nflLogo: string;
    contractYears: number;
  }>;
  salaryAverages?: Record<string, { positions?: Record<string, { top5Average?: number; top3Average?: number }> }>;
  season?: string;
  showTeamLogo?: boolean;
}

// NFL team code to full name mapping
const NFL_TEAM_NAMES: Record<string, string> = {
  ARI: 'Arizona', ATL: 'Atlanta', BAL: 'Baltimore', BUF: 'Buffalo',
  CAR: 'Carolina', CHI: 'Chicago', CIN: 'Cincinnati', CLE: 'Cleveland',
  DAL: 'Dallas', DEN: 'Denver', DET: 'Detroit', GB: 'Green Bay',
  HOU: 'Houston', IND: 'Indianapolis', JAC: 'Jacksonville', KC: 'Kansas City',
  LV: 'Las Vegas', LAC: 'Los Angeles', LAR: 'Los Angeles', MIA: 'Miami',
  MIN: 'Minnesota', NE: 'New England', NO: 'New Orleans', NYG: 'New York',
  NYJ: 'New York', PHI: 'Philadelphia', PIT: 'Pittsburgh', SEA: 'Seattle',
  SF: 'San Francisco', TB: 'Tampa Bay', TEN: 'Tennessee', WAS: 'Washington',
};

import { getCurrentLeagueYear } from '../../utils/league-year';
const { players = [], salaryAverages = {}, season = String(getCurrentLeagueYear()), showTeamLogo = true } = Astro.props;

// Franchise tag thresholds by position
const TAG_THRESHOLDS: Record<string, number> = {
  QB: 5, RB: 5, WR: 7, TE: 5, PK: 5, DEF: 5,
};

// Helper function to calculate franchise tag value
// Formula: max(currentSalary * 1.2, top3Average)
const calculateFranchiseTag = (salary: number, position: string): number => {
  const pos = position?.toUpperCase() || 'UNK';
  const dataForSeason = salaryAverages[season] || salaryAverages['2025'];
  const top3Avg = dataForSeason?.positions?.[pos]?.top3Average ?? 0;
  const tagBased120 = Math.round(salary * 1.2);

  if (top3Avg > 0) {
    return Math.max(tagBased120, Math.round(top3Avg));
  }
  return tagBased120;
};

const positionOrder = ['QB', 'RB', 'WR', 'TE', 'PK', 'DEF'];

const salaryYear = season;
const tagYear = String(Number(season) + 1);

// Rank ALL players by position by points
const playersByPosition = new Map<string, (typeof players)[number][]>();
players.forEach((player) => {
  const pos = player.position?.toUpperCase() || 'UNK';
  if (!playersByPosition.has(pos)) playersByPosition.set(pos, []);
  playersByPosition.get(pos)!.push(player);
});

const pointsRankings = new Map<string, number>();
playersByPosition.forEach((posPlayers) => {
  posPlayers
    .sort((a, b) => (b.points ?? 0) - (a.points ?? 0))
    .forEach((player, idx) => {
      pointsRankings.set(player.id, idx + 1);
    });
});

// Salary rankings by position (top 3 by salary is an alternate qualifier)
const salaryRankings = new Map<string, number>();
playersByPosition.forEach((posPlayers) => {
  posPlayers
    .sort((a, b) => (b.salary ?? 0) - (a.salary ?? 0))
    .forEach((player, idx) => {
      salaryRankings.set(player.id, idx + 1);
    });
});

// Filter eligible players (server-side: points + salary only)
const franchiseTagEligible: (typeof players[number] & { pointsPosRank: number; salaryPosRank: number })[] = [];
players.forEach((player) => {
  if (player.contractYears !== 1) return;

  const pos = player.position?.toUpperCase() || 'UNK';
  const threshold = TAG_THRESHOLDS[pos] ?? 5;
  const pointsPosRank = pointsRankings.get(player.id) ?? Infinity;
  const salaryPosRank = salaryRankings.get(player.id) ?? Infinity;

  // Top N by points at position OR top 3 by salary at position
  if (pointsPosRank <= threshold || salaryPosRank <= 3) {
    franchiseTagEligible.push({
      ...player,
      pointsPosRank,
      salaryPosRank,
      position: pos,
    });
  }
});

// Sort by position order, then by points rank within position
franchiseTagEligible.sort((a, b) => {
  const posDiff = positionOrder.indexOf(a.position) - positionOrder.indexOf(b.position);
  if (posDiff !== 0) return posDiff;
  return a.pointsPosRank - b.pointsPosRank;
});

const withRanks = franchiseTagEligible;

const DEFAULT_HEADSHOT_URL = 'https://s.yimg.com/cv/apiv2/default/nfl/nophoto.png';

const getPlayerDisplayName = (player: typeof players[0]): string => {
  if (player.position?.toUpperCase() === 'DEF') {
    const teamName = NFL_TEAM_NAMES[player.nflTeam] || player.nflTeam;
    return `${teamName} Defense`;
  }
  return player.name;
};

---

<div class="franchise-tag-eligibility" data-all-players={JSON.stringify(players)} data-salary-averages={JSON.stringify(salaryAverages)} data-season={season}>
  {withRanks.length === 0 ? (
    <div class="no-results">
      <p>No players on their last year currently meet franchise tag criteria (top at position by rank, points, or salary).</p>
    </div>
  ) : (
    <div class="table-wrapper">
      <table class="eligibility-table">
        <thead>
          <tr>
            <th scope="col">Player</th>
            <th scope="col" class="align-right">Points</th>
            <th scope="col" class="align-right">{salaryYear} Salary</th>
            <th scope="col" class="align-right">{tagYear} Tag Value</th>
          </tr>
        </thead>
        <tbody>
          {withRanks.map((player) => {
            const displayName = getPlayerDisplayName(player);
            return (
            <tr>
              <td data-label="Player">
                <PlayerCell
                  name={displayName}
                  headshot={player.headshot}
                  position={player.position}
                  nflTeam={player.nflTeam}
                />
              </td>
              <td data-label="Points" class="align-right">{(player.points ?? 0).toFixed(2)}</td>
              <td data-label={`${salaryYear} Salary`} class="align-right salary-value-cell">{currencyFormatter.format(player.salary)}</td>
              <td data-label={`${tagYear} Tag Value`} class="align-right salary-value-cell">{currencyFormatter.format(calculateFranchiseTag(player.salary, player.position))}</td>
            </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</div>

<script>
  import { buildRankingLookup, COMPOSITE_IMPORT_ID, AVERAGE_IMPORT_ID, onRankingsChanged } from '../../utils/rankings-lookup';
  import { buildPlayerCellHTML } from '../../utils/player-cell-html';

  // NFL team code to full name mapping
  const NFL_TEAM_NAMES = {
    ARI: 'Arizona', ATL: 'Atlanta', BAL: 'Baltimore', BUF: 'Buffalo',
    CAR: 'Carolina', CHI: 'Chicago', CIN: 'Cincinnati', CLE: 'Cleveland',
    DAL: 'Dallas', DEN: 'Denver', DET: 'Detroit', GB: 'Green Bay',
    HOU: 'Houston', IND: 'Indianapolis', JAC: 'Jacksonville', KC: 'Kansas City',
    LV: 'Las Vegas', LAC: 'Los Angeles', LAR: 'Los Angeles', MIA: 'Miami',
    MIN: 'Minnesota', NE: 'New England', NO: 'New Orleans', NYG: 'New York',
    NYJ: 'New York', PHI: 'Philadelphia', PIT: 'Pittsburgh', SEA: 'Seattle',
    SF: 'San Francisco', TB: 'Tampa Bay', TEN: 'Tennessee', WAS: 'Washington',
  };

  // Franchise tag thresholds by position
  const TAG_THRESHOLDS = { QB: 5, RB: 5, WR: 7, TE: 5, PK: 5, DEF: 5 };

  // Choose best ranking import: composite > average > first dynasty > first any
  function chooseBestImport(lookup) {
    if (lookup.byImport.has(COMPOSITE_IMPORT_ID)) return COMPOSITE_IMPORT_ID;
    if (lookup.byImport.has(AVERAGE_IMPORT_ID)) return AVERAGE_IMPORT_ID;
    const dynasty = lookup.columns.find(c => c.type === 'dynasty' && !c.isAverage && !c.isComposite);
    if (dynasty) return dynasty.importId;
    const first = lookup.columns.find(c => !c.isAverage && !c.isComposite);
    return first?.importId ?? null;
  }

  // Derive position ranks from overall ranking map
  function derivePositionRanks(allPlayers, rankMap) {
    const posRanks = new Map(); // playerId → position rank
    if (!rankMap) return posRanks;

    const byPos = new Map();
    for (const player of allPlayers) {
      const rank = rankMap.get(player.id);
      if (rank == null) continue;
      const pos = (player.position ?? '').toUpperCase();
      if (!byPos.has(pos)) byPos.set(pos, []);
      byPos.get(pos).push({ id: player.id, rank });
    }

    for (const [, players] of byPos) {
      players.sort((a, b) => a.rank - b.rank);
      players.forEach((p, i) => posRanks.set(p.id, i + 1));
    }

    return posRanks;
  }

  // Re-render the franchise tag eligibility table when data changes
  const renderFranchiseTagTable = (containerEl) => {
    const allPlayersJson = containerEl.dataset.allPlayers;
    const currentTeam = containerEl.dataset.currentTeam;
    const salaryAveragesJson = containerEl.dataset.salaryAverages || '{}';
    const season = containerEl.dataset.season || String(new Date().getFullYear());
    if (!allPlayersJson) return;

    try {
      const allPlayers = JSON.parse(allPlayersJson);
      const salaryAverages = JSON.parse(salaryAveragesJson);

      const salaryYear = season;
      const tagYear = String(Number(season) + 1);

      // Helper function to calculate franchise tag value
      // Formula: max(currentSalary * 1.2, top3Average)
      const calculateFranchiseTag = (salary, position) => {
        const pos = position?.toUpperCase() || 'UNK';
        const dataForSeason = salaryAverages[season] || salaryAverages['2025'];
        const top3Avg = dataForSeason?.franchiseSalaries?.[pos] ?? 0;
        const tagBased120 = Math.round(salary * 1.2);

        if (top3Avg > 0) {
          return Math.max(tagBased120, Math.round(top3Avg));
        }
        return tagBased120;
      };

      const positionOrder = ['QB', 'RB', 'WR', 'TE', 'PK', 'DEF'];

      // --- Rankings-based position ranks (from localStorage imports) ---
      const lookup = buildRankingLookup();
      const bestImportId = chooseBestImport(lookup);
      const rankMap = bestImportId ? lookup.byImport.get(bestImportId) : null;
      const posRankByRanking = derivePositionRanks(allPlayers, rankMap);

      // --- Points-based position ranks ---
      const allPlayersByPosition = new Map();
      allPlayers.forEach((player) => {
        const pos = (player.position ?? 'UNK').toUpperCase();
        if (!allPlayersByPosition.has(pos)) allPlayersByPosition.set(pos, []);
        allPlayersByPosition.get(pos).push(player);
      });

      const pointsRankings = new Map();
      allPlayersByPosition.forEach((posPlayers) => {
        posPlayers
          .sort((a, b) => (b.points ?? 0) - (a.points ?? 0))
          .forEach((player, idx) => {
            pointsRankings.set(player.id, idx + 1);
          });
      });

      // --- Salary rankings by position (top 3 alternate qualifier) ---
      const salaryRankings = new Map();
      allPlayersByPosition.forEach((posPlayers) => {
        posPlayers
          .sort((a, b) => (b.salary ?? 0) - (a.salary ?? 0))
          .forEach((player, idx) => {
            salaryRankings.set(player.id, idx + 1);
          });
      });

      // Filter to only the current team's players for display
      const teamPlayers = currentTeam ? allPlayers.filter(p => p.franchiseId === currentTeam) : allPlayers;

      // Filter eligible players: last year, top N by rank/points OR top 3 by salary
      const eligible = [];
      teamPlayers.forEach((player) => {
        if (player.contractYears !== 1) return;

        const pos = (player.position ?? 'UNK').toUpperCase();
        const threshold = TAG_THRESHOLDS[pos] ?? 5;

        const rankingPosRank = posRankByRanking.get(player.id) ?? Infinity;
        const pointsPosRank = pointsRankings.get(player.id) ?? Infinity;
        const salaryPosRank = salaryRankings.get(player.id) ?? Infinity;

        // Qualifies if top N by ranking OR points, OR top 3 by salary
        if (rankingPosRank <= threshold || pointsPosRank <= threshold || salaryPosRank <= 3) {
          eligible.push({
            ...player,
            rankingPosRank,
            pointsPosRank,
            salaryPosRank,
            position: pos,
          });
        }
      });

      // Sort by position order, then by best rank within position
      eligible.sort((a, b) => {
        const posDiff = positionOrder.indexOf(a.position) - positionOrder.indexOf(b.position);
        if (posDiff !== 0) return posDiff;
        const bestA = Math.min(a.rankingPosRank, a.pointsPosRank);
        const bestB = Math.min(b.rankingPosRank, b.pointsPosRank);
        return bestA - bestB;
      });

      if (eligible.length === 0) {
        containerEl.innerHTML = '<div class="no-results"><p>No players on their last year currently meet franchise tag criteria (top at position by rank, points, or salary).</p></div>';
        return;
      }

      // Build table HTML
      let tableHtml = `
        <div class="table-wrapper">
          <table class="eligibility-table">
            <thead>
              <tr>
                <th scope="col">Player</th>
                <th scope="col" class="align-right">Points</th>
                <th scope="col" class="align-right">${salaryYear} Salary</th>
                <th scope="col" class="align-right">${tagYear} Tag Value</th>
              </tr>
            </thead>
            <tbody>
      `;

      const currencyFormatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0,
      });

      eligible.forEach((player) => {
        const isDefense = (player.position ?? '').toUpperCase() === 'DEF';
        const displayName = isDefense
          ? `${NFL_TEAM_NAMES[player.nflTeam] || player.nflTeam} Defense`
          : player.name;

        tableHtml += `
          <tr>
            <td data-label="Player">
              ${buildPlayerCellHTML({ name: displayName, headshot: player.headshot, position: player.position, nflTeam: player.nflTeam })}
            </td>
            <td data-label="Points" class="align-right">${(player.points ?? 0).toFixed(2)}</td>
            <td data-label="${salaryYear} Salary" class="align-right salary-value-cell">${currencyFormatter.format(player.salary)}</td>
            <td data-label="${tagYear} Tag Value" class="align-right salary-value-cell">${currencyFormatter.format(calculateFranchiseTag(player.salary, player.position))}</td>
          </tr>
        `;
      });

      tableHtml += `
            </tbody>
          </table>
        </div>
      `;

      containerEl.innerHTML = tableHtml;
    } catch (error) {
      console.error('Failed to render franchise tag eligibility:', error);
    }
  };

  // Find and render all franchise tag eligibility containers
  document.querySelectorAll('.franchise-tag-eligibility').forEach((el) => {
    renderFranchiseTagTable(el);
  });

  // Watch for data updates (team switching, roster changes)
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.type === 'attributes' && (mutation.attributeName === 'data-all-players' || mutation.attributeName === 'data-current-team')) {
        renderFranchiseTagTable(mutation.target);
      }
    });
  });

  document.querySelectorAll('.franchise-tag-eligibility').forEach((el) => {
    observer.observe(el, { attributes: true });
  });

  // Re-render when rankings are imported/updated
  onRankingsChanged(() => {
    document.querySelectorAll('.franchise-tag-eligibility').forEach((el) => {
      renderFranchiseTagTable(el);
    });
  });
</script>

<style is:global>
  .franchise-tag-eligibility {
    width: 100%;
  }

  .no-results {
    text-align: center;
    padding: 2rem;
    background: #f5f5f5;
    border-radius: 8px;
    color: #666;
    font-size: 0.95rem;
  }

  .eligibility-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .eligibility-table thead {
    background: #f8f9fa;
    border-bottom: 2px solid #e9ecef;
  }

  .eligibility-table th {
    padding: 0.75rem;
    text-align: left;
    font-weight: 600;
    color: #333;
  }

  .eligibility-table th.align-right {
    text-align: right;
  }

  .eligibility-table th.align-center {
    text-align: center;
  }

  .eligibility-table tbody tr {
    border-bottom: 1px solid #e9ecef;
    transition: background 0.2s ease;
  }

  .eligibility-table tbody tr:nth-child(even) {
    background: #e0e0e0;
  }

  .eligibility-table tbody tr:hover {
    background: #eef1fb;
  }

  .eligibility-table td {
    padding: 0.75rem;
    vertical-align: middle;
  }

  .eligibility-table td.align-right {
    text-align: right;
    padding-right: 0.5rem;
  }

  .eligibility-table .salary-value-cell {
    font-size: 0.85rem;
    color: #555;
  }

  .eligibility-table td.align-center {
    text-align: center;
  }

  .franchise-cell {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .franchise-logo {
    width: 24px;
    height: 24px;
    object-fit: contain;
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .eligibility-table {
      font-size: 0.8rem;
    }

    .eligibility-table th,
    .eligibility-table td {
      padding: 0.5rem;
    }

    .franchise-logo {
      width: 20px;
      height: 20px;
    }
  }
</style>
