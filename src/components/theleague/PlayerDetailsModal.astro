---
/**
 * PlayerDetailsModal — Refined editorial player profile
 *
 * Information hierarchy:
 * 1. Hero identity (name, team, position, age)
 * 2. Key metrics strip (points, PPG, contract)
 * 3. Weekly results (game-by-game performance)
 * 4. Supporting details (physical, status, draft, contract breakdown)
 */

export interface Props {
  class?: string;
  /**
   * Hide all contract / salary UI. AFL has no salaries or contracts;
   * showing the "Free Agent" fallback is misleading there.
   */
  hideContract?: boolean;
}

const { class: className, hideContract = false } = Astro.props;
---

<div class:list={['player-details-modal', className]}>
  <div class="player-details-modal__overlay"></div>
  <div class="player-details-modal__content">
    <button class="pdm-close" aria-label="Close" title="Close (ESC)">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M14 4L4 14M4 4l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="pdm-body">
      <!-- Hero Profile -->
      <div class="pdm-hero">
        <div class="pdm-hero__avatar" id="pdm-avatar-wrap">
          <img id="detail-headshot" src="" alt="Player headshot" />
        </div>
        <div class="pdm-hero__info">
          <div class="pdm-hero__name-row">
            <h3 class="pdm-hero__name" id="detail-name">&mdash;</h3>
            <span class="pdm-hero__age" id="detail-age-pill"></span>
          </div>
          <div class="pdm-hero__meta">
            <img class="pdm-hero__team-logo" id="detail-nfl-team-logo" src="" alt="" />
            <span class="pdm-hero__meta-text" id="detail-meta-text">&mdash;</span>
          </div>
          <div class="pdm-hero__sub" id="detail-sub-text">&mdash;</div>
        </div>
      </div>

      <!-- Key Metrics -->
      <div class="pdm-metrics" id="pdm-metrics">
        <div class="pdm-metric" id="metric-card-points">
          <span class="pdm-metric__value" id="metric-points-value">&mdash;</span>
          <span class="pdm-metric__label" id="metric-points-label">Points</span>
        </div>
        <div class="pdm-metric" id="metric-card-ppg">
          <span class="pdm-metric__value" id="metric-ppg-value">&mdash;</span>
          <span class="pdm-metric__label">Per Game</span>
        </div>
        {!hideContract && (
          <div class="pdm-metric" id="metric-card-contract">
            <span class="pdm-metric__value" id="metric-contract-value">&mdash;</span>
            <span class="pdm-metric__label" id="metric-contract-label">Contract</span>
          </div>
        )}
      </div>

      <!-- Weekly Results (promoted position) -->
      <div class="pdm-section" id="section-weekly-results" style="display: none;">
        <h4 class="pdm-section__title" id="weekly-results-title">Season Results</h4>
        <div class="weekly-results-table-wrapper">
          <table class="weekly-results-table">
            <thead>
              <tr>
                <th class="wr-wk">Wk</th>
                <th class="wr-pts">Pts</th>
                <th class="wr-opp">Opponent</th>
                <th class="wr-avg" id="wr-avg-header">Opp Avg</th>
                <th class="wr-rank" id="wr-rank-header">Opp Rank</th>
                <th class="wr-status">Status</th>
              </tr>
            </thead>
            <tbody id="weekly-results-body"></tbody>
            <tfoot id="weekly-results-foot" style="display: none;">
              <tr>
                <td class="wr-wk"><strong>Total</strong></td>
                <td class="wr-pts" id="weekly-results-total"><strong>&mdash;</strong></td>
                <td colspan="4"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      <!-- Supporting Details -->
      <div class="pdm-section pdm-details" id="section-details">
        <h4 class="pdm-section__title">Details</h4>
        <div class="pdm-details__grid">
          <div class="pdm-detail" id="detail-row-physical">
            <span class="pdm-detail__label">Build</span>
            <span class="pdm-detail__value" id="detail-physical-value">&mdash;</span>
          </div>
          <div class="pdm-detail" id="detail-row-status">
            <span class="pdm-detail__label">Status</span>
            <span class="pdm-detail__value" id="detail-status-value">&mdash;</span>
          </div>
          <div class="pdm-detail" id="detail-row-draft">
            <span class="pdm-detail__label">Draft</span>
            <span class="pdm-detail__value pdm-detail__value--with-logo" id="detail-draft-value">
              <img class="pdm-detail__logo" id="detail-draft-team-logo" src="" alt="" />
              <span id="detail-draft-text">&mdash;</span>
            </span>
          </div>
          <div class="pdm-detail" id="detail-row-college">
            <span class="pdm-detail__label">College</span>
            <span class="pdm-detail__value pdm-detail__value--with-logo" id="detail-college-value">
              <img class="pdm-detail__logo pdm-detail__logo--college" id="detail-college-logo" src="" alt="" />
              <span id="detail-college">&mdash;</span>
            </span>
          </div>
          {!hideContract && (
            <div class="pdm-detail" id="detail-row-contract">
              <span class="pdm-detail__label">Contract</span>
              <span class="pdm-detail__value" id="detail-contract-detail">&mdash;</span>
            </div>
          )}
          <div class="pdm-detail" id="detail-row-bye">
            <span class="pdm-detail__label">Bye</span>
            <span class="pdm-detail__value" id="detail-bye-value">&mdash;</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ================================================================
     Modal Shell
     ================================================================ */
  .player-details-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .player-details-modal.active {
    display: flex;
  }

  .player-details-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .player-details-modal__content {
    position: relative;
    background: var(--color-white, #fff);
    border-radius: var(--radius-lg, 1rem);
    box-shadow: var(--shadow-xl);
    width: 100%;
    max-width: 580px;
    max-height: 88vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: pdm-enter 0.22s ease-out;
  }

  @keyframes pdm-enter {
    from {
      opacity: 0;
      transform: scale(0.97) translateY(6px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* ================================================================
     Close Button
     ================================================================ */
  .pdm-close {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    background: var(--color-gray-100, #f3f4f6);
    border: none;
    border-radius: var(--radius-full, 9999px);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .pdm-close:hover {
    background: var(--color-gray-200, #dddedf);
    color: var(--color-gray-800, #1f2937);
  }

  /* ================================================================
     Body (scrollable area)
     ================================================================ */
  .pdm-body {
    overflow-y: auto;
    flex: 1;
    padding: 1.75rem 1.75rem 1.5rem;
  }

  /* ================================================================
     Hero Section
     ================================================================ */
  .pdm-hero {
    display: flex;
    align-items: flex-start;
    gap: 1.125rem;
    margin-bottom: 1.5rem;
    position: relative;
  }

  .pdm-hero__avatar {
    width: 88px;
    height: 88px;
    border-radius: var(--radius-lg, 1rem);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-gray-100, #f3f4f6);
    box-shadow: var(--shadow-md);
  }

  .pdm-hero__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .pdm-hero__avatar--def {
    background: transparent;
    box-shadow: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pdm-hero__avatar--def img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .pdm-hero__info {
    flex: 1;
    min-width: 0;
    padding-top: 0.125rem;
  }

  .pdm-hero__name-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.375rem;
    padding-right: 2rem;
  }

  .pdm-hero__name {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    margin: 0;
    line-height: 1.2;
  }

  .pdm-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.25rem;
  }

  .pdm-hero__team-logo {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .pdm-hero__meta-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gray-600, #4b5563);
  }

  .pdm-hero__sub {
    font-size: 0.8125rem;
    color: var(--color-gray-400, #9ca3af);
    line-height: 1.4;
  }

  .pdm-hero__age {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-600, #4b5563);
    background: var(--color-gray-100, #f3f4f6);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full, 9999px);
    white-space: nowrap;
    line-height: 1.4;
    flex-shrink: 0;
  }

  /* ================================================================
     Key Metrics Strip
     ================================================================ */
  .pdm-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
    margin-bottom: 1.75rem;
  }

  .pdm-metric {
    background: var(--color-gray-50, #f9fafb);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    padding: 0.75rem 0.5rem;
    text-align: center;
  }

  .pdm-metric__value {
    display: block;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gray-900, #111827);
    line-height: 1.2;
    font-variant-numeric: tabular-nums;
  }

  .pdm-metric__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray-400, #9ca3af);
    margin-top: 0.25rem;
  }

  .pdm-metric--fa .pdm-metric__value {
    color: var(--color-gray-400, #9ca3af);
    font-weight: 600;
  }

  /* ================================================================
     Section Title
     ================================================================ */
  .pdm-section {
    margin-bottom: 1.5rem;
  }

  .pdm-section:last-child {
    margin-bottom: 0;
  }

  .pdm-section__title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    padding-left: 0.625rem;
    border-left: 2px solid var(--color-primary, #1c497c);
  }

  /* ================================================================
     Weekly Results Table
     ================================================================ */
  .weekly-results-table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
  }

  .weekly-results-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
    line-height: 1.3;
  }

  .weekly-results-table thead th {
    background: var(--color-gray-50, #f9fafb);
    color: var(--color-gray-400, #9ca3af);
    font-weight: 600;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid var(--content-border, #e2e8f0);
    white-space: nowrap;
    position: sticky;
    top: 0;
  }

  /* Dynamic rows via innerHTML lack Astro scope attrs — use :global */
  .weekly-results-table :global(td) {
    padding: 0.3rem 0.5rem;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    color: var(--color-gray-700, #374151);
    white-space: nowrap;
    vertical-align: middle;
    font-size: 0.75rem;
    line-height: 1.3;
  }

  .weekly-results-table :global(tbody tr:hover) {
    background: var(--color-gray-50, #f9fafb);
  }

  .weekly-results-table :global(tfoot td) {
    padding: 0.4rem 0.5rem;
    border-top: 1px solid var(--content-border, #e2e8f0);
    border-bottom: none;
    background: var(--color-gray-50, #f9fafb);
    font-weight: 600;
  }

  .weekly-results-table :global(.wr-wk) {
    text-align: center;
    width: 1.75rem;
    color: var(--color-gray-400, #9ca3af);
    font-size: 0.6875rem;
  }

  .weekly-results-table :global(.wr-pts) {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--color-gray-900, #111827);
  }

  .weekly-results-table :global(.wr-opp) {
    min-width: 4rem;
  }

  .weekly-results-table :global(.wr-avg),
  .weekly-results-table :global(.wr-rank) {
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  .weekly-results-table :global(.wr-status) {
    font-size: 0.6875rem;
    color: var(--color-gray-400, #9ca3af);
    text-align: center;
  }

  .weekly-results-table :global(.wr-rank-easy) { color: var(--color-success-dark, #059669); font-weight: 600; }
  .weekly-results-table :global(.wr-rank-hard) { color: var(--color-error, #dc2626); font-weight: 600; }

  .weekly-results-table :global(.wr-bye-row td) { opacity: 0.4; font-style: italic; }
  .weekly-results-table :global(.wr-empty-row td) { color: var(--color-gray-300, #d1d5db); }

  .weekly-results-table :global(.wr-starter) { color: var(--color-success-dark, #059669); }
  .weekly-results-table :global(.wr-nonstarter) { color: var(--color-gray-400, #9ca3af); }

  /* ================================================================
     Details Section
     ================================================================ */
  .pdm-details__grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pdm-detail {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
  }

  .pdm-detail:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .pdm-detail:first-child {
    padding-top: 0;
  }

  .pdm-detail__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-400, #9ca3af);
    width: 4.5rem;
    flex-shrink: 0;
  }

  .pdm-detail__value {
    font-size: 0.875rem;
    color: var(--color-gray-700, #374151);
    line-height: 1.4;
  }

  .pdm-detail__value--with-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .pdm-detail__logo {
    height: 1rem;
    width: auto;
    max-width: 1.5rem;
    object-fit: contain;
    display: none;
  }

  .pdm-detail__logo--college {
    height: 1.25rem;
    max-width: 1.75rem;
  }

  /* ================================================================
     Mobile
     ================================================================ */
  @media (max-width: 640px) {
    .player-details-modal {
      padding: 0.5rem;
      align-items: flex-end;
    }

    .player-details-modal__content {
      max-height: 92vh;
      border-radius: var(--radius-lg, 1rem) var(--radius-lg, 1rem) 0 0;
    }

    .pdm-body {
      padding: 1.25rem;
    }

    .pdm-hero__avatar {
      width: 64px;
      height: 64px;
      border-radius: var(--radius-md, 0.5rem);
    }

    .pdm-hero__name {
      font-size: 1.125rem;
    }

    .pdm-hero__name-row {
      padding-right: 1.5rem;
    }

    .pdm-hero__meta-text {
      font-size: 0.8125rem;
    }

    .pdm-hero__sub {
      font-size: 0.75rem;
    }

    .pdm-metrics {
      gap: 0.5rem;
    }

    .pdm-metric {
      padding: 0.625rem 0.375rem;
    }

    .pdm-metric__value {
      font-size: 1.0625rem;
    }

    .pdm-metric__label {
      font-size: 0.625rem;
    }

    .weekly-results-table {
      font-size: 0.6875rem;
    }

    .weekly-results-table thead th,
    .weekly-results-table :global(td) {
      padding: 0.25rem 0.3rem;
      font-size: 0.6875rem;
    }

    .weekly-results-table :global(.wr-avg) { display: none; }
    #wr-avg-header { display: none; }

    .pdm-detail__label {
      width: 3.75rem;
      font-size: 0.6875rem;
    }

    .pdm-detail__value {
      font-size: 0.8125rem;
    }
  }
</style>

<script>
  function initPlayerDetailsModal() {
    const modal = document.querySelector('.player-details-modal');
    const overlay = document.querySelector('.player-details-modal__overlay');
    const closeBtn = document.querySelector('.pdm-close');

    const closeModal = () => {
      if (modal) modal.classList.remove('active');
    };

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (overlay) overlay.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal?.classList.contains('active')) {
        closeModal();
      }
    });

    window.openPlayerDetailsModal = function(playerData) {
      // ── Helpers ──

      const nflTeamNames = {
        ARI: 'Arizona Cardinals', ATL: 'Atlanta Falcons', BAL: 'Baltimore Ravens',
        BUF: 'Buffalo Bills', CAR: 'Carolina Panthers', CHI: 'Chicago Bears',
        CIN: 'Cincinnati Bengals', CLE: 'Cleveland Browns', DAL: 'Dallas Cowboys',
        DEN: 'Denver Broncos', DET: 'Detroit Lions', GB: 'Green Bay Packers',
        HOU: 'Houston Texans', IND: 'Indianapolis Colts', JAX: 'Jacksonville Jaguars',
        KC: 'Kansas City Chiefs', LV: 'Las Vegas Raiders', LAC: 'LA Chargers',
        LAR: 'LA Rams', MIA: 'Miami Dolphins', MIN: 'Minnesota Vikings',
        NE: 'New England Patriots', NO: 'New Orleans Saints', NYG: 'NY Giants',
        NYJ: 'NY Jets', PHI: 'Philadelphia Eagles', PIT: 'Pittsburgh Steelers',
        SEA: 'Seattle Seahawks', SF: 'San Francisco 49ers', TB: 'Tampa Bay Buccaneers',
        TEN: 'Tennessee Titans', WAS: 'Washington Commanders', WSH: 'Washington Commanders',
      };

      const nflTeamCities = {
        ARI: 'Arizona', ATL: 'Atlanta', BAL: 'Baltimore', BUF: 'Buffalo',
        CAR: 'Carolina', CHI: 'Chicago', CIN: 'Cincinnati', CLE: 'Cleveland',
        DAL: 'Dallas', DEN: 'Denver', DET: 'Detroit', GB: 'Green Bay',
        HOU: 'Houston', IND: 'Indianapolis', JAX: 'Jacksonville', KC: 'Kansas City',
        LV: 'Las Vegas', LAC: 'Los Angeles', LAR: 'Los Angeles', MIA: 'Miami',
        MIN: 'Minnesota', NE: 'New England', NO: 'New Orleans', NYG: 'New York',
        NYJ: 'New York', PHI: 'Philadelphia', PIT: 'Pittsburgh', SEA: 'Seattle',
        SF: 'San Francisco', TB: 'Tampa Bay', TEN: 'Tennessee', WAS: 'Washington', WSH: 'Washington',
      };

      const setText = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value || '\u2014';
      };

      const normalizeTeamCode = (team) => {
        if (!team) return null;
        const map = {
          NEP: 'NE', GBP: 'GB', KCC: 'KC', SFO: 'SF', LVR: 'LV', OAK: 'LV',
          SD: 'LAC', STL: 'LAR', NOS: 'NO', NOR: 'NO', JAC: 'JAX', TBB: 'TB',
          HST: 'HOU', BLT: 'BAL', CLV: 'CLE', ARZ: 'ARI', WAS: 'WSH', FA: 'NFL',
        };
        const code = team.toUpperCase();
        return map[code] ?? code;
      };

      const formatCurrency = (value) => {
        if (value === undefined || value === null) return null;
        return new Intl.NumberFormat('en-US', {
          style: 'currency', currency: 'USD', maximumFractionDigits: 0,
        }).format(value);
      };

      const formatSalaryCompact = (value) => {
        if (value === undefined || value === null) return null;
        if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
        if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
        return '$' + value;
      };

      const formatHeight = (inches) => {
        if (!inches) return null;
        const feet = Math.floor(inches / 12);
        const rem = inches % 12;
        return feet + "'" + rem + '"';
      };

      const formatPosition = (pos) => {
        if (!pos) return null;
        const upper = pos.toUpperCase();
        if (upper === 'SWR') return 'Slot WR';
        if (upper === 'LWR') return 'Left WR';
        if (upper === 'RWR') return 'Right WR';
        if (upper === 'PK') return 'Kicker';
        if (upper === 'DEF') return 'Defense';
        return upper;
      };

      const formatDraft = (year, round, pick, teamCode) => {
        const normalizedTeam = teamCode ? normalizeTeamCode(teamCode) : null;
        const rawTeam = teamCode ? teamCode.toUpperCase() : '';
        const isUndrafted = !year || rawTeam === 'FA' || rawTeam === 'UFA' ||
          (!round && !pick && (normalizedTeam === 'NFL' || normalizedTeam === null));
        if (isUndrafted) return 'Undrafted';
        const fmtPick = (v) => {
          if (v == null) return '??';
          const n = parseInt(String(v), 10);
          return Number.isFinite(n) ? String(n).padStart(2, '0') : '??';
        };
        if (year && round) return year + ' Round ' + round + ', Pick ' + fmtPick(pick);
        if (year && pick) return year + ' Pick ' + fmtPick(pick);
        return 'Undrafted';
      };

      const formatContractType = (type) => {
        if (!type) return null;
        const normalized = type.toUpperCase() === 'INJURED_RESERVE' ? 'Injured Reserve' : type;
        return normalized.replace(/_/g, ' ');
      };

      // ── Data ──

      const position = playerData.position;
      const isDefense = position ? position.toUpperCase() === 'DEF' : false;
      const teamCode = normalizeTeamCode(playerData.nflTeam);

      // ── Hero: Headshot ──

      const headshot = document.getElementById('detail-headshot');
      if (headshot && playerData.id) {
        const DEFAULT_IMG = 'https://www49.myfantasyleague.com/player_photos_2010/no_photo_available.jpg';
        const MFL_IMG = 'https://www49.myfantasyleague.com/player_photos_big_2014/' + playerData.id + '_thumb.jpg';
        const COLLEGE_IMG = playerData.espnId
          ? 'https://a.espncdn.com/i/headshots/college-football/players/full/' + playerData.espnId + '.png'
          : null;

        if (isDefense && teamCode) {
          headshot.src = '/assets/nfl-logos/' + teamCode + '.svg';
          headshot.onerror = function() { headshot.onerror = null; headshot.src = DEFAULT_IMG; };
        } else if (playerData.headshot) {
          headshot.src = playerData.headshot;
          // Fallback chain from pre-set headshot: College → MFL → default
          if (COLLEGE_IMG) {
            headshot.onerror = function() {
              headshot.onerror = function() {
                headshot.onerror = function() { headshot.onerror = null; headshot.src = DEFAULT_IMG; };
                headshot.src = MFL_IMG;
              };
              headshot.src = COLLEGE_IMG;
            };
          } else {
            headshot.onerror = function() {
              headshot.onerror = function() { headshot.onerror = null; headshot.src = DEFAULT_IMG; };
              headshot.src = MFL_IMG;
            };
          }
        } else if (playerData.espnId) {
          headshot.src = 'https://a.espncdn.com/i/headshots/nfl/players/full/' + playerData.espnId + '.png';
          // Fallback chain: NFL → College → MFL → default
          headshot.onerror = function() {
            headshot.onerror = function() {
              headshot.onerror = function() { headshot.onerror = null; headshot.src = DEFAULT_IMG; };
              headshot.src = MFL_IMG;
            };
            headshot.src = COLLEGE_IMG;
          };
        } else {
          headshot.src = MFL_IMG;
          headshot.onerror = function() { headshot.onerror = null; headshot.src = DEFAULT_IMG; };
        }
        headshot.alt = playerData.name || 'Player headshot';
      }

      const avatarWrap = document.getElementById('pdm-avatar-wrap');
      if (avatarWrap) {
        if (isDefense) {
          avatarWrap.classList.add('pdm-hero__avatar--def');
        } else {
          avatarWrap.classList.remove('pdm-hero__avatar--def');
        }
      }

      // ── Hero: Name ──

      setText('detail-name', playerData.name);

      // ── Hero: Meta line (Team · Position · #Jersey) ──

      const teamCity = nflTeamCities[teamCode] || nflTeamCities[playerData.nflTeam] || playerData.nflTeam || 'Free Agent';
      const posLabel = formatPosition(position) || '';
      const jersey = playerData.number ? '#' + playerData.number : '';
      const metaParts = [teamCity, posLabel, jersey].filter(Boolean);
      setText('detail-meta-text', metaParts.join(' \u00B7 '));

      const logoEl = document.getElementById('detail-nfl-team-logo');
      if (logoEl) {
        logoEl.src = (!teamCode || teamCode === 'NFL')
          ? '/assets/nfl-logos/NFL.svg'
          : '/assets/nfl-logos/' + teamCode + '.svg';
        logoEl.alt = nflTeamNames[teamCode] || teamCode || 'NFL';
      }

      // ── Hero: Sub line (College · Experience · Draft) ──

      var subParts = [];
      if (playerData.college) subParts.push(playerData.college);
      if (playerData.experience != null) {
        if (playerData.experience === 0) subParts.push('Rookie');
        else if (playerData.experience === 1) subParts.push('1 yr');
        else subParts.push(playerData.experience + ' yrs');
      }
      if (!isDefense) {
        var draftStr = formatDraft(playerData.draftYear, playerData.draftRound, playerData.draftPick, playerData.draftTeam);
        if (draftStr !== 'Undrafted' || !playerData.college) subParts.push(draftStr);
      }
      setText('detail-sub-text', subParts.join(' \u00B7 '));

      // ── Hero: Age pill ──

      var agePill = document.getElementById('detail-age-pill');
      if (agePill) {
        if (playerData.birthdate) {
          var bd = new Date(playerData.birthdate * 1000);
          var today = new Date();
          var age = today.getFullYear() - bd.getFullYear();
          var md = today.getMonth() - bd.getMonth();
          if (md < 0 || (md === 0 && today.getDate() < bd.getDate())) age--;
          if (age >= 0) {
            agePill.textContent = age + ' yrs';
            agePill.style.display = '';
          } else {
            agePill.style.display = 'none';
          }
        } else {
          agePill.style.display = 'none';
        }
      }

      // ── Metrics: Points (placeholder — updated from weekly data below) ──

      if (playerData.points != null) {
        setText('metric-points-value', playerData.points.toFixed(1));
        setText('metric-points-label', 'Projected');
      } else {
        setText('metric-points-value', '\u2014');
        setText('metric-points-label', 'Points');
      }

      setText('metric-ppg-value', '\u2014');

      // ── Metrics: Contract ──

      var contractCard = document.getElementById('metric-card-contract');
      if (playerData.salary != null) {
        setText('metric-contract-value', formatSalaryCompact(playerData.salary) || '\u2014');
        var yrsLabel = playerData.contractYears
          ? playerData.contractYears + ' yr' + (playerData.contractYears > 1 ? 's' : '')
          : 'Salary';
        setText('metric-contract-label', yrsLabel);
        if (contractCard) contractCard.classList.remove('pdm-metric--fa');
      } else {
        setText('metric-contract-value', 'FA');
        setText('metric-contract-label', 'Free Agent');
        if (contractCard) contractCard.classList.add('pdm-metric--fa');
      }

      // ── Details: Build ──

      var physRow = document.getElementById('detail-row-physical');
      if (physRow) physRow.style.display = isDefense ? 'none' : '';
      var ht = formatHeight(playerData.height);
      var wt = playerData.weight ? playerData.weight + ' lbs' : null;
      setText('detail-physical-value', [ht, wt].filter(Boolean).join(' \u00B7 ') || '\u2014');

      // ── Details: Status ──

      var statusRow = document.getElementById('detail-row-status');
      if (statusRow) statusRow.style.display = isDefense ? 'none' : '';
      var injury = playerData.injuryStatus || 'Healthy';
      var depth = 'Starter';
      if (playerData.depthChartAhead && Array.isArray(playerData.depthChartAhead) && playerData.depthChartAhead.length > 0) {
        depth = 'Behind ' + playerData.depthChartAhead.map(function(p) { return p.name; }).join(', ');
      }
      setText('detail-status-value', injury + ' \u00B7 ' + depth);

      // ── Details: Draft ──

      var draftRow = document.getElementById('detail-row-draft');
      if (draftRow) draftRow.style.display = isDefense ? 'none' : '';

      if (!isDefense) {
        setText('detail-draft-text', formatDraft(playerData.draftYear, playerData.draftRound, playerData.draftPick, playerData.draftTeam));

        var draftLogo = document.getElementById('detail-draft-team-logo');
        if (draftLogo) {
          var normalizedTeam = playerData.draftTeam ? normalizeTeamCode(playerData.draftTeam) : null;
          var rawTeam = playerData.draftTeam ? playerData.draftTeam.toUpperCase() : '';
          var isUndrafted = !playerData.draftYear || rawTeam === 'FA' || rawTeam === 'UFA' ||
            (!playerData.draftRound && !playerData.draftPick && (normalizedTeam === 'NFL' || !normalizedTeam));
          if (isUndrafted) {
            draftLogo.src = '/assets/nfl-logos/NFL.svg';
            draftLogo.alt = 'NFL';
            draftLogo.style.display = 'inline-block';
          } else if (normalizedTeam) {
            draftLogo.src = '/assets/nfl-logos/' + normalizedTeam + '.svg';
            draftLogo.alt = nflTeamNames[normalizedTeam] || normalizedTeam;
            draftLogo.style.display = 'inline-block';
          } else {
            draftLogo.style.display = 'none';
          }
        }
      }

      // ── Details: College ──

      setText('detail-college', playerData.college || '\u2014');
      var collegeLogo = document.getElementById('detail-college-logo');
      if (collegeLogo) {
        if (playerData.collegeLogo) {
          collegeLogo.src = playerData.collegeLogo;
          collegeLogo.alt = playerData.college ? playerData.college + ' logo' : '';
          collegeLogo.style.display = 'inline-block';
        } else {
          collegeLogo.style.display = 'none';
          collegeLogo.src = '';
        }
      }

      // ── Details: Contract breakdown ──

      var cParts = [];
      var salaryStr = formatCurrency(playerData.salary);
      if (salaryStr) cParts.push(salaryStr);
      if (playerData.contractYears) cParts.push(playerData.contractYears + ' yr' + (playerData.contractYears > 1 ? 's' : ''));
      var totalRem = formatCurrency(playerData.totalRemaining);
      if (totalRem) cParts.push(totalRem + ' remaining');
      var cType = formatContractType(playerData.contractType);
      if (cType) cParts.push(cType);
      setText('detail-contract-detail', cParts.length > 0 ? cParts.join(' \u00B7 ') : 'Free Agent');

      // ── Details: Bye ──

      setText('detail-bye-value', playerData.byeWeek != null ? 'Week ' + playerData.byeWeek : '\u2014');

      // ── Weekly Results ──

      var weeklySection = document.getElementById('section-weekly-results');
      var weeklyBody = document.getElementById('weekly-results-body');
      var weeklyFoot = document.getElementById('weekly-results-foot');
      var weeklyTotal = document.getElementById('weekly-results-total');
      var avgHeader = document.getElementById('wr-avg-header');
      var rankHeader = document.getElementById('wr-rank-header');

      if (weeklySection && weeklyBody) {
        if (!window._weeklyPlayerData) {
          var dataEl = document.getElementById('weekly-player-results');
          if (dataEl) {
            try { window._weeklyPlayerData = JSON.parse(dataEl.textContent || '{}'); }
            catch (_e) { window._weeklyPlayerData = {}; }
          } else {
            window._weeklyPlayerData = {};
          }
        }

        var playerWeeks = window._weeklyPlayerData[playerData.id];

        if (playerWeeks && playerWeeks.length > 0) {
          weeklySection.style.display = '';

          var pos = (playerData.position || '').toUpperCase();
          var displayPos = ['SWR', 'LWR', 'RWR'].indexOf(pos) >= 0 ? 'WR' : pos;
          if (avgHeader) avgHeader.textContent = 'Avg vs ' + displayPos;
          if (rankHeader) rankHeader.textContent = 'Rank vs ' + displayPos;

          var html = '';
          var totalPts = 0;
          var gamesPlayed = 0;

          for (var i = 0; i < playerWeeks.length; i++) {
            var w = playerWeeks[i];
            var isBye = w.st === 'BYE';
            var ptsStr = w.p !== null ? w.p.toFixed(2) : '';
            var oppStr = w.opp || (isBye ? 'Bye' : '');
            var avgStr = w.avg !== null ? w.avg.toFixed(1) : '';
            var rankStr = w.rank !== null ? String(w.rank) : '';

            var badgeBg = w.st === 'S' ? '#2563eb' : '#9333ea';
            var statusStr = '';
            if (isBye) {
              statusStr = '';
            } else if (w.fi && w.st) {
              statusStr = '<div style="position:relative;display:inline-block;width:28px;height:28px;"><img src="/assets/theleague/icons/' + w.fi + '.png" alt="' + (w.fn || '') + '" style="width:24px;height:24px;display:block;" onerror="this.style.display=\'none\'"><span style="position:absolute;bottom:-3px;right:-5px;background:' + badgeBg + ';color:#fff;font-size:0.5rem;font-weight:700;line-height:1;padding:2px 3px;border-radius:50%;border:1.5px solid #fff;min-width:12px;text-align:center;">' + w.st + '</span></div>';
            } else if (w.st) {
              statusStr = w.st;
            }

            var rankClass = 'wr-rank';
            if (w.rank !== null) {
              if (w.rank <= 8) rankClass += ' wr-rank-easy';
              else if (w.rank >= 25) rankClass += ' wr-rank-hard';
            }

            var statusClass = w.st === 'S' ? 'wr-starter' : w.st === 'NS' ? 'wr-nonstarter' : '';
            var rowClass = isBye ? 'wr-bye-row' : (w.p === null && !isBye ? 'wr-empty-row' : '');

            if (w.p !== null) {
              totalPts += w.p;
              gamesPlayed++;
            }

            html += '<tr class="' + rowClass + '">' +
              '<td class="wr-wk">' + w.w + '</td>' +
              '<td class="wr-pts">' + ptsStr + '</td>' +
              '<td class="wr-opp">' + oppStr + '</td>' +
              '<td class="wr-avg">' + avgStr + '</td>' +
              '<td class="' + rankClass + '">' + rankStr + '</td>' +
              '<td class="wr-status ' + statusClass + '">' + statusStr + '</td>' +
              '</tr>';
          }

          weeklyBody.innerHTML = html;

          if (weeklyFoot && weeklyTotal && gamesPlayed > 0) {
            weeklyFoot.style.display = '';
            weeklyTotal.textContent = totalPts.toFixed(2);
          } else if (weeklyFoot) {
            weeklyFoot.style.display = 'none';
          }

          // Update metric cards with actual season data
          if (gamesPlayed > 0) {
            setText('metric-points-value', totalPts.toFixed(1));
            setText('metric-points-label', gamesPlayed + ' Games');
            setText('metric-ppg-value', (totalPts / gamesPlayed).toFixed(1));
          }
        } else {
          weeklySection.style.display = 'none';
          weeklyBody.innerHTML = '';
          if (weeklyFoot) weeklyFoot.style.display = 'none';
        }
      }

      // ── Open ──

      if (modal) modal.classList.add('active');
    };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayerDetailsModal);
  } else {
    initPlayerDetailsModal();
  }

  // Re-initialize after View Transitions (Astro page navigation)
  document.addEventListener('astro:page-load', initPlayerDetailsModal);
</script>
