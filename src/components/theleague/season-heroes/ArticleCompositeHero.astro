---
/**
 * ArticleCompositeHero — the 'article' daily slot (a waiver-pickup Schefter
 * article, non-Friday), composite edition. The SUBJECT of the story models the
 * hero: the article's own player (`post.playerIds`) rendered as a transparent
 * ESPN cutout on his NFL team's color, with the article headline, an excerpt,
 * and a "Read" CTA (the article's link, or its Schefter thread page).
 *
 * Selects the SAME article ArticleHero.astro would (waiver/pickup/claim match
 * within 7 days, else newest) via the pure `selectWaiverPickupArticle`, then
 * casts that article's own player with `castStoryModel`. When the article has
 * no playerIds or nothing composites (DEF / MFL-only photo), it renders the
 * legacy <ArticleHero> — a gradient with no face reads as broken.
 *
 * Self-loads the feed + casts internally (mirrors the other season composite
 * heroes, which load their own data).
 */
import type { HeroState } from '../../../types/hero-state';
import { getCurrentLeagueYear } from '../../../utils/league-year';
import { getPlayerMap } from '../../../utils/player-map';
import { castStoryModel } from '../../../utils/hero-casting';
import { selectWaiverPickupArticle } from '../../../utils/hero-data/article-hero-data';
import { getNflTeamColors, getNflTeamNickname, hexToRgba } from '../../../utils/nfl-team-colors';
import { normalizeTeamCode } from '../../../utils/nfl-logo';
import feedData from '../../../data/theleague/schefter-feed.json';
import ArticleHero from './ArticleHero.astro';

export interface Props {
  state: HeroState;
  resolveLeaguePath: (path: string) => string;
}

const { state, resolveLeaguePath: r } = Astro.props;

const refDate = state.metadata.referenceDate;
const article = selectWaiverPickupArticle((feedData as any)?.posts, refDate);

// Cast the article's OWN player (the subject of the story).
const players = getPlayerMap(getCurrentLeagueYear(refDate));
const model = article && article.playerIds.length > 0
  ? castStoryModel(article.playerIds, players, 'In the News')
  : null;

// Everything below is only used on the composite path.
const teamCode = model ? normalizeTeamCode(model.nflTeam) : '';
const nickname = model ? getNflTeamNickname(teamCode) : '';
const { primary } = model ? getNflTeamColors(teamCode) : { primary: '#1c497c' };
const glowDark = hexToRgba(primary, 0.4);
const glowLight = hexToRgba(primary, 0.22);

// Relative-day eyebrow ("2 DAYS AGO") from the article timestamp.
let timeAgo = '';
if (article?.timestamp) {
  const ts = Date.parse(article.timestamp);
  if (Number.isFinite(ts)) {
    const minsAgo = Math.max(0, Math.floor((refDate.getTime() - ts) / 60_000));
    timeAgo =
      minsAgo < 60
        ? `${Math.max(1, minsAgo)} MIN AGO`
        : minsAgo < 1440
          ? `${Math.floor(minsAgo / 60)} HR${Math.floor(minsAgo / 60) === 1 ? '' : 'S'} AGO`
          : `${Math.floor(minsAgo / 1440)} DAY${Math.floor(minsAgo / 1440) === 1 ? '' : 'S'} AGO`;
  }
}

// Trim the body to a hero-sized excerpt without cutting a word mid-way.
const excerpt = article
  ? article.body.length > 180
    ? article.body.slice(0, 180).replace(/\s+\S*$/, '') + '…'
    : article.body
  : '';

// Prefer the article's own link; fall back to its Schefter thread page.
const ctaHref = article?.link || (article ? r(`/theleague/schefter/thread/${article.id}`) : '#');
const ctaExternal = /^https?:\/\//.test(ctaHref);
---

{article && model ? (
  <section
    class="ach-hero"
    style={`--ach-glow-dark: ${glowDark}; --ach-glow-light: ${glowLight};`}
    aria-label="Waiver report"
  >
    <span class="ach-hero__ghost" aria-hidden="true">{nickname}</span>
    <div class="ach-hero__glow" aria-hidden="true"></div>
    <img
      class="ach-hero__model"
      src={model.headshot}
      alt=""
      aria-hidden="true"
      loading="eager"
      decoding="async"
      onerror="this.style.display='none'; this.closest('.ach-hero').classList.add('ach-hero--no-model')"
    />
    <span class="ach-hero__caption">
      <strong>{model.name}</strong>
      <span class="ach-hero__caption-meta">{model.position} · {teamCode}</span>
    </span>

    <div class="ach-hero__content">
      <p class="ach-hero__eyebrow">
        <span class="ach-hero__tag">Waiver Report</span>
        {timeAgo && <time class="ach-hero__time">{timeAgo}</time>}
      </p>
      <h2 class="ach-hero__title">{article.headline}</h2>
      {excerpt && <p class="ach-hero__summary">{excerpt}</p>}
      <a
        class="ach-hero__cta"
        href={ctaHref}
        target={ctaExternal ? '_blank' : undefined}
        rel={ctaExternal ? 'noopener noreferrer' : undefined}
      >
        Read the report
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
) : (
  <ArticleHero state={state} articleType="waiver-pickup" />
)}

<style>
  .ach-hero {
    /* Light theme (default); html.dark flips to the deep-charcoal chrome. */
    --ach-surface: linear-gradient(115deg, #f6f8fb 0%, #eef2f7 52%, #e4ebf3 100%);
    --ach-ink: var(--color-gray-900, #0f1419);
    --ach-body: rgba(22, 32, 44, 0.72);
    --ach-ghost: rgba(28, 73, 124, 0.06);
    --ach-glow: var(--ach-glow-light, rgba(28, 73, 124, 0.22));
    --ach-shadow: rgba(15, 30, 46, 0.3);
    --ach-tag-bg: var(--color-primary, #1c497c);
    --ach-tag-ink: #ffffff;
    --ach-cta-bg: var(--color-gray-900, #0f1419);
    --ach-cta-ink: #ffffff;
    --ach-border: rgba(28, 73, 124, 0.18);

    position: relative;
    overflow: hidden;
    min-height: clamp(250px, 25vw, 300px);
    border-radius: var(--radius-lg, 0.75rem);
    border: 1px solid var(--ach-border);
    background: var(--ach-surface);
    color: var(--ach-ink);
    display: flex;
    align-items: center;
    padding: clamp(1.25rem, 2.5vw, 1.9rem);
  }

  :global(html.dark) .ach-hero {
    --ach-surface: linear-gradient(115deg, #0b1017 0%, #101a26 46%, #14263a 130%);
    --ach-ink: #ffffff;
    --ach-body: rgba(255, 255, 255, 0.78);
    --ach-ghost: rgba(255, 255, 255, 0.045);
    --ach-glow: var(--ach-glow-dark, rgba(28, 73, 124, 0.4));
    --ach-shadow: rgba(0, 0, 0, 0.5);
    --ach-tag-bg: #7cb2ff;
    --ach-tag-ink: #0b1017;
    --ach-cta-bg: #ffffff;
    --ach-cta-ink: #0b1017;
    --ach-border: rgba(255, 255, 255, 0.1);
  }

  .ach-hero__ghost {
    position: absolute;
    left: 40%;
    top: -1.1rem;
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 800;
    font-style: italic;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ach-ghost);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .ach-hero__glow {
    position: absolute;
    right: -70px;
    top: -100px;
    width: 440px;
    height: 440px;
    background: radial-gradient(circle, var(--ach-glow) 0%, transparent 65%);
    pointer-events: none;
  }

  .ach-hero__model {
    position: absolute;
    right: clamp(0.25rem, 2vw, 1.75rem);
    bottom: 0;
    width: clamp(288px, 38vw, 438px);
    filter: drop-shadow(0 16px 32px var(--ach-shadow));
  }

  .ach-hero--no-model .ach-hero__caption {
    display: none;
  }

  .ach-hero__caption {
    position: absolute;
    z-index: 2;
    right: clamp(0.875rem, 2vw, 1.5rem);
    bottom: 0.875rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.125rem;
    text-align: right;
    color: #fff;
    background: rgba(6, 9, 13, 0.55);
    padding: 0.4rem 0.65rem;
    border-radius: 6px;
    backdrop-filter: blur(2px);
  }

  .ach-hero__caption strong {
    font-size: 0.8125rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .ach-hero__caption-meta {
    font-size: 0.575rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.65);
  }

  .ach-hero__content {
    position: relative;
    z-index: 2;
    max-width: min(34rem, 64%);
  }

  .ach-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 0.7rem;
  }

  .ach-hero__tag {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ach-tag-ink);
    background: var(--ach-tag-bg);
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
  }

  .ach-hero__time {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ach-body);
    font-variant-numeric: tabular-nums;
  }

  .ach-hero__title {
    color: var(--ach-ink);
    font-size: clamp(1.35rem, 2.7vw, 1.8rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin: 0 0 0.5rem;
  }

  .ach-hero__summary {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ach-body);
    max-width: 48ch;
    margin: 0 0 1rem;
  }

  .ach-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ach-cta-bg);
    color: var(--ach-cta-ink);
    font-size: 0.8125rem;
    font-weight: 700;
    padding: 0.6rem 1.05rem;
    border-radius: var(--radius-md, 0.5rem);
    text-decoration: none;
    transition: transform 120ms ease;
  }

  .ach-hero__cta:hover {
    transform: translateY(-1px);
  }

  .ach-hero__cta:focus-visible {
    outline: 2px solid var(--ach-tag-bg);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .ach-hero__cta {
      transition: none;
    }

    .ach-hero__cta:hover {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .ach-hero {
      min-height: 260px;
    }

    .ach-hero__model {
      width: 175px;
      right: -1.5rem;
      opacity: 0.4;
    }

    .ach-hero__caption {
      display: none;
    }

    .ach-hero__content {
      max-width: 100%;
    }
  }
</style>
