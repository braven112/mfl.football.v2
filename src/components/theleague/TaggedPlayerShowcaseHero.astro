---
/**
 * TaggedPlayerShowcaseHero — franchise-tagged players during the showcase
 * window (Feb 15 → auction start). Wears the shared branded EventHeroShell
 * with a panel of tagged players (on-navy rows: headshot + name/pos + the
 * tagging franchise). Gracefully handles the empty state before any tags.
 */
import EventHeroShell from './EventHeroShell.astro';
import type { HeroState } from '../../types/hero-state';

export interface Props {
  taggedShowcaseProps?: HeroState['taggedShowcaseProps'];
  resolveLeaguePath: (path: string) => string;
  spriteUrl: string;
}

const { taggedShowcaseProps, resolveLeaguePath: r } = Astro.props;
const taggedPlayers = taggedShowcaseProps?.taggedPlayers ?? [];
const hasPlayers = taggedPlayers.length > 0;
const displayPlayers = taggedPlayers.slice(0, 5);
const moreCount = Math.max(0, taggedPlayers.length - 5);

const summary = hasPlayers
  ? 'These franchise-tagged players can still be poached — make an offer before the matching period ends.'
  : 'No franchise tags filed yet. Check back as teams protect their cores before the auction opens.';
---

<EventHeroShell
  pill="Tag showcase"
  headline="Tagged players"
  accentWord="in play."
  summary={summary}
  icon="franchise-tag"
  accent="#2563eb"
  glow="rgba(37,99,235,.5)"
  countValue={hasPlayers ? taggedPlayers.length : undefined}
  countLabel={hasPlayers ? (taggedPlayers.length === 1 ? 'Player tagged' : 'Players tagged') : undefined}
  link={r('/theleague/rosters')}
  linkLabel={hasPlayers ? 'View roster details' : 'View all rosters'}
  regionLabel="Tagged players showcase"
>
  <div class="tl-hero-panel" slot="panel">
    <h3 class="tl-hero-panel__title">{hasPlayers ? 'On the tag' : 'Tag status'}</h3>

    {hasPlayers ? (
      <>
        {displayPlayers.map((p) => (
          <div class="tl-hero-panel__row tps-row">
            <img class="tps-row__head" src={p.headshot} alt="" width="30" height="30" loading="eager" />
            <div class="tps-row__id">
              <span class="tps-row__name">{p.playerName}</span>
              <span class="tps-row__meta">{[p.position, p.nflTeam].filter(Boolean).join(' · ')}</span>
            </div>
            {p.franchiseIcon && (
              <img class="tps-row__fran" src={p.franchiseIcon} alt="" width="18" height="18" loading="eager" title={`Tagged by ${p.franchiseName}`} />
            )}
          </div>
        ))}
        {moreCount > 0 && (
          <a href={r('/theleague/rosters')} class="tl-hero-panel__more-link">
            and {moreCount} more tagged player{moreCount !== 1 ? 's' : ''} →
          </a>
        )}
      </>
    ) : (
      <p class="tl-hero-panel__empty">
        Tags are filed through the deadline. The board fills in as owners lock down their keepers.
      </p>
    )}
  </div>
</EventHeroShell>

<style>
  .tps-row {
    flex-direction: row;
    align-items: center;
    gap: 0.55rem;
  }
  .tps-row__head {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }
  .tps-row__id {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .tps-row__name {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .tps-row__meta {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
  }
  .tps-row__fran {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
</style>
