---
/**
 * DraftHero — Rookie draft command center (draft hero window: Monday after the
 * NFL Draft → +30 days / completion). Wears the shared branded EventHeroShell
 * (draft-purple accent) with a day countdown / LIVE state, the draft-a-player
 * CTA, and a quick-links panel. Key format rules are folded into the summary;
 * full rules sit one click away in the panel.
 */
import EventHeroShell from './EventHeroShell.astro';
import { getRookieDraftDate } from '../../utils/league-event-resolver';

export interface Props {
  leagueYear: number;
  mflHost?: string;
  leagueId?: string;
  resolveLeaguePath: (path: string) => string;
  /** Cache-busted sprite URL (for the quick-link icons) */
  spriteUrl: string;
  live?: boolean;
  draftStartFormatted: string;
  /** Reference date (from the resolver) — drives the countdown to the rookie draft. */
  referenceDate?: Date;
}

const {
  leagueYear,
  mflHost = 'www49.myfantasyleague.com',
  leagueId = '13522',
  resolveLeaguePath: r,
  spriteUrl,
  live = true,
  draftStartFormatted,
  referenceDate,
} = Astro.props;

const now = referenceDate ?? new Date();
const mflBase = `https://${mflHost}/${leagueYear}/options?L=${leagueId}`;

const draftDate = getRookieDraftDate(leagueYear);
const startOfDay = (d: Date) => { const o = new Date(d); o.setHours(0, 0, 0, 0); return o; };
const daysUntil = Math.max(0, Math.ceil((startOfDay(draftDate).getTime() - startOfDay(now).getTime()) / 86_400_000));

const summary = live
  ? 'The rookie draft is under way — three rounds, rookies only, 12-hour pick timer. Make your picks.'
  : `Three rounds, rookies only, 12-hour pick timer (paused 3am–7am PT). Draft starts ${draftStartFormatted}.`;

interface QuickLink { label: string; href: string; icon: string; external: boolean; }
const quickLinks: QuickLink[] = [
  { label: 'Draft order', href: r(`/theleague/draft-predictor?view=history&year=${leagueYear}&team=all`), icon: 'standings-2', external: false },
  { label: 'Draft results', href: r('/theleague/draft-room'), icon: 'check', external: false },
  { label: 'Future picks', href: `${mflBase}&O=100`, icon: 'calendar', external: true },
  { label: 'Free agents', href: r('/theleague/players'), icon: 'binoculars', external: false },
  { label: 'Trade builder', href: r('/theleague/trade-builder'), icon: 'transactions-2', external: false },
  { label: 'Rosters', href: r('/theleague/rosters'), icon: 'banknote', external: false },
  { label: 'Draft rules', href: r('/theleague/rules#draft-rules'), icon: 'clipboard', external: false },
];
---

<EventHeroShell
  pill={live ? 'Draft under way' : 'Draft day is coming'}
  headline="Rookie"
  accentWord="draft."
  summary={summary}
  icon="draft-podium"
  accent="#7c3aed"
  glow="rgba(124,58,237,.5)"
  bordered
  countValue={live ? 'LIVE' : daysUntil}
  countLabel={live ? 'Drafting now' : 'Days to rookie draft'}
  link={`${mflBase}&O=52`}
  linkLabel="Draft a player"
  isExternal
  regionLabel="Rookie draft command center"
>
  <nav class="tl-hero-panel" slot="panel" aria-label="Rookie draft quick links">
    <h3 class="tl-hero-panel__title">Quick links</h3>
    <div class="tl-hero-panel__links">
      {quickLinks.map((link) => (
        <a
          href={link.href}
          class="tl-hero-panel__link"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          aria-label={link.external ? `${link.label} (opens in new tab)` : undefined}
        >
          <svg class="tl-hero-panel__link-icon" aria-hidden="true"><use href={`${spriteUrl}#icon-${link.icon}`}></use></svg>
          <span class="tl-hero-panel__link-label">{link.label}</span>
          {link.external && <span class="tl-hero-panel__link-ext" aria-hidden="true">↗</span>}
        </a>
      ))}
    </div>
  </nav>
</EventHeroShell>
