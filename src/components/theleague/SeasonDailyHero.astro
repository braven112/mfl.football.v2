---
/**
 * SeasonDailyHero — Routing wrapper for the context-aware hero system.
 *
 * Pure conditional renderer: receives a fully-resolved HeroState from the page
 * frontmatter and routes to the correct sub-component. Contains zero data-fetching
 * logic and zero business logic about which slot to show.
 */
import type { HeroState } from '../../types/hero-state';
import type { MatchupPairing, TeamInfo } from '../../types/live-scoring';
import AuctionHero from './AuctionHero.astro';
import AuctionCompositeHero from './AuctionCompositeHero.astro';
import DraftHero from './DraftHero.astro';
import FeatureCompositeHero from './FeatureCompositeHero.astro';
import HeroBanner from './HeroBanner.astro';
import LeagueEventHero from './LeagueEventHero.astro';
import type { HeroModel } from '../../utils/hero-casting';
import LiveScoringHero from '../shared/LiveScoringHero';
import TradeDeadlineHero from './TradeDeadlineHero';
import PlayoffBracketHero from './PlayoffBracketHero';
import '../../styles/live-scoring-hero.css';
import '../../styles/trade-deadline-hero.css';
import '../../styles/playoff-bracket-hero.css';
import '../../styles/playoff-round-hero.css';

// Off-season hero components (Phase C)
import ChampionCrownedHero from './ChampionCrownedHero.astro';
import TagExtensionHero from './TagExtensionHero.astro';
import TaggedPlayerShowcaseHero from './TaggedPlayerShowcaseHero.astro';
import CutWatchHero from './CutWatchHero.astro';
import CutWatchCompositeHero from './CutWatchCompositeHero.astro';
import PreseasonCompositeHero from './PreseasonCompositeHero.astro';
import UdfaCompositeHero from './UdfaCompositeHero.astro';
import UDFAHero from './UDFAHero.astro';
import PreseasonCountdownHero from './PreseasonCountdownHero.astro';
import DraftCountdownHero from './DraftCountdownHero.astro';

// Daily rotation — real components (Phase D)
import StandingsHero from './season-heroes/StandingsHero.astro';
import RecapHero from './season-heroes/RecapHero.astro';
import WaiverWireHero from './season-heroes/WaiverWireHero.astro';
import ArticleHero from './season-heroes/ArticleHero.astro';
import WeekendPreviewHero from './season-heroes/WeekendPreviewHero.astro';
import MatchupPreviewHero from './season-heroes/MatchupPreviewHero.astro';
import PlayoffRoundHero from './playoff-heroes/PlayoffRoundHero.astro';
import BreakingStoryHero from './BreakingStoryHero.astro';
import type { BreakingStory } from '../../utils/offseason-hero-data';

export interface Props {
  /** Fully resolved hero state from the page frontmatter */
  state: HeroState;
  /** Path resolver from layout (needed by AuctionHero/DraftHero) */
  resolveLeaguePath: (path: string) => string;
  /** Sprite URL (needed by AuctionHero/DraftHero) */
  spriteUrl: string;
  /** Live scoring data (only when slot === 'live-scoring') */
  liveScoring?: {
    week: number;
    userFranchiseId?: string;
    matchups: MatchupPairing[];
    teams: Record<string, TeamInfo>;
    initialScores?: Record<string, number>;
    initialRemaining?: Record<string, number>;
  };
  /** Logged-in user's franchise ID (for personalized heroes) */
  userFranchiseId?: string;
  /** Whether the user is authenticated */
  isAuthenticated?: boolean;
  /** Cast rookie model for the fresh What's New composite hero (page-resolved) */
  featureModel?: HeroModel | null;
  /** Cast best-available free agent for the auction composite hero (page-resolved) */
  auctionModel?: HeroModel | null;
  /** Live auction: the soonest-closing bid the model represents */
  auctionClosingBid?: { bid: number; franchiseName: string; endsAtMs: number } | null;
  /** Cast bubble player for the cut-watch composite hero (page-resolved) */
  cutWatchModel?: HeroModel | null;
  /** Best rookies on the board for the UDFA panel hero (page-resolved) */
  udfaModels?: HeroModel[];
  /** Cast kickoff-game headliner for the preseason composite hero (page-resolved) */
  preseasonModel?: HeroModel | null;
  /** Whether preseasonModel is the signed-in owner's own player */
  preseasonModelIsOwn?: boolean;
  /** The earliest game of the week (for the opener line in the summary) */
  kickoffGame?: { awayName: string; homeName: string } | null;
  /** Cast headline player + story for the breaking-story hero (page-resolved) */
  breakingModel?: HeroModel | null;
  breakingStory?: BreakingStory | null;
}

const { state, resolveLeaguePath, spriteUrl, liveScoring, userFranchiseId, isAuthenticated, featureModel, auctionModel, auctionClosingBid, cutWatchModel, udfaModels = [], preseasonModel, preseasonModelIsOwn, kickoffGame, breakingModel, breakingStory } = Astro.props;

// Fresh What's New (P2) always gets the composite treatment. The model is
// category-cast in the page frontmatter (rookie for new pages/features,
// first-five-years for enhancements) and deliberately null for bug-fix
// rollups — the component renders the league logo silhouette instead.
const showFeatureComposite =
  state.phase === 'offseason-fallback' && state.fallbackHero?.source === 'feature';

const phase = state.phase;
const slot = state.slot;
const fallback = state.fallbackHero;

// Article slot disambiguation: Friday → weekend preview, else → waiver pickup report
const ptWeekday = slot === 'article'
  ? new Intl.DateTimeFormat('en-US', { timeZone: 'America/Los_Angeles', weekday: 'short' }).format(state.metadata.referenceDate)
  : undefined;
const isFridayArticle = ptWeekday === 'Fri';
---

{/* P0: Auction hero — composite with the best available free agent when a
    model was cast; legacy command-center shell as the defensive fallback */}
{(phase === 'auction-preview' || phase === 'auction-live') && state.auctionProps && (
  auctionModel ? (
    <AuctionCompositeHero
      leagueYear={state.auctionProps.leagueYear}
      resolveLeaguePath={resolveLeaguePath}
      live={state.auctionProps.live}
      model={auctionModel}
      closingBid={auctionClosingBid}
      referenceDate={state.metadata.referenceDate}
    />
  ) : (
    <AuctionHero
      leagueYear={state.auctionProps.leagueYear}
      resolveLeaguePath={resolveLeaguePath}
      spriteUrl={spriteUrl}
      live={state.auctionProps.live}
      referenceDate={state.metadata.referenceDate}
    />
  )
)}

{/* P0: Draft hero — delegate to existing component */}
{(phase === 'draft-announced' || phase === 'draft-live') && state.draftProps && (
  <DraftHero
    leagueYear={state.draftProps.leagueYear}
    resolveLeaguePath={resolveLeaguePath}
    spriteUrl={spriteUrl}
    live={state.draftProps.live}
    draftStartFormatted={state.draftProps.draftStartFormatted}
    referenceDate={state.metadata.referenceDate}
  />
)}

{/* P0++: Trade Deadline hero — dedicated countdown component */}
{phase === 'trade-deadline' && state.tradeDeadlineProps && (
  <TradeDeadlineHero
    client:load
    deadlineMidnightPT={state.tradeDeadlineProps.deadlineMidnightPT}
    referenceNowISO={state.metadata.testMode ? state.metadata.referenceDate.toISOString() : undefined}
  />
)}

{/* Breaking story (P0) — a fresh <48h trade/auction bomb leads every non-live slot. */}
{phase === 'breaking-story' && breakingModel && breakingStory && (
  <BreakingStoryHero
    model={breakingModel}
    story={breakingStory}
    resolveLeaguePath={resolveLeaguePath}
    referenceDate={state.metadata.referenceDate}
  />
)}

{/* Daily rotation slots (regular-season, playoffs, championship) */}
{slot === 'live-scoring' && liveScoring && (
  <LiveScoringHero
    client:load
    week={liveScoring.week}
    phase={state.phase as 'regular-season' | 'playoffs' | 'championship'}
    gameWindow={state.metadata.gameWindow}
    isLive={state.metadata.isLive}
    userFranchiseId={liveScoring.userFranchiseId}
    matchups={liveScoring.matchups}
    teams={liveScoring.teams}
    initialScores={liveScoring.initialScores}
    initialRemaining={liveScoring.initialRemaining}
  />
)}
{/* Playoff round hero (wild card / semifinals / championship) — the composite
    round view when resolved, else the legacy bracket list, else standings. */}
{slot === 'standings' && (phase === 'playoffs' || phase === 'championship') && state.playoffProps?.roundView && (
  <PlayoffRoundHero view={state.playoffProps.roundView} r={resolveLeaguePath} />
)}
{slot === 'standings' && (phase === 'playoffs' || phase === 'championship') && state.playoffProps && !state.playoffProps.roundView && (
  <PlayoffBracketHero
    client:idle
    leagueYear={state.playoffProps.leagueYear}
    userFranchiseId={state.playoffProps.userFranchiseId}
    userIsEliminated={state.playoffProps.userIsEliminated}
    bracketSummary={state.playoffProps.bracketSummary}
  />
)}
{slot === 'standings' && ((phase !== 'playoffs' && phase !== 'championship') || !state.playoffProps) && (
  <StandingsHero state={state} resolveLeaguePath={resolveLeaguePath} userFranchiseId={userFranchiseId} />
)}
{slot === 'recap' && <RecapHero state={state} />}
{slot === 'waiver-wire' && <WaiverWireHero state={state} resolveLeaguePath={resolveLeaguePath} />}
{slot === 'article' && isFridayArticle && <WeekendPreviewHero state={state} />}
{slot === 'article' && !isFridayArticle && <ArticleHero state={state} articleType="waiver-pickup" />}
{slot === 'game-day-preview' && <MatchupPreviewHero state={state} resolveLeaguePath={resolveLeaguePath} userFranchiseId={userFranchiseId} />}

{/* Off-season heroes: dedicated components */}
{phase === 'champion-crowned' && state.championProps && (
  <ChampionCrownedHero
    championProps={state.championProps}
    resolveLeaguePath={resolveLeaguePath}
    spriteUrl={spriteUrl}
    userFranchiseId={userFranchiseId}
  />
)}

{phase === 'tag-window' && (
  <TagExtensionHero
    resolveLeaguePath={resolveLeaguePath}
    referenceDate={state.metadata.referenceDate}
  />
)}

{phase === 'tagged-showcase' && (
  <TaggedPlayerShowcaseHero
    taggedShowcaseProps={state.taggedShowcaseProps}
    resolveLeaguePath={resolveLeaguePath}
  />
)}

{phase === 'udfa-window' && (
  udfaModels.length >= 2 ? (
    <UdfaCompositeHero models={udfaModels} resolveLeaguePath={resolveLeaguePath} />
  ) : (
    <UDFAHero
      resolveLeaguePath={resolveLeaguePath}
      referenceDate={state.metadata.referenceDate}
    />
  )
)}

{phase === 'cut-watch' && (
  cutWatchModel && state.cutWatchProps ? (
    <CutWatchCompositeHero
      cutWatchProps={state.cutWatchProps}
      model={cutWatchModel}
      resolveLeaguePath={resolveLeaguePath}
      userFranchiseId={userFranchiseId}
    />
  ) : (
    <CutWatchHero
      cutWatchProps={state.cutWatchProps}
      resolveLeaguePath={resolveLeaguePath}
      spriteUrl={spriteUrl}
      userFranchiseId={userFranchiseId}
    />
  )
)}

{phase === 'preseason-countdown' && (
  preseasonModel && state.preseasonProps ? (
    <PreseasonCompositeHero
      preseasonProps={state.preseasonProps}
      model={preseasonModel}
      resolveLeaguePath={resolveLeaguePath}
      isOwnHeadliner={preseasonModelIsOwn}
      kickoffGame={kickoffGame}
    />
  ) : (
    <PreseasonCountdownHero
      preseasonProps={state.preseasonProps}
      resolveLeaguePath={resolveLeaguePath}
      referenceDate={state.metadata.referenceDate}
    />
  )
)}

{phase === 'draft-countdown' && (
  <DraftCountdownHero
    draftCountdownProps={state.draftCountdownProps}
    resolveLeaguePath={resolveLeaguePath}
    referenceDate={state.metadata.referenceDate}
  />
)}

{/* P2 fresh What's New: composite hero with a rookie model */}
{showFeatureComposite && (
  <FeatureCompositeHero
    content={state.fallbackHero!}
    model={featureModel}
    resolveLeaguePath={resolveLeaguePath}
  />
)}

{/* Fallback phases (offseason-fallback): branded LeagueEventHero, with HeroBanner as a defensive fallback */}
{!showFeatureComposite && !slot && !state.auctionProps && !state.draftProps && !state.tradeDeadlineProps
  && !state.championProps && !state.taggedShowcaseProps && !state.cutWatchProps
  && !state.preseasonProps && !state.draftCountdownProps
  && phase !== 'tag-window' && phase !== 'udfa-window' && phase !== 'preseason-countdown'
  && phase !== 'draft-countdown'
  && (state.eventView ? (
  <LeagueEventHero
    {...state.eventView}
    bordered={state.eventBordered}
    regionLabel="Featured league event"
  />
) : fallback ? (
  <HeroBanner
    title={fallback.title}
    summary={fallback.summary}
    link={fallback.link}
    linkLabel={fallback.linkLabel}
    icon={fallback.icon}
    accentColor={fallback.accentColor}
    variant="editorial"
    isActive={fallback.isActive}
    isUrgent={fallback.isUrgent}
    kicker={fallback.kicker}
    kickerDate={fallback.kickerDate}
  />
) : null)}

{/* Defensive empty-state: ensures the section landmark is never silently empty */}
{!slot && !state.auctionProps && !state.draftProps && !fallback && (
  <div class="hero-stub">
    <div class="hero-stub__body">
      <p class="hero-stub__desc">League updates coming soon.</p>
    </div>
  </div>
)}
