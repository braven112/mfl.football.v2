---
/**
 * AuctionHero — Free-agent auction command center (auction hero window: Monday
 * before the 3rd Thursday of March → +30 days). Wears the shared branded
 * EventHeroShell (amber "money" accent) with a day countdown / LIVE state, the
 * Place-a-bid CTA, and a quick-links panel. Key rules are folded into the
 * summary; the full rules sit one click away in the panel.
 */
import EventHeroShell from './EventHeroShell.astro';
import { randomHeroPlayer } from '../../utils/hero-players';
import { getNthDayOfMonth } from '../../utils/league-event-resolver';

export interface Props {
  /** League year for constructing MFL external URLs */
  leagueYear: number;
  mflHost?: string;
  leagueId?: string;
  resolveLeaguePath: (path: string) => string;
  /** Cache-busted sprite URL (for the quick-link icons) */
  spriteUrl: string;
  /** Whether the auction is live (true) or upcoming (false) */
  live?: boolean;
  /** Reference date (from the resolver) — countdown + day-stable player image. */
  referenceDate?: Date;
}

const {
  leagueYear,
  mflHost = 'www49.myfantasyleague.com',
  leagueId = '13522',
  resolveLeaguePath: r,
  spriteUrl,
  live = true,
  referenceDate,
} = Astro.props;

const now = referenceDate ?? new Date();
const mflBase = `https://${mflHost}/${leagueYear}/options?L=${leagueId}`;

const auctionStartDate = getNthDayOfMonth(leagueYear, 2, 4, 3); // 3rd Thursday of March
const startOfDay = (d: Date) => { const o = new Date(d); o.setHours(0, 0, 0, 0); return o; };
const daysUntil = Math.max(0, Math.ceil((startOfDay(auctionStartDate).getTime() - startOfDay(now).getTime()) / 86_400_000));

const summary = live
  ? 'The auction is under way — place bids, track results, and build your roster.'
  : 'Auction season is almost here — $425K minimum bid, $25K increments, 36 hours without a new bid wins. Get your roster ready.';

interface QuickLink { label: string; href: string; icon: string; external: boolean; }
const quickLinks: QuickLink[] = [
  { label: 'Auction summary', href: `${mflBase}&O=44`, icon: 'bar-chart', external: true },
  { label: 'Completed auctions', href: `${mflBase}&O=43`, icon: 'check', external: true },
  { label: 'Free agents', href: r('/theleague/players'), icon: 'binoculars', external: false },
  { label: 'Trade builder', href: r('/theleague/trade-builder'), icon: 'transactions-2', external: false },
  { label: 'Rosters', href: r('/theleague/rosters'), icon: 'banknote', external: false },
  { label: 'Salary trends', href: r('/theleague/salary-history'), icon: 'standings-2', external: false },
  { label: 'Auction rules', href: r('/theleague/rules#free-agent-bidding'), icon: 'clipboard', external: false },
];
---

<EventHeroShell
  pill={live ? 'Auction live' : 'Auction opens soon'}
  headline="Free agent"
  accentWord="auction."
  summary={summary}
  icon="gavel"
  accent="#d97706"
  glow="rgba(217,119,6,.5)"
  bordered
  countValue={live ? 'LIVE' : daysUntil}
  countLabel={live ? 'Bidding now' : 'Days to auction · 7AM PT'}
  link={`${mflBase}&O=43`}
  linkLabel="Place auction bid"
  isExternal
  regionLabel="Free agent auction command center"
>
  <nav class="tl-hero-panel" slot="panel" aria-label="Auction quick links">
    <h3 class="tl-hero-panel__title">Quick links</h3>
    <div class="ah-links">
      {quickLinks.map((link) => (
        <a
          href={link.href}
          class="ah-link"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          aria-label={link.external ? `${link.label} (opens in new tab)` : undefined}
        >
          <svg class="ah-link__icon" aria-hidden="true"><use href={`${spriteUrl}#icon-${link.icon}`}></use></svg>
          <span class="ah-link__label">{link.label}</span>
          {link.external && <span class="ah-link__ext" aria-hidden="true">↗</span>}
        </a>
      ))}
    </div>
  </nav>
</EventHeroShell>

<style>
  .ah-links {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .ah-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-md, 0.5rem);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.78rem;
    font-weight: 600;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .ah-link:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.25);
  }
  .ah-link__icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
    fill: var(--ev-accent, #d97706);
  }
  .ah-link__label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ah-link__ext {
    margin-left: auto;
    font-size: 0.7rem;
    opacity: 0.5;
    flex-shrink: 0;
  }
</style>
