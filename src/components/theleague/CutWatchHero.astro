---
/**
 * CutWatchHero — the cut-to-22 / "declare rookie contracts" roster deadline
 * hero (phase `cut-watch`, Jul 15 → 3rd Sunday of August).
 *
 * Wears the shared branded EventHeroShell (deep navy, red urgency accent) and
 * keeps its full functionality: a day countdown to the deadline plus a panel
 * of teams over the 22-man active limit, each with the bubble players most
 * likely to be cut — now surfacing position + salary (already in the data).
 */
import EventHeroShell from './EventHeroShell.astro';
import { formatCompactNumber } from '../../utils/formatters';
import { TARGET_ACTIVE_COUNT } from '../../utils/salary-calculations';
import type { HeroState } from '../../types/hero-state';

export interface Props {
  cutWatchProps?: HeroState['cutWatchProps'];
  resolveLeaguePath: (path: string) => string;
  spriteUrl: string;
  /** Logged-in user's franchise id — their team leads the list when over the limit. */
  userFranchiseId?: string;
}

const { cutWatchProps, resolveLeaguePath: r, userFranchiseId } = Astro.props;
const overLimitTeams = cutWatchProps?.overLimitTeams ?? [];
const deadlineDate = cutWatchProps?.deadlineDate ?? '';
const daysUntilDeadline = cutWatchProps?.daysUntilDeadline ?? 0;
const hasOverLimit = overLimitTeams.length > 0;
const isDeadlineDay = daysUntilDeadline === 0;

// Personalized order: the user's team leads (if over the limit), then everyone
// else by most active players descending (closest to the chopping block first).
const byActiveDesc = [...overLimitTeams].sort((a, b) => b.activeCount - a.activeCount);
const userTeam = userFranchiseId
  ? byActiveDesc.find((t) => t.franchiseId === userFranchiseId)
  : undefined;
const orderedTeams = userTeam
  ? [userTeam, ...byActiveDesc.filter((t) => t.franchiseId !== userFranchiseId)]
  : byActiveDesc;
// Side-by-side (height-matched) shows 3; stacked (mobile) has room for 4. The
// 4th row + the "more" counts are toggled by the panel's stacking breakpoint.
const displayTeams = orderedTeams.slice(0, 4);
const sideMore = Math.max(0, orderedTeams.length - 3);
const stackMore = Math.max(0, orderedTeams.length - 4);

/** Player names arrive as "Last, First" — keep the last name for a compact bubble. */
const lastName = (name: string) => name.split(',')[0].trim();
/** Compact bubble meta, e.g. "RB $7M" — both fields are optional. */
const playerMeta = (position: string, salary: number) =>
  [position, salary ? `$${formatCompactNumber(salary)}` : null].filter(Boolean).join(' ');

// How many the logged-in user is over the 22-man limit (0 if not over / not logged in).
const userOverBy = userTeam ? Math.max(0, userTeam.activeCount - TARGET_ACTIVE_COUNT) : 0;

const summary = userOverBy > 0
  ? `${isDeadlineDay ? 'Final cuts are due today' : `Roster cuts are due ${deadlineDate}`} — you're ${userOverBy} over the limit.`
  : isDeadlineDay
    ? 'Final cuts are due today — every roster must be at 22 active players. Who goes?'
    : `Teams must cut to 22 active players by ${deadlineDate}. Who's on the bubble?`;
---

<EventHeroShell
  pill="Cut watch"
  headline="Roster deadline"
  accentWord={isDeadlineDay ? 'today.' : 'approaching.'}
  summary={summary}
  icon="clipboard"
  accent="#dc2626"
  glow="rgba(220,38,38,.30)"
  bordered
  countValue={daysUntilDeadline}
  countLabel={isDeadlineDay ? 'Cuts due today' : 'Days to lock'}
  link={r('/theleague/rosters')}
  linkLabel="View full rosters"
  regionLabel="Cut Watch — roster deadline"
>
  <div class="tl-hero-panel" slot="panel">
    <h3 class="tl-hero-panel__title">{hasOverLimit ? 'Over the limit' : 'Roster status'}</h3>

    {hasOverLimit ? (
      <>
        {displayTeams.map((team, i) => (
          <div class:list={['tl-hero-panel__row', { 'tl-hero-panel__row--mine': team.franchiseId === userFranchiseId, 'cw-row--overflow': i === 3 }]}>
            <div class="cw-team">
              {team.franchiseIcon && (
                <img class="cw-team__icon" src={team.franchiseIcon} alt="" width="22" height="22" loading="eager" />
              )}
              <span class="cw-team__name">{team.franchiseNameShort || team.franchiseName}</span>
              {team.franchiseId === userFranchiseId && <span class="cw-team__you">You</span>}
              <span class="cw-team__count">{team.activeCount} active</span>
            </div>
            {team.cutCandidates.length > 0 && (
              <p class="cw-bubble">
                <span class="cw-bubble__label">Bubble</span>
                {team.cutCandidates.slice(0, 3).map((c, i) => (
                  <>
                    {i > 0 && <span class="cw-bubble__sep"> · </span>}
                    <span class="cw-bubble__player">
                      {lastName(c.playerName)} <span class="cw-bubble__meta">{playerMeta(c.position, c.salary)}</span>
                    </span>
                  </>
                ))}
              </p>
            )}
          </div>
        ))}
        {sideMore > 0 && (
          <a href={r('/theleague/rosters')} class="tl-hero-panel__more-link cw-more--side">
            and {sideMore} more team{sideMore !== 1 ? 's' : ''} →
          </a>
        )}
        {stackMore > 0 && (
          <a href={r('/theleague/rosters')} class="tl-hero-panel__more-link cw-more--stack">
            and {stackMore} more team{stackMore !== 1 ? 's' : ''} →
          </a>
        )}
      </>
    ) : (
      <p class="tl-hero-panel__empty">
        All teams are at or below the 22-player active limit. Looking good.
      </p>
    )}
  </div>
</EventHeroShell>

<style>
  .cw-team {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cw-team__icon {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .cw-team__name {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .cw-team__you {
    flex-shrink: 0;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.08rem 0.4rem;
    border-radius: 999px;
    background: var(--ev-accent, #dc2626);
    color: #fff;
  }
  .cw-team__count {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ev-accent, #dc2626);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
    white-space: nowrap;
    margin-left: auto;
  }

  /* The logged-in user's team — brighter row so it reads as "yours". */
  .tl-hero-panel__row--mine {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.12);
  }

  /* Side-by-side panel is height-matched to the content — show the top 3.
     When the panel stacks (mobile) there's room, so reveal the 4th. */
  .tl-hero-panel__row.cw-row--overflow {
    display: none;
  }
  .cw-more--stack {
    display: none;
  }
  @media (max-width: 640px) {
    .tl-hero-panel__row.cw-row--overflow {
      display: flex;
    }
    .cw-more--side {
      display: none;
    }
    .cw-more--stack {
      display: inline;
    }
  }

  /* Compact bubble: last names + muted pos/salary, players inline, wrapping
     between players (each player name stays on one line). */
  .cw-bubble {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.82);
    overflow-wrap: break-word;
  }
  .cw-bubble__label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.4);
    margin-right: 0.4rem;
  }
  .cw-bubble__player {
    white-space: nowrap;
  }
  .cw-bubble__sep {
    color: rgba(255, 255, 255, 0.3);
  }
  .cw-bubble__meta {
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
  }
</style>
