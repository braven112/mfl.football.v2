---
/**
 * HpStandingsCompact — All 16 teams in a compact standings table with cap space.
 * During the offseason (no games played), shows cap space rankings instead.
 */
import { chooseTeamName } from '../../../utils/team-names';
import { resolveLeaguePath } from '../../../utils/nav-utils';
import { formatCompactNumber } from '../../../utils/formatters';
import { getCurrentSeasonYear } from '../../../utils/league-year';
import { getContextualRows } from '../../../utils/homepage-dashboard';
import { getLeagueStandings } from '../../../utils/standings';
import type { TeamSummary } from '../../../utils/league-summary-utils';
import config from '../../../data/theleague.config.json';

interface Props {
  userFranchiseId?: string;
  teamSummaries?: TeamSummary[];
  referenceDate?: Date;
}

const { userFranchiseId, teamSummaries, referenceDate } = Astro.props;
const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

const year = getCurrentSeasonYear(referenceDate);
const teams = config.teams ?? [];
const teamMap = new Map(teams.map((t: any) => [t.franchiseId, t]));

// Build cap space lookup from teamSummaries
const capMap = new Map<string, number>();
if (teamSummaries) {
  for (const ts of teamSummaries) {
    capMap.set(ts.franchiseId, ts.metrics.capSpace?.[0] ?? 0);
  }
}

// Load standings data
let standingsData: any;
try {
  standingsData = await import(`../../../../data/theleague/mfl-feeds/${year}/standings.json`);
} catch {
  standingsData = null;
}

const franchises = standingsData?.leagueStandings?.franchise ?? standingsData?.default?.leagueStandings?.franchise ?? [];
const hasGamesPlayed = franchises.some((f: any) => parseFloat(f.pf) > 0);

interface StandingRow {
  id: string;
  rank: number;
  name: string;
  record: string;
  wins: number;
  pf: number;
  capSpace: number;
  isUser: boolean;
  color: string;
}

let rows: StandingRow[] = [];

if (hasGamesPlayed) {
  // In-season: use playoff seeding with full tiebreakers (division winners seeds 1-4)
  const seeded = getLeagueStandings(franchises, config as any);
  rows = seeded.map((t, idx) => {
    const team = teamMap.get(t.id);
    const record = t.h2hwlt ?? '0-0-0';
    const [w] = record.split('-').map(Number);
    const pf = parseFloat(t.pf || '0');
    const displayName = team
      ? chooseTeamName({
          fullName: team.name,
          nameMedium: team.nameMedium,
          nameShort: team.nameShort,
          abbrev: team.abbrev,
        }, 'default')
      : t.teamName ?? t.id;

    return {
      id: t.id,
      rank: t.seed ?? idx + 1,
      name: displayName,
      record,
      wins: w,
      pf,
      capSpace: capMap.get(t.id) ?? 0,
      isUser: t.id === userFranchiseId,
      color: team?.color ?? 'var(--color-primary, #1c497c)',
    };
  });
} else {
  // Offseason: sort by cap space, show cap as the primary metric
  rows = (teamSummaries ?? [])
    .map(ts => {
      const team = teamMap.get(ts.franchiseId);
      const displayName = team
        ? chooseTeamName({
            fullName: team.name,
            nameMedium: team.nameMedium,
            nameShort: team.nameShort,
            abbrev: team.abbrev,
          }, 'default')
        : ts.teamName;

      return {
        id: ts.franchiseId,
        rank: 0,
        name: displayName,
        record: '--',
        wins: 0,
        pf: 0,
        capSpace: ts.metrics.capSpace?.[0] ?? 0,
        isUser: ts.franchiseId === userFranchiseId,
        color: team?.color ?? 'var(--color-primary, #1c497c)',
      };
    })
    .sort((a, b) => b.capSpace - a.capSpace);
}

if (!hasGamesPlayed) {
  rows = rows.map((row, index) => ({
    ...row,
    rank: index + 1,
  }));
}

const contextual = getContextualRows(rows, userFranchiseId, 2, 6);
const displayRows = contextual.rows;
const userRow = userFranchiseId ? rows.find((row) => row.id === userFranchiseId) : undefined;
const teamAbove = userRow && userRow.rank > 1 ? rows[userRow.rank - 2] : undefined;
const teamBelow = userRow && userRow.rank < rows.length ? rows[userRow.rank] : undefined;

function formatOrdinal(value: number): string {
  const mod100 = value % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${value}th`;
  const mod10 = value % 10;
  if (mod10 === 1) return `${value}st`;
  if (mod10 === 2) return `${value}nd`;
  if (mod10 === 3) return `${value}rd`;
  return `${value}th`;
}

const subtitle = userRow
  ? hasGamesPlayed
    ? teamAbove && teamBelow
      ? `You are ${formatOrdinal(userRow.rank)} of ${rows.length}, between ${teamAbove.name} and ${teamBelow.name}.`
      : userRow.rank === 1
        ? `You are ${formatOrdinal(userRow.rank)} of ${rows.length} and currently leading the league.`
        : `You are ${formatOrdinal(userRow.rank)} of ${rows.length} with one team directly above you.`
    : teamAbove && teamBelow
      ? `You are ${formatOrdinal(userRow.rank)} of ${rows.length} in cap space, between ${teamAbove.name} and ${teamBelow.name}.`
      : userRow.rank === 1
        ? `You currently lead the league in cap space.`
        : `You are ${formatOrdinal(userRow.rank)} of ${rows.length} in cap space.`
  : hasGamesPlayed
    ? 'Showing the teams nearest the top of the current race.'
    : 'Showing the current cap-space leaders.';

const formatCap = (v: number) => {
  const prefix = v < 0 ? '-' : '';
  return `${prefix}$${formatCompactNumber(Math.abs(v))}`;
};
---

<section class="hp-standings" aria-label="League standings">
  <div class="hp-standings__header">
    <div class="hp-standings__section-header">
      <h3 class="hp-standings__section-title">
        {hasGamesPlayed ? 'Playoff Standings' : 'Cap Space Rankings'}
      </h3>
      <p class="hp-standings__sub">{subtitle}</p>
    </div>
    <a href={r('/theleague/standings?view=league')} class="hp-standings__cta">
      Full standings
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <div class="hp-standings__table-wrap">
    <table class="hp-standings__table" role="table">
      <thead>
        <tr>
          <th class="hp-standings__th hp-standings__th--rank">#</th>
          <th class="hp-standings__th hp-standings__th--team">Team</th>
          {hasGamesPlayed && (
            <th class="hp-standings__th hp-standings__th--record">Record</th>
          )}
          {hasGamesPlayed && (
            <th class="hp-standings__th hp-standings__th--pf">PF</th>
          )}
          <th class="hp-standings__th hp-standings__th--cap">Cap Space</th>
        </tr>
      </thead>
      <tbody>
        {displayRows.map((row) => (
          <tr class:list={['hp-standings__row', { 'hp-standings__row--user': row.isUser }]}>
            <td class="hp-standings__td hp-standings__td--rank">{row.rank}</td>
            <td class="hp-standings__td hp-standings__td--team">
              <span class="hp-standings__team-indicator" style={`background: ${row.color}`} aria-hidden="true"></span>
              <span class={row.isUser ? 'hp-standings__team-name--bold' : ''}>{row.name}</span>
            </td>
            {hasGamesPlayed && (
              <td class="hp-standings__td hp-standings__td--record">{row.record}</td>
            )}
            {hasGamesPlayed && (
              <td class="hp-standings__td hp-standings__td--pf">{row.pf.toLocaleString('en-US', { maximumFractionDigits: 1 })}</td>
            )}
            <td class:list={[
              'hp-standings__td',
              'hp-standings__td--cap',
              { 'hp-standings__td--cap-negative': row.capSpace < 0 },
            ]}>
              {formatCap(row.capSpace)}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .hp-standings {
    --dh-accent: var(--color-primary, #1c497c);
    --dh-highlight-bg: color-mix(in srgb, var(--dh-accent) 6%, transparent);
    background: var(--content-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-md);
    padding: 1.5rem;
  }

  .hp-standings__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .hp-standings__section-header {
    padding-left: 0.625rem;
    border-left: 2px solid var(--dh-accent);
  }

  .hp-standings__section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    line-height: 1;
    color: var(--color-gray-700, #374151);
  }

  .hp-standings__sub {
    margin: 0.375rem 0 0;
    font-size: 0.8125rem;
    color: var(--color-gray-500, #6b7280);
  }

  .hp-standings__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--dh-accent);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .hp-standings__cta:hover {
    gap: 0.5rem;
  }

  .hp-standings__table-wrap {
    overflow-x: auto;
  }

  .hp-standings__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }

  .hp-standings__th {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-400, #9ca3af);
    padding: 0 0.5rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    white-space: nowrap;
  }

  .hp-standings__th--rank { width: 2rem; text-align: center; }
  .hp-standings__th--record,
  .hp-standings__th--pf,
  .hp-standings__th--cap { text-align: right; }

  .hp-standings__row {
    transition: background 0.1s ease;
  }

  .hp-standings__row:hover {
    background: var(--color-gray-50, #f9fafb);
  }

  .hp-standings__row--user {
    background: var(--dh-highlight-bg);
  }

  .hp-standings__row--user .hp-standings__td:first-child {
    box-shadow: inset 3px 0 0 var(--dh-accent);
  }

  .hp-standings__row--user:hover {
    background: color-mix(in srgb, var(--dh-accent) 10%, transparent);
  }

  .hp-standings__td {
    padding: 0.375rem 0.5rem;
    border-bottom: 1px solid var(--color-gray-50, #f9fafb);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .hp-standings__td--rank {
    text-align: center;
    color: var(--color-gray-400, #9ca3af);
    font-size: 0.6875rem;
    font-weight: 600;
    width: 2rem;
  }

  .hp-standings__td--team {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--color-gray-800, #1f2937);
  }

  .hp-standings__team-indicator {
    width: 3px;
    height: 0.875rem;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .hp-standings__team-name--bold {
    font-weight: 700;
  }

  .hp-standings__td--record {
    text-align: right;
    color: var(--color-gray-700, #374151);
  }

  .hp-standings__td--pf {
    text-align: right;
    color: var(--color-gray-600, #4b5563);
  }

  .hp-standings__td--cap {
    text-align: right;
    color: var(--color-gray-600, #4b5563);
    font-size: 0.75rem;
  }

  .hp-standings__td--cap-negative {
    color: var(--color-red-600, #dc2626);
  }

  @media (max-width: 640px) {
    .hp-standings {
      padding: 1.25rem;
    }

    .hp-standings__header {
      flex-direction: column;
      align-items: stretch;
    }

    .hp-standings__th--pf,
    .hp-standings__td--pf {
      display: none;
    }
  }
</style>
