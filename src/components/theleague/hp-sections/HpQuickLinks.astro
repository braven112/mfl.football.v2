---
/**
 * HpQuickLinks — thin wrapper around the shared QuickLinks component.
 *
 * Kept so existing importers (src/pages/theleague/index.astro) need no
 * changes. All logic + markup live in shared/hp-sections/QuickLinks.astro;
 * this just forwards the auth flag and pins TheLeague league prop.
 */
import QuickLinks from '../../shared/hp-sections/QuickLinks.astro';

interface Props {
  isAuthenticated?: boolean;
}

const { isAuthenticated } = Astro.props;
---
<QuickLinks league="theleague" isAuthenticated={isAuthenticated} />
