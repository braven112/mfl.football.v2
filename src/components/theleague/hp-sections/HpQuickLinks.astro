---
/**
 * HpQuickLinks — Discovery grid for the homepage.
 * Shows top pages sorted by popularity, with "My Team" tools prioritized for logged-in users.
 */
import { spriteUrl } from '../../../utils/sprite-url';
import { resolveLeaguePath } from '../../../utils/nav-utils';

interface Props {
  isAuthenticated?: boolean;
}

const { isAuthenticated } = Astro.props;
const hideLeaguePrefix = Astro.locals.hideLeaguePrefix ?? false;
const r = (path: string) => resolveLeaguePath(path, hideLeaguePrefix);

interface PageEntry {
  id: string;
  title: string;
  description: string;
  path: string;
  icon: string;
  category: string;
  visibility: string;
  popularity: number;
}

const allPages: PageEntry[] = (await import('../../../data/page-directory.json')).default;

// Filter to visible, non-admin pages (except for authenticated users)
const visible = allPages.filter(p => p.visibility === 'all' && p.id !== 'homepage' && p.id !== 'new-hp');

// Sort: logged-in users get "my-team" tools first, then by popularity
const sorted = [...visible].sort((a, b) => {
  if (isAuthenticated) {
    const aMyTeam = a.category === 'my-team' ? 1 : 0;
    const bMyTeam = b.category === 'my-team' ? 1 : 0;
    if (aMyTeam !== bMyTeam) return bMyTeam - aMyTeam;
  }
  return b.popularity - a.popularity;
});

// Pin the Stats & Reports hub so it always surfaces on the homepage.
const PINNED_IDS = ['stats'];
const pinned = PINNED_IDS
  .map(id => visible.find(p => p.id === id))
  .filter((p): p is PageEntry => Boolean(p));
const rest = sorted.filter(p => !PINNED_IDS.includes(p.id));
const pages = [...pinned, ...rest].slice(0, 8);
---

<section class="hp-links" aria-label="Quick links">
  <div class="hp-links__header">
    <h3 class="hp-links__title">Explore</h3>
    <a href={r('/theleague/search')} class="hp-links__cta">
      All pages
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
  <div class="hp-links__grid">
    {pages.map(page => (
      <a href={r(`/theleague${page.path}`)} class="hp-links__card">
        <svg class="hp-links__icon" width="20" height="20" aria-hidden="true">
          <use href={`${spriteUrl}#icon-${page.icon}`} />
        </svg>
        <div class="hp-links__text">
          <span class="hp-links__name">{page.title}</span>
          <span class="hp-links__desc">{page.description}</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .hp-links {
    --dh-accent: var(--color-primary, #1c497c);
    background: var(--content-bg, #fff);
    border: 1px solid var(--content-border, #e2e8f0);
    border-radius: var(--radius-md, 0.5rem);
    box-shadow: var(--shadow-md);
    padding: 1.5rem;
  }

  .hp-links__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .hp-links__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-left: 0.625rem;
    border-left: 2px solid var(--dh-accent);
    margin: 0;
    line-height: 1;
    color: var(--color-gray-700, #374151);
  }

  .hp-links__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--dh-accent);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .hp-links__cta:hover {
    gap: 0.5rem;
  }

  .hp-links__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .hp-links__card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: var(--radius-md, 0.5rem);
    background: var(--color-gray-50, #f9fafb);
    text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .hp-links__card:hover {
    background: var(--color-gray-100, #f3f4f6);
    transform: translateY(-1px);
  }

  .hp-links__icon {
    flex-shrink: 0;
    color: var(--dh-accent);
    margin-top: 0.125rem;
  }

  .hp-links__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .hp-links__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gray-800, #1f2937);
    line-height: 1.3;
  }

  .hp-links__desc {
    font-size: 0.6875rem;
    color: var(--color-gray-500, #6b7280);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .hp-links {
      padding: 1.25rem;
    }

    .hp-links__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
