---
/**
 * FreeAgentNeedsCard - Shows top free agents at positions where a team has gaps
 *
 * Displays position tabs (only for positions with needs) with a list of 5
 * recommended free agents per tab. Uses PlayerCell for avatar/name/position
 * lockup and supports client-side ranking column injection.
 */
import ChartCard from './ChartCard.astro';
import PlayerCell from './PlayerCell.astro';
import { normalizeTeamCode } from '../../utils/nfl-logo';
import type { PositionNeed } from '../../utils/free-agent-needs';

export interface Props {
  needs: PositionNeed[];
  franchiseId: string;
}

const { needs, franchiseId } = Astro.props;
const cardId = `fa-needs-${franchiseId}`;
const hasNeeds = needs.length > 0;
---

<ChartCard title="Potential Targets" subtitle={hasNeeds ? 'Top available players at positions your roster needs' : undefined}>
  <a href="/theleague/players" class="chart-card-link" title="Browse all free agents" slot="actions">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M8.5 1.5H2.5a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V7.5M14.5 1.5l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>
  </a>

  {hasNeeds ? (
    <div class="fa-needs" id={cardId}>
      <div class="fa-needs__tabs" role="tablist">
        {needs.map((need, i) => (
          <button
            class:list={['fa-needs__tab', { 'fa-needs__tab--active': i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`${cardId}-panel-${need.position}`}
            data-fa-tab={need.position}
          >
            {need.position}
          </button>
        ))}
      </div>

      {needs.map((need, i) => (
        <div
          class="fa-needs__panel"
          id={`${cardId}-panel-${need.position}`}
          role="tabpanel"
          data-fa-panel={need.position}
          style={i === 0 ? '' : 'display: none;'}
        >
          <ol class="fa-needs__list">
            {need.topFreeAgents.map((fa, idx) => {
              const isDef = fa.position?.toUpperCase() === 'DEF';
              const teamLogo = `/assets/nfl-logos/${normalizeTeamCode(fa.nflTeam || 'NFL')}.svg`;
              return (
              <li class="fa-needs__player" data-fa-player-id={fa.id}>
                <span class="fa-needs__rank">{idx + 1}</span>
                <PlayerCell
                  name={fa.name}
                  headshot={isDef ? teamLogo : fa.headshot}
                  position={fa.position}
                  nflTeam={fa.nflTeam}
                  nflLogo={isDef ? undefined : teamLogo}
                  class="fa-needs__player-cell"
                />
                <span class="fa-needs__proj">{fa.projectedScore.toFixed(1)} pts</span>
              </li>
              );
            })}
          </ol>
          <a href="/theleague/players" class="fa-needs__browse">
            Browse all {need.position} free agents &rarr;
          </a>
        </div>
      ))}
    </div>
  ) : (
    <div class="fa-needs__empty">
      <p>Your roster looks solid across all positions.</p>
      <a href="/theleague/players" class="fa-needs__browse">Browse free agents &rarr;</a>
    </div>
  )}
</ChartCard>

<style>
  .fa-needs__tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 2px solid var(--primary-content-border-color, #e2e8f0);
    padding-bottom: 0;
    margin-bottom: 0.75rem;
  }

  .fa-needs__tab {
    all: unset;
    cursor: pointer;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary-color, #64748b);
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: color 0.15s, border-color 0.15s;
  }

  .fa-needs__tab:hover {
    color: var(--text-primary-color, #111827);
  }

  .fa-needs__tab--active {
    color: var(--primary-color, #1c497c);
    border-bottom-color: var(--primary-color, #1c497c);
  }

  .fa-needs__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .fa-needs__player {
    display: grid;
    grid-template-columns: 1.5rem 1fr auto;
    gap: 0.5rem;
    align-items: center;
    padding: 0.5rem 0.25rem;
    border-radius: 0.375rem;
  }

  .fa-needs__player:nth-child(odd) {
    background: var(--table-stripe-bg, rgba(0, 0, 0, 0.02));
  }

  .fa-needs__rank {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-secondary-color, #64748b);
    text-align: center;
  }

  /* Compact PlayerCell within FA needs card */
  .fa-needs__player-cell :global(.player-cell) {
    gap: 0.5rem;
  }

  .fa-needs__player-cell :global(.player-cell__avatar) {
    width: 32px;
    height: 32px;
  }

  .fa-needs__player-cell :global(.player-cell__name) {
    font-size: 0.8125rem;
  }

  .fa-needs__player-cell :global(.player-meta) {
    font-size: 0.75rem;
  }

  .fa-needs__player-cell :global(.player-meta__logo) {
    width: 14px;
    height: 14px;
  }

  .fa-needs__proj {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--secondary-color, #2e8743);
    white-space: nowrap;
  }

  .fa-needs__browse {
    display: block;
    text-align: center;
    margin-top: 0.75rem;
    padding: 0.5rem;
    font-size: 0.8125rem;
    color: var(--primary-color, #1c497c);
    text-decoration: none;
    border-top: 1px solid var(--primary-content-border-color, #e2e8f0);
  }

  .fa-needs__browse:hover {
    text-decoration: underline;
  }

  .fa-needs__empty {
    text-align: center;
    padding: 1rem 0;
  }

  .fa-needs__empty p {
    margin: 0 0 0.5rem;
    color: var(--text-secondary-color, #64748b);
    font-size: 0.875rem;
  }

  /* Ranking column values injected by client-side JS */
  :global(.fa-needs__rank-value) {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary-color, #64748b);
    text-align: center;
    min-width: 2rem;
  }

  :global(.fa-needs__rank-headers) {
    display: grid;
    gap: 0.5rem;
    padding: 0 0.25rem 0.25rem;
    align-items: center;
  }

  :global(.fa-needs__rank-header) {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--text-secondary-color, #64748b);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  @media (max-width: 640px) {
    .fa-needs__tab {
      padding: 0.375rem 0.625rem;
      font-size: 0.8125rem;
    }

    .fa-needs__player-cell :global(.player-cell__avatar) {
      width: 28px;
      height: 28px;
    }

    .fa-needs__player-cell :global(.player-cell__name) {
      font-size: 0.75rem;
    }
  }
</style>
