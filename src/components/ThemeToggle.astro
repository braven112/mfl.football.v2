---
/**
 * ThemeToggle - Reusable dark-mode preference control
 *
 * A 3-option segmented control (Light / Auto / Dark) implementing the
 * ARIA radiogroup pattern. Reads/writes the theme preference cookie via
 * `src/utils/theme-preference.ts` and hands resolution off to the global
 * `window.__applyTheme()` hook (defined by the inline head script that
 * resolves + applies the theme and dispatches a `theme-change` event).
 *
 * Multiple instances on the same page (e.g. a header dropdown + a drawer
 * footer control) stay in sync: every instance listens for the shared
 * `theme-change` event and re-renders its own checked state, regardless
 * of which instance triggered the change.
 *
 * NOTE: This component is not mounted anywhere yet. A later task wires
 * it into the nav header / drawer footer.
 *
 * @example Default (icon + label):
 * ```astro
 * <ThemeToggle />
 * ```
 *
 * @example Compact (icon-only, for nav drawer footer):
 * ```astro
 * <ThemeToggle size="compact" />
 * ```
 *
 * @example Explicit id (only needed if mounted twice on one page and you
 * need to target a specific instance from other code — internals use
 * classes, not ids, so this is rarely required):
 * ```astro
 * <ThemeToggle id="theme-toggle-header" />
 * ```
 */

export interface Props {
  /** Size variant. 'compact' is icon-only (label becomes a tooltip + aria-label). */
  size?: 'default' | 'compact';
  /** Optional wrapper id. Not required for instance sync — internals use classes. */
  id?: string;
  /** Additional CSS classes on the wrapper */
  class?: string;
}

const { size = 'default', id, class: className } = Astro.props;

const sizeClass = size === 'compact' ? 'theme-toggle--compact' : '';

const OPTIONS = [
  { value: 'light', label: 'Light' },
  { value: 'auto', label: 'Auto' },
  { value: 'dark', label: 'Dark' },
] as const;
---

<div class:list={['theme-toggle', sizeClass, className]} id={id}>
  <div class="theme-toggle__group" role="radiogroup" aria-label="Theme">
    {OPTIONS.map((opt, i) => (
      <button
        type="button"
        class="theme-toggle__option"
        role="radio"
        aria-checked="false"
        data-theme-value={opt.value}
        tabindex={i === 0 ? 0 : -1}
        aria-label={size === 'compact' ? opt.label : undefined}
        title={size === 'compact' ? opt.label : undefined}
      >
        <span class="theme-toggle__icon" aria-hidden="true">
          {opt.value === 'light' && (
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="8" r="3.25" />
              <path d="M8 0.75v1.75M8 13.5v1.75M2.4 2.4l1.24 1.24M12.36 12.36l1.24 1.24M0.75 8h1.75M13.5 8h1.75M2.4 13.6l1.24-1.24M12.36 3.64l1.24-1.24" />
            </svg>
          )}
          {opt.value === 'auto' && (
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="0.75" y="2.25" width="14.5" height="9.5" rx="1.25" />
              <path d="M5 14.25h6M8 11.75v2.5" />
              <path d="M8 2.25a4 4 0 0 1 0 8" fill="currentColor" stroke="none" />
            </svg>
          )}
          {opt.value === 'dark' && (
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13.5 8.6A5.75 5.75 0 1 1 7.4 2.5a4.6 4.6 0 0 0 6.1 6.1z" />
            </svg>
          )}
        </span>
        {size !== 'compact' && <span class="theme-toggle__label">{opt.label}</span>}
      </button>
    ))}
  </div>
</div>

<style>
  .theme-toggle {
    display: inline-flex;
  }

  .theme-toggle__group {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    padding: 0.1875rem;
    background: var(--nav-switcher-bg, #f3f4f6);
    border-radius: var(--radius-md, 0.5rem);
  }

  .theme-toggle__option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    background: transparent;
    border: none;
    border-radius: calc(var(--radius-md, 0.5rem) - 0.1875rem);
    color: var(--color-gray-500, #6b7280);
    cursor: pointer;
    line-height: 1;
    transition: background-color 150ms ease, color 150ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle__option {
      transition: none;
    }
  }

  .theme-toggle__option:hover {
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-700, #374151);
  }

  .theme-toggle__option[aria-checked='true'] {
    background: var(--league-accent, #1c497c);
    color: #fff;
  }

  .theme-toggle__option[aria-checked='true']:hover {
    background: var(--league-accent, #1c497c);
    color: #fff;
  }

  .theme-toggle__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .theme-toggle__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* Compact: icon-only, tighter padding */
  .theme-toggle--compact .theme-toggle__option {
    padding: 0.375rem;
  }

  /* Dark mode: same tokens re-resolve via tokens-dark.css; no overrides needed
     beyond ensuring the checked state keeps white text against the accent. */
  :global(.dark) .theme-toggle__option {
    color: var(--color-gray-400, #9ca3af);
  }

  :global(.dark) .theme-toggle__option:hover {
    background: var(--color-gray-100, #f3f4f6);
    color: var(--color-gray-700, #374151);
  }

  :global(.dark) .theme-toggle__option[aria-checked='true'] {
    background: var(--league-accent, #1c497c);
    color: #fff;
  }
</style>

<script>
  import { getClientThemePreference, setClientThemePreference, type ThemePreference } from '../utils/theme-preference';

  const VALUES: ThemePreference[] = ['light', 'auto', 'dark'];

  declare global {
    interface Window {
      __applyTheme?: (pref?: ThemePreference) => void;
      __themeToggleListenerBound?: boolean;
    }
  }

  /**
   * Manual fallback resolver, used only if window.__applyTheme is unavailable
   * (e.g. the resolver script hasn't loaded yet). Mirrors resolveTheme() in
   * theme-preference.ts without importing it, since this is a pure DOM fallback.
   */
  function resolveAndApplyFallback(pref: ThemePreference): void {
    const systemPrefersDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches ?? false;
    const resolved = pref === 'auto' ? (systemPrefersDark ? 'dark' : 'light') : pref;
    document.documentElement.classList.toggle('dark', resolved === 'dark');
  }

  function applyTheme(pref: ThemePreference): void {
    if (typeof window.__applyTheme === 'function') {
      window.__applyTheme(pref);
    } else {
      resolveAndApplyFallback(pref);
    }
  }

  function syncInstance(toggle: Element, pref: ThemePreference): void {
    const options = toggle.querySelectorAll<HTMLButtonElement>('.theme-toggle__option');
    options.forEach((btn) => {
      const isChecked = btn.dataset.themeValue === pref;
      btn.setAttribute('aria-checked', String(isChecked));
      btn.tabIndex = isChecked ? 0 : -1;
    });
  }

  function syncAllInstances(pref: ThemePreference): void {
    document.querySelectorAll('.theme-toggle').forEach((toggle) => syncInstance(toggle, pref));
  }

  function selectValue(toggle: Element, value: ThemePreference): void {
    setClientThemePreference(value);
    applyTheme(value);
    // Optimistically sync immediately; the theme-change listener will also
    // fire and re-sync (idempotent), covering cases where __applyTheme
    // resolves asynchronously or another instance needs updating too.
    syncAllInstances(value);
  }

  function handleClick(e: Event): void {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.theme-toggle__option');
    if (!btn) return;
    const value = btn.dataset.themeValue as ThemePreference | undefined;
    if (!value) return;
    selectValue(btn.closest('.theme-toggle')!, value);
  }

  function handleKeydown(e: KeyboardEvent): void {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.theme-toggle__option');
    if (!btn) return;
    const group = btn.closest('.theme-toggle__group');
    if (!group) return;

    const options = Array.from(group.querySelectorAll<HTMLButtonElement>('.theme-toggle__option'));
    const currentIndex = options.indexOf(btn);
    if (currentIndex === -1) return;

    let nextIndex: number | null = null;

    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
        nextIndex = (currentIndex + 1) % options.length;
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
        nextIndex = (currentIndex - 1 + options.length) % options.length;
        break;
      case 'Home':
        nextIndex = 0;
        break;
      case 'End':
        nextIndex = options.length - 1;
        break;
      case ' ':
      case 'Enter': {
        e.preventDefault();
        const value = btn.dataset.themeValue as ThemePreference | undefined;
        if (value) selectValue(btn.closest('.theme-toggle')!, value);
        return;
      }
      default:
        return;
    }

    e.preventDefault();
    const nextBtn = options[nextIndex];
    const value = nextBtn.dataset.themeValue as ThemePreference | undefined;
    if (!value) return;
    nextBtn.focus();
    selectValue(nextBtn.closest('.theme-toggle')!, value);
  }

  function initThemeToggles(): void {
    const toggles = document.querySelectorAll('.theme-toggle');
    if (toggles.length === 0) return;

    const currentPref = getClientThemePreference();

    toggles.forEach((toggle) => {
      syncInstance(toggle, currentPref);

      // Remove any previously-bound handlers before rebinding (defensive
      // against re-init on the same DOM node — matches the NavDrawer
      // cleanup-then-rebind pattern, though in practice astro:page-load
      // swaps in fresh nodes for SSR pages).
      toggle.removeEventListener('click', handleClick);
      toggle.addEventListener('click', handleClick);
      toggle.removeEventListener('keydown', handleKeydown as EventListener);
      toggle.addEventListener('keydown', handleKeydown as EventListener);
    });

    // Bind the shared theme-change listener exactly once per document.
    // `document` persists across ClientRouter soft navigations, so a
    // module-level re-run of initThemeToggles() on every astro:page-load
    // must not stack duplicate listeners.
    if (!window.__themeToggleListenerBound) {
      document.addEventListener('theme-change', ((e: CustomEvent<{ pref: ThemePreference; resolved: 'light' | 'dark' }>) => {
        syncAllInstances(e.detail.pref);
      }) as EventListener);
      window.__themeToggleListenerBound = true;
    }
  }

  initThemeToggles();
  document.addEventListener('astro:page-load', initThemeToggles);
</script>
