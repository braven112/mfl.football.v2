---
/**
 * NavFooter Component
 *
 * Fixed footer for the navigation drawer showing either:
 * 1. Authenticated state: Team logo, name, and owner info
 * 2. Unauthenticated state: "Verify Your Team" prompt with link to MFL
 *
 * Commissioners see a toggle button (up/down chevron) to switch between
 * owner mode and commissioner mode. Commissioner mode shows a circular
 * Goodell avatar and "Commissioner / League Office" labels.
 *
 * @see NavFooterProps in src/types/nav.ts
 * @see Design tokens in src/assets/css/src/_nav-tokens.scss
 */

import type { NavFooterProps, NavFooterLink, LeagueSlug } from '../../types/nav';
import { spriteUrl } from '../../utils/sprite-url';
import leagueConfigData from '../../data/theleague.config.json';

interface Props extends NavFooterProps {
  /** Current league for constructing roster link */
  league?: LeagueSlug;
}

// Build minimal team lookup map for client-side auth:login handling
const teamMap: Record<string, { name: string; icon: string | null }> = {};
for (const t of leagueConfigData.teams) {
  teamMap[t.franchiseId] = { name: t.name, icon: t.icon || null };
}

const {
  team,
  footerLinks = [],
  host,
  year,
  leagueId,
  verifyTeamUrl,
  league = 'theleague',
  isCommissioner = false,
  isCommishMode = false,
} = Astro.props;

// Build the roster GM page URL
const leagueBase = league === 'afl' ? '/afl-fantasy' : '/theleague';
const rosterUrl = `${leagueBase}/rosters`;

/**
 * Build the MFL verify team URL
 * Points to the custom MFL page with embedded script that detects franchise ID
 */
const defaultVerifyUrl = `https://${host}/${year}/home/${leagueId}?MODULE=MESSAGE20`;
const verifyUrl = verifyTeamUrl || defaultVerifyUrl;

/**
 * Resolve URL templates with runtime values
 */
function resolveUrlTemplate(template: string): string {
  return template
    .replace('{host}', host)
    .replace('{year}', String(year))
    .replace('{leagueId}', leagueId);
}

/**
 * Get the resolved URL for a footer link
 */
function getFooterLinkUrl(link: NavFooterLink): string {
  if (link.urlTemplate) {
    return resolveUrlTemplate(link.urlTemplate);
  }
  return link.url || '#';
}

const isAuthenticated = !!team;

// Determine initial display state for commissioner toggle
const showCommish = isCommissioner && isCommishMode;
---

<footer
  class="nav-footer"
  role="contentinfo"
  data-nav-footer
  data-team-map={JSON.stringify(teamMap)}
  data-roster-url={rosterUrl}
  data-sprite-url={spriteUrl}
>
  {/* Authenticated State: Team Info Row with optional commissioner toggle */}
  {isAuthenticated && (
    <div class="nav-footer__team-row">
      <a
        href={rosterUrl}
        class="nav-footer__team"
        aria-label={showCommish ? 'Commissioner dashboard' : `View ${team.teamName} roster`}
        data-commish-link
        data-owner-label={`View ${team.teamName} roster`}
      >
        <div
          class:list={['nav-footer__team-logo', { 'nav-footer__team-logo--commish': showCommish }]}
          data-commish-swap="logo"
        >
          {showCommish && (
            <img
              src="/assets/commissioner-avatar.webp?v=5"
              alt="Commissioner"
              class="nav-footer__team-img"
              width="40"
              height="40"
              loading="lazy"
            />
          )}
          {!showCommish && team.iconUrl && (
            <img
              src={team.iconUrl}
              alt={`${team.teamName} logo`}
              class="nav-footer__team-img"
              width="40"
              height="40"
              loading="lazy"
            />
          )}
          {!showCommish && !team.iconUrl && (
            <div class="nav-footer__team-placeholder">
              <svg class="nav-footer__icon" aria-hidden="true">
                <use href={`${spriteUrl}#icon-shield-2`}></use>
              </svg>
            </div>
          )}
        </div>
        <div class="nav-footer__team-info" data-commish-swap="info">
          <span class="nav-footer__team-name">{showCommish ? 'Commissioner' : team.teamName}</span>
          {showCommish && (
            <span class="nav-footer__owner-name">League Office</span>
          )}
          {!showCommish && team.ownerName && (
            <span class="nav-footer__owner-name">{team.ownerName}</span>
          )}
        </div>
      </a>
      {isCommissioner && (
        <button
          type="button"
          class="nav-footer__commish-toggle"
          aria-label={showCommish ? 'Switch to owner mode' : 'Switch to commissioner mode'}
          aria-pressed={showCommish ? 'true' : 'false'}
          data-commish-toggle
          data-commish-team-name={team.teamName}
          data-commish-team-icon={team.iconUrl || ''}
          data-commish-team-owner={team.ownerName || ''}
          data-sprite-url={spriteUrl}
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 15l5 5 5-5" />
            <path d="M7 9l5-5 5 5" />
          </svg>
        </button>
      )}
    </div>
  )}

  {/* Screen reader announcement region for commissioner toggle */}
  {isAuthenticated && isCommissioner && (
    <div class="visually-hidden" aria-live="polite" role="status" aria-atomic="true" data-commish-announce></div>
  )}

  {/* Unauthenticated State: Verify Prompt */}
  {!isAuthenticated && (
    <a
      href={`${leagueBase}/login`}
      class="nav-footer__verify"
      aria-label="Log in to verify your team"
    >
      <div class="nav-footer__verify-icon">
        <svg class="nav-footer__icon" aria-hidden="true">
          <use href={`${spriteUrl}#icon-user`}></use>
        </svg>
      </div>
      <div class="nav-footer__verify-info">
        <span class="nav-footer__verify-label">Verify Your Team</span>
        <span class="nav-footer__verify-hint">Link your MFL account</span>
      </div>
      <svg class="nav-footer__verify-arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6" />
      </svg>
    </a>
  )}

  {/* Footer Links (e.g., "Back to MFL") */}
  {footerLinks.length > 0 && (
    <div class="nav-footer__links">
      {footerLinks.map((link) => (
        <a
          href={getFooterLinkUrl(link)}
          class="nav-footer__link"
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
        >
          <svg class="nav-footer__link-icon" aria-hidden="true">
            <use href={`${spriteUrl}#icon-${link.icon}`}></use>
          </svg>
          <span>{link.label}</span>
        </a>
      ))}
    </div>
  )}
</footer>

{/* Commissioner toggle client-side behavior — unconditional script, guarded by element check */}
<script>
  function initCommishToggle() {
    const COOKIE_NAME = 'commish-mode';
    const toggle = document.querySelector('[data-commish-toggle]') as HTMLButtonElement | null;
    if (!toggle) return;
    if (toggle.dataset.commishToggleBound === '1') return;
    toggle.dataset.commishToggleBound = '1';

    function isCommishMode(): boolean {
      return document.cookie.split('; ').some(c => c === `${COOKIE_NAME}=true`);
    }

    toggle.addEventListener('click', () => {
      const entering = !isCommishMode();
      // Set or clear the cookie, then reload so the server renders the correct state
      if (entering) {
        document.cookie = `${COOKIE_NAME}=true; path=/; max-age=31536000; SameSite=Lax`;
      } else {
        document.cookie = `${COOKIE_NAME}=; path=/; max-age=0`;
      }
      window.location.reload();
    });
  }

  // Initialize on page load and after View Transitions
  document.addEventListener('astro:page-load', initCommishToggle);
</script>

{/* Client-side auth:login handler — swaps "Verify Your Team" → team info when login happens without page reload */}
<script>
  let navFooterAuthLoginBound = false;

  function initAuthLoginListener() {
    if (navFooterAuthLoginBound) return;
    navFooterAuthLoginBound = true;

    window.addEventListener('auth:login', ((e: CustomEvent<{ franchiseId: string }>) => {
      const footer = document.querySelector('[data-nav-footer]') as HTMLElement | null;
      if (!footer) return;

      const teamMapRaw = footer.dataset.teamMap;
      const rosterUrl = footer.dataset.rosterUrl || '/theleague/rosters';
      const spUrl = footer.dataset.spriteUrl || '/assets/icons/sprite.svg';
      if (!teamMapRaw) return;

      let teamMap: Record<string, { name: string; icon: string | null }>;
      try { teamMap = JSON.parse(teamMapRaw); } catch { return; }

      const franchiseId = e.detail?.franchiseId;
      if (!franchiseId) return;

      const team = teamMap[franchiseId];
      if (!team) return;

      // Find and remove the verify prompt
      const verifyEl = footer.querySelector('.nav-footer__verify');
      if (!verifyEl) return; // Already authenticated — nothing to swap

      // Copy Astro's scoping attribute from an existing element so scoped CSS applies
      // to dynamically created elements. Astro adds data-astro-cid-xxxxx to all elements.
      const scopeAttr = Array.from(footer.attributes).find(a => a.name.startsWith('data-astro-cid-'));
      function applyScope(el: Element): void {
        if (scopeAttr) el.setAttribute(scopeAttr.name, scopeAttr.value);
      }

      // Build the authenticated team row
      const teamRow = document.createElement('div');
      teamRow.className = 'nav-footer__team-row';
      applyScope(teamRow);

      const link = document.createElement('a');
      link.href = rosterUrl;
      link.className = 'nav-footer__team';
      link.setAttribute('aria-label', `View ${team.name} roster`);
      applyScope(link);

      const logoDiv = document.createElement('div');
      logoDiv.className = 'nav-footer__team-logo';
      applyScope(logoDiv);
      if (team.icon) {
        const img = document.createElement('img');
        img.src = team.icon;
        img.alt = `${team.name} logo`;
        img.className = 'nav-footer__team-img';
        img.width = 40;
        img.height = 40;
        img.loading = 'lazy';
        applyScope(img);
        logoDiv.appendChild(img);
      } else {
        const placeholder = document.createElement('div');
        placeholder.className = 'nav-footer__team-placeholder';
        applyScope(placeholder);
        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'nav-footer__icon');
        svg.setAttribute('aria-hidden', 'true');
        applyScope(svg);
        const use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
        use.setAttribute('href', `${spUrl}#icon-shield-2`);
        svg.appendChild(use);
        placeholder.appendChild(svg);
        logoDiv.appendChild(placeholder);
      }

      const infoDiv = document.createElement('div');
      infoDiv.className = 'nav-footer__team-info';
      applyScope(infoDiv);
      const nameSpan = document.createElement('span');
      nameSpan.className = 'nav-footer__team-name';
      nameSpan.textContent = team.name;
      applyScope(nameSpan);
      infoDiv.appendChild(nameSpan);

      link.appendChild(logoDiv);
      link.appendChild(infoDiv);
      teamRow.appendChild(link);

      // Swap: remove verify, insert team row before footer links
      verifyEl.replaceWith(teamRow);
    }) as EventListener);
  }

  document.addEventListener('astro:page-load', initAuthLoginListener);
</script>

<style>
  /* ==============================================
   * NAV FOOTER - Base Styles
   * ============================================== */
  .nav-footer {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--nav-spacing-md, 12px);
    padding: var(--nav-spacing-lg, 16px);
    background: var(--nav-footer-bg, #f9fafb);
    border-top: 1px solid var(--nav-footer-border, #e5e7eb);
    min-height: var(--nav-footer-height, 80px);
    box-sizing: border-box;
    box-shadow: 0 -1px 1px hsl(220deg 3% 15% / 0.08),
                0 -2px 2px hsl(220deg 3% 15% / 0.06),
                0 -3px 4px hsl(220deg 3% 15% / 0.04);
  }

  /* ==============================================
   * TEAM ROW - Wrapper for team info + toggle
   * ============================================== */
  .nav-footer__team-row {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-xs, 4px);
  }

  .nav-footer__team-row .nav-footer__team {
    flex: 1;
    min-width: 0;
  }

  /* ==============================================
   * AUTHENTICATED STATE - Team Info (clickable link)
   * ============================================== */
  .nav-footer__team {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-md, 12px);
    position: relative;
    text-decoration: none;
    color: inherit;
    padding: var(--nav-spacing-sm, 8px);
    margin: calc(-1 * var(--nav-spacing-sm, 8px));
    border-radius: var(--nav-border-radius-md, 8px);
    transition: var(--nav-hover-transition, background-color 0.15s ease);
  }

  .nav-footer__team:hover {
    background: var(--nav-hover-bg, #f3f4f6);
  }

  .nav-footer__team:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  .nav-footer__team-logo {
    flex-shrink: 0;
    width: var(--nav-team-logo-size, 40px);
    height: var(--nav-team-logo-size, 40px);
    border-radius: var(--nav-border-radius-md, 8px);
    overflow: hidden;
    background: var(--nav-bg, #ffffff);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Circular avatar for commissioner mode */
  .nav-footer__team-logo--commish {
    border-radius: 50%;
  }

  .nav-footer__team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nav-footer__team-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--nav-bg-subtle, #f9fafb);
  }

  .nav-footer__team-placeholder .nav-footer__icon {
    width: 24px;
    height: 24px;
    fill: var(--nav-text-muted, #6b7280);
  }

  .nav-footer__team-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0; /* Allow text truncation */
  }

  .nav-footer__team-name {
    font-size: var(--nav-team-name-size, 0.9375rem);
    font-weight: 600;
    color: var(--nav-footer-text, #333333);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-footer__owner-name {
    font-size: var(--nav-owner-name-size, 0.8125rem);
    color: var(--nav-footer-text-muted, #6b7280);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ==============================================
   * COMMISSIONER TOGGLE - Up/down chevron button
   * ============================================== */
  .nav-footer__commish-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--nav-border-radius-sm, 4px);
    color: var(--nav-text-muted, #6b7280);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    position: relative;
    transition: var(--nav-hover-transition, background-color 0.15s ease);
  }

  /* Expand tap area to 44px minimum (WCAG 2.5.8) */
  .nav-footer__commish-toggle::before {
    content: '';
    position: absolute;
    inset: -8px;
    min-width: 44px;
    min-height: 44px;
  }

  .nav-footer__commish-toggle:hover {
    background: var(--nav-hover-bg, #f3f4f6);
    color: var(--nav-text, #333333);
  }

  .nav-footer__commish-toggle:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  /* Active pressed state — subtle primary tint */
  .nav-footer__commish-toggle[aria-pressed="true"] {
    background: rgba(28, 73, 124, 0.08);
    color: var(--color-primary, #1c497c);
  }

  /* Crossfade transition on swappable content */
  [data-commish-swap] {
    transition: opacity 0.2s ease;
  }

  :global([data-commish-swap].is-fading) {
    opacity: 0;
  }

  /* ==============================================
   * UNAUTHENTICATED STATE - Verify Prompt
   * ============================================== */
  .nav-footer__verify {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-md, 12px);
    padding: var(--nav-spacing-md, 12px);
    margin: calc(-1 * var(--nav-spacing-md, 12px));
    margin-bottom: 0;
    background: var(--nav-verify-bg, rgba(28, 73, 124, 0.05));
    border: 1px dashed var(--nav-verify-border, #1c497c);
    border-radius: var(--nav-border-radius-md, 8px);
    text-decoration: none;
    transition: var(--nav-hover-transition, background-color 0.15s ease, color 0.15s ease);
    position: relative;
    min-height: var(--nav-touch-target-min, 44px);
  }

  .nav-footer__verify:hover,
  .nav-footer__verify:focus-visible {
    background: var(--nav-verify-hover-bg, rgba(28, 73, 124, 0.1));
  }

  .nav-footer__verify:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
    outline-offset: var(--nav-focus-ring-offset, 2px);
  }

  .nav-footer__verify-icon {
    flex-shrink: 0;
    width: var(--nav-team-logo-size, 40px);
    height: var(--nav-team-logo-size, 40px);
    border-radius: 50%;
    background: var(--nav-verify-border, #1c497c);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-footer__verify-icon .nav-footer__icon {
    width: 20px;
    height: 20px;
    fill: var(--nav-bg, #ffffff);
  }

  .nav-footer__verify-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .nav-footer__verify-label {
    font-size: var(--nav-team-name-size, 0.9375rem);
    font-weight: 600;
    color: var(--nav-verify-text, #1c497c);
    line-height: 1.3;
  }

  .nav-footer__verify-hint {
    font-size: var(--nav-owner-name-size, 0.8125rem);
    color: var(--nav-footer-text-muted, #6b7280);
    line-height: 1.3;
  }

  .nav-footer__verify-arrow {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--nav-verify-text, #1c497c);
    transition: transform 0.15s ease;
  }

  .nav-footer__verify:hover .nav-footer__verify-arrow {
    transform: translateX(2px);
  }

  /* ==============================================
   * FOOTER LINKS
   * ============================================== */
  .nav-footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--nav-spacing-xs, 4px);
    padding-top: var(--nav-spacing-sm, 8px);
    border-top: 1px solid var(--nav-border-subtle, #f3f4f6);
  }

  .nav-footer__link {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-sm, 8px);
    padding: var(--nav-spacing-sm, 8px) 0;
    color: var(--nav-footer-text-muted, #6b7280);
    text-decoration: none;
    font-size: 0.8125rem;
    transition: var(--nav-hover-transition, background-color 0.15s ease, color 0.15s ease);
  }

  .nav-footer__link:hover,
  .nav-footer__link:focus-visible {
    color: var(--nav-footer-text, #333333);
  }

  .nav-footer__link:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
    border-radius: var(--nav-border-radius-sm, 4px);
  }

  .nav-footer__link-icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex-shrink: 0;
  }

  /* ==============================================
   * ICON STYLES
   * ============================================== */
  .nav-footer__icon {
    display: block;
  }

  /* ==============================================
   * DARK MODE
   * ============================================== */
  :global(.dark) .nav-footer__commish-toggle {
    color: var(--nav-text-muted);
  }

  :global(.dark) .nav-footer__commish-toggle:hover {
    background: var(--nav-hover-bg);
    color: var(--nav-text);
  }

  :global(.dark) .nav-footer__commish-toggle[aria-pressed="true"] {
    background: rgba(96, 165, 250, 0.12);
    color: #60a5fa;
  }

  /* ==============================================
   * VISUALLY HIDDEN (accessible screen reader text)
   * ============================================== */
  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* ==============================================
   * ACCESSIBILITY
   * ============================================== */
  @media (prefers-reduced-motion: reduce) {
    .nav-footer__verify,
    .nav-footer__verify-arrow,
    .nav-footer__link,
    .nav-footer__commish-toggle,
    [data-commish-swap] {
      transition: none;
    }
  }
</style>
