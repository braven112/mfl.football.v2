---
/**
 * NavHeader Component
 *
 * Fixed header at the top of the navigation drawer.
 * Displays the current league logo and name with a switcher button.
 *
 * Design: Logo + League Name + chevron icon for switching.
 * With one other league in the registry, the chevron links straight to the
 * equivalent page in that league; with two or more it opens a dropdown
 * listing every league (current one marked). Cross-league targets are
 * absolute URLs to the other league's apex domain when serving on
 * theleague.us / afl-fantasy.com — see nav-utils#getLeagueSwitchTargets.
 *
 * @component
 * @example
 * <NavHeader
 *   league="theleague"
 *   logoUrl="/assets/logos/theleague-logo.svg"
 *   currentPath="/theleague/rosters"
 *   isCollapsed={false}
 * />
 */

import type { LeagueSlug, NavHeaderProps } from '../../types/nav';
import { getLeagueByNavSlug } from '../../config/leagues';
import { resolveLeaguePath, getLeagueSwitchTargets } from '../../utils/nav-utils';

interface Props extends NavHeaderProps {
  /** Current page path for smart routing when switching leagues */
  currentPath: string;
  /** Strip /theleague prefix from links (true on theleague.us domain) */
  hideLeaguePrefix?: boolean;
}

const {
  league,
  logoUrl,
  currentPath,
  hideLeaguePrefix = false,
} = Astro.props;

// NOTE (add-a-league checklist): the home URL comes from the registry, but
// the logo files, dark-logo swap, and wordmark markup below are still
// two-league ternaries — a third league needs its own assets and branches
// there (the switcher itself already scales).
const currentLeagueDef = getLeagueByNavSlug(league);
const leagueHome = resolveLeaguePath(`/${currentLeagueDef.slug}`, hideLeaguePrefix);

// Display name for screen readers and the dropdown's current-league row,
// from the registry so it matches the switch targets' labels.
const leagueName = currentLeagueDef.name;

// Logo alt text
const logoAlt = league === 'afl' ? 'AFL Logo' : 'TheLeague Logo';

// Single chevron glyph shared by both switcher modes (direct link + dropdown
// toggle) so the icon can't drift between them.
const chevronSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 15l5 5 5-5" /><path d="M7 9l5-5 5 5" /></svg>`;

// Equivalent-route + cross-domain logic lives in nav-utils
// (#getLeagueSwitchTargets / #getLeagueSwitchUrl). It consults the
// route-equivalence map, falls back to the
// target league home, and — critically — on a league apex host
// (theleague.us / afl-fantasy.com) returns an absolute URL to the OTHER
// league's apex domain. Do not pass these through resolveLeaguePath:
// stripping the target league's prefix on an apex host turns a switch link
// back into a same-league URL.
//
// With exactly one other league the chevron is a direct switch link (one
// tap). With two or more (a 3+-league registry) it opens a dropdown listing
// every league, current one marked.
const switchTargets = getLeagueSwitchTargets(league, currentPath, hideLeaguePrefix);
const useDropdown = switchTargets.length > 1;
const directTarget = switchTargets[0];
---

<header
  class="nav-header"
  role="banner"
>
  <div class="nav-header__content">
    <a
      href={leagueHome}
      class="nav-header__logo-link"
      aria-label={`Go to ${leagueName} home`}
    >
      <img
        src={logoUrl}
        alt={logoAlt}
        class="nav-header__logo nav-header__logo--light"
        width="48"
        height="48"
      />
      <img
        src={league === 'afl' ? '/assets/logos/afl-logo-dark.svg' : '/assets/logos/theleague-logo-dark.svg'}
        alt={logoAlt}
        class="nav-header__logo nav-header__logo--dark"
        width="48"
        height="48"
      />
      <span class="nav-header__league-name">
        {league === 'afl' ? (
          <span class="nav-header__league-name--afl">AFL</span>
        ) : (
          <>
            <span class="nav-header__league-name--the">The</span>
            <span class="nav-header__league-name--league">League</span>
          </>
        )}
      </span>
    </a>

    {/* League switcher - chevron button. Rendered for every visitor: league
        pages are public, so switching is plain navigation and must not
        depend on being logged in (sessions don't cross the apex domains,
        so a login-gated switcher would vanish right after a switch).
        One other league → direct link; several → dropdown menu. */}
    {!useDropdown && directTarget && (
      <a
        href={directTarget.href}
        class="nav-header__switch-btn"
        aria-label={`Switch to ${directTarget.name}`}
        title={`Switch to ${directTarget.name}`}
      >
        <Fragment set:html={chevronSvg} />
      </a>
    )}
    {useDropdown && (
      /* Disclosure pattern, not an ARIA menu: a menu role promises arrow-key
         navigation and roving tabindex we don't implement — a plain expanded
         list of links keeps the announced model honest. */
      <div class="nav-header__switcher" data-league-switcher>
        <button
          type="button"
          class="nav-header__switch-btn"
          aria-label="Switch league"
          title="Switch league"
          aria-expanded="false"
          aria-controls="nav-league-switch-list"
          data-league-switcher-toggle
        >
          <Fragment set:html={chevronSvg} />
        </button>
        <div
          class="nav-header__switch-menu"
          id="nav-league-switch-list"
          role="group"
          aria-label="Select league"
          hidden
          data-league-switcher-menu
        >
          <span class="nav-header__switch-item nav-header__switch-item--current">
            {leagueName}
            <svg
              class="nav-header__switch-check"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6L9 17l-5-5" />
            </svg>
            <span class="visually-hidden">(current league)</span>
          </span>
          {switchTargets.map((target) => (
            <a href={target.href} class="nav-header__switch-item">
              {target.name}
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Close button - pushed to right */}
    <button
      type="button"
      class="nav-header__close-btn"
      aria-label="Close navigation"
      data-nav-close
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<style>
  .nav-header {
    display: flex;
    align-items: center;
    height: var(--nav-header-height, 72px);
    padding: 0 var(--nav-spacing-lg, 16px);
    background: var(--nav-bg, #ffffff);
    border-bottom: 1px solid var(--nav-border, #e5e7eb);
    flex-shrink: 0;
    position: sticky;
    top: 0;
    z-index: var(--nav-z-header, 960);
    box-shadow: var(--shadow-md);
  }

  .nav-header__content {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-sm, 8px);
    width: 100%;
  }

  .nav-header__logo-link {
    display: flex;
    align-items: center;
    gap: var(--nav-spacing-md, 12px);
    text-decoration: none;
    color: var(--nav-text, #333333);
    border-radius: var(--nav-border-radius-md, 8px);
    padding: var(--nav-spacing-sm, 8px);
    margin: calc(-1 * var(--nav-spacing-sm, 8px));
    transition: var(--nav-hover-transition);
  }

  .nav-header__logo-link:hover {
    background: var(--nav-hover-bg, #f3f4f6);
  }

  .nav-header__logo-link:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  .nav-header__logo {
    /* Height-based sizing with natural aspect ratio — identical proportions
       to the main header logo (which is height + width:auto), just smaller.
       The old fixed 48x48 box letterboxed the non-square mark. */
    height: 36px;
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Theme-driven logo swap — mirrors the main header: original blue mark in
     light, bright variant in dark, driven by CSS so live toggles apply. */
  .nav-header__logo--dark {
    display: none;
  }

  :global(html.dark) .nav-header__logo--light {
    display: none;
  }

  :global(html.dark) .nav-header__logo--dark {
    display: block;
  }

  .nav-header__league-name {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .nav-header__league-name--the {
    color: var(--primary-color, #1c497c);
    margin-right: 0.125rem;
  }

  .nav-header__league-name--league {
    color: var(--secondary-color, #2e8743);
  }

  .nav-header__league-name--afl {
    background: linear-gradient(135deg, var(--league-accent, #c41e3a) 0%, var(--league-accent, #c41e3a) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* League switch button */
  .nav-header__switch-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--nav-border-radius-sm, 4px);
    color: var(--nav-text-muted, #6b7280);
    transition: var(--nav-hover-transition);
    flex-shrink: 0;
    margin-left: 4px;
  }

  .nav-header__switch-btn:hover {
    background: var(--nav-hover-bg, #f3f4f6);
    color: var(--nav-text, #333333);
  }

  .nav-header__switch-btn:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  /* Multi-league dropdown (renders only with a 3+-league registry) */
  .nav-header__switcher {
    position: relative;
    flex-shrink: 0;
  }

  .nav-header__switcher .nav-header__switch-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .nav-header__switch-menu {
    position: absolute;
    top: calc(100% + 6px);
    /* Right-anchored, growing leftward into the drawer body: a centered menu
       can poke past the drawer's right edge on narrow mobile drawers and get
       clipped by .nav-drawer__content's overflow:hidden. */
    right: 0;
    min-width: 180px;
    max-width: calc(var(--nav-width-expanded, 320px) - 32px);
    padding: var(--nav-spacing-xs, 4px);
    background: var(--nav-bg, #ffffff);
    border: 1px solid var(--nav-border, #e5e7eb);
    border-radius: var(--nav-border-radius-md, 8px);
    box-shadow: var(--shadow-md);
    z-index: 1;
  }

  .nav-header__switch-menu[hidden] {
    display: none;
  }

  .nav-header__switch-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--nav-spacing-sm, 8px);
    padding: var(--nav-spacing-sm, 8px) var(--nav-spacing-md, 12px);
    border-radius: var(--nav-border-radius-sm, 4px);
    color: var(--nav-text, #333333);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 600;
    white-space: nowrap;
  }

  a.nav-header__switch-item:hover {
    background: var(--nav-hover-bg, #f3f4f6);
  }

  a.nav-header__switch-item:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  .nav-header__switch-item--current {
    color: var(--nav-text-muted, #6b7280);
    cursor: default;
  }

  .nav-header__switch-check {
    flex-shrink: 0;
    color: var(--secondary-color, #2e8743);
  }

  /* Close button */
  .nav-header__close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    margin-left: auto;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--nav-text-muted, #6b7280);
    border-radius: var(--nav-border-radius-sm, 4px);
    transition: var(--nav-hover-transition);
    flex-shrink: 0;
  }

  .nav-header__close-btn:hover {
    background: var(--nav-hover-bg, #f3f4f6);
    color: var(--nav-text, #333333);
  }

  .nav-header__close-btn:focus-visible {
    outline: none;
    box-shadow: var(--nav-focus-ring, 0 0 0 2px #1c497c);
  }

  /* Dark mode support via html.dark (set by the theme resolver on
     documentElement — see ThemeScript.astro / ThemeToggle.astro). Most
     properties already flow from tokens-dark.css via the plain var()
     references above; these overrides only handle values that don't have
     a token (the league-name gradient text colors below). */
  :global(html.dark) .nav-header {
    background: var(--nav-bg);
    border-bottom-color: var(--nav-border);
  }

  :global(html.dark) .nav-header__logo-link {
    color: var(--nav-text);
  }

  :global(html.dark) .nav-header__logo-link:hover {
    background: var(--nav-hover-bg);
  }

  :global(html.dark) .nav-header__league-name--the {
    color: #ffffff; /* matches the dark logo lockup: white THE + green LEAGUE */
  }

  :global(html.dark) .nav-header__league-name--league {
    color: var(--color-secondary-light, #4ade80); /* matches tokens-dark.css --link-color-hover / --color-secondary-light */
  }

  :global(html.dark) .nav-header__switch-btn {
    color: var(--nav-text-muted);
  }

  :global(html.dark) .nav-header__switch-btn:hover {
    background: var(--nav-hover-bg);
    color: var(--nav-text);
  }

  :global(html.dark) .nav-header__switch-menu {
    background: var(--nav-bg);
    border-color: var(--nav-border);
  }

  :global(html.dark) .nav-header__switch-item {
    color: var(--nav-text);
  }

  :global(html.dark) a.nav-header__switch-item:hover {
    background: var(--nav-hover-bg);
  }

  :global(html.dark) .nav-header__switch-item--current {
    color: var(--nav-text-muted);
  }

  :global(html.dark) .nav-header__close-btn {
    color: var(--nav-text-muted);
  }

  :global(html.dark) .nav-header__close-btn:hover {
    background: var(--nav-hover-bg);
    color: var(--nav-text);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .nav-header__logo {
      height: 32px;
      width: auto;
    }

    .nav-header__league-name {
      font-size: 1rem;
    }
  }
</style>

{/* League dropdown behavior — only present when the dropdown markup rendered
    (3+ leagues in the registry). Guarded by an element check so the script
    is a no-op in the two-league direct-link mode. */}
<script>
  // Fully delegated: the document listeners resolve the live DOM at event
  // time, so View Transitions replacing the drawer need no re-binding and no
  // per-element idempotency flags. Bound at most once per session — guarded
  // by a window sentinel (repo convention, cf. ThemeToggle) so listeners
  // can't stack even if this module is ever re-executed — and only after a
  // page actually renders a switcher: the registry is constant, so in
  // two-league mode (direct-link chevron, no dropdown markup) nothing is
  // ever registered and every handler below is dead weight avoided.
  const BOUND_FLAG = '__leagueSwitcherBound';

  function openMenus(): HTMLElement[] {
    return Array.from(
      document.querySelectorAll('[data-league-switcher-menu]:not([hidden])')
    ) as HTMLElement[];
  }

  function setMenu(menu: HTMLElement, open: boolean, focusTarget?: 'first-link' | 'toggle'): void {
    const switcher = menu.closest('[data-league-switcher]');
    const toggle = switcher?.querySelector('[data-league-switcher-toggle]') as HTMLElement | null;
    menu.hidden = !open;
    toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open && focusTarget === 'first-link') {
      (menu.querySelector('a') as HTMLElement | null)?.focus();
    } else if (!open && focusTarget === 'toggle') {
      toggle?.focus();
    }
  }

  function bindLeagueSwitcher(): void {
    document.addEventListener('click', (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const toggle = target.closest('[data-league-switcher-toggle]');
      const ownSwitcher = toggle?.closest('[data-league-switcher]') ?? null;

      // Close any open menu this click landed outside of.
      for (const menu of openMenus()) {
        const owner = menu.closest('[data-league-switcher]');
        if (owner !== ownSwitcher && owner && !owner.contains(target)) {
          setMenu(menu, false);
        }
      }

      if (toggle && ownSwitcher) {
        const menu = ownSwitcher.querySelector('[data-league-switcher-menu]') as HTMLElement | null;
        if (!menu) return;
        // Move focus into the list only on keyboard activation (click events
        // from Enter/Space have detail === 0) — pointer users shouldn't see
        // a focus ring jump.
        setMenu(menu, menu.hidden, menu.hidden && e.detail === 0 ? 'first-link' : undefined);
      }
    });

    document.addEventListener(
      'keydown',
      (e: KeyboardEvent) => {
        if (e.key !== 'Escape') return;
        for (const menu of openMenus()) {
          const switcher = menu.closest('[data-league-switcher]');
          const ownsFocus = !!switcher && switcher.contains(document.activeElement);
          setMenu(menu, false, ownsFocus ? 'toggle' : undefined);
          // Swallow the keypress (so NavDrawer's own Escape handler doesn't
          // also close the drawer) only when the menu owned focus — if the
          // user has moved on, Escape should act on whatever they're in now.
          if (ownsFocus) e.stopPropagation();
        }
      },
      { capture: true }
    );

    // Tabbing or clicking focus out of the switcher closes the list, so a
    // menu can't linger open when the drawer closes without a click (e.g.
    // programmatic close, viewport rotation).
    document.addEventListener('focusin', (e: FocusEvent) => {
      for (const menu of openMenus()) {
        const owner = menu.closest('[data-league-switcher]');
        if (owner && !owner.contains(e.target as Node)) {
          setMenu(menu, false);
        }
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    if ((window as any)[BOUND_FLAG]) return;
    if (!document.querySelector('[data-league-switcher]')) return;
    (window as any)[BOUND_FLAG] = true;
    bindLeagueSwitcher();
  });
</script>
