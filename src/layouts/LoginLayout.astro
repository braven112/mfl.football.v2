---
import { Font } from 'astro:assets';
import TheLeagueHeader from '../components/theleague/Header.astro';
import Footer from '../components/Footer.astro';
import { getThemePreference } from '../utils/theme-preference';
import ThemeScript from '../components/ThemeScript.astro';

export interface Props {
	title: string;
	host?: string;
	leagueId?: string;
	year?: string | number;
	staticHost?: string;
}

const { title, host, leagueId, year, staticHost } = Astro.props as Props;

// Resolve theme preference (server-side). 'auto' renders no class — the
// pre-paint ThemeScript resolves it against prefers-color-scheme.
const themePref = getThemePreference(Astro.cookies);
---

<!DOCTYPE html>
<html lang="en" class:list={[{ dark: themePref === 'dark' }]}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<ThemeScript />
		<link rel="icon" type="image/svg+xml" href="/assets/logos/theleague-logo.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<Font cssVariable="--font-vend-sans" />
		<title>{title}</title>
	</head>
	<body>
		<TheLeagueHeader {host} {leagueId} {year} {staticHost} />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style>
	/* Design tokens — shared across the site */
	@import '../styles/tokens.css';
	/* Dark-mode token overrides (scoped under html.dark) — must come after tokens.css */
	@import '../styles/tokens-dark.css';

	:root {
		/* Login-specific local overrides (kept minimal; tokens.css supplies the rest) */
		--primary-color: #1c497c;
		--secondary-color: #2e8743;
		--font-size-base: clamp(1rem, 0.34vw + 0.91rem, 1.19rem);
		--font-size-lg: clamp(1.2rem, 0.7vw + 1.2rem, 1.5rem);
		--font-size-xl: clamp(2.44rem, 2.38vw + 1.85rem, 3.75rem);

		--login-page-bg: #f5f5f5;
		--login-text-color: var(--color-gray-900, #111827);

		--primary-content-bg-color: #ffffff;
		--primary-content-border-color: #e2e8f0;
		--primary-content-boxshadow-size: 0 2px 6px rgba(0, 0, 0, 0.05);
	}

	/* Dark-theme reconciliation for the login-specific vars. tokens-dark.css
	   already overrides the shared --color-* tokens under html.dark; here we
	   just point the login-local vars at sensible dark values so the page
	   background / content surface / text read correctly in dark mode. */
	html.dark {
		--login-page-bg: var(--page-bg, #121212);
		--login-text-color: var(--color-gray-100, #e5e7eb);
		--primary-content-bg-color: var(--color-surface-2, #1e1e1e);
		--primary-content-border-color: var(--color-gray-700, #374151);
	}

	html {
		font-family: system-ui, sans-serif;
		font-size: var(--font-size-base);
		background-color: var(--login-page-bg);
		color: var(--login-text-color);
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	:global(h1) {
		font-size: var(--font-size-xl);
		color: var(--primary-color);
	}

	:global(h2) {
		font-size: var(--font-size-lg);
		color: var(--primary-color);
	}

	:global(code) {
		font-family: Menlo, Monaco, Lucida Console, Liberation Mono, DejaVu Sans Mono,
			Bitstream Vera Sans Mono, Courier New, monospace;
		background: #f5f5f5;
		padding: 0.125rem 0.25rem;
		border-radius: 0.25rem;
	}

	:global(a) {
		color: var(--primary-color);
		text-decoration: none;
	}

	:global(a:hover) {
		color: var(--secondary-color);
		text-decoration: underline;
	}

	:global(a:focus) {
		color: var(--secondary-color);
		text-decoration: underline;
	}

	main {
		flex: 1;
	}

	main {
		margin-inline: auto;
		margin-block: 0;
		max-width: 1232px;
		display: block;
		padding: 1rem 1.5rem 5rem;
	}

	@media (max-width: 767px) {
		main {
			padding: 1rem 1rem 4rem;
		}
	}
</style>
